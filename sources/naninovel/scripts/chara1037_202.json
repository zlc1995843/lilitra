{
  "lines": [
    {
      "key": "15.0",
      "line_index": 15,
      "inline_index": 0,
      "line_hash": "e24de491",
      "speaker": "{G_PlayerName}",
      "ja": "おい！　しっかりしろ！　大丈夫か？！",
      "zh": ""
    },
    {
      "key": "22.0",
      "line_index": 22,
      "inline_index": 0,
      "line_hash": "9306c593",
      "speaker": "コルト",
      "ja": "うっ……う～ん……",
      "zh": ""
    },
    {
      "key": "24.0",
      "line_index": 24,
      "inline_index": 0,
      "line_hash": "452874a9",
      "speaker": "",
      "ja": "俺の呼びかけにようやくコルトが目を開けた。",
      "zh": ""
    },
    {
      "key": "26.0",
      "line_index": 26,
      "inline_index": 0,
      "line_hash": "3ef22494",
      "speaker": "",
      "ja": "倒れているのを発見した時にはかなり焦ったが、気がついて良かった。",
      "zh": ""
    },
    {
      "key": "28.0",
      "line_index": 28,
      "inline_index": 0,
      "line_hash": "ee2f0ed9",
      "speaker": "",
      "ja": "ホッとしつつも俺は、この状況に戸惑いを隠せない。",
      "zh": ""
    },
    {
      "key": "34.0",
      "line_index": 34,
      "inline_index": 0,
      "line_hash": "83fa038c",
      "speaker": "コルト",
      "ja": "あら～？　どうしてここにあなたがいるのですか～？",
      "zh": ""
    },
    {
      "key": "37.0",
      "line_index": 37,
      "inline_index": 0,
      "line_hash": "154f2242",
      "speaker": "{G_PlayerName}",
      "ja": "いや……ちょっと用事があって来てみたら……コルトが倒れていたから",
      "zh": ""
    },
    {
      "key": "42.0",
      "line_index": 42,
      "inline_index": 0,
      "line_hash": "efa5ea38",
      "speaker": "コルト",
      "ja": "あらあら、わたしったら気絶しちゃったみたいですね～",
      "zh": ""
    },
    {
      "key": "44.0",
      "line_index": 44,
      "inline_index": 0,
      "line_hash": "48665096",
      "speaker": "",
      "ja": "そう言うとコルトは自分の周りを見渡した。",
      "zh": ""
    },
    {
      "key": "46.0",
      "line_index": 46,
      "inline_index": 0,
      "line_hash": "5141bba0",
      "speaker": "",
      "ja": "彼女の周りは自ら溢れさせた汁でベチョベチョになっているし、",
      "zh": ""
    },
    {
      "key": "46.2",
      "line_index": 46,
      "inline_index": 2,
      "line_hash": "5141bba0",
      "speaker": "",
      "ja": "湿ってふにゃふにゃになってしまっているバゲットが転がっているし、",
      "zh": ""
    },
    {
      "key": "46.4",
      "line_index": 46,
      "inline_index": 4,
      "line_hash": "5141bba0",
      "speaker": "",
      "ja": "すさまじい惨状だ。",
      "zh": ""
    },
    {
      "key": "48.0",
      "line_index": 48,
      "inline_index": 0,
      "line_hash": "d89031cf",
      "speaker": "",
      "ja": "おまけにコルトはベチョベチョに濡れたおまんこを丸出しにしているし",
      "zh": ""
    },
    {
      "key": "48.2",
      "line_index": 48,
      "inline_index": 2,
      "line_hash": "d89031cf",
      "speaker": "",
      "ja": "目のやり場に困る。",
      "zh": ""
    },
    {
      "key": "54.0",
      "line_index": 54,
      "inline_index": 0,
      "line_hash": "1c49c919",
      "speaker": "コルト",
      "ja": "（これは……どう見てもオナニーしていたのバレバレですよね～床はヌルヌルですし、バゲットもベチョベチョですし～）",
      "zh": ""
    },
    {
      "key": "56.0",
      "line_index": 56,
      "inline_index": 0,
      "line_hash": "ece240f7",
      "speaker": "",
      "ja": "店の中に漂っているエッチなニオイで俺の股間が大きく膨らんできた。",
      "zh": ""
    },
    {
      "key": "58.0",
      "line_index": 58,
      "inline_index": 0,
      "line_hash": "8cc22015",
      "speaker": "",
      "ja": "コルトはそんな俺の股間に目をとめるとジーッと見つめてくる。",
      "zh": ""
    },
    {
      "key": "58.2",
      "line_index": 58,
      "inline_index": 2,
      "line_hash": "8cc22015",
      "speaker": "",
      "ja": "その表情はどこか欲情しているように見えた。",
      "zh": ""
    },
    {
      "key": "62.0",
      "line_index": 62,
      "inline_index": 0,
      "line_hash": "4db1b3b",
      "speaker": "コルト",
      "ja": "あらあらあら♥　ここ……こんなに大きくしちゃって～♥",
      "zh": ""
    },
    {
      "key": "64.0",
      "line_index": 64,
      "inline_index": 0,
      "line_hash": "329976c2",
      "speaker": "",
      "ja": "案の定というかコルトは甘い声でそう言うと、",
      "zh": ""
    },
    {
      "key": "64.2",
      "line_index": 64,
      "inline_index": 2,
      "line_hash": "329976c2",
      "speaker": "",
      "ja": "おもむろに俺の服を脱がせ始める。",
      "zh": ""
    },
    {
      "key": "67.0",
      "line_index": 67,
      "inline_index": 0,
      "line_hash": "f540b80b",
      "speaker": "{G_PlayerName}",
      "ja": "ちょ、ちょっと……なにを……",
      "zh": ""
    },
    {
      "key": "73.0",
      "line_index": 73,
      "inline_index": 0,
      "line_hash": "67ff3fa1",
      "speaker": "コルト",
      "ja": "いいからいいから……わたしに任せて♥",
      "zh": ""
    },
    {
      "key": "75.0",
      "line_index": 75,
      "inline_index": 0,
      "line_hash": "3a158ff6",
      "speaker": "",
      "ja": "激しく狼狽える俺に構わず、",
      "zh": ""
    },
    {
      "key": "75.2",
      "line_index": 75,
      "inline_index": 2,
      "line_hash": "3a158ff6",
      "speaker": "",
      "ja": "コルトは俺のズボンの中で勃起しているペニスを何の躊躇もなく取り出すと",
      "zh": ""
    },
    {
      "key": "75.4",
      "line_index": 75,
      "inline_index": 4,
      "line_hash": "3a158ff6",
      "speaker": "",
      "ja": "軽い力でトンと押し倒した。",
      "zh": ""
    },
    {
      "key": "78.0",
      "line_index": 78,
      "inline_index": 0,
      "line_hash": "51e7d2a5",
      "speaker": "コルト",
      "ja": "じゃあ～、挿入れちゃうわね♥",
      "zh": ""
    },
    {
      "key": "80.0",
      "line_index": 80,
      "inline_index": 0,
      "line_hash": "d0868185",
      "speaker": "",
      "ja": "俺が拒む暇すら与えず、",
      "zh": ""
    },
    {
      "key": "80.2",
      "line_index": 80,
      "inline_index": 2,
      "line_hash": "d0868185",
      "speaker": "",
      "ja": "彼女は上にまたがってグチョグチョのオマンコで勃起している肉棒を",
      "zh": ""
    },
    {
      "key": "80.4",
      "line_index": 80,
      "inline_index": 4,
      "line_hash": "d0868185",
      "speaker": "",
      "ja": "ズッポリと咥え込んでしまう。",
      "zh": ""
    },
    {
      "key": "93.0",
      "line_index": 93,
      "inline_index": 0,
      "line_hash": "938b141e",
      "speaker": "コルト",
      "ja": "おほっ♥　あなたのおちんちん、太くて大きいっ♥",
      "zh": ""
    },
    {
      "key": "95.0",
      "line_index": 95,
      "inline_index": 0,
      "line_hash": "e815e51",
      "speaker": "",
      "ja": "濡れたおまんこは簡単に俺のちんぽを奥まで迎え入れた。",
      "zh": ""
    },
    {
      "key": "97.0",
      "line_index": 97,
      "inline_index": 0,
      "line_hash": "147a0bc5",
      "speaker": "",
      "ja": "そこはすっかりヌルヌルになっていて温かくとても気持ちがいい。",
      "zh": ""
    },
    {
      "key": "100.0",
      "line_index": 100,
      "inline_index": 0,
      "line_hash": "6ca938fe",
      "speaker": "{G_PlayerName}",
      "ja": "うっ……す、すごい……くっ……あぁぁぁ……",
      "zh": ""
    },
    {
      "key": "103.0",
      "line_index": 103,
      "inline_index": 0,
      "line_hash": "fae186d9",
      "speaker": "",
      "ja": "あまりの快感に俺が呻き声を漏らすと、コルトはすごく嬉しそうな顔をした。",
      "zh": ""
    },
    {
      "key": "106.0",
      "line_index": 106,
      "inline_index": 0,
      "line_hash": "10615942",
      "speaker": "コルト",
      "ja": "わたしのおまんこ気持ちいい？",
      "zh": ""
    },
    {
      "key": "106.2",
      "line_index": 106,
      "inline_index": 2,
      "line_hash": "10615942",
      "speaker": "コルト",
      "ja": "あなたすごく気持ちよさそうな顔しちゃってるわよ♥",
      "zh": ""
    },
    {
      "key": "109.0",
      "line_index": 109,
      "inline_index": 0,
      "line_hash": "45b07386",
      "speaker": "{G_PlayerName}",
      "ja": "き、気持ち……いいっ……",
      "zh": ""
    },
    {
      "key": "113.0",
      "line_index": 113,
      "inline_index": 0,
      "line_hash": "b8236198",
      "speaker": "コルト",
      "ja": "わたしも♥　あなたの大きなおちんちん、すごく気持ちいいわ～♥",
      "zh": ""
    },
    {
      "key": "115.0",
      "line_index": 115,
      "inline_index": 0,
      "line_hash": "9f31a6",
      "speaker": "",
      "ja": "すっかり快楽に溺れているような表情を浮かべながら",
      "zh": ""
    },
    {
      "key": "115.2",
      "line_index": 115,
      "inline_index": 2,
      "line_hash": "9f31a6",
      "speaker": "",
      "ja": "コルトが甘い声を漏らす。",
      "zh": ""
    },
    {
      "key": "117.0",
      "line_index": 117,
      "inline_index": 0,
      "line_hash": "68d5133f",
      "speaker": "",
      "ja": "肉棒を咥え込んだ膣もビュクビュクと蠢いて離すまいと",
      "zh": ""
    },
    {
      "key": "117.2",
      "line_index": 117,
      "inline_index": 2,
      "line_hash": "68d5133f",
      "speaker": "",
      "ja": "強く吸い付いてきていた。",
      "zh": ""
    },
    {
      "key": "120.0",
      "line_index": 120,
      "inline_index": 0,
      "line_hash": "1842ef55",
      "speaker": "コルト",
      "ja": "それじゃあ、ふたりでいっぱい気持ちよくなりましょうね～♥",
      "zh": ""
    },
    {
      "key": "122.0",
      "line_index": 122,
      "inline_index": 0,
      "line_hash": "13c5257",
      "speaker": "",
      "ja": "そう囁きかけてくるとすぐに、コルトの腰が動き始める。",
      "zh": ""
    },
    {
      "key": "130.0",
      "line_index": 130,
      "inline_index": 0,
      "line_hash": "cd311040",
      "speaker": "コルト",
      "ja": "んっ♥　んんっ♥　あぁぁ、すごくいいっ♥",
      "zh": ""
    },
    {
      "key": "130.2",
      "line_index": 130,
      "inline_index": 2,
      "line_hash": "cd311040",
      "speaker": "コルト",
      "ja": "あなたのおちんちん、いいわ～♥",
      "zh": ""
    },
    {
      "key": "132.0",
      "line_index": 132,
      "inline_index": 0,
      "line_hash": "e9c9d5f7",
      "speaker": "",
      "ja": "すっかり興奮した声で歓喜の声を漏らしながら",
      "zh": ""
    },
    {
      "key": "132.2",
      "line_index": 132,
      "inline_index": 2,
      "line_hash": "e9c9d5f7",
      "speaker": "",
      "ja": "コルトの腰がイヤらしく前後した。",
      "zh": ""
    },
    {
      "key": "134.0",
      "line_index": 134,
      "inline_index": 0,
      "line_hash": "ae856995",
      "speaker": "",
      "ja": "その度にグチュグチュという淫らな水音が店内に響き渡る。",
      "zh": ""
    },
    {
      "key": "137.0",
      "line_index": 137,
      "inline_index": 0,
      "line_hash": "22e4d25d",
      "speaker": "コルト",
      "ja": "あふぅ♥　バゲットも気持ちよかったけれど、",
      "zh": ""
    },
    {
      "key": "137.2",
      "line_index": 137,
      "inline_index": 2,
      "line_hash": "22e4d25d",
      "speaker": "コルト",
      "ja": "あなたのおちんちんの方が固くて太くてビックンビックンして♥",
      "zh": ""
    },
    {
      "key": "137.4",
      "line_index": 137,
      "inline_index": 4,
      "line_hash": "22e4d25d",
      "speaker": "コルト",
      "ja": "はぁぁん♥　すごくいいわ～♥",
      "zh": ""
    },
    {
      "key": "139.0",
      "line_index": 139,
      "inline_index": 0,
      "line_hash": "5068a6f3",
      "speaker": "",
      "ja": "すっかり我を忘れたかのようにコルトは快楽を貪った。",
      "zh": ""
    },
    {
      "key": "141.0",
      "line_index": 141,
      "inline_index": 0,
      "line_hash": "fb11eca4",
      "speaker": "",
      "ja": "何度も何度も腰をくねらせ彼女の体が上下に揺れると",
      "zh": ""
    },
    {
      "key": "141.2",
      "line_index": 141,
      "inline_index": 2,
      "line_hash": "fb11eca4",
      "speaker": "",
      "ja": "強く絡みついた濡れた肉襞がちんぽをしごき上げてくる。",
      "zh": ""
    },
    {
      "key": "143.0",
      "line_index": 143,
      "inline_index": 0,
      "line_hash": "499da687",
      "speaker": "",
      "ja": "その刺激に俺はもう何も考えられなくなって、",
      "zh": ""
    },
    {
      "key": "143.2",
      "line_index": 143,
      "inline_index": 2,
      "line_hash": "499da687",
      "speaker": "",
      "ja": "だんだん射精したいという感覚が強まってきた。",
      "zh": ""
    },
    {
      "key": "146.0",
      "line_index": 146,
      "inline_index": 0,
      "line_hash": "76bcd9b",
      "speaker": "コルト",
      "ja": "あっ♥　あっ♥　イクッ、あなたもイキそうなの？　いいよっ♥",
      "zh": ""
    },
    {
      "key": "146.2",
      "line_index": 146,
      "inline_index": 2,
      "line_hash": "76bcd9b",
      "speaker": "コルト",
      "ja": "一緒にイッちゃおう♥",
      "zh": ""
    },
    {
      "key": "148.0",
      "line_index": 148,
      "inline_index": 0,
      "line_hash": "3192d28c",
      "speaker": "",
      "ja": "膣内で跳ねるペニスを感じてか、コルトは嬉しそうに俺に囁きかけてくる。",
      "zh": ""
    },
    {
      "key": "150.0",
      "line_index": 150,
      "inline_index": 0,
      "line_hash": "5100b04f",
      "speaker": "",
      "ja": "そして俺をイカせようと腰の動きが激しさを増してきた。",
      "zh": ""
    },
    {
      "key": "153.0",
      "line_index": 153,
      "inline_index": 0,
      "line_hash": "4488a056",
      "speaker": "コルト",
      "ja": "ほら♥　ほら♥　一緒にイこ♥",
      "zh": ""
    },
    {
      "key": "153.2",
      "line_index": 153,
      "inline_index": 2,
      "line_hash": "4488a056",
      "speaker": "コルト",
      "ja": "んんんっ♥　わたしの中にいっぱい出してぇ♥",
      "zh": ""
    },
    {
      "key": "155.0",
      "line_index": 155,
      "inline_index": 0,
      "line_hash": "2c7cc105",
      "speaker": "",
      "ja": "コルトが激しく腰を振るとヌルヌルの柔襞が俺のちんぽに絡みついて",
      "zh": ""
    },
    {
      "key": "155.2",
      "line_index": 155,
      "inline_index": 2,
      "line_hash": "2c7cc105",
      "speaker": "",
      "ja": "擦り上げその上強く締め付けてくる。",
      "zh": ""
    },
    {
      "key": "157.0",
      "line_index": 157,
      "inline_index": 0,
      "line_hash": "31c66fcb",
      "speaker": "",
      "ja": "まるでペニスを強く吸われるような感覚に俺は我慢できなくなってしまい",
      "zh": ""
    },
    {
      "key": "157.2",
      "line_index": 157,
      "inline_index": 2,
      "line_hash": "31c66fcb",
      "speaker": "",
      "ja": "彼女の膣内に込み上げてきた精液を一気に放出してしまった。",
      "zh": ""
    },
    {
      "key": "165.0",
      "line_index": 165,
      "inline_index": 0,
      "line_hash": "eb971815",
      "speaker": "コルト",
      "ja": "んほぉぉ♥　どぴゅどぴゅ出てるぅ♥　おまんこにびゅるるって出てるぅ♥",
      "zh": ""
    },
    {
      "key": "165.2",
      "line_index": 165,
      "inline_index": 2,
      "line_hash": "eb971815",
      "speaker": "コルト",
      "ja": "き、気持ちいいっ♥　中に射精すごくいいっ♥",
      "zh": ""
    },
    {
      "key": "167.0",
      "line_index": 167,
      "inline_index": 0,
      "line_hash": "7e39db5e",
      "speaker": "",
      "ja": "コルトはすっかり蕩けた顔をしながらイヤらしい声を上げてイッた。",
      "zh": ""
    },
    {
      "key": "169.0",
      "line_index": 169,
      "inline_index": 0,
      "line_hash": "2c34e9c4",
      "speaker": "",
      "ja": "そんなコルトの中に俺は何度も何度も白濁した精液を発射し続けてしまう。",
      "zh": ""
    },
    {
      "key": "172.0",
      "line_index": 172,
      "inline_index": 0,
      "line_hash": "a5275e81",
      "speaker": "コルト",
      "ja": "んはぁぁっ♥　いっぱい出てるぅ♥　びゅるるって奥に出てるぅ♥",
      "zh": ""
    },
    {
      "key": "174.0",
      "line_index": 174,
      "inline_index": 0,
      "line_hash": "bf3e9db2",
      "speaker": "",
      "ja": "ビクンビクンと腰を震わせながらコルトは恍惚の表情を浮かべた。",
      "zh": ""
    },
    {
      "key": "176.0",
      "line_index": 176,
      "inline_index": 0,
      "line_hash": "96dc80df",
      "speaker": "",
      "ja": "ちんぽを咥え込んだおまんこもビュクビュクと蠢いて",
      "zh": ""
    },
    {
      "key": "176.2",
      "line_index": 176,
      "inline_index": 2,
      "line_hash": "96dc80df",
      "speaker": "",
      "ja": "精子を搾り取ろうとするように強く吸い付いてくる。",
      "zh": ""
    },
    {
      "key": "178.0",
      "line_index": 178,
      "inline_index": 0,
      "line_hash": "93179732",
      "speaker": "",
      "ja": "その強い締まりに俺はコルトの膣中へ大量に射精してしまう。",
      "zh": ""
    },
    {
      "key": "181.0",
      "line_index": 181,
      "inline_index": 0,
      "line_hash": "9d85aa56",
      "speaker": "コルト",
      "ja": "すごぉいっ♥　いっぱい中に出てるぅ♥",
      "zh": ""
    },
    {
      "key": "181.2",
      "line_index": 181,
      "inline_index": 2,
      "line_hash": "9d85aa56",
      "speaker": "コルト",
      "ja": "あはぁんっ♥　イクッ♥　イクゥッ♥",
      "zh": ""
    },
    {
      "key": "183.0",
      "line_index": 183,
      "inline_index": 0,
      "line_hash": "6e229fc5",
      "speaker": "",
      "ja": "俺のペニスが強く跳ねながら膣内に精液を発射する度に",
      "zh": ""
    },
    {
      "key": "183.2",
      "line_index": 183,
      "inline_index": 2,
      "line_hash": "6e229fc5",
      "speaker": "",
      "ja": "彼女は歓喜の声を上げながら何度も体をのけ反らせた。",
      "zh": ""
    },
    {
      "key": "185.0",
      "line_index": 185,
      "inline_index": 0,
      "line_hash": "c7060954",
      "speaker": "",
      "ja": "肉襞も波打つように震えて脈動する肉棒を強く締め上げてくる。",
      "zh": ""
    },
    {
      "key": "187.0",
      "line_index": 187,
      "inline_index": 0,
      "line_hash": "a9fb40cd",
      "speaker": "",
      "ja": "それはまるでちんぽから全ての精液を搾り取ろうとするようで、",
      "zh": ""
    },
    {
      "key": "187.2",
      "line_index": 187,
      "inline_index": 2,
      "line_hash": "a9fb40cd",
      "speaker": "",
      "ja": "あまりの快感に俺はそのまま全てをコルトの中に注ぎ込んで果てた。",
      "zh": ""
    },
    {
      "key": "190.0",
      "line_index": 190,
      "inline_index": 0,
      "line_hash": "19ec45e3",
      "speaker": "コルト",
      "ja": "気持ちいい♥　おちんちん気持ちいいのぉ♥　も、もっとぉ♥　もっとぉ♥",
      "zh": ""
    },
    {
      "key": "192.0",
      "line_index": 192,
      "inline_index": 0,
      "line_hash": "42cfb32",
      "speaker": "",
      "ja": "射精が終わるとまたすぐにコルトは腰を上下させ始めてくる。",
      "zh": ""
    },
    {
      "key": "200.0",
      "line_index": 200,
      "inline_index": 0,
      "line_hash": "22aa998b",
      "speaker": "コルト",
      "ja": "イグ♥　イグ♥　おおきいおちんぽでイッはう♥",
      "zh": ""
    },
    {
      "key": "200.2",
      "line_index": 200,
      "inline_index": 2,
      "line_hash": "22aa998b",
      "speaker": "コルト",
      "ja": "もっとちょうだいっ♥　中にぢょうだいっ♥",
      "zh": ""
    },
    {
      "key": "202.0",
      "line_index": 202,
      "inline_index": 0,
      "line_hash": "a6049e7a",
      "speaker": "",
      "ja": "ワナワナと唇を震わせながらコルトは淫らな言葉を並べた。",
      "zh": ""
    },
    {
      "key": "204.0",
      "line_index": 204,
      "inline_index": 0,
      "line_hash": "5f6f361",
      "speaker": "",
      "ja": "その声とグチョグチョのおまんこでしごかれ、",
      "zh": ""
    },
    {
      "key": "204.2",
      "line_index": 204,
      "inline_index": 2,
      "line_hash": "5f6f361",
      "speaker": "",
      "ja": "俺のちんぽは萎える暇すらない。",
      "zh": ""
    },
    {
      "key": "207.0",
      "line_index": 207,
      "inline_index": 0,
      "line_hash": "259d5b",
      "speaker": "{G_PlayerName}",
      "ja": "ちょ……まっ……あうぅっ……",
      "zh": ""
    },
    {
      "key": "210.0",
      "line_index": 210,
      "inline_index": 0,
      "line_hash": "e691e00f",
      "speaker": "",
      "ja": "何とかコルトを制止しようとするけれど、",
      "zh": ""
    },
    {
      "key": "210.2",
      "line_index": 210,
      "inline_index": 2,
      "line_hash": "e691e00f",
      "speaker": "",
      "ja": "俺の口からは呻き声しか出てこなかった。",
      "zh": ""
    },
    {
      "key": "212.0",
      "line_index": 212,
      "inline_index": 0,
      "line_hash": "92482094",
      "speaker": "",
      "ja": "彼女の腰が動く度にグチュグチュに濡れた柔襞が",
      "zh": ""
    },
    {
      "key": "212.2",
      "line_index": 212,
      "inline_index": 2,
      "line_hash": "92482094",
      "speaker": "",
      "ja": "ゾロリゾロリと肉棒を擦り上げてきてすごい快感が俺を襲った。",
      "zh": ""
    },
    {
      "key": "214.0",
      "line_index": 214,
      "inline_index": 0,
      "line_hash": "8f5419e",
      "speaker": "",
      "ja": "さっき出したばかりのちんぽはまた剛直して強く脈打っていく。",
      "zh": ""
    },
    {
      "key": "217.0",
      "line_index": 217,
      "inline_index": 0,
      "line_hash": "452f31fb",
      "speaker": "コルト",
      "ja": "あっ♥　ああっ♥",
      "zh": ""
    },
    {
      "key": "217.2",
      "line_index": 217,
      "inline_index": 2,
      "line_hash": "452f31fb",
      "speaker": "コルト",
      "ja": "いっぱい出したのに、おちんちんがおまんこでビクビクして♥",
      "zh": ""
    },
    {
      "key": "217.4",
      "line_index": 217,
      "inline_index": 4,
      "line_hash": "452f31fb",
      "speaker": "コルト",
      "ja": "んんんっ♥　すごく元気に暴れてるぅ♥",
      "zh": ""
    },
    {
      "key": "219.0",
      "line_index": 219,
      "inline_index": 0,
      "line_hash": "2d68c291",
      "speaker": "",
      "ja": "膣内で跳ねるペニスに欲情したかのようにコルトの抽送が激しくなった。",
      "zh": ""
    },
    {
      "key": "221.0",
      "line_index": 221,
      "inline_index": 0,
      "line_hash": "d49ff15b",
      "speaker": "",
      "ja": "彼女の体が俺の上でイヤらしく動く度にさっきよりも大きな水音が鳴る。",
      "zh": ""
    },
    {
      "key": "224.0",
      "line_index": 224,
      "inline_index": 0,
      "line_hash": "510b52aa",
      "speaker": "コルト",
      "ja": "あぁぁ♥　わたしのおまんこ、あなたの精液でグチュグチュになって♥",
      "zh": ""
    },
    {
      "key": "224.2",
      "line_index": 224,
      "inline_index": 2,
      "line_hash": "510b52aa",
      "speaker": "コルト",
      "ja": "んんんっ♥　おまんこから精液ブチュブチュって溢れちゃっている♥",
      "zh": ""
    },
    {
      "key": "226.0",
      "line_index": 226,
      "inline_index": 0,
      "line_hash": "8ee0a91e",
      "speaker": "",
      "ja": "卑猥な言葉を口にしながらコルトは何度も激しく腰を振って身悶えた。",
      "zh": ""
    },
    {
      "key": "228.0",
      "line_index": 228,
      "inline_index": 0,
      "line_hash": "a8853214",
      "speaker": "",
      "ja": "そんなコルトに煽られ、",
      "zh": ""
    },
    {
      "key": "228.2",
      "line_index": 228,
      "inline_index": 2,
      "line_hash": "a8853214",
      "speaker": "",
      "ja": "俺もついつい下からドロドロのおまんこを突き上げていく。",
      "zh": ""
    },
    {
      "key": "231.0",
      "line_index": 231,
      "inline_index": 0,
      "line_hash": "d798f8c2",
      "speaker": "コルト",
      "ja": "あっ♥　あっ♥　ああぁ♥　し、子宮にズンズンッて♥　んはぁぁぁ♥",
      "zh": ""
    },
    {
      "key": "234.0",
      "line_index": 234,
      "inline_index": 0,
      "line_hash": "1185535",
      "speaker": "{G_PlayerName}",
      "ja": "くっ……ううっ……さっきよりも強く締まって……",
      "zh": ""
    },
    {
      "key": "237.0",
      "line_index": 237,
      "inline_index": 0,
      "line_hash": "66acd47c",
      "speaker": "",
      "ja": "激しい抽送を続けていると",
      "zh": ""
    },
    {
      "key": "237.2",
      "line_index": 237,
      "inline_index": 2,
      "line_hash": "66acd47c",
      "speaker": "",
      "ja": "あっという間に込み上げてくる感覚が強くなってきた。",
      "zh": ""
    },
    {
      "key": "239.0",
      "line_index": 239,
      "inline_index": 0,
      "line_hash": "43cee83a",
      "speaker": "",
      "ja": "さっきあんなに出した筈なのに、また大量に射精したい衝動が高まる。",
      "zh": ""
    },
    {
      "key": "242.0",
      "line_index": 242,
      "inline_index": 0,
      "line_hash": "c50f7c53",
      "speaker": "コルト",
      "ja": "すごぉいっ♥　こんなに気持ちいいの、たまらないわ♥　あっ♥　あんっ♥",
      "zh": ""
    },
    {
      "key": "244.0",
      "line_index": 244,
      "inline_index": 0,
      "line_hash": "bc5ba706",
      "speaker": "",
      "ja": "コルトも絶頂が近づいてきたのか、",
      "zh": ""
    },
    {
      "key": "244.2",
      "line_index": 244,
      "inline_index": 2,
      "line_hash": "bc5ba706",
      "speaker": "",
      "ja": "悲鳴のような喘ぎ声を上げながら身をよじった。",
      "zh": ""
    },
    {
      "key": "246.0",
      "line_index": 246,
      "inline_index": 0,
      "line_hash": "7b8e2ecb",
      "speaker": "",
      "ja": "俺も射精に向けて腰の動きを激しくさせて、",
      "zh": ""
    },
    {
      "key": "246.2",
      "line_index": 246,
      "inline_index": 2,
      "line_hash": "7b8e2ecb",
      "speaker": "",
      "ja": "ヌルヌルのおまんこを何度も奥まで貫いていく。",
      "zh": ""
    },
    {
      "key": "249.0",
      "line_index": 249,
      "inline_index": 0,
      "line_hash": "fed0c8f6",
      "speaker": "コルト",
      "ja": "イッ、イクっ！　んんんっ♥　またイクっ♥",
      "zh": ""
    },
    {
      "key": "249.2",
      "line_index": 249,
      "inline_index": 2,
      "line_hash": "fed0c8f6",
      "speaker": "コルト",
      "ja": "あああっ♥　イッ、グッ……んんっ♥",
      "zh": ""
    },
    {
      "key": "251.0",
      "line_index": 251,
      "inline_index": 0,
      "line_hash": "6d89d066",
      "speaker": "",
      "ja": "俺が大きく腰を突き出しチンポの先で子宮を思いっきり強く突き上げてやると",
      "zh": ""
    },
    {
      "key": "251.2",
      "line_index": 251,
      "inline_index": 2,
      "line_hash": "6d89d066",
      "speaker": "",
      "ja": "コルトの体が弾けたように何度も大きく跳ねた。",
      "zh": ""
    },
    {
      "key": "259.0",
      "line_index": 259,
      "inline_index": 0,
      "line_hash": "80b5e3e3",
      "speaker": "コルト",
      "ja": "ヒギィ♥　イグ、イグ、イグッ♥　イッ、イッグぅぅぅぅぅッ♥",
      "zh": ""
    },
    {
      "key": "261.0",
      "line_index": 261,
      "inline_index": 0,
      "line_hash": "216ea399",
      "speaker": "",
      "ja": "俺のちんぽが激しく脈打ちながら膣内に精液をぶちまけると同時に",
      "zh": ""
    },
    {
      "key": "261.2",
      "line_index": 261,
      "inline_index": 2,
      "line_hash": "216ea399",
      "speaker": "",
      "ja": "コルトも絶頂に達して体をのけ反らしながら大きな声で叫ぶ。",
      "zh": ""
    },
    {
      "key": "264.0",
      "line_index": 264,
      "inline_index": 0,
      "line_hash": "7c5386f6",
      "speaker": "コルト",
      "ja": "イッグぅぅぅ♥　あぁぁ♥　おまんこに熱いのどぴゅどぴゅ出てるぅ♥",
      "zh": ""
    },
    {
      "key": "264.2",
      "line_index": 264,
      "inline_index": 2,
      "line_hash": "7c5386f6",
      "speaker": "コルト",
      "ja": "はふぅぅ♥　も、もっとぉ♥　もっと中に出してぇぇ♥",
      "zh": ""
    },
    {
      "key": "266.0",
      "line_index": 266,
      "inline_index": 0,
      "line_hash": "3ebcf5ce",
      "speaker": "",
      "ja": "グチュグチュのおまんこは、",
      "zh": ""
    },
    {
      "key": "266.2",
      "line_index": 266,
      "inline_index": 2,
      "line_hash": "3ebcf5ce",
      "speaker": "",
      "ja": "また俺のちんぽから精液を搾り取るようにグイグイと強く締め付けてきた。",
      "zh": ""
    },
    {
      "key": "268.0",
      "line_index": 268,
      "inline_index": 0,
      "line_hash": "1efee130",
      "speaker": "",
      "ja": "俺はあまりの気持ちよさに何度も膣内で射精を繰り返してしまう。",
      "zh": ""
    },
    {
      "key": "271.0",
      "line_index": 271,
      "inline_index": 0,
      "line_hash": "a9248c12",
      "speaker": "コルト",
      "ja": "んひぃぃっ♥　いっぱい出てるぅ♥　びゅるるって奥に出てるぅ♥",
      "zh": ""
    },
    {
      "key": "271.2",
      "line_index": 271,
      "inline_index": 2,
      "line_hash": "a9248c12",
      "speaker": "コルト",
      "ja": "あはぁぁんっ♥　気持ちいいっ♥　気持ちいいのぉ♥",
      "zh": ""
    },
    {
      "key": "273.0",
      "line_index": 273,
      "inline_index": 0,
      "line_hash": "4404f181",
      "speaker": "",
      "ja": "何度も絶頂に達しているのか、腰を何度も震わせながら淫らな声を上げた。",
      "zh": ""
    },
    {
      "key": "275.0",
      "line_index": 275,
      "inline_index": 0,
      "line_hash": "99e6354f",
      "speaker": "",
      "ja": "そして……。",
      "zh": ""
    },
    {
      "key": "278.0",
      "line_index": 278,
      "inline_index": 0,
      "line_hash": "9c90375f",
      "speaker": "コルト",
      "ja": "あ～♥　気持ちよかったわ……",
      "zh": ""
    },
    {
      "key": "280.0",
      "line_index": 280,
      "inline_index": 0,
      "line_hash": "b0a4ed55",
      "speaker": "",
      "ja": "事を終えるとコルトはすごく満足げな表情をしながらそう呟く。",
      "zh": ""
    },
    {
      "key": "282.0",
      "line_index": 282,
      "inline_index": 0,
      "line_hash": "24155585",
      "speaker": "",
      "ja": "俺の方はというと二度の射精でもうグッタリしてしまっていた。",
      "zh": ""
    },
    {
      "key": "285.0",
      "line_index": 285,
      "inline_index": 0,
      "line_hash": "b1245515",
      "speaker": "コルト",
      "ja": "それにしてもあなたのおちんちん、固くて大きくてすごく気持ちよかった♥",
      "zh": ""
    },
    {
      "key": "285.2",
      "line_index": 285,
      "inline_index": 2,
      "line_hash": "b1245515",
      "speaker": "コルト",
      "ja": "もうバゲットじゃ物足りなくなっちゃう♥",
      "zh": ""
    },
    {
      "key": "288.0",
      "line_index": 288,
      "inline_index": 0,
      "line_hash": "5e708743",
      "speaker": "{G_PlayerName}",
      "ja": "そ、そう……なんだ……",
      "zh": ""
    },
    {
      "key": "291.0",
      "line_index": 291,
      "inline_index": 0,
      "line_hash": "b0ad04e3",
      "speaker": "",
      "ja": "やはり床に転がっているグチュグチュになっているバゲットは、",
      "zh": ""
    },
    {
      "key": "291.2",
      "line_index": 291,
      "inline_index": 2,
      "line_hash": "b0ad04e3",
      "speaker": "",
      "ja": "そういう使われ方をしたんだな。",
      "zh": ""
    },
    {
      "key": "293.0",
      "line_index": 293,
      "inline_index": 0,
      "line_hash": "c5febb75",
      "speaker": "",
      "ja": "そんな事を考えている俺に彼女は顔を寄せてきて。",
      "zh": ""
    },
    {
      "key": "296.0",
      "line_index": 296,
      "inline_index": 0,
      "line_hash": "9859ecb5",
      "speaker": "コルト",
      "ja": "また明日も閉店後に……ねっ♥",
      "zh": ""
    },
    {
      "key": "298.0",
      "line_index": 298,
      "inline_index": 0,
      "line_hash": "282d2ed5",
      "speaker": "",
      "ja": "屈託なくそう言ってニッコリと微笑むコルトを見て、",
      "zh": ""
    },
    {
      "key": "298.2",
      "line_index": 298,
      "inline_index": 2,
      "line_hash": "282d2ed5",
      "speaker": "",
      "ja": "俺はドキドキしてしまった。",
      "zh": ""
    }
  ]
}
