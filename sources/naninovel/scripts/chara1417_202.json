    {
      "key": "234.0",
      "line_index": 234,
      "inline_index": 0,
      "line_hash": "e3f90353",
      "speaker": "{G_PlayerName}",
      "ja": "あうぅっ……し、搾り取られる……あぁぁぁっ……",
