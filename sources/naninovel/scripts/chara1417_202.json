    {
      "key": "256.0",
      "line_index": 256,
      "inline_index": 0,
      "line_hash": "31fddabc",
      "speaker": "{G_PlayerName}",
      "ja": "お礼なのに朱桃まで気持ちよくなっていいのか……？",
