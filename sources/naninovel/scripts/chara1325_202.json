{
  "lines": [
    {
      "key": "20.1",
      "line_index": 20,
      "inline_index": 1,
      "line_hash": "e94a9cf4",
      "speaker": "リンファン",
      "ja": "ほらほら～♥　お待ちかねの……お・ま・ん・こ♥",
      "zh": ""
    },
    {
      "key": "22.0",
      "line_index": 22,
      "inline_index": 0,
      "line_hash": "d7f84c57",
      "speaker": "",
      "ja": "２度の手コキで射精させられた{G_PlayerName}にリンファンは自らの股間を見せつけながら甘い声で囁きかける。",
      "zh": ""
    },
    {
      "key": "25.1",
      "line_index": 25,
      "inline_index": 1,
      "line_hash": "a0b7b350",
      "speaker": "リンファン",
      "ja": "ちっちゃな、ちっちゃなキツキツおまんこ♥　もうトロトロになっちゃってるんだよ……♥",
      "zh": ""
    },
    {
      "key": "27.0",
      "line_index": 27,
      "inline_index": 0,
      "line_hash": "ade2fb16",
      "speaker": "",
      "ja": "そう言ってリンファンは自らの割れ目を広げて見せてきた。",
      "zh": ""
    },
    {
      "key": "29.0",
      "line_index": 29,
      "inline_index": 0,
      "line_hash": "61fcd60",
      "speaker": "",
      "ja": "そこは彼女の言う通りヌルヌルに濡れヒクヒクと息づくように蠢いている。",
      "zh": ""
    },
    {
      "key": "31.0",
      "line_index": 31,
      "inline_index": 0,
      "line_hash": "2d917c29",
      "speaker": "",
      "ja": "{G_PlayerName}はそのいやらしい光景に、またおちんちんを硬く勃起させていった。",
      "zh": ""
    },
    {
      "key": "33.0",
      "line_index": 33,
      "inline_index": 0,
      "line_hash": "454f7a13",
      "speaker": "",
      "ja": "リンファンは{G_PlayerName}の股間で反り返っていく陰茎を見て更に挑発するかのように小さなお尻をふりふりと振ってみせる。",
      "zh": ""
    },
    {
      "key": "38.1",
      "line_index": 38,
      "inline_index": 1,
      "line_hash": "951290e2",
      "speaker": "リンファン",
      "ja": "お兄ちゃん♥　はやく～♥　リンのおまんこにおちんぽ入れて、子宮にぴゅっぴゅって射精して～♥",
      "zh": ""
    },
    {
      "key": "40.0",
      "line_index": 40,
      "inline_index": 0,
      "line_hash": "66fe0d4b",
      "speaker": "",
      "ja": "からかうような挑発行為に{G_PlayerName}は興奮の高まりと妙な憤りを感じた。",
      "zh": ""
    },
    {
      "key": "43.0",
      "line_index": 43,
      "inline_index": 0,
      "line_hash": "a20bc720",
      "speaker": "{G_PlayerName}",
      "ja": "そんなに欲しいなら……お望み通りくれてやるよっ！",
      "zh": ""
    },
    {
      "key": "46.0",
      "line_index": 46,
      "inline_index": 0,
      "line_hash": "c2685639",
      "speaker": "",
      "ja": "そう言い放つと{G_PlayerName}はリンファンの小さなおまんこに反り返った肉棒をずぶずぶと挿入していく。",
      "zh": ""
    },
    {
      "key": "60.0",
      "line_index": 60,
      "inline_index": 0,
      "line_hash": "57b365a5",
      "speaker": "リンファン",
      "ja": "おっ♥　んぉほっ♥　きたぁぁぁ♥　お兄ちゃんのぶっといおちんぽぉ♥",
      "zh": ""
    },
    {
      "key": "62.0",
      "line_index": 62,
      "inline_index": 0,
      "line_hash": "8c71dcb",
      "speaker": "",
      "ja": "いきなりの挿入にリンファンは思わず下品な声を上げながら一気に登り詰めてしまった。",
      "zh": ""
    },
    {
      "key": "64.0",
      "line_index": 64,
      "inline_index": 0,
      "line_hash": "2b3e9eed",
      "speaker": "",
      "ja": "さっきまでの余裕はどこへやら、強烈な快楽に襲われて簡単にイってしまう。",
      "zh": ""
    },
    {
      "key": "68.0",
      "line_index": 68,
      "inline_index": 0,
      "line_hash": "12d20a22",
      "speaker": "",
      "ja": "それでも{G_PlayerName}は構うことなく、ガンガンと強く突き上げていく。",
      "zh": ""
    },
    {
      "key": "71.0",
      "line_index": 71,
      "inline_index": 0,
      "line_hash": "31d4579",
      "speaker": "リンファン",
      "ja": "お、おなかっ♥　ぼこっ、ぼこってなってりゅぅ♥　どちゅどちゅダメっ♥",
      "zh": ""
    },
    {
      "key": "73.0",
      "line_index": 73,
      "inline_index": 0,
      "line_hash": "5ac14514",
      "speaker": "",
      "ja": "激しい抽送にリンファンは白目をむきかけアヘ顔を晒してしまっていた。",
      "zh": ""
    },
    {
      "key": "75.0",
      "line_index": 75,
      "inline_index": 0,
      "line_hash": "f921b4cb",
      "speaker": "",
      "ja": "そんなリンファンに{G_PlayerName}がピストンを繰り返しながら告げる。",
      "zh": ""
    },
    {
      "key": "78.0",
      "line_index": 78,
      "inline_index": 0,
      "line_hash": "9e84eca9",
      "speaker": "{G_PlayerName}",
      "ja": "さっきからおまんこの中が痙攣しっぱなしだな、そんなにこれが欲しかったのか？",
      "zh": ""
    },
    {
      "key": "81.0",
      "line_index": 81,
      "inline_index": 0,
      "line_hash": "57a5fd6",
      "speaker": "",
      "ja": "そう言いながら腰の動きを速めていくとリンファンは我を忘れた感じで声を上げた。",
      "zh": ""
    },
    {
      "key": "84.0",
      "line_index": 84,
      "inline_index": 0,
      "line_hash": "d52d0732",
      "speaker": "リンファン",
      "ja": "お、お兄ちゃんのおちんちんっ♥　ずっと欲しかったのぉっ♥",
      "zh": ""
    },
    {
      "key": "86.0",
      "line_index": 86,
      "inline_index": 0,
      "line_hash": "cf5455b9",
      "speaker": "",
      "ja": "歓喜の声を上げて悶えるリンファンを{G_PlayerName}は強く何度も突き上げていく。",
      "zh": ""
    },
    {
      "key": "88.0",
      "line_index": 88,
      "inline_index": 0,
      "line_hash": "b2fe0aff",
      "speaker": "",
      "ja": "その度にリンファンはビクンビクンと体を跳ねさせながら恍惚の表情を浮かべた。",
      "zh": ""
    },
    {
      "key": "91.0",
      "line_index": 91,
      "inline_index": 0,
      "line_hash": "ff9548a5",
      "speaker": "リンファン",
      "ja": "こ、これぇ♥　これ想像してっ♥　ひとりでおまんこくちゅくちゅしてたのっ♥",
      "zh": ""
    },
    {
      "key": "94.0",
      "line_index": 94,
      "inline_index": 0,
      "line_hash": "88f44072",
      "speaker": "{G_PlayerName}",
      "ja": "なんだ？　俺のちんぽを想像してオナニーしてたのかっ？",
      "zh": ""
    },
    {
      "key": "98.0",
      "line_index": 98,
      "inline_index": 0,
      "line_hash": "17fd0446",
      "speaker": "リンファン",
      "ja": "し、してたのぉ♥　毎日想像しておまんこいじって♥　ぐちゅぐちゅに濡らしてたのぉ♥",
      "zh": ""
    },
    {
      "key": "101.0",
      "line_index": 101,
      "inline_index": 0,
      "line_hash": "6ab037d5",
      "speaker": "{G_PlayerName}",
      "ja": "まったく……呆れたエロガキだな……",
      "zh": ""
    },
    {
      "key": "104.0",
      "line_index": 104,
      "inline_index": 0,
      "line_hash": "2862e6f7",
      "speaker": "",
      "ja": "そう言いながらも{G_PlayerName}は大きく腰を突き出し何度もリンファンを貫いていく。",
      "zh": ""
    },
    {
      "key": "106.0",
      "line_index": 106,
      "inline_index": 0,
      "line_hash": "281d6cdf",
      "speaker": "",
      "ja": "深々と陰茎が押し込まれる度にリンファンの下腹部が中から押し上げられて膨らんだ。",
      "zh": ""
    },
    {
      "key": "109.0",
      "line_index": 109,
      "inline_index": 0,
      "line_hash": "caf7d2a9",
      "speaker": "リンファン",
      "ja": "おふぅっ♥　おっ♥　おおっ♥　し、子宮に入っちゃうぅ♥　おなかがっ♥　あふううぅっ♥",
      "zh": ""
    },
    {
      "key": "111.0",
      "line_index": 111,
      "inline_index": 0,
      "line_hash": "31f9d8d0",
      "speaker": "",
      "ja": "狭いおまんこは奥までおちんちんを咥え込む程に、更に狭く締まっていく。",
      "zh": ""
    },
    {
      "key": "113.0",
      "line_index": 113,
      "inline_index": 0,
      "line_hash": "43723bd5",
      "speaker": "",
      "ja": "吸いつくような感覚に心地よさを覚えた{G_PlayerName}は、徐々に腰の動きを速めていった。",
      "zh": ""
    },
    {
      "key": "116.0",
      "line_index": 116,
      "inline_index": 0,
      "line_hash": "63e819a5",
      "speaker": "{G_PlayerName}",
      "ja": "そらっ！　そらっ！　そんなに欲しかったなら、たっぷりと味わわせてやるっ！",
      "zh": ""
    },
    {
      "key": "120.0",
      "line_index": 120,
      "inline_index": 0,
      "line_hash": "4a0fa681",
      "speaker": "リンファン",
      "ja": "んひぃぃっ♥　お、奥にずんずんくるぅ♥　あっ♥　ああっ♥　子宮に響くぅ♥　おふぅぅっ♥",
      "zh": ""
    },
    {
      "key": "122.0",
      "line_index": 122,
      "inline_index": 0,
      "line_hash": "450965c7",
      "speaker": "",
      "ja": "強く突き上げる程に膣はどんどんぬめり気を増していき、くちゅくちゅという水音が鳴り始める。",
      "zh": ""
    },
    {
      "key": "124.0",
      "line_index": 124,
      "inline_index": 0,
      "line_hash": "729e8587",
      "speaker": "",
      "ja": "その音と彼女の喘ぎ声に興奮が煽られた{G_PlayerName}はピストンを加速させていった。",
      "zh": ""
    },
    {
      "key": "127.0",
      "line_index": 127,
      "inline_index": 0,
      "line_hash": "4a1d61f7",
      "speaker": "リンファン",
      "ja": "んっ♥　んはぁぁぁっ♥　き、気持ちいいっ♥　おちんぽいい～♥　もっとっ♥　もっとぉ～～～っ♥",
      "zh": ""
    },
    {
      "key": "129.0",
      "line_index": 129,
      "inline_index": 0,
      "line_hash": "e2d99367",
      "speaker": "",
      "ja": "リンファンは可愛らしくおねだりしながら腰をくねらせて身悶えていく。",
      "zh": ""
    },
    {
      "key": "131.0",
      "line_index": 131,
      "inline_index": 0,
      "line_hash": "ee66f533",
      "speaker": "",
      "ja": "その度に肉襞が陰茎に絡みつき擦れて{G_PlayerName}にゾクゾクする快感を与えた。",
      "zh": ""
    },
    {
      "key": "134.0",
      "line_index": 134,
      "inline_index": 0,
      "line_hash": "7cc144bd",
      "speaker": "{G_PlayerName}",
      "ja": "はぁはぁ……すごい……締まる……うっ……くぅぅっ……",
      "zh": ""
    },
    {
      "key": "137.0",
      "line_index": 137,
      "inline_index": 0,
      "line_hash": "a04a83d5",
      "speaker": "",
      "ja": "強く吸いついてくるおまんこの感触に込み上げてくるものを感じながらも{G_PlayerName}は激しく腰を振り抽送を繰り返していく。",
      "zh": ""
    },
    {
      "key": "139.0",
      "line_index": 139,
      "inline_index": 0,
      "line_hash": "24318d9c",
      "speaker": "",
      "ja": "その突き上げにリンファンも絶頂へと追い込まれていった。",
      "zh": ""
    },
    {
      "key": "142.0",
      "line_index": 142,
      "inline_index": 0,
      "line_hash": "8acfa396",
      "speaker": "リンファン",
      "ja": "あっ♥　あああっ♥　イクっ♥　そんなに激しく突かれたらイっちゃうっ♥　んんんっ♥　あっ、はあぁぁんっ♥",
      "zh": ""
    },
    {
      "key": "144.0",
      "line_index": 144,
      "inline_index": 0,
      "line_hash": "14cb9b01",
      "speaker": "",
      "ja": "奥までおちんちんが押し込まれる度にリンファンの腰がビクンビクンと小さく跳ねる。",
      "zh": ""
    },
    {
      "key": "146.0",
      "line_index": 146,
      "inline_index": 0,
      "line_hash": "e7b4e2f1",
      "speaker": "",
      "ja": "その動きに合わせて膣も波打つように蠢いて出入りする肉竿に強く吸いついていった。",
      "zh": ""
    },
    {
      "key": "149.0",
      "line_index": 149,
      "inline_index": 0,
      "line_hash": "22d78cec",
      "speaker": "{G_PlayerName}",
      "ja": "うっ……くぅぅ……",
      "zh": ""
    },
    {
      "key": "152.0",
      "line_index": 152,
      "inline_index": 0,
      "line_hash": "35d6be71",
      "speaker": "",
      "ja": "あまりの気持ちよさに{G_PlayerName}は小さく呻くと大きく腰を突き出していく。",
      "zh": ""
    },
    {
      "key": "154.0",
      "line_index": 154,
      "inline_index": 0,
      "line_hash": "a124e8b8",
      "speaker": "",
      "ja": "そして子宮口におちんちんを押しつけると堪えきれなくなった{G_PlayerName}は、そのまま勢いよく精液を放った。",
      "zh": ""
    },
    {
      "key": "162.0",
      "line_index": 162,
      "inline_index": 0,
      "line_hash": "2a2f9af8",
      "speaker": "リンファン",
      "ja": "んぁ～っ♥　出てりゅ、出てりゅ、出てりゅうっ～♥",
      "zh": ""
    },
    {
      "key": "164.0",
      "line_index": 164,
      "inline_index": 0,
      "line_hash": "dbc60ca4",
      "speaker": "",
      "ja": "注ぎ込まれる精液の熱さにリンファンは舌を出しながら蕩けた声を上げながら絶頂に至っていた。",
      "zh": ""
    },
    {
      "key": "166.0",
      "line_index": 166,
      "inline_index": 0,
      "line_hash": "145f0a86",
      "speaker": "",
      "ja": "そんなリンファンのおまんこに、{G_PlayerName}は何度も射精し続ける。",
      "zh": ""
    },
    {
      "key": "168.0",
      "line_index": 168,
      "inline_index": 0,
      "line_hash": "3f0e6c0c",
      "speaker": "",
      "ja": "小さなおまんこはあっという間に{G_PlayerName}が出した精液でいっぱいになっていった。",
      "zh": ""
    },
    {
      "key": "171.0",
      "line_index": 171,
      "inline_index": 0,
      "line_hash": "54e8cffb",
      "speaker": "リンファン",
      "ja": "おなかっ、お兄ちゃんの精液で……たぷたぷ……♥",
      "zh": ""
    },
    {
      "key": "173.0",
      "line_index": 173,
      "inline_index": 0,
      "line_hash": "69b24fdb",
      "speaker": "",
      "ja": "甘えるような声でそう呟くリンファンの膣内に{G_PlayerName}はそのまま全ての精液を注ぎ込んで果てる。",
      "zh": ""
    },
    {
      "key": "175.0",
      "line_index": 175,
      "inline_index": 0,
      "line_hash": "6614975e",
      "speaker": "",
      "ja": "しかしそれだけではリンファンは満足していなく、甘えるような声で{G_PlayerName}におねだりした。",
      "zh": ""
    },
    {
      "key": "178.0",
      "line_index": 178,
      "inline_index": 0,
      "line_hash": "dc91f4eb",
      "speaker": "リンファン",
      "ja": "もっとぉ、もっとお兄ちゃんのおちんちん欲しいよぉ……♥",
      "zh": ""
    },
    {
      "key": "180.0",
      "line_index": 180,
      "inline_index": 0,
      "line_hash": "20886a7d",
      "speaker": "",
      "ja": "淫らな吐息を漏らしながら懇願してくるリンファンの姿に、射精したばかりの{G_PlayerName}のおちんちんは萎えることなく硬くなっていく。",
      "zh": ""
    },
    {
      "key": "183.0",
      "line_index": 183,
      "inline_index": 0,
      "line_hash": "2de45546",
      "speaker": "{G_PlayerName}",
      "ja": "仕方ないな……",
      "zh": ""
    },
    {
      "key": "186.0",
      "line_index": 186,
      "inline_index": 0,
      "line_hash": "744d5eae",
      "speaker": "",
      "ja": "そう呟いた{G_PlayerName}は、高まる興奮に任せて再び腰を振り始めた。",
      "zh": ""
    },
    {
      "key": "193.0",
      "line_index": 193,
      "inline_index": 0,
      "line_hash": "752ed3a0",
      "speaker": "リンファン",
      "ja": "出してっ♥　ザーメン全部、リンの子宮に出してぇ♥　んぉっ♥",
      "zh": ""
    },
    {
      "key": "195.0",
      "line_index": 195,
      "inline_index": 0,
      "line_hash": "265de08b",
      "speaker": "",
      "ja": "すっかり快楽に溺れトロトロの表情をしたリンファンは淫らな言葉を口にして求める。",
      "zh": ""
    },
    {
      "key": "197.0",
      "line_index": 197,
      "inline_index": 0,
      "line_hash": "58c2692d",
      "speaker": "",
      "ja": "その言葉に触発されたように{G_PlayerName}は夢中でピストンを繰り返していった。",
      "zh": ""
    },
    {
      "key": "199.0",
      "line_index": 199,
      "inline_index": 0,
      "line_hash": "3535dd5a",
      "speaker": "",
      "ja": "{G_PlayerName}の強い突き上げにリンファンは激しく腰を震わせながら喘ぎ声を上げる。",
      "zh": ""
    },
    {
      "key": "202.0",
      "line_index": 202,
      "inline_index": 0,
      "line_hash": "7a034b33",
      "speaker": "リンファン",
      "ja": "もっと♥　もっと一つになりたいのっ♥　ずっと、もっと、お兄ちゃんと繋がっていたいのっ♥　おぉっ♥",
      "zh": ""
    },
    {
      "key": "204.0",
      "line_index": 204,
      "inline_index": 0,
      "line_hash": "f33b817e",
      "speaker": "",
      "ja": "そんなリンファンの求めに応じるかのように、{G_PlayerName}は何度も腰を突き出し精液が溜まっている膣を奥まで強く貫いていった。",
      "zh": ""
    },
    {
      "key": "207.0",
      "line_index": 207,
      "inline_index": 0,
      "line_hash": "982f8aaf",
      "speaker": "リンファン",
      "ja": "おふぅっ♥　おちんぽぉ♥　お兄ちゃんのおちんぽすごぉいっ♥　おっ♥　おおぉっ♥　おほぉぉぉっ♥",
      "zh": ""
    },
    {
      "key": "209.0",
      "line_index": 209,
      "inline_index": 0,
      "line_hash": "859461d0",
      "speaker": "",
      "ja": "勃起したおちんちんがおまんこを掻き回しぐちゅぐちゅという淫らな水音を立てる。",
      "zh": ""
    },
    {
      "key": "211.0",
      "line_index": 211,
      "inline_index": 0,
      "line_hash": "c0ef623b",
      "speaker": "",
      "ja": "そのいやらしい音とリンファンの喘ぎ声に興奮を高めた{G_PlayerName}は徐々に腰の動きを激しくさせていった。",
      "zh": ""
    },
    {
      "key": "214.0",
      "line_index": 214,
      "inline_index": 0,
      "line_hash": "ac10f0bb",
      "speaker": "リンファン",
      "ja": "あんっ♥　あぁんっ♥　おちんぽずぽずぽ気持ちいい～♥　お兄ちゃんっ♥　もっとっ♥　もっとぉ～♥",
      "zh": ""
    },
    {
      "key": "217.0",
      "line_index": 217,
      "inline_index": 0,
      "line_hash": "b90b9e3b",
      "speaker": "{G_PlayerName}",
      "ja": "あ、ああ……わかってるよ……",
      "zh": ""
    },
    {
      "key": "220.0",
      "line_index": 220,
      "inline_index": 0,
      "line_hash": "ecc570b0",
      "speaker": "",
      "ja": "すっかり気持ちが高ぶった{G_PlayerName}はリンファンのおねだりに応えるように何度もおまんこを深々と貫いていく。",
      "zh": ""
    },
    {
      "key": "222.0",
      "line_index": 222,
      "inline_index": 0,
      "line_hash": "5b2a7406",
      "speaker": "",
      "ja": "その度にリンファンは大きな声で喘ぎ身をよじって悶えた。",
      "zh": ""
    },
    {
      "key": "225.0",
      "line_index": 225,
      "inline_index": 0,
      "line_hash": "16ef0f2d",
      "speaker": "リンファン",
      "ja": "んっ♥　あっ♥　んはぁぁ♥　またイクっ♥　イっちゃうっ♥　気持ちよすぎて蕩けちゃうぅ♥　はふぅ♥　あっ、はぁぁぁんっ♥",
      "zh": ""
    },
    {
      "key": "228.0",
      "line_index": 228,
      "inline_index": 0,
      "line_hash": "58dc3b15",
      "speaker": "{G_PlayerName}",
      "ja": "うっ……また締め付けが……強くなって……くっ……",
      "zh": ""
    },
    {
      "key": "231.0",
      "line_index": 231,
      "inline_index": 0,
      "line_hash": "eef936bd",
      "speaker": "",
      "ja": "突き上げる度に強く吸いついてくるおまんこの感触に{G_PlayerName}はまた射精したくなってくる。",
      "zh": ""
    },
    {
      "key": "233.0",
      "line_index": 233,
      "inline_index": 0,
      "line_hash": "20d365e",
      "speaker": "",
      "ja": "しかしそれを堪えて{G_PlayerName}はピストンを続けラストスパートをかけるようにリンファンを突き上げていった。",
      "zh": ""
    },
    {
      "key": "236.0",
      "line_index": 236,
      "inline_index": 0,
      "line_hash": "4c38be87",
      "speaker": "リンファン",
      "ja": "おほぉぉっ♥　おちんぽずぽずぽぉ♥　ぎ、ぎぼぢいいいいいっ♥　し、子宮がきゅんきゅんしゅるぅ♥",
      "zh": ""
    },
    {
      "key": "239.0",
      "line_index": 239,
      "inline_index": 0,
      "line_hash": "807d9525",
      "speaker": "{G_PlayerName}",
      "ja": "くっ……このまま最後まで……思いっきり突いてやるっ……そらっ！　そぉらっ！",
      "zh": ""
    },
    {
      "key": "243.0",
      "line_index": 243,
      "inline_index": 0,
      "line_hash": "5e692d85",
      "speaker": "リンファン",
      "ja": "んひいぃぃっ♥　お、おなかぁ♥　おちんぽの形にふくらんでりゅぅ♥　おっ♥　んおぉっ♥",
      "zh": ""
    },
    {
      "key": "245.0",
      "line_index": 245,
      "inline_index": 0,
      "line_hash": "30f35250",
      "speaker": "",
      "ja": "突き上げられる度にリンファンの口からは淫らな声が溢れ出る。",
      "zh": ""
    },
    {
      "key": "247.0",
      "line_index": 247,
      "inline_index": 0,
      "line_hash": "c2c779dd",
      "speaker": "",
      "ja": "そんな声に興奮を高めた{G_PlayerName}は夢中でピストンを繰り返した。",
      "zh": ""
    },
    {
      "key": "250.0",
      "line_index": 250,
      "inline_index": 0,
      "line_hash": "be21fb46",
      "speaker": "{G_PlayerName}",
      "ja": "どんどんおまんこが狭くなってきて……くっ……うぅぅっ……",
      "zh": ""
    },
    {
      "key": "254.0",
      "line_index": 254,
      "inline_index": 0,
      "line_hash": "7307b990",
      "speaker": "リンファン",
      "ja": "イっ、イグっ♥　イっちゃうっ♥　お兄ちゃんのおちんぽでまたイっちゃうぅ♥　あふぅ♥　お゛っ♥　おほぉぉ♥",
      "zh": ""
    },
    {
      "key": "257.0",
      "line_index": 257,
      "inline_index": 0,
      "line_hash": "550875f1",
      "speaker": "{G_PlayerName}",
      "ja": "俺もそろそろ……で、出そうだ……はぁ……はぁ……",
      "zh": ""
    },
    {
      "key": "260.0",
      "line_index": 260,
      "inline_index": 0,
      "line_hash": "cb90f64b",
      "speaker": "",
      "ja": "限界が近づいてきた{G_PlayerName}は射精に向かって何度も腰を突き上げていく。",
      "zh": ""
    },
    {
      "key": "262.0",
      "line_index": 262,
      "inline_index": 0,
      "line_hash": "885cabeb",
      "speaker": "",
      "ja": "その抽送にリンファンも一気に登り詰めていった。",
      "zh": ""
    },
    {
      "key": "265.0",
      "line_index": 265,
      "inline_index": 0,
      "line_hash": "3ea9e72c",
      "speaker": "リンファン",
      "ja": "イグぅぅっ♥　イっちゃうぅ♥　んっ♥　んんっ♥　おなかぼこぼこぉ♥　おほぉっ♥　んほおぉぉおおおっ♥",
      "zh": ""
    },
    {
      "key": "267.0",
      "line_index": 267,
      "inline_index": 0,
      "line_hash": "87b71258",
      "speaker": "",
      "ja": "アクメが近づいてきた膣は強く締まり{G_PlayerName}もとうとう限界に達してしまう。",
      "zh": ""
    },
    {
      "key": "270.0",
      "line_index": 270,
      "inline_index": 0,
      "line_hash": "272da32d",
      "speaker": "{G_PlayerName}",
      "ja": "で、出る……中に……うっ……うぅぅっ！",
      "zh": ""
    },
    {
      "key": "273.0",
      "line_index": 273,
      "inline_index": 0,
      "line_hash": "d492c43",
      "speaker": "",
      "ja": "再び込み上げてきた{G_PlayerName}はまた大きく腰を突き出すと、膣の奥に熱い精液をぶちまけた。",
      "zh": ""
    },
    {
      "key": "282.0",
      "line_index": 282,
      "inline_index": 0,
      "line_hash": "c9513408",
      "speaker": "リンファン",
      "ja": "イっぐぅっ♥　リンの赤ちゃんの部屋っ、お兄ちゃんのザーメンでいっぱいにされちゃってりゅっ～♥",
      "zh": ""
    },
    {
      "key": "284.0",
      "line_index": 284,
      "inline_index": 0,
      "line_hash": "59e412c0",
      "speaker": "",
      "ja": "先程以上に大きな声を上げながらリンファンは派手に絶頂に達してしまう。",
      "zh": ""
    },
    {
      "key": "286.0",
      "line_index": 286,
      "inline_index": 0,
      "line_hash": "84aa714b",
      "speaker": "",
      "ja": "そんなリンファンの膣内に{G_PlayerName}はまた大量の精液を放ち続けた。",
      "zh": ""
    },
    {
      "key": "289.0",
      "line_index": 289,
      "inline_index": 0,
      "line_hash": "4167bf5b",
      "speaker": "{G_PlayerName}",
      "ja": "うっ……くっ……うぅぅっ……",
      "zh": ""
    },
    {
      "key": "292.0",
      "line_index": 292,
      "inline_index": 0,
      "line_hash": "43967aa4",
      "speaker": "",
      "ja": "どぴゅどぴゅとおちんちんが射精する度に狭い膣がびゅくびゅくと蠢いて強く吸いついてくる。",
      "zh": ""
    },
    {
      "key": "294.0",
      "line_index": 294,
      "inline_index": 0,
      "line_hash": "b8c4eedc",
      "speaker": "",
      "ja": "搾り取ろうとするようなその強い締め付けに{G_PlayerName}は全ての精液を放って果てた。",
      "zh": ""
    },
    {
      "key": "297.0",
      "line_index": 297,
      "inline_index": 0,
      "line_hash": "8f467fd",
      "speaker": "{G_PlayerName}",
      "ja": "はぁ……はぁ……はぁ……これに懲りたら、寝込みを襲ったりするなよっ……",
      "zh": ""
    },
    {
      "key": "300.0",
      "line_index": 300,
      "inline_index": 0,
      "line_hash": "840ebd1d",
      "speaker": "",
      "ja": "全て出しきった{G_PlayerName}が息を切らしつつ釘を刺すようにそう告げるが、リンファンは悪びれもなく甘い声で呟く。",
      "zh": ""
    },
    {
      "key": "303.0",
      "line_index": 303,
      "inline_index": 0,
      "line_hash": "e47902d0",
      "speaker": "リンファン",
      "ja": "やだ……♥　ま、また襲っちゃうもん……♥　何回でも……何度でも……♥",
      "zh": ""
    },
    {
      "key": "305.0",
      "line_index": 305,
      "inline_index": 0,
      "line_hash": "aa9601f7",
      "speaker": "",
      "ja": "まるで懲りていない彼女の言葉に{G_PlayerName}は呆れ顔を浮かべてしまっていた。",
      "zh": ""
    },
    {
      "key": "307.0",
      "line_index": 307,
      "inline_index": 0,
      "line_hash": "4bdc61cd",
      "speaker": "",
      "ja": "そんな{G_PlayerName}にリンファンはどこか幸せそうな表情を浮かべ甘えるように呟く。",
      "zh": ""
    },
    {
      "key": "310.0",
      "line_index": 310,
      "inline_index": 0,
      "line_hash": "f8563bb6",
      "speaker": "リンファン",
      "ja": "お兄ちゃんに、おまんこめちゃくちゃにされるの……気持ちいいんだもん……♥",
      "zh": ""
    },
    {
      "key": "313.0",
      "line_index": 313,
      "inline_index": 0,
      "line_hash": "b03e6aa4",
      "speaker": "{G_PlayerName}",
      "ja": "まったく……",
      "zh": ""
    },
    {
      "key": "316.0",
      "line_index": 316,
      "inline_index": 0,
      "line_hash": "39f6e31c",
      "speaker": "",
      "ja": "しょうがないなと思いつつも{G_PlayerName}は果てた陰茎をリンファンのどろどろになったおまんこからずるりと引き抜いていった。",
      "zh": ""
    },
    {
      "key": "323.0",
      "line_index": 323,
      "inline_index": 0,
      "line_hash": "33d3f8fe",
      "speaker": "リンファン",
      "ja": "んはぁぁっ♥　あっ……♥　あぁぁ……♥　おちんぽぬけりゅぅぅ♥",
      "zh": ""
    },
    {
      "key": "325.0",
      "line_index": 325,
      "inline_index": 0,
      "line_hash": "8310e62a",
      "speaker": "",
      "ja": "おちんちんが抜けたリンファンのおまんこは、ぽっかりと広がったままヒクヒクと蠢き、中から白濁した汁がどろりと溢れ出てくる。",
      "zh": ""
    },
    {
      "key": "328.0",
      "line_index": 328,
      "inline_index": 0,
      "line_hash": "af55d4b",
      "speaker": "リンファン",
      "ja": "こぽぉって……♥　どぷどぷぅってぇ……♥　ザーメン……こんなに出されちゃったぁ♥",
      "zh": ""
    },
    {
      "key": "330.0",
      "line_index": 330,
      "inline_index": 0,
      "line_hash": "221a7adf",
      "speaker": "",
      "ja": "だらしなくヨダレを垂らしている口を動かし、快楽に浸りきった表情を浮かべながらリンファンはそんな言葉を口にした。",
      "zh": ""
    },
    {
      "key": "332.0",
      "line_index": 332,
      "inline_index": 0,
      "line_hash": "38edde18",
      "speaker": "",
      "ja": "そんなリンファンを見ながら{G_PlayerName}は改めて思う。",
      "zh": ""
    },
    {
      "key": "335.0",
      "line_index": 335,
      "inline_index": 0,
      "line_hash": "3026c6b7",
      "speaker": "{G_PlayerName}",
      "ja": "（この調子だと、全然反省してないな……。）",
      "zh": ""
    },
    {
      "key": "338.0",
      "line_index": 338,
      "inline_index": 0,
      "line_hash": "95fc92b3",
      "speaker": "",
      "ja": "呆れ顔の{G_PlayerName}をよそに、リンファンは恍惚の表情を浮かべながら気持ちよさそうに呟いていた。",
      "zh": ""
    },
    {
      "key": "341.0",
      "line_index": 341,
      "inline_index": 0,
      "line_hash": "34f8f9a7",
      "speaker": "リンファン",
      "ja": "精液、漏れちゃう……ダメっ♥　また、イクっ♥　イグイグっ……イクっ……おっ♥",
      "zh": ""
    },
    {
      "key": "345.0",
      "line_index": 345,
      "inline_index": 0,
      "line_hash": "c41e9435",
      "speaker": "",
      "ja": "おまんこから精液をこぼしながらリンファンはその感触で絶頂を繰り返している。",
      "zh": ""
    },
    {
      "key": "347.0",
      "line_index": 347,
      "inline_index": 0,
      "line_hash": "63af2b63",
      "speaker": "",
      "ja": "そんな淫らな姿を{G_PlayerName}はしばらくの間眺めていた。",
      "zh": ""
    }
  ]
}
