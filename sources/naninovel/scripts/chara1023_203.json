{
  "lines": [
    {
      "key": "12.0",
      "line_index": 12,
      "inline_index": 0,
      "line_hash": "590354ff",
      "speaker": "雫",
      "ja": "はぁ……♥　はぁ……♥　はぁ……♥",
      "zh": ""
    },
    {
      "key": "14.0",
      "line_index": 14,
      "inline_index": 0,
      "line_hash": "8cad067d",
      "speaker": "",
      "ja": "{G_PlayerName}から少し離れた場所で、雫は息を荒げていた。しかも足を大きく広げてパンツの上から股間を指で撫で上げている。",
      "zh": ""
    },
    {
      "key": "17.0",
      "line_index": 17,
      "inline_index": 0,
      "line_hash": "da23af1e",
      "speaker": "雫",
      "ja": "わ、わたくし……どうしてこんな……んっ♥　んんんっ♥",
      "zh": ""
    },
    {
      "key": "19.0",
      "line_index": 19,
      "inline_index": 0,
      "line_hash": "f7c588ff",
      "speaker": "",
      "ja": "自らの興奮に戸惑いつつも、おまんこをいじらずにはいられない程彼女の気持ちは高ぶってしまっていた。",
      "zh": ""
    },
    {
      "key": "22.0",
      "line_index": 22,
      "inline_index": 0,
      "line_hash": "e643d961",
      "speaker": "雫",
      "ja": "あぁぁ……おまんこが疼く……あふっ……うっ……くふぅぅ♥",
      "zh": ""
    },
    {
      "key": "24.0",
      "line_index": 24,
      "inline_index": 0,
      "line_hash": "79fd86d3",
      "speaker": "",
      "ja": "パンツの上から割れ目に沿って指を動かすと、ゾクッとする快感が走りネットリとした汁が奥から溢れ出てきてしまう。",
      "zh": ""
    },
    {
      "key": "26.0",
      "line_index": 26,
      "inline_index": 0,
      "line_hash": "120fef74",
      "speaker": "",
      "ja": "その汁が染みこんだパンツにはシミが浮かんできていた。",
      "zh": ""
    },
    {
      "key": "29.0",
      "line_index": 29,
      "inline_index": 0,
      "line_hash": "19d78566",
      "speaker": "雫",
      "ja": "んっ♥　なんで……こんなに濡れて……っ♥　あっ♥　ふぅんっ♥",
      "zh": ""
    },
    {
      "key": "31.0",
      "line_index": 31,
      "inline_index": 0,
      "line_hash": "b1de1fcd",
      "speaker": "",
      "ja": "雫の体はすっかり高揚してしまい、全身が熱く火照っている。",
      "zh": ""
    },
    {
      "key": "33.0",
      "line_index": 33,
      "inline_index": 0,
      "line_hash": "7dfae94e",
      "speaker": "",
      "ja": "その高ぶりを慰めるために、彼女は自ら股間を撫で上げていた。",
      "zh": ""
    },
    {
      "key": "36.0",
      "line_index": 36,
      "inline_index": 0,
      "line_hash": "82fca2d4",
      "speaker": "雫",
      "ja": "なんでわたくし……こんなに興奮してしまって……もしかして……あの男の裸を見た……せい……？",
      "zh": ""
    },
    {
      "key": "38.0",
      "line_index": 38,
      "inline_index": 0,
      "line_hash": "6eddb84d",
      "speaker": "",
      "ja": "ずぶ濡れになって服を乾かすため全裸になっていたnameの姿を見てから雫の心臓はドキドキしてしまっている。",
      "zh": ""
    },
    {
      "key": "41.0",
      "line_index": 41,
      "inline_index": 0,
      "line_hash": "e4717967",
      "speaker": "雫",
      "ja": "わたくしが……男の……裸を……み、見た程度で……んんんっ♥　こ、こんなに……欲情してしまって……あふぅぅ♥",
      "zh": ""
    },
    {
      "key": "43.0",
      "line_index": 43,
      "inline_index": 0,
      "line_hash": "2d2ae57a",
      "speaker": "",
      "ja": "パンツの上から割れ目を指でなぞり上げる度に雫の口からは甘い声が漏れた。",
      "zh": ""
    },
    {
      "key": "45.0",
      "line_index": 45,
      "inline_index": 0,
      "line_hash": "bc3eb2b0",
      "speaker": "",
      "ja": "その度に股間の部分にシミが広がっていくが、そんなことなど気にせずに雫の指先はおまんこを撫で上げていく。",
      "zh": ""
    },
    {
      "key": "48.0",
      "line_index": 48,
      "inline_index": 0,
      "line_hash": "d6abb35d",
      "speaker": "雫",
      "ja": "んふぅぅ……♥　あっ……あんっ♥　こんなことするなんて……で、でも……指が……とめられない……はぁぁ♥",
      "zh": ""
    },
    {
      "key": "50.0",
      "line_index": 50,
      "inline_index": 0,
      "line_hash": "13ac436c",
      "speaker": "",
      "ja": "その指の動きはどんどん激しさを増してきて、パンツのシミも大きくなった。",
      "zh": ""
    },
    {
      "key": "52.0",
      "line_index": 52,
      "inline_index": 0,
      "line_hash": "e43a5d2b",
      "speaker": "",
      "ja": "おかげでパンツの上からもおまんこの形がハッキリと透けて見え、クリトリスがすっかり勃起しているのが丸わかりだ。",
      "zh": ""
    },
    {
      "key": "55.0",
      "line_index": 55,
      "inline_index": 0,
      "line_hash": "8a0369ad",
      "speaker": "雫",
      "ja": "んっ、んんっ♥　クリ……硬くなってる……あっ……ああっ……♥　おまんこも……ヒクヒクして……はぁ……はぁ……♥",
      "zh": ""
    },
    {
      "key": "57.0",
      "line_index": 57,
      "inline_index": 0,
      "line_hash": "8875687f",
      "speaker": "",
      "ja": "すっかり興奮してしまった雫は、何度も割れ目を撫で上げて膨らんだクリトリスを指先で転がしていた。",
      "zh": ""
    },
    {
      "key": "59.0",
      "line_index": 59,
      "inline_index": 0,
      "line_hash": "98b218e6",
      "speaker": "",
      "ja": "その刺激におまんこは物欲しげに蠢き更に濡れていってしまう。",
      "zh": ""
    },
    {
      "key": "61.0",
      "line_index": 61,
      "inline_index": 0,
      "line_hash": "ce3bd8f",
      "speaker": "",
      "ja": "そんな彼女の脳裏には先程見てしまったnameのチンポが思い浮かんでいた。",
      "zh": ""
    },
    {
      "key": "64.0",
      "line_index": 64,
      "inline_index": 0,
      "line_hash": "ec2d0729",
      "speaker": "雫",
      "ja": "あ、あの男……普段はふにゃふにゃしているくせに……んんんっ♥　ゴツゴツしていて……大きくて……あっ……あぅぅ♥",
      "zh": ""
    },
    {
      "key": "66.0",
      "line_index": 66,
      "inline_index": 0,
      "line_hash": "61603411",
      "speaker": "",
      "ja": "思い出す程に心臓の鼓動は速まり体が火照っていってしまう。",
      "zh": ""
    },
    {
      "key": "68.0",
      "line_index": 68,
      "inline_index": 0,
      "line_hash": "6f6aba0f",
      "speaker": "",
      "ja": "ムラムラは治まるどころか大きくなる一方なのだがそれに雫自身は納得出来なかった。",
      "zh": ""
    },
    {
      "key": "71.0",
      "line_index": 71,
      "inline_index": 0,
      "line_hash": "41915875",
      "speaker": "雫",
      "ja": "もう！　わたくしったら何を考えているの！",
      "zh": ""
    },
    {
      "key": "74.0",
      "line_index": 74,
      "inline_index": 0,
      "line_hash": "55e171c0",
      "speaker": "雫",
      "ja": "どうしてわたくしのおまんこはこんなに疼いてしまうんですか！　ば、馬鹿じゃありませんの！",
      "zh": ""
    },
    {
      "key": "76.0",
      "line_index": 76,
      "inline_index": 0,
      "line_hash": "1276911c",
      "speaker": "",
      "ja": "雫は発情してしまっている自らに憤りながらも指の動きを止められない。",
      "zh": ""
    },
    {
      "key": "79.0",
      "line_index": 79,
      "inline_index": 0,
      "line_hash": "1cc63a8e",
      "speaker": "雫",
      "ja": "ああ！　もう！",
      "zh": ""
    },
    {
      "key": "81.0",
      "line_index": 81,
      "inline_index": 0,
      "line_hash": "4e796b41",
      "speaker": "",
      "ja": "すごく苛立ちながらも雫は我慢できなくなり、おもむろにパンツをずらすとすっかり濡れたおまんこに躊躇なく中指と人差し指を挿入した。",
      "zh": ""
    },
    {
      "key": "88.0",
      "line_index": 88,
      "inline_index": 0,
      "line_hash": "65a9324e",
      "speaker": "雫",
      "ja": "フーッ♥　フゥーーーッ♥",
      "zh": ""
    },
    {
      "key": "90.0",
      "line_index": 90,
      "inline_index": 0,
      "line_hash": "e2f26b16",
      "speaker": "",
      "ja": "濡れたおまんこは簡単に２本の指を咥え込んでびゅくびゅくとイヤらしく蠢いている。",
      "zh": ""
    },
    {
      "key": "92.0",
      "line_index": 92,
      "inline_index": 0,
      "line_hash": "480ff9e2",
      "speaker": "",
      "ja": "そんなおまんこを雫は挿入した指で掻き回し始めた。",
      "zh": ""
    },
    {
      "key": "95.0",
      "line_index": 95,
      "inline_index": 0,
      "line_hash": "e6e90d30",
      "speaker": "雫",
      "ja": "こ、こんな……グチョグチョになってしまって……うぅぅっ……わ、わたくしが……あんなもので興奮するなど……くっ……ふぅぅ♥",
      "zh": ""
    },
    {
      "key": "97.0",
      "line_index": 97,
      "inline_index": 0,
      "line_hash": "c7a514b5",
      "speaker": "",
      "ja": "そう言っても疼く身体はどうしようもなく、おまんこで蠢く指を",
      "zh": ""
    },
    {
      "key": "98.0",
      "line_index": 98,
      "inline_index": 0,
      "line_hash": "698e6712",
      "speaker": "",
      "ja": "止めることもできない。",
      "zh": ""
    },
    {
      "key": "101.0",
      "line_index": 101,
      "inline_index": 0,
      "line_hash": "2c14690c",
      "speaker": "雫",
      "ja": "ふぅーっ……ふぅーっ……なんでこんな……くふぅぅ……んんんっ♥　あぁぁ……どんどん溢れてきてる……もうベチョベチョで……♥",
      "zh": ""
    },
    {
      "key": "103.0",
      "line_index": 103,
      "inline_index": 0,
      "line_hash": "90fa6e47",
      "speaker": "",
      "ja": "雫の指はおまんこを出入りしながら掻き回すように動き続けた。",
      "zh": ""
    },
    {
      "key": "105.0",
      "line_index": 105,
      "inline_index": 0,
      "line_hash": "d3b67a34",
      "speaker": "",
      "ja": "その度に淫らな水音が鳴り、ネットリとした汁が滴っていく。",
      "zh": ""
    },
    {
      "key": "108.0",
      "line_index": 108,
      "inline_index": 0,
      "line_hash": "cd9ab048",
      "speaker": "雫",
      "ja": "んっ♥　んんんっ♥　指がヌルヌルになって……ふぅぅ♥　んあぁぁ♥",
      "zh": ""
    },
    {
      "key": "111.0",
      "line_index": 111,
      "inline_index": 0,
      "line_hash": "c8f70bfa",
      "speaker": "雫",
      "ja": "こ、こんなにびしょびしょに濡れてしまって……んっ♥　くふぅ♥",
      "zh": ""
    },
    {
      "key": "114.0",
      "line_index": 114,
      "inline_index": 0,
      "line_hash": "8655a784",
      "speaker": "雫",
      "ja": "も、もしエッチすることになったら、あのおちんちんがここに……っ",
      "zh": ""
    },
    {
      "key": "116.0",
      "line_index": 116,
      "inline_index": 0,
      "line_hash": "e9ff18c1",
      "speaker": "",
      "ja": "そんな想像をした雫だが、すぐにそれを否定するように激しく首を横に振った。",
      "zh": ""
    },
    {
      "key": "119.0",
      "line_index": 119,
      "inline_index": 0,
      "line_hash": "5ad6687a",
      "speaker": "雫",
      "ja": "いいえ！　ありえません！　わたくしが男となんかと！",
      "zh": ""
    },
    {
      "key": "121.0",
      "line_index": 121,
      "inline_index": 0,
      "line_hash": "f7e43ff",
      "speaker": "",
      "ja": "必死に口では否定してみるが、nameの裸体を思い出すと悶々としてしまい指の動きがどんどん激しくなっていってしまう。",
      "zh": ""
    },
    {
      "key": "124.0",
      "line_index": 124,
      "inline_index": 0,
      "line_hash": "eae3c9fa",
      "speaker": "雫",
      "ja": "んんんっ！　な、なんでわたくしがっ！　あ、あんなのに興奮して！　くっ、うぅぅっ！　あふっ……うっ、んくぅぅぅっ♥",
      "zh": ""
    },
    {
      "key": "126.0",
      "line_index": 126,
      "inline_index": 0,
      "line_hash": "ad0d0606",
      "speaker": "",
      "ja": "拒絶しようとすればする程、nameの全裸がハッキリと蘇ってきた。",
      "zh": ""
    },
    {
      "key": "128.0",
      "line_index": 128,
      "inline_index": 0,
      "line_hash": "a6f274a8",
      "speaker": "",
      "ja": "それが雫の興奮を煽り、おまんこからはネットリとした汁が後から後から溢れ出てしまう。",
      "zh": ""
    },
    {
      "key": "131.0",
      "line_index": 131,
      "inline_index": 0,
      "line_hash": "3dba25ff",
      "speaker": "雫",
      "ja": "……だ、だめっ……おまんこ指でズボズボするの……んんんっ♥　どんどん気持ちよくなって……はふぅ♥　はぁんっ♥　あんあんっ♥",
      "zh": ""
    },
    {
      "key": "134.0",
      "line_index": 134,
      "inline_index": 0,
      "line_hash": "57e065c2",
      "speaker": "雫",
      "ja": "ど、どうしてわたくし……こ、こんなっ♥　あふぅぅんっ♥　も、もう……だめっ♥　おまんこ……いっ、いいっ♥",
      "zh": ""
    },
    {
      "key": "136.0",
      "line_index": 136,
      "inline_index": 0,
      "line_hash": "57cd8d7",
      "speaker": "",
      "ja": "いつの間にかさっきまで否定していた言葉すら出なくなってきて雫は夢中で濡れたおまんこを指で掻き回し喘ぐ。",
      "zh": ""
    },
    {
      "key": "138.0",
      "line_index": 138,
      "inline_index": 0,
      "line_hash": "16559737",
      "speaker": "",
      "ja": "その度に腰が何度も小さく跳ねて、おまんこが物欲しげに蠢いた。",
      "zh": ""
    },
    {
      "key": "141.0",
      "line_index": 141,
      "inline_index": 0,
      "line_hash": "ac122dcb",
      "speaker": "雫",
      "ja": "んふぅぅ♥　どんどん溢れてくるぅ♥　ぐっちゅぐちゅになるぅ♥　はふぅぅ♥　はぁ♥　はぁ♥　おまんこ気持ちいい～っ♥",
      "zh": ""
    },
    {
      "key": "143.0",
      "line_index": 143,
      "inline_index": 0,
      "line_hash": "a83e5edc",
      "speaker": "",
      "ja": "息を荒げながら雫はすっかり夢中になっておまんこを指で掻き回す。",
      "zh": ""
    },
    {
      "key": "145.0",
      "line_index": 145,
      "inline_index": 0,
      "line_hash": "172af006",
      "speaker": "",
      "ja": "その刺激で雫は、絶頂が徐々に近づいてくるのを感じた。",
      "zh": ""
    },
    {
      "key": "148.0",
      "line_index": 148,
      "inline_index": 0,
      "line_hash": "c39633b6",
      "speaker": "雫",
      "ja": "イくっ♥　イッちゃうぅ♥　はぁはぁ♥　あっ……あぁんっ♥",
      "zh": ""
    },
    {
      "key": "151.0",
      "line_index": 151,
      "inline_index": 0,
      "line_hash": "9aa6eb9e",
      "speaker": "雫",
      "ja": "ああ～っ！　だめっ！　気持ちいいっ！　イくっ、イっくぅっ！",
      "zh": ""
    },
    {
      "key": "158.0",
      "line_index": 158,
      "inline_index": 0,
      "line_hash": "1410a7ba",
      "speaker": "",
      "ja": "ぷしゃぁぁぁ～～～～～っ！",
      "zh": ""
    },
    {
      "key": "161.0",
      "line_index": 161,
      "inline_index": 0,
      "line_hash": "da5c5744",
      "speaker": "雫",
      "ja": "んんん～～～～～っ♥",
      "zh": ""
    },
    {
      "key": "163.0",
      "line_index": 163,
      "inline_index": 0,
      "line_hash": "a284b682",
      "speaker": "",
      "ja": "雫は派手に潮を吹きながら大きな絶頂に襲われてしまう。",
      "zh": ""
    },
    {
      "key": "168.0",
      "line_index": 168,
      "inline_index": 0,
      "line_hash": "972185d5",
      "speaker": "雫",
      "ja": "気持ちいい♥　気持ちいい♥　おまんこ天国になるっ♥　すごいっ、いいっ♥",
      "zh": ""
    },
    {
      "key": "170.0",
      "line_index": 170,
      "inline_index": 0,
      "line_hash": "1083bafe",
      "speaker": "",
      "ja": "すっかり快感に溺れている雫は、ギュッと目をつむり歯を食いしばっていた。",
      "zh": ""
    },
    {
      "key": "172.0",
      "line_index": 172,
      "inline_index": 0,
      "line_hash": "4f4c4314",
      "speaker": "",
      "ja": "絶頂に集中しすぎ何も考えられず、口の端からヨダレが垂れていることにすら気づいていない。",
      "zh": ""
    },
    {
      "key": "175.0",
      "line_index": 175,
      "inline_index": 0,
      "line_hash": "db9a22c9",
      "speaker": "雫",
      "ja": "はぁ……はぁ……はぁ……ふぅ～……ふぅ～……",
      "zh": ""
    },
    {
      "key": "177.0",
      "line_index": 177,
      "inline_index": 0,
      "line_hash": "cde6881b",
      "speaker": "",
      "ja": "絶頂の余韻が徐々に治まり息づかいは荒いものの雫は徐々に思考を取り戻し始めた。",
      "zh": ""
    },
    {
      "key": "179.0",
      "line_index": 179,
      "inline_index": 0,
      "line_hash": "8f5e79b4",
      "speaker": "",
      "ja": "そして自らの姿にハッとする。",
      "zh": ""
    },
    {
      "key": "182.0",
      "line_index": 182,
      "inline_index": 0,
      "line_hash": "f30cc38d",
      "speaker": "雫",
      "ja": "あっ……まずい……見つからないうちに処理しなくては……！",
      "zh": ""
    },
    {
      "key": "184.0",
      "line_index": 184,
      "inline_index": 0,
      "line_hash": "13c49662",
      "speaker": "",
      "ja": "我に返った雫はそそくさと乱れた服を整えると、びしょびしょに濡れてしまっているおまんこを拭き始めた。",
      "zh": ""
    }
  ]
}
