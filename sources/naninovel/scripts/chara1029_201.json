      "key": "252.0",
      "line_index": 252,
      "inline_index": 0,
      "line_hash": "bf6418c0",
      "speaker": "{G_PlayerName}",
      "ja": "うぅぅっ……まだ……で、出るっ……くぅぅっ……",
      "zh": ""
