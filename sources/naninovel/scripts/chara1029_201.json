    },
    {
      "key": "234.4",
      "line_index": 234,
      "inline_index": 4,
      "line_hash": "c2569fba",
      "speaker": "シーシャ",
      "ja": "んぐんぐっ♥　ちゅっ♥　ちゅるるっ♥　うっ、んんんっ♥",
