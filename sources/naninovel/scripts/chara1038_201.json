      "key": "239.0",
      "line_index": 239,
      "inline_index": 0,
      "line_hash": "6187efa",
      "speaker": "ヴァイン",
      "ja": "ふううっ！？♥　ああ、熱いの……たくさん出て……はぁぁ～っ♥",
      "zh": ""
    },
