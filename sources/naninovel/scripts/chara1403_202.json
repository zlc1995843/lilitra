{
  "lines": [
    {
      "key": "18.1",
      "line_index": 18,
      "inline_index": 1,
      "line_hash": "b35e8693",
      "speaker": "オーロラ",
      "ja": "欲しい……早くあなたのおちんちんが欲しい……♥",
      "zh": ""
    },
    {
      "key": "20.0",
      "line_index": 20,
      "inline_index": 0,
      "line_hash": "d6bc55c6",
      "speaker": "",
      "ja": "オーロラは恥ずかしがることもなく服をまくる。",
      "zh": ""
    },
    {
      "key": "21.0",
      "line_index": 21,
      "inline_index": 0,
      "line_hash": "dca52ad4",
      "speaker": "",
      "ja": "パンツをずらすと、ネバっとした愛液が糸を引きながら垂れ落ちる。",
      "zh": ""
    },
    {
      "key": "23.0",
      "line_index": 23,
      "inline_index": 0,
      "line_hash": "63f2fbc9",
      "speaker": "",
      "ja": "俺の想像よりもエロくなっているオーロラに心音の高鳴りが止まらない。",
      "zh": ""
    },
    {
      "key": "24.0",
      "line_index": 24,
      "inline_index": 0,
      "line_hash": "4e0afb2d",
      "speaker": "",
      "ja": "ゆっくりとオーロラに近づくと、そっと小さな身体を抱きしめた。",
      "zh": ""
    },
    {
      "key": "27.1",
      "line_index": 27,
      "inline_index": 1,
      "line_hash": "82f0d781",
      "speaker": "オーロラ",
      "ja": "んふふ……♥　あなたのおちんちん、もうおっきくなってる……♥",
      "zh": ""
    },
    {
      "key": "30.0",
      "line_index": 30,
      "inline_index": 0,
      "line_hash": "d85331e9",
      "speaker": "{G_PlayerName}",
      "ja": "オーロラがエロくて可愛い過ぎるんだよ……一つになったらどこまでも求めてしまうかもしれない……",
      "zh": ""
    },
    {
      "key": "34.1",
      "line_index": 34,
      "inline_index": 1,
      "line_hash": "6e50efd3",
      "speaker": "オーロラ",
      "ja": "いいよ、それで……♥　あたしもそうして欲しいって思ってるからね……♥",
      "zh": ""
    },
    {
      "key": "37.0",
      "line_index": 37,
      "inline_index": 0,
      "line_hash": "e5aa4c37",
      "speaker": "{G_PlayerName}",
      "ja": "そうか……でもできれば声は抑えてくれよ？　外に聞こえるかもしれないしさ",
      "zh": ""
    },
    {
      "key": "41.1",
      "line_index": 41,
      "inline_index": 1,
      "line_hash": "25957531",
      "speaker": "オーロラ",
      "ja": "んー……頑張ってみるけど、たぶんムリだと思うよ……♥　今あたしすごくエッチになっちゃってるから……♥",
      "zh": ""
    },
    {
      "key": "44.1",
      "line_index": 44,
      "inline_index": 1,
      "line_hash": "bb3c1db2",
      "speaker": "オーロラ",
      "ja": "誰かに見られたら、その時はその時だよ……♥　なるようにしかならないから♥",
      "zh": ""
    },
    {
      "key": "47.1",
      "line_index": 47,
      "inline_index": 1,
      "line_hash": "726c19e7",
      "speaker": "オーロラ",
      "ja": "……もうお話はおしまい♥　早くセックスして……あたしを気持ち良くさせて♥",
      "zh": ""
    },
    {
      "key": "63.0",
      "line_index": 63,
      "inline_index": 0,
      "line_hash": "e1ad932d",
      "speaker": "オーロラ",
      "ja": "ふぅ……！♥　ふああ、おちんちんさっきより熱くなってるぅ……♥　はぁ、はぁ、んはぁぁ……♥",
      "zh": ""
    },
    {
      "key": "65.0",
      "line_index": 65,
      "inline_index": 0,
      "line_hash": "6ee68302",
      "speaker": "",
      "ja": "挿入の準備をするようにオーロラのあそこに肉棒を押し付けると、身体を震わせながら甘い声をあげる。",
      "zh": ""
    },
    {
      "key": "67.0",
      "line_index": 67,
      "inline_index": 0,
      "line_hash": "378e88a2",
      "speaker": "",
      "ja": "素股のように割れ目を肉棒で擦ると、さらに大量の愛液が溢れ肉棒が真っ白な愛液でヌルヌルになってしまう。",
      "zh": ""
    },
    {
      "key": "70.0",
      "line_index": 70,
      "inline_index": 0,
      "line_hash": "4b9626f0",
      "speaker": "オーロラ",
      "ja": "んふぅ……ふぅ……♥　おまんこの奥、すっごく疼いてるぅ……♥　おちんちん欲しいっておねだりしてるぅ……♥",
      "zh": ""
    },
    {
      "key": "73.0",
      "line_index": 73,
      "inline_index": 0,
      "line_hash": "cd9a4833",
      "speaker": "{G_PlayerName}",
      "ja": "ああ、はっきりわかるぞ……俺のちんぽ、オーロラの愛液まみれだ……このまま素股でも射精できそう",
      "zh": ""
    },
    {
      "key": "77.0",
      "line_index": 77,
      "inline_index": 0,
      "line_hash": "9a4b6a9e",
      "speaker": "オーロラ",
      "ja": "そんなのダメだよぉ……♥　これ以上お預けされたらあたしおかしくなるぅ……♥",
      "zh": ""
    },
    {
      "key": "79.0",
      "line_index": 79,
      "inline_index": 0,
      "line_hash": "1307d53d",
      "speaker": "",
      "ja": "オーロラは亀頭を掴むと、そっと膣穴に肉棒を押し当てる。",
      "zh": ""
    },
    {
      "key": "80.0",
      "line_index": 80,
      "inline_index": 0,
      "line_hash": "a050296a",
      "speaker": "",
      "ja": "あとは俺が腰を突き出せば一つになれる、オーロラはそんなことを言いたげな視線を俺に向けてくる。",
      "zh": ""
    },
    {
      "key": "83.0",
      "line_index": 83,
      "inline_index": 0,
      "line_hash": "e6a0ef4",
      "speaker": "オーロラ",
      "ja": "あたしのおまんこ、ぐちゅぐちゅ掻き回して……♥　あなたのこと、好きで好きでたまらないんだって再認識させて……♥",
      "zh": ""
    },
    {
      "key": "86.0",
      "line_index": 86,
      "inline_index": 0,
      "line_hash": "65e071fc",
      "speaker": "オーロラ",
      "ja": "あなたのこと……独り占めさせて……♥　あたしだけの男の人になって……♥",
      "zh": ""
    },
    {
      "key": "94.0",
      "line_index": 94,
      "inline_index": 0,
      "line_hash": "c6711061",
      "speaker": "オーロラ",
      "ja": "はうううっ！♥　んぅ、んあ、あ……ううっ！♥　おちんちん、奥にぃ……あうっ！♥",
      "zh": ""
    },
    {
      "key": "96.0",
      "line_index": 96,
      "inline_index": 0,
      "line_hash": "73609dab",
      "speaker": "",
      "ja": "オーロラの想いに応えるように俺は腰を突き出す。",
      "zh": ""
    },
    {
      "key": "97.0",
      "line_index": 97,
      "inline_index": 0,
      "line_hash": "dd6418b9",
      "speaker": "",
      "ja": "狭い膣を肉棒で強引にこじ開けると、膣穴を押し広げるように抽送を繰り返す。",
      "zh": ""
    },
    {
      "key": "99.0",
      "line_index": 99,
      "inline_index": 0,
      "line_hash": "7460cbc2",
      "speaker": "",
      "ja": "オーロラの膣がきゅっと締まり、膣が意思を持っているように肉棒に絡む。",
      "zh": ""
    },
    {
      "key": "100.0",
      "line_index": 100,
      "inline_index": 0,
      "line_hash": "d15b45b3",
      "speaker": "",
      "ja": "柔らかでぬるぬるな膣に包まれ、動くだけで甘すぎる快感が肉棒から全身へと広がっていく。",
      "zh": ""
    },
    {
      "key": "103.0",
      "line_index": 103,
      "inline_index": 0,
      "line_hash": "8986d215",
      "speaker": "オーロラ",
      "ja": "おちんちん気持ち良い……もっと、もっと突いて……んっ！♥　はぁ、あああ、おまんこ蕩けそうだよぉっ！！♥",
      "zh": ""
    },
    {
      "key": "106.0",
      "line_index": 106,
      "inline_index": 0,
      "line_hash": "3e6316ec",
      "speaker": "{G_PlayerName}",
      "ja": "オーロラ、声抑えてくれっ……！　外に聞こえてしまう！",
      "zh": ""
    },
    {
      "key": "110.0",
      "line_index": 110,
      "inline_index": 0,
      "line_hash": "183f1e5b",
      "speaker": "オーロラ",
      "ja": "わかってる、けどぉ……あうっ！♥　ムリだよぉ……！♥　おちんちん気持ち良すぎるのぉっ！♥　ふあ、ふあ、あん……んは、あああぁんっ！！♥",
      "zh": ""
    },
    {
      "key": "113.0",
      "line_index": 113,
      "inline_index": 0,
      "line_hash": "e691d83f",
      "speaker": "オーロラ",
      "ja": "おっぱい、そんなに強く……あう、ダメぇ……！♥　おまんこだけでも気持ち良すぎるのにぃ……！！♥",
      "zh": ""
    },
    {
      "key": "116.0",
      "line_index": 116,
      "inline_index": 0,
      "line_hash": "620e440",
      "speaker": "オーロラ",
      "ja": "声抑えるなんてぇ……んふぅっ！♥　絶対にムリムリムリぃっ……！！♥",
      "zh": ""
    },
    {
      "key": "118.0",
      "line_index": 118,
      "inline_index": 0,
      "line_hash": "8961f6c",
      "speaker": "",
      "ja": "オーロラの甘い声と蕩ける表情に釣られるように俺の腰の動きも自然と早くなる。",
      "zh": ""
    },
    {
      "key": "120.0",
      "line_index": 120,
      "inline_index": 0,
      "line_hash": "fd7468dc",
      "speaker": "",
      "ja": "声を出させてはいけない、そう考えてはいたが俺自身オーロラを求めるオスの本能を抑えられない。",
      "zh": ""
    },
    {
      "key": "123.0",
      "line_index": 123,
      "inline_index": 0,
      "line_hash": "1d0bf31e",
      "speaker": "オーロラ",
      "ja": "あひぃ、ひぃっ！♥　ああ、ずんずんっ、そこ、いいのっ！♥　もっとぉ……あうううっ！！♥",
      "zh": ""
    },
    {
      "key": "126.0",
      "line_index": 126,
      "inline_index": 0,
      "line_hash": "82119e89",
      "speaker": "{G_PlayerName}",
      "ja": "ああ、オーロラの弱いところはもう把握済みだから……もっと喜ばせてやるからな……！",
      "zh": ""
    },
    {
      "key": "130.0",
      "line_index": 130,
      "inline_index": 0,
      "line_hash": "63ecd051",
      "speaker": "オーロラ",
      "ja": "んひぃっ！♥　乳首っ、らめぇっ！♥　あう、ジンジン気持ち良いぃぃっ！♥　んんぅ、ふぅ、ふあ、ふあああぁんっ！！♥",
      "zh": ""
    },
    {
      "key": "132.0",
      "line_index": 132,
      "inline_index": 0,
      "line_hash": "c93c4e83",
      "speaker": "",
      "ja": "溢れる愛液をローション代わりにして抽送がさらにスムーズになっていく。",
      "zh": ""
    },
    {
      "key": "134.0",
      "line_index": 134,
      "inline_index": 0,
      "line_hash": "7766d24a",
      "speaker": "",
      "ja": "オーロラの小さなお尻に腰を叩きつけるように腰を突き出し、肌と肌のぶつかり合う音が部屋中に響く。",
      "zh": ""
    },
    {
      "key": "136.0",
      "line_index": 136,
      "inline_index": 0,
      "line_hash": "989ee09",
      "speaker": "",
      "ja": "下腹部に感じるオーロラの柔らかなお尻の感触も俺の興奮を煽り、肉棒にさらに血が集まっていくのが自分でもはっきりとわかってしまう。",
      "zh": ""
    },
    {
      "key": "139.0",
      "line_index": 139,
      "inline_index": 0,
      "line_hash": "4557b582",
      "speaker": "オーロラ",
      "ja": "おまんこもっ、おっぱいもっ、気持ちぃよぉっ！！♥　あなたとセックスするのすごくいいのぉっ！♥",
      "zh": ""
    },
    {
      "key": "142.0",
      "line_index": 142,
      "inline_index": 0,
      "line_hash": "1a82cc1",
      "speaker": "オーロラ",
      "ja": "ずっとずっと、毎日だってセックスしたいぃっ！♥　あなたと一緒に快楽に溺れたいのぉっ！！♥",
      "zh": ""
    },
    {
      "key": "145.0",
      "line_index": 145,
      "inline_index": 0,
      "line_hash": "dc7e1989",
      "speaker": "{G_PlayerName}",
      "ja": "オーロラが望むならいくらでもするさっ……！　毎日何回だってしてやる……！　俺だってそんくらいオーロラのこと好きでたまらないんだっ……！！",
      "zh": ""
    },
    {
      "key": "149.0",
      "line_index": 149,
      "inline_index": 0,
      "line_hash": "7c0e9512",
      "speaker": "オーロラ",
      "ja": "うれ、しいっ！♥　今の言葉、絶対に忘れないからねぇっ……！♥　あんっ！♥　毎日あなたとラブラブセックスするんだからぁっ……！！♥",
      "zh": ""
    },
    {
      "key": "151.0",
      "line_index": 151,
      "inline_index": 0,
      "line_hash": "e03cea62",
      "speaker": "",
      "ja": "オーロラは俺に身体を預け、さらに快感に溺れていく。",
      "zh": ""
    },
    {
      "key": "152.0",
      "line_index": 152,
      "inline_index": 0,
      "line_hash": "b67b9bdb",
      "speaker": "",
      "ja": "膣が精液を搾り出そうとさらにぎゅうぎゅうに締まる。",
      "zh": ""
    },
    {
      "key": "154.0",
      "line_index": 154,
      "inline_index": 0,
      "line_hash": "c8c2230d",
      "speaker": "",
      "ja": "柔膣と大量の愛液の刺激に、こみ上げてくる射精衝動。",
      "zh": ""
    },
    {
      "key": "155.0",
      "line_index": 155,
      "inline_index": 0,
      "line_hash": "9ec79cc7",
      "speaker": "",
      "ja": "射精を求め子宮口を押し潰すように小刻みに腰を乱雑に振り乱していく。",
      "zh": ""
    },
    {
      "key": "158.0",
      "line_index": 158,
      "inline_index": 0,
      "line_hash": "83dce60b",
      "speaker": "オーロラ",
      "ja": "んああぁっ！♥　も、もうっ！♥　イ、ちゃ……んぅ、んぅぅぅっ！♥　おまんこ、イクよぉっ！！♥",
      "zh": ""
    },
    {
      "key": "161.0",
      "line_index": 161,
      "inline_index": 0,
      "line_hash": "25dcb91e",
      "speaker": "オーロラ",
      "ja": "イク、イクっ！♥　んぅぅぅっ！♥　ふあ、ふあ、あ、んっ……んんんんん～～～～っ！！♥♥",
      "zh": ""
    },
    {
      "key": "170.0",
      "line_index": 170,
      "inline_index": 0,
      "line_hash": "a0cb8e9c",
      "speaker": "オーロラ",
      "ja": "はううううっ！♥　んぅぅぅっ！♥　おまんこイクぅぅぅぅっ！♥　あああぁぁぁ～～っ！！♥♥",
      "zh": ""
    },
    {
      "key": "172.0",
      "line_index": 172,
      "inline_index": 0,
      "line_hash": "19da09b",
      "speaker": "",
      "ja": "オーロラの膣がぎゅっと肉棒に吸い付き、こみ上げる快感のままに熱いモノを一気に膣奥に吐き出す。",
      "zh": ""
    },
    {
      "key": "174.0",
      "line_index": 174,
      "inline_index": 0,
      "line_hash": "bab894ad",
      "speaker": "",
      "ja": "オーロラの甘い悲鳴が部屋に響き渡り、ビクンビクンと俺の腕の中で身体を跳ねらせる。",
      "zh": ""
    },
    {
      "key": "175.0",
      "line_index": 175,
      "inline_index": 0,
      "line_hash": "7ef730a5",
      "speaker": "",
      "ja": "背後からでもわかるほど潮をプシャっと噴かせ、何度も絶頂を繰り返していた。",
      "zh": ""
    },
    {
      "key": "178.0",
      "line_index": 178,
      "inline_index": 0,
      "line_hash": "6a923442",
      "speaker": "オーロラ",
      "ja": "精液、いっぱいぃ……♥　きもぢいいよぉ……あおっ♥　もっとびゅるびゅるしてぇ……んひぃっ！♥",
      "zh": ""
    },
    {
      "key": "181.0",
      "line_index": 181,
      "inline_index": 0,
      "line_hash": "f2af970f",
      "speaker": "{G_PlayerName}",
      "ja": "ふう、ふうっ！　オーロラ、少し声抑えて……！　マジで外に聞こえちゃうから……！",
      "zh": ""
    },
    {
      "key": "185.0",
      "line_index": 185,
      "inline_index": 0,
      "line_hash": "bfc15c07",
      "speaker": "オーロラ",
      "ja": "んんんぅっ！♥　ムリぃ……♥　おまんこ溶けるぅ……♥　イクの、止まらないよぉ……ふああ、はあぁぁぁ……！♥♥",
      "zh": ""
    },
    {
      "key": "187.0",
      "line_index": 187,
      "inline_index": 0,
      "line_hash": "c09fce97",
      "speaker": "",
      "ja": "外に誰かいたら確実にセックスしていることがバレる。",
      "zh": ""
    },
    {
      "key": "188.0",
      "line_index": 188,
      "inline_index": 0,
      "line_hash": "ee9134c1",
      "speaker": "",
      "ja": "それほど大きな喘ぎ声を上げながらオーロラは絶頂し続ける。",
      "zh": ""
    },
    {
      "key": "190.0",
      "line_index": 190,
      "inline_index": 0,
      "line_hash": "37b09b23",
      "speaker": "",
      "ja": "そんな状況に冷や汗をかきながらも、心がゾクゾクとしてしまう。",
      "zh": ""
    },
    {
      "key": "191.0",
      "line_index": 191,
      "inline_index": 0,
      "line_hash": "63e6334c",
      "speaker": "",
      "ja": "まだオーロラとセックスしたい、その想いをぶつけるように俺は心の命じるままに腰を再び動かし始めた。",
      "zh": ""
    },
    {
      "key": "198.0",
      "line_index": 198,
      "inline_index": 0,
      "line_hash": "5fc8f762",
      "speaker": "オーロラ",
      "ja": "はううっ！？♥　ゆ、指ぃ？♥　な、なんで……はうっ……んっ！！♥　ふぅ、ふうううっ！！♥",
      "zh": ""
    },
    {
      "key": "201.0",
      "line_index": 201,
      "inline_index": 0,
      "line_hash": "c4699cd6",
      "speaker": "{G_PlayerName}",
      "ja": "俺の指しゃぶって……それで少しは声抑えられると思うから",
      "zh": ""
    },
    {
      "key": "205.0",
      "line_index": 205,
      "inline_index": 0,
      "line_hash": "30ffcef1",
      "speaker": "オーロラ",
      "ja": "わ、わかったよぉ……ちゅ……ちゅ……ぢゅるっ………ふううっ！♥　んっ、んっ、んんんん～～っ！！♥",
      "zh": ""
    },
    {
      "key": "207.0",
      "line_index": 207,
      "inline_index": 0,
      "line_hash": "f205c977",
      "speaker": "",
      "ja": "オーロラは夢中に俺の指をしゃぶり、更なる快感欲しさに自らも腰を動かす。",
      "zh": ""
    },
    {
      "key": "209.0",
      "line_index": 209,
      "inline_index": 0,
      "line_hash": "7a52a961",
      "speaker": "",
      "ja": "息の合った動きに先ほどよりも肉棒に快感が伝わり、気持ち良さに両脚がガクガクと震える。",
      "zh": ""
    },
    {
      "key": "211.0",
      "line_index": 211,
      "inline_index": 0,
      "line_hash": "4be74a1a",
      "speaker": "",
      "ja": "柔らかなお尻がむにゅっと下腹部に強く当たり、俺はそのお返しをするようにクニクニと乳首を捏ね回していく。",
      "zh": ""
    },
    {
      "key": "214.0",
      "line_index": 214,
      "inline_index": 0,
      "line_hash": "a184c8ec",
      "speaker": "オーロラ",
      "ja": "んふぅっ！♥　んぅぅぅっ！♥　らめぇ……！♥　おまんこ、イキっぱなしぃ……！♥　ふぅ、んんんっ！！♥",
      "zh": ""
    },
    {
      "key": "217.0",
      "line_index": 217,
      "inline_index": 0,
      "line_hash": "ef72ce32",
      "speaker": "オーロラ",
      "ja": "乳首も、おまんこも、気持ち良すぎてヘンになりゅぅっ！♥　んひぃぃ……ひいいいっ！！♥",
      "zh": ""
    },
    {
      "key": "220.0",
      "line_index": 220,
      "inline_index": 0,
      "line_hash": "8475f39e",
      "speaker": "{G_PlayerName}",
      "ja": "もっともっと俺で気持ち良くなってくれ。いくらでも快感に溺れてくれっ",
      "zh": ""
    },
    {
      "key": "224.0",
      "line_index": 224,
      "inline_index": 0,
      "line_hash": "16ba1d96",
      "speaker": "{G_PlayerName}",
      "ja": "オーロラの一番可愛くて、一番エロい姿をもっと見せてくれっ！",
      "zh": ""
    },
    {
      "key": "228.0",
      "line_index": 228,
      "inline_index": 0,
      "line_hash": "cce978b9",
      "speaker": "オーロラ",
      "ja": "んぎいいっ！♥　おまんこ、壊れりゅぅっ！♥　はお、おおっ！！♥　おぐ、おぐぅぅっ！♥　もっとぉっ！♥　あひいいいっ！！♥",
      "zh": ""
    },
    {
      "key": "230.0",
      "line_index": 230,
      "inline_index": 0,
      "line_hash": "62405dd",
      "speaker": "",
      "ja": "……──ヒソヒソ",
      "zh": ""
    },
    {
      "key": "233.0",
      "line_index": 233,
      "inline_index": 0,
      "line_hash": "9570aa3b",
      "speaker": "{G_PlayerName}",
      "ja": "──ッ！？",
      "zh": ""
    },
    {
      "key": "236.0",
      "line_index": 236,
      "inline_index": 0,
      "line_hash": "144baf9a",
      "speaker": "",
      "ja": "オーロラの喘ぎ声に混ざり、外から何か声が聞こえたような気がした。",
      "zh": ""
    },
    {
      "key": "237.0",
      "line_index": 237,
      "inline_index": 0,
      "line_hash": "b2235c1e",
      "speaker": "",
      "ja": "それでも俺はピストンをやめられず、夢中になってオーロラのおまんこを責め立てる。",
      "zh": ""
    },
    {
      "key": "239.0",
      "line_index": 239,
      "inline_index": 0,
      "line_hash": "8de11042",
      "speaker": "",
      "ja": "──ヒソヒソ",
      "zh": ""
    },
    {
      "key": "240.0",
      "line_index": 240,
      "inline_index": 0,
      "line_hash": "62405dd",
      "speaker": "",
      "ja": "……──ヒソヒソ",
      "zh": ""
    },
    {
      "key": "243.0",
      "line_index": 243,
      "inline_index": 0,
      "line_hash": "16c272e",
      "speaker": "{G_PlayerName}",
      "ja": "（声、大きくなってる……！？　これ完全に何をしてるか気づかれてないか……？）",
      "zh": ""
    },
    {
      "key": "247.0",
      "line_index": 247,
      "inline_index": 0,
      "line_hash": "2396440",
      "speaker": "オーロラ",
      "ja": "んぢゅるっ、ちゅっ！♥　もっと、もっと滅茶苦茶にしてぇ……！♥　ちゅ……ちゅぅぅ……ふうう、んぅぅっ！♥　んふぅ、ふああっ！！♥",
      "zh": ""
    },
    {
      "key": "250.0",
      "line_index": 250,
      "inline_index": 0,
      "line_hash": "33c8cb0d",
      "speaker": "{G_PlayerName}",
      "ja": "オーロラ、指しゃぶって……！　声、完全に外に漏れてる……！！",
      "zh": ""
    },
    {
      "key": "254.0",
      "line_index": 254,
      "inline_index": 0,
      "line_hash": "ddb31684",
      "speaker": "オーロラ",
      "ja": "ちゅちゅ……んふぅっ♥　んふぅ、ふうう、んはっ！♥　そこぉっ！♥　いいの、ぐちゅぐちゅ突いてぇ……！♥　んひぃ、ひいいいっ！！♥",
      "zh": ""
    },
    {
      "key": "256.0",
      "line_index": 256,
      "inline_index": 0,
      "line_hash": "62a9d815",
      "speaker": "",
      "ja": "オーロラは外の声はおろか、俺の声も半分届いていない。",
      "zh": ""
    },
    {
      "key": "257.0",
      "line_index": 257,
      "inline_index": 0,
      "line_hash": "797a37b4",
      "speaker": "",
      "ja": "完全に快楽に溺れ、肉棒を求めお尻を夢中になって俺に押し付ける。",
      "zh": ""
    },
    {
      "key": "259.0",
      "line_index": 259,
      "inline_index": 0,
      "line_hash": "eb2b984f",
      "speaker": "",
      "ja": "一瞬やめようかと思ったが、オスの本能がそれを拒絶する。",
      "zh": ""
    },
    {
      "key": "260.0",
      "line_index": 260,
      "inline_index": 0,
      "line_hash": "a414dcc6",
      "speaker": "",
      "ja": "もうバレるならバレるで仕方ない、俺はそう開き直りさらに激しく腰を前後させていく。",
      "zh": ""
    },
    {
      "key": "263.0",
      "line_index": 263,
      "inline_index": 0,
      "line_hash": "bbe2b101",
      "speaker": "オーロラ",
      "ja": "んぅぅっ！♥　おちんちん、しゅごいっ！♥　まだ硬くなってぇ……んぅ、ん、おっ、おっ！！♥　一番奥、穿ってるぅっ！！♥",
      "zh": ""
    },
    {
      "key": "266.0",
      "line_index": 266,
      "inline_index": 0,
      "line_hash": "9435dadd",
      "speaker": "オーロラ",
      "ja": "ほぉ、おっ！♥　んぅ、ま、またしゅごいの、キちゃうっ！♥　んんぅぅぅっ！♥　素敵なおちんちんでまたイっちゃうよぉっ！！♥",
      "zh": ""
    },
    {
      "key": "269.0",
      "line_index": 269,
      "inline_index": 0,
      "line_hash": "8107340a",
      "speaker": "{G_PlayerName}",
      "ja": "俺もそろそろ……またこのまま出すぞ……！",
      "zh": ""
    },
    {
      "key": "273.0",
      "line_index": 273,
      "inline_index": 0,
      "line_hash": "cfb78371",
      "speaker": "オーロラ",
      "ja": "らしてぇっ！♥　おまんこせーえきでいっぱいにしてぇっ！♥　中イキしゃせてぇええっ！！♥",
      "zh": ""
    },
    {
      "key": "275.0",
      "line_index": 275,
      "inline_index": 0,
      "line_hash": "afdc6183",
      "speaker": "",
      "ja": "いつドアをノックされるのか……それほどまでに外のヒソヒソ声が大きくなっていく。",
      "zh": ""
    },
    {
      "key": "277.0",
      "line_index": 277,
      "inline_index": 0,
      "line_hash": "9377e762",
      "speaker": "",
      "ja": "でももう俺の耳にもその声が半分も入ってこない。",
      "zh": ""
    },
    {
      "key": "278.0",
      "line_index": 278,
      "inline_index": 0,
      "line_hash": "aa8d658a",
      "speaker": "",
      "ja": "オーロラの中に射精する……思考が完全にオスの欲望に支配され、大量の精液を注ぎ込もうと夢中になって腰を振り乱す。",
      "zh": ""
    },
    {
      "key": "281.0",
      "line_index": 281,
      "inline_index": 0,
      "line_hash": "a54e0789",
      "speaker": "オーロラ",
      "ja": "イぎゅぅっ！♥　おまんこイぎゅぅううっ！！♥　イグイグっ！！♥　イっちゃう、イっちゃう～～～～っ！！♥♥",
      "zh": ""
    },
    {
      "key": "291.0",
      "line_index": 291,
      "inline_index": 0,
      "line_hash": "ffcd5130",
      "speaker": "オーロラ",
      "ja": "んひぃぃぃぃぃっ！♥　んぅぅぅっ！♥　んは、あっ、何か、出っ……あうううっ！！♥♥",
      "zh": ""
    },
    {
      "key": "294.0",
      "line_index": 294,
      "inline_index": 0,
      "line_hash": "8792668a",
      "speaker": "{G_PlayerName}",
      "ja": "こ、これっ！？　ううううっ！！",
      "zh": ""
    },
    {
      "key": "297.0",
      "line_index": 297,
      "inline_index": 0,
      "line_hash": "85b23407",
      "speaker": "",
      "ja": "予想だにしなかったオーロラの母乳。",
      "zh": ""
    },
    {
      "key": "298.0",
      "line_index": 298,
      "inline_index": 0,
      "line_hash": "25e69dba",
      "speaker": "",
      "ja": "思わぬ光景に俺の興奮が異様に高まり、乳首を捏ねながら腰を小刻みに揺らす。",
      "zh": ""
    },
    {
      "key": "301.0",
      "line_index": 301,
      "inline_index": 0,
      "line_hash": "c4bd4df6",
      "speaker": "オーロラ",
      "ja": "あうう、な、なんでおっぱいが……ううう……！♥　らめぇ……乳首、捏ねないでぇ……出るの、気持ち良しゅぎるのぉ……あひぃっ！！♥",
      "zh": ""
    },
    {
      "key": "303.0",
      "line_index": 303,
      "inline_index": 0,
      "line_hash": "418c21c1",
      "speaker": "",
      "ja": "母乳同様に尿道からは大量の潮がプシャっと噴き出し、床が潮と母乳で濡れていく。",
      "zh": ""
    },
    {
      "key": "304.0",
      "line_index": 304,
      "inline_index": 0,
      "line_hash": "ab821326",
      "speaker": "",
      "ja": "卑猥すぎるオーロラの姿に俺の射精も収まらず、何度も子宮へ精液を注ぎ込む。",
      "zh": ""
    },
    {
      "key": "306.0",
      "line_index": 306,
      "inline_index": 0,
      "line_hash": "3e84ff5e",
      "speaker": "",
      "ja": "しかしそれも収まり始め、俺達の荒い吐息だけが部屋の中に響き渡っていく。",
      "zh": ""
    },
    {
      "key": "309.0",
      "line_index": 309,
      "inline_index": 0,
      "line_hash": "3f6a2529",
      "speaker": "オーロラ",
      "ja": "は、んはぁ……母乳出ちゃうなんてぇ……ううう、く、薬の副作用なのかなぁ……♥",
      "zh": ""
    },
    {
      "key": "312.0",
      "line_index": 312,
      "inline_index": 0,
      "line_hash": "6960b47b",
      "speaker": "オーロラ",
      "ja": "か、考えたいけどぉ……あうっ♥　頭の中ぐちゃぐちゃで……考えがまとまらないよぉ……♥",
      "zh": ""
    },
    {
      "key": "315.0",
      "line_index": 315,
      "inline_index": 0,
      "line_hash": "79280652",
      "speaker": "{G_PlayerName}",
      "ja": "それはあとで考えればいいよ……今は実験とかそういう忘れてくれ……",
      "zh": ""
    },
    {
      "key": "318.0",
      "line_index": 318,
      "inline_index": 0,
      "line_hash": "ec071ece",
      "speaker": "",
      "ja": "俺はそう耳元で囁きながら、オーロラの小さな身体をぎゅっと抱きしめる。",
      "zh": ""
    },
    {
      "key": "321.0",
      "line_index": 321,
      "inline_index": 0,
      "line_hash": "e983427e",
      "speaker": "オーロラ",
      "ja": "そう、だね……ごめんなさい、ついそっちに考えが向いちゃって……♥　せっかくあなたとラブラブエッチしてるんだもん……今はこっちの方が大事だよね……♥",
      "zh": ""
    },
    {
      "key": "324.0",
      "line_index": 324,
      "inline_index": 0,
      "line_hash": "72d1e336",
      "speaker": "オーロラ",
      "ja": "ねぇ……もっとあなたとラブラブエッチしたい……続きして……♥",
      "zh": ""
    },
    {
      "key": "327.0",
      "line_index": 327,
      "inline_index": 0,
      "line_hash": "a4c4a8fc",
      "speaker": "{G_PlayerName}",
      "ja": "そうしたいのは山々だけどさ……さすがにこれ以上ここでするのは無理だ……続きは宇宙船に戻ってからにしよう？",
      "zh": ""
    },
    {
      "key": "331.0",
      "line_index": 331,
      "inline_index": 0,
      "line_hash": "3f73ad68",
      "speaker": "オーロラ",
      "ja": "うう……残念……♥　でもでも、絶対に続きはするからね？♥",
      "zh": ""
    },
    {
      "key": "334.0",
      "line_index": 334,
      "inline_index": 0,
      "line_hash": "1990af89",
      "speaker": "{G_PlayerName}",
      "ja": "ああ、約束だ……とりあえず今はここからバレずに脱出する方法を考えないと",
      "zh": ""
    },
    {
      "key": "337.0",
      "line_index": 337,
      "inline_index": 0,
      "line_hash": "fb6d3fc5",
      "speaker": "",
      "ja": "とはいえ、今オーロラを連れ出すのは無理だ。",
      "zh": ""
    },
    {
      "key": "338.0",
      "line_index": 338,
      "inline_index": 0,
      "line_hash": "1746da70",
      "speaker": "",
      "ja": "俺はそう考え、オーロラが落ち着くまで小さな身体を抱きしめ続けているのであった。",
      "zh": ""
    }
  ]
}
