    {
      "key": "231.0",
      "line_index": 231,
      "inline_index": 0,
      "line_hash": "376678e9",
      "speaker": "{G_PlayerName}",
      "ja": "ひいいいいっ！？♥　息吹きかけるのダメぇっ！♥　あああああぁっ！！♥",
