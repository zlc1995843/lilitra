{
  "lines": [
    {
      "key": "19.1",
      "line_index": 19,
      "inline_index": 1,
      "line_hash": "7fd17ada",
      "speaker": "ティティア",
      "ja": "はぁ……♥　はぁ……♥　お兄さん……お兄さん……♥",
      "zh": ""
    },
    {
      "key": "21.0",
      "line_index": 21,
      "inline_index": 0,
      "line_hash": "6c49e291",
      "speaker": "",
      "ja": "みんなが寝静まった深夜、{G_PlayerName}の部屋に無断で入るティティア。",
      "zh": ""
    },
    {
      "key": "22.0",
      "line_index": 22,
      "inline_index": 0,
      "line_hash": "c11f6ed1",
      "speaker": "",
      "ja": "もちろん{G_PlayerName}も他の人達同様に寝息を立て夢の中にいた。",
      "zh": ""
    },
    {
      "key": "24.0",
      "line_index": 24,
      "inline_index": 0,
      "line_hash": "85e10a37",
      "speaker": "",
      "ja": "ティティアの頬は真っ赤に染まり、瞳には涙が浮かぶ。",
      "zh": ""
    },
    {
      "key": "25.0",
      "line_index": 25,
      "inline_index": 0,
      "line_hash": "eaed5f85",
      "speaker": "",
      "ja": "明らかに普段の元気な女の子の様子とは違い、一人の女として眠っている{G_PlayerName}に熱い眼差しを向けていた。",
      "zh": ""
    },
    {
      "key": "28.1",
      "line_index": 28,
      "inline_index": 1,
      "line_hash": "4b33e4b7",
      "speaker": "ティティア",
      "ja": "お兄さんがいけないんですよ……♥　ティティに優しくするから……♥",
      "zh": ""
    },
    {
      "key": "31.1",
      "line_index": 31,
      "inline_index": 1,
      "line_hash": "1654fb42",
      "speaker": "ティティア",
      "ja": "ティティ、お兄さんのことを想うだけでお股ぐちゅぐちゅ……♥　もうエッチなお汁が溢れて止まらないですぅ……♥",
      "zh": ""
    },
    {
      "key": "34.1",
      "line_index": 34,
      "inline_index": 1,
      "line_hash": "e136c91d",
      "speaker": "ティティア",
      "ja": "発情したうさちゃんはエッチなこと我慢できないんです……♥　だからお兄さん、ごめんなさい、お兄さんの身体で……♥",
      "zh": ""
    },
    {
      "key": "36.0",
      "line_index": 36,
      "inline_index": 0,
      "line_hash": "b06d8e0f",
      "speaker": "",
      "ja": "ティティアは懐から懐中時計を取り出す。",
      "zh": ""
    },
    {
      "key": "37.0",
      "line_index": 37,
      "inline_index": 0,
      "line_hash": "d8a67d09",
      "speaker": "",
      "ja": "そしてカチリという音と共に、寝息を立てていた{G_PlayerName}の呼吸がピタリと止まってしまう。",
      "zh": ""
    },
    {
      "key": "40.1",
      "line_index": 40,
      "inline_index": 1,
      "line_hash": "197cd9fb",
      "speaker": "ティティア",
      "ja": "はぁ……♥　んはぁ……♥　これでお兄さんに何をしても……誰にもわからないですぅ……♥",
      "zh": ""
    },
    {
      "key": "43.1",
      "line_index": 43,
      "inline_index": 1,
      "line_hash": "3fc01397",
      "speaker": "ティティア",
      "ja": "お兄さん、今だけ、時間が静止している今だけ、今だけでいいからティティのモノになって……♥",
      "zh": ""
    },
    {
      "key": "46.1",
      "line_index": 46,
      "inline_index": 1,
      "line_hash": "df53a850",
      "speaker": "ティティア",
      "ja": "今だけ、切なくて寂しん坊のおまんこ慰めさせて……♥",
      "zh": ""
    },
    {
      "key": "60.0",
      "line_index": 60,
      "inline_index": 0,
      "line_hash": "8d9469c5",
      "speaker": "ティティア",
      "ja": "はぁ♥　はぁぁっ♥　ああ、お兄さんのお顔、こんなに近くにぃ……♥",
      "zh": ""
    },
    {
      "key": "62.0",
      "line_index": 62,
      "inline_index": 0,
      "line_hash": "84122892",
      "speaker": "",
      "ja": "ティティアは興奮のままに{G_PlayerName}を全裸にすると、すでに蕩け切っているあそこを{G_PlayerName}の顔に近づける。",
      "zh": ""
    },
    {
      "key": "64.0",
      "line_index": 64,
      "inline_index": 0,
      "line_hash": "bbe9d48b",
      "speaker": "",
      "ja": "愛液が糸を引きながら垂れ落ち、ポタポタと{G_PlayerName}の顔を濡らす。",
      "zh": ""
    },
    {
      "key": "65.0",
      "line_index": 65,
      "inline_index": 0,
      "line_hash": "b45d05d",
      "speaker": "",
      "ja": "時間が止まっているせいで{G_PlayerName}は一切動かない。",
      "zh": ""
    },
    {
      "key": "66.0",
      "line_index": 66,
      "inline_index": 0,
      "line_hash": "8be5d13c",
      "speaker": "",
      "ja": "それでもティティアには{G_PlayerName}にあそこを近くで見られている、その快感を味わっていた。",
      "zh": ""
    },
    {
      "key": "69.0",
      "line_index": 69,
      "inline_index": 0,
      "line_hash": "24c83c95",
      "speaker": "ティティア",
      "ja": "こんなこと本当はいけないのに……♥　あぁ、お兄さんの顔、エッチなお汁で……♥　ああ、私、お兄さんの顔汚しちゃってる……♥",
      "zh": ""
    },
    {
      "key": "72.0",
      "line_index": 72,
      "inline_index": 0,
      "line_hash": "d48c1a75",
      "speaker": "ティティア",
      "ja": "う、あ……おまんこの奥、疼いて……♥　はぁ、はぁ♥　あぁ、いつの日か、起きているお兄さんにこんなことできたらいいのに……♥",
      "zh": ""
    },
    {
      "key": "75.0",
      "line_index": 75,
      "inline_index": 0,
      "line_hash": "eda2e0ba",
      "speaker": "ティティア",
      "ja": "でもそれを望んではダメ……お兄さんには想い人が……♥　この気持ちをお兄さんに知られるわけにはいかないんだからぁ……♥",
      "zh": ""
    },
    {
      "key": "77.0",
      "line_index": 77,
      "inline_index": 0,
      "line_hash": "26c4da6a",
      "speaker": "",
      "ja": "ティティアは興奮を抑えきれず、ゆっくりと{G_PlayerName}の顔にあそこを近づける。",
      "zh": ""
    },
    {
      "key": "78.0",
      "line_index": 78,
      "inline_index": 0,
      "line_hash": "f36667a2",
      "speaker": "",
      "ja": "そして自分の愛液を飲ませる感覚であそこを自分から開き、溢れ落ちる愛液で{G_PlayerName}の唇を濡らす。",
      "zh": ""
    },
    {
      "key": "80.0",
      "line_index": 80,
      "inline_index": 0,
      "line_hash": "8116606b",
      "speaker": "",
      "ja": "{G_PlayerName}にクンニをされている妄想に囚われ、興奮のあまりティティアの胸がトクントクンと大きな音を奏でる。",
      "zh": ""
    },
    {
      "key": "83.0",
      "line_index": 83,
      "inline_index": 0,
      "line_hash": "cdf4c913",
      "speaker": "ティティア",
      "ja": "ごめん、本当にごめんなさい、お兄さん……♥　でももう我慢できない……♥",
      "zh": ""
    },
    {
      "key": "86.0",
      "line_index": 86,
      "inline_index": 0,
      "line_hash": "7351d6a4",
      "speaker": "ティティア",
      "ja": "あとでお顔、綺麗にするから……だからお兄さんのカッコいいお顔でオナニーさせてっ♥",
      "zh": ""
    },
    {
      "key": "93.0",
      "line_index": 93,
      "inline_index": 0,
      "line_hash": "606c1a4e",
      "speaker": "ティティア",
      "ja": "はうううっ！♥　お兄さんっ♥　はぁ、んはぁっ！♥　おまんこ、ゾクゾクして……あうっ！♥　気持ち良いですぅっ！♥",
      "zh": ""
    },
    {
      "key": "95.0",
      "line_index": 95,
      "inline_index": 0,
      "line_hash": "e2fb35aa",
      "speaker": "",
      "ja": "ティティアは{G_PlayerName}の鼻にあそこを押し付けると、膣穴を擦るように腰を小刻みに動かす。",
      "zh": ""
    },
    {
      "key": "96.0",
      "line_index": 96,
      "inline_index": 0,
      "line_hash": "3f62b243",
      "speaker": "",
      "ja": "鼻から唇に器用に腰を動かし、{G_PlayerName}の唇の柔らかさに甘い声を上げる。",
      "zh": ""
    },
    {
      "key": "98.0",
      "line_index": 98,
      "inline_index": 0,
      "line_hash": "cae4493e",
      "speaker": "",
      "ja": "時間が完全に停止し、{G_PlayerName}はまるで物になってしまったように一切反応しない。",
      "zh": ""
    },
    {
      "key": "99.0",
      "line_index": 99,
      "inline_index": 0,
      "line_hash": "a5e65829",
      "speaker": "",
      "ja": "それでも顔は愛液でヌルヌルになり、その滑りを利用しティティアの動きがどんどんリズミカルなものになっていく。",
      "zh": ""
    },
    {
      "key": "102.0",
      "line_index": 102,
      "inline_index": 0,
      "line_hash": "70979486",
      "speaker": "ティティア",
      "ja": "自分の指でするより……んっ！♥　全然すごいですぅ……あうっ！♥　やっぱり好きな人でオナニーをするのが一番なのですね……♥",
      "zh": ""
    },
    {
      "key": "105.0",
      "line_index": 105,
      "inline_index": 0,
      "line_hash": "5a4ead21",
      "speaker": "ティティア",
      "ja": "でもこんな卑怯なやり方……やっぱり何度もできない……♥　いくら気持ち良くても今だけ……ううん、今日だけにしないと……はぁ、はぁっ！♥",
      "zh": ""
    },
    {
      "key": "108.0",
      "line_index": 108,
      "inline_index": 0,
      "line_hash": "cf84e149",
      "speaker": "ティティア",
      "ja": "ふあぁ♥　ふあぁぁっ！♥　お兄さんっ♥　お兄さんっ♥　んぅ、ふぅ、ふうううっ！！♥",
      "zh": ""
    },
    {
      "key": "110.0",
      "line_index": 110,
      "inline_index": 0,
      "line_hash": "c9daecd3",
      "speaker": "",
      "ja": "ティティアは腰を動かしながら、脳内で{G_PlayerName}にあそこを舐め回されるのを妄想する。",
      "zh": ""
    },
    {
      "key": "111.0",
      "line_index": 111,
      "inline_index": 0,
      "line_hash": "8dfdda54",
      "speaker": "",
      "ja": "それだけでも快感がどんどん強くなり、妄想がどんどんエスカレートしていく。",
      "zh": ""
    },
    {
      "key": "113.0",
      "line_index": 113,
      "inline_index": 0,
      "line_hash": "4ebc1f38",
      "speaker": "",
      "ja": "目の前の勃起していない肉棒を見つめ、一つになった妄想。",
      "zh": ""
    },
    {
      "key": "114.0",
      "line_index": 114,
      "inline_index": 0,
      "line_hash": "45a6250",
      "speaker": "",
      "ja": "肉棒にメチャクチャに犯される妄想。",
      "zh": ""
    },
    {
      "key": "115.0",
      "line_index": 115,
      "inline_index": 0,
      "line_hash": "80f35d46",
      "speaker": "",
      "ja": "何時間もあそこを舐められ続け、ふにゃふにゃになってしまう妄想。",
      "zh": ""
    },
    {
      "key": "117.0",
      "line_index": 117,
      "inline_index": 0,
      "line_hash": "c167d89b",
      "speaker": "",
      "ja": "ティティアの中にあらゆるエッチな妄想が駆け巡り、その妄想と現実を少しでも近づけようと腰の動きがさらに速くなっていく。",
      "zh": ""
    },
    {
      "key": "120.0",
      "line_index": 120,
      "inline_index": 0,
      "line_hash": "1d2671e7",
      "speaker": "ティティア",
      "ja": "お兄さんの唇、柔らかくて……はぁ♥　んんぅ、ゾクゾクが止まらないですぅ……あうっ！♥",
      "zh": ""
    },
    {
      "key": "123.0",
      "line_index": 123,
      "inline_index": 0,
      "line_hash": "f374536b",
      "speaker": "ティティア",
      "ja": "この唇が動いて……エッチなお汁をぢゅるぢゅるって……あああぁっ！♥　想像するだけでおまんこの奥キュンキュンしますぅっ！♥",
      "zh": ""
    },
    {
      "key": "125.0",
      "line_index": 125,
      "inline_index": 0,
      "line_hash": "627f0af6",
      "speaker": "",
      "ja": "ティティアは執拗に唇にあそこを押し当て、腰を揺するたびにくちゅくちゅといやらしい音が強くなる。",
      "zh": ""
    },
    {
      "key": "126.0",
      "line_index": 126,
      "inline_index": 0,
      "line_hash": "39795c22",
      "speaker": "",
      "ja": "あまりの快感に表情は甘く蕩け、ツンと自己主張している乳首を自らコリコリと弄る。",
      "zh": ""
    },
    {
      "key": "128.0",
      "line_index": 128,
      "inline_index": 0,
      "line_hash": "7ef179cc",
      "speaker": "",
      "ja": "時間が停止しているので、どれだけ大きな甘い悲鳴を口から漏らしても{G_PlayerName}は動かない。",
      "zh": ""
    },
    {
      "key": "129.0",
      "line_index": 129,
      "inline_index": 0,
      "line_hash": "7d103394",
      "speaker": "",
      "ja": "それをいいことにティティアは顔面オナニーで快感に浸りきってしまっていた。",
      "zh": ""
    },
    {
      "key": "132.0",
      "line_index": 132,
      "inline_index": 0,
      "line_hash": "cd672aeb",
      "speaker": "ティティア",
      "ja": "お兄さんっ♥　お兄しゃんっ♥　好きっ、好き好きっ、好きぃっ！♥　お兄しゃんの顔も身体も性格も何もかも好きぃっ♥",
      "zh": ""
    },
    {
      "key": "135.0",
      "line_index": 135,
      "inline_index": 0,
      "line_hash": "f001b7a8",
      "speaker": "ティティア",
      "ja": "ティティの運命の人なのっ♥　絶対絶対運命の赤い糸で結ばれた人なのぉっ！♥　そうでなきゃこんなに心奪われたりしないよぉっ♥",
      "zh": ""
    },
    {
      "key": "137.0",
      "line_index": 137,
      "inline_index": 0,
      "line_hash": "15348715",
      "speaker": "",
      "ja": "ティティアの思いの丈を今の{G_PlayerName}が聞くことは絶対にない。",
      "zh": ""
    },
    {
      "key": "138.0",
      "line_index": 138,
      "inline_index": 0,
      "line_hash": "ba8b795f",
      "speaker": "",
      "ja": "そのことをわかっているからこそ、ティティアは自分の隠している気持ちを吐き出す。",
      "zh": ""
    },
    {
      "key": "141.0",
      "line_index": 141,
      "inline_index": 0,
      "line_hash": "b77719d4",
      "speaker": "ティティア",
      "ja": "あ、あぁっ！♥　お兄しゃんっ♥　ティティ、おまんこイっちゃう、イっちゃうのっ♥　お兄しゃんのお顔の上でティティ、イっちゃうよぉっ！♥",
      "zh": ""
    },
    {
      "key": "144.0",
      "line_index": 144,
      "inline_index": 0,
      "line_hash": "143575d3",
      "speaker": "ティティア",
      "ja": "お兄しゃん、ティティのイクとこ、いつか見て……！♥　ティティのエッチなところ、いつか見てもらうからぁっ！♥",
      "zh": ""
    },
    {
      "key": "147.0",
      "line_index": 147,
      "inline_index": 0,
      "line_hash": "85c24b86",
      "speaker": "ティティア",
      "ja": "んんんっ！♥　イクっ！　イクっ……！♥　イっちゃうぅぅぅ～～っ！！♥♥",
      "zh": ""
    },
    {
      "key": "158.0",
      "line_index": 158,
      "inline_index": 0,
      "line_hash": "3d014f45",
      "speaker": "ティティア",
      "ja": "あうううっ！♥　ふあ、あ、んはぁぁぁ～～っ！！♥♥",
      "zh": ""
    },
    {
      "key": "160.0",
      "line_index": 160,
      "inline_index": 0,
      "line_hash": "4db14adb",
      "speaker": "",
      "ja": "ビクンと小さな身体を跳ねらせ、絶頂に達するティティア。",
      "zh": ""
    },
    {
      "key": "161.0",
      "line_index": 161,
      "inline_index": 0,
      "line_hash": "78775c87",
      "speaker": "",
      "ja": "プシャっと勢いよく潮が噴き出し、{G_PlayerName}の顔や身体にびちゃびちゃと降り注ぐ。",
      "zh": ""
    },
    {
      "key": "163.0",
      "line_index": 163,
      "inline_index": 0,
      "line_hash": "7338051d",
      "speaker": "",
      "ja": "膣穴からは真っ白で粘り気の強い愛液がどぷりと溢れ、{G_PlayerName}の口の周りがむわっとした熱気と共にさらにぬるぬるになっていった。",
      "zh": ""
    },
    {
      "key": "166.0",
      "line_index": 166,
      "inline_index": 0,
      "line_hash": "284d0545",
      "speaker": "ティティア",
      "ja": "こんなに気持ち良いオナニー……生まれて初めてぇ……♥　あう、また……んんんんっ！！♥♥",
      "zh": ""
    },
    {
      "key": "168.0",
      "line_index": 168,
      "inline_index": 0,
      "line_hash": "eeede0a3",
      "speaker": "",
      "ja": "絶頂の繰り返しで完全に心が蕩け、ティティアの思考が快楽へ飲まれてしまう。",
      "zh": ""
    },
    {
      "key": "171.0",
      "line_index": 171,
      "inline_index": 0,
      "line_hash": "3e01c8c1",
      "speaker": "{G_PlayerName}",
      "ja": "う゛……？　うううぅ……！？",
      "zh": ""
    },
    {
      "key": "175.0",
      "line_index": 175,
      "inline_index": 0,
      "line_hash": "10bfa4c9",
      "speaker": "ティティア",
      "ja": "ふえっ！？♥",
      "zh": ""
    },
    {
      "key": "177.0",
      "line_index": 177,
      "inline_index": 0,
      "line_hash": "f88f586b",
      "speaker": "",
      "ja": "そのせいで時間停止を維持できなくなり、{G_PlayerName}は呻き声と共に身体を一瞬だけ跳ねらせる。",
      "zh": ""
    },
    {
      "key": "180.0",
      "line_index": 180,
      "inline_index": 0,
      "line_hash": "ad1766cd",
      "speaker": "{G_PlayerName}",
      "ja": "（い、息が……これどうなって……この声、ティティア……？　それにこの強烈な甘い匂い……ま、まさか……？）",
      "zh": ""
    },
    {
      "key": "183.0",
      "line_index": 183,
      "inline_index": 0,
      "line_hash": "c39c2385",
      "speaker": "",
      "ja": "目を開けても視界がティティアのお尻で塞がれ何も見えない状態。",
      "zh": ""
    },
    {
      "key": "184.0",
      "line_index": 184,
      "inline_index": 0,
      "line_hash": "221511d1",
      "speaker": "",
      "ja": "それでも{G_PlayerName}はむわっとした熱気と卑猥な匂いで、自分の顔を自慰に使われていることに気づき始める。",
      "zh": ""
    },
    {
      "key": "187.0",
      "line_index": 187,
      "inline_index": 0,
      "line_hash": "c2260cbf",
      "speaker": "ティティア",
      "ja": "あう……♥　お兄しゃん動き出しちゃいましたぁ……ごめんなさい、ごめんなさい、お兄しゃん……♥",
      "zh": ""
    },
    {
      "key": "190.0",
      "line_index": 190,
      "inline_index": 0,
      "line_hash": "1c9aaa82",
      "speaker": "ティティア",
      "ja": "で、でもあと少し……もう一度だけお兄しゃんでっ……！！♥",
      "zh": ""
    },
    {
      "key": "196.0",
      "line_index": 196,
      "inline_index": 0,
      "line_hash": "cd710b91",
      "speaker": "{G_PlayerName}",
      "ja": "ふぶっ！？　んぐううっ！？",
      "zh": ""
    },
    {
      "key": "200.0",
      "line_index": 200,
      "inline_index": 0,
      "line_hash": "2902a9cb",
      "speaker": "ティティア",
      "ja": "んはぁ、ああぁっ！♥　腰、勝手に動いちゃうよぉ♥　んんんっ！♥　ふあぁ、あああぁぁんっ！！♥",
      "zh": ""
    },
    {
      "key": "202.0",
      "line_index": 202,
      "inline_index": 0,
      "line_hash": "b7f83688",
      "speaker": "",
      "ja": "時間の停止をするよりも快楽を求めることを優先してしまうティティア。",
      "zh": ""
    },
    {
      "key": "203.0",
      "line_index": 203,
      "inline_index": 0,
      "line_hash": "aa6e0250",
      "speaker": "",
      "ja": "再び腰を揺すり、唇にあそこをグニグニと押し付けながら擦り上げる。",
      "zh": ""
    },
    {
      "key": "206.0",
      "line_index": 206,
      "inline_index": 0,
      "line_hash": "27f1437",
      "speaker": "{G_PlayerName}",
      "ja": "（や、やっぱりこれティティアの……！？）",
      "zh": ""
    },
    {
      "key": "209.0",
      "line_index": 209,
      "inline_index": 0,
      "line_hash": "6a99788c",
      "speaker": "",
      "ja": "ティティアの声で改めて今の状況を確信し、興奮のあまりムクムクと大きくなっていく肉棒。",
      "zh": ""
    },
    {
      "key": "210.0",
      "line_index": 210,
      "inline_index": 0,
      "line_hash": "baa06473",
      "speaker": "",
      "ja": "あのティティアが……そう思うだけで身体が勝手に熱くなり、目の前にある幸運を離すまいと小さな脚をガシっと掴んでしまう。",
      "zh": ""
    },
    {
      "key": "213.0",
      "line_index": 213,
      "inline_index": 0,
      "line_hash": "4ea7f73c",
      "speaker": "ティティア",
      "ja": "はわぁっ？♥　お兄しゃん？♥　うあっ！？♥　あ、あ……お兄しゃんのおちんちん、おっきくぅ……あううううっ！？♥",
      "zh": ""
    },
    {
      "key": "215.0",
      "line_index": 215,
      "inline_index": 0,
      "line_hash": "c23472b8",
      "speaker": "",
      "ja": "そして割れ目にそっと舌を這わせると、愛液が最も溢れる部分に舌をねじ込み、ぢゅるっと音を立て愛液を吸い出していく。",
      "zh": ""
    },
    {
      "key": "218.0",
      "line_index": 218,
      "inline_index": 0,
      "line_hash": "51b992e7",
      "speaker": "ティティア",
      "ja": "あううっ！♥　お兄しゃんっ！♥　ああ、吸っちゃ……んんんっ！♥　こっ、これ、しゅごい～～っ！♥　想像より全然気持ち良いでしゅぅううっ！！♥",
      "zh": ""
    },
    {
      "key": "221.0",
      "line_index": 221,
      "inline_index": 0,
      "line_hash": "ec49ba99",
      "speaker": "ティティア",
      "ja": "おまんこ蕩けちゃうよぉ♥　もっと……もっとぉ……あひいいぃ～っ！！♥",
      "zh": ""
    },
    {
      "key": "223.0",
      "line_index": 223,
      "inline_index": 0,
      "line_hash": "414cff0c",
      "speaker": "",
      "ja": "ティティアの小さな身体、{G_PlayerName}はそれをどかそうと思えば簡単にできた。",
      "zh": ""
    },
    {
      "key": "224.0",
      "line_index": 224,
      "inline_index": 0,
      "line_hash": "8d390ce4",
      "speaker": "",
      "ja": "しかしティティアが女の快楽を優先するのと同じく、{G_PlayerName}もオスの本能が優先され、ティティアを気持ち良く……それだけに思考が囚われる。",
      "zh": ""
    },
    {
      "key": "226.0",
      "line_index": 226,
      "inline_index": 0,
      "line_hash": "e2d5e414",
      "speaker": "",
      "ja": "愛液が溢れる膣穴を舌で強引に拡げ、ひたすらに熱い膣内を掻き回す。",
      "zh": ""
    },
    {
      "key": "227.0",
      "line_index": 227,
      "inline_index": 0,
      "line_hash": "1a3d219e",
      "speaker": "",
      "ja": "ティティアのカワイイ悲鳴のような喘ぎ声が{G_PlayerName}を異様なまでに高ぶらせ、痛みを感じるほど肉棒が肥大化していく。",
      "zh": ""
    },
    {
      "key": "230.0",
      "line_index": 230,
      "inline_index": 0,
      "line_hash": "4053cc1a",
      "speaker": "ティティア",
      "ja": "あぁぁんっ♥　お兄しゃん、おまんこ気持ち良いのっ♥　今までのどんなオナニーよりも感じちゃってるのっ♥　お兄しゃんの舌気持ち良すぎるよぉっ！♥",
      "zh": ""
    },
    {
      "key": "233.0",
      "line_index": 233,
      "inline_index": 0,
      "line_hash": "ccb92a81",
      "speaker": "ティティア",
      "ja": "もっと吸って……舐めてぇ♥　ティティのおまんこ、お兄しゃんの舌でもっととろとろにしてぇ……んあ、ああぁぁん！！♥",
      "zh": ""
    },
    {
      "key": "236.0",
      "line_index": 236,
      "inline_index": 0,
      "line_hash": "fc8bc6d6",
      "speaker": "{G_PlayerName}",
      "ja": "（愛液、どんどん溢れて……触ってもいないのにちんぽが……気持ち良く……！！）",
      "zh": ""
    },
    {
      "key": "239.0",
      "line_index": 239,
      "inline_index": 0,
      "line_hash": "e34d467a",
      "speaker": "",
      "ja": "肉棒を見つめるティティアの熱い眼差しがそうさせるのか、{G_PlayerName}自身も快感に身体を震わせる。",
      "zh": ""
    },
    {
      "key": "241.0",
      "line_index": 241,
      "inline_index": 0,
      "line_hash": "8a83408e",
      "speaker": "",
      "ja": "本能のままに、相手のことを一切気遣うことなくひたすらに膣を掻き回し、口の中に広がる愛液を飲み込み続ける。",
      "zh": ""
    },
    {
      "key": "244.0",
      "line_index": 244,
      "inline_index": 0,
      "line_hash": "33cb4b8",
      "speaker": "ティティア",
      "ja": "はぁ、んはぁっ！♥　お兄しゃん、お兄ちゃんっ！♥　ダメ、ティティ、もう……あうっ！♥　おまんこまたイっちゃいましゅぅっ！♥",
      "zh": ""
    },
    {
      "key": "247.0",
      "line_index": 247,
      "inline_index": 0,
      "line_hash": "9274313e",
      "speaker": "ティティア",
      "ja": "お兄しゃんっ！♥　イかせて……ティティのこと滅茶苦茶にイかせてぇ～っ！！♥",
      "zh": ""
    },
    {
      "key": "250.0",
      "line_index": 250,
      "inline_index": 0,
      "line_hash": "977e068c",
      "speaker": "{G_PlayerName}",
      "ja": "（ティティアが……イク……俺の目の前で……うあっ！？　せ、精液、昇って……！？）",
      "zh": ""
    },
    {
      "key": "254.0",
      "line_index": 254,
      "inline_index": 0,
      "line_hash": "98d52eaf",
      "speaker": "ティティア",
      "ja": "ああぁ、お兄しゃん！♥　お兄しゃんっ！♥　イっちゃう！♥　ティティ、イっちゃうよぉ～～っ！！♥",
      "zh": ""
    },
    {
      "key": "257.0",
      "line_index": 257,
      "inline_index": 0,
      "line_hash": "5d14e0f",
      "speaker": "ティティア",
      "ja": "イクイクイクっ……！♥　おまんこイっちゃううう～～～～っ！！♥♥",
      "zh": ""
    },
    {
      "key": "266.0",
      "line_index": 266,
      "inline_index": 0,
      "line_hash": "39d03aba",
      "speaker": "ティティア",
      "ja": "はううううっ！♥　うあ、あああああ……！！♥　んぅ、ふあ、ふあぁぁぁん！！♥♥",
      "zh": ""
    },
    {
      "key": "269.0",
      "line_index": 269,
      "inline_index": 0,
      "line_hash": "be75be86",
      "speaker": "{G_PlayerName}",
      "ja": "う゛……！！　ぐぅ、んぅぅぅ……んんんんん……！！",
      "zh": ""
    },
    {
      "key": "272.0",
      "line_index": 272,
      "inline_index": 0,
      "line_hash": "2b3fbea2",
      "speaker": "",
      "ja": "ティティアの絶頂の悲鳴と同時に、熱いモノが一気に肉竿を駆け上がる。",
      "zh": ""
    },
    {
      "key": "273.0",
      "line_index": 273,
      "inline_index": 0,
      "line_hash": "5f82f3c9",
      "speaker": "",
      "ja": "{G_PlayerName}は驚きつつも気持ち良い射精の快感に、脳が蕩けるような錯覚すら覚える。",
      "zh": ""
    },
    {
      "key": "276.0",
      "line_index": 276,
      "inline_index": 0,
      "line_hash": "41b2d8f6",
      "speaker": "ティティア",
      "ja": "あひぃ、あひぃぃ……イっちゃったぁ……♥　お兄しゃんのぺろぺろでイっちゃったぁ……♥　あはぁ～……！♥",
      "zh": ""
    },
    {
      "key": "279.0",
      "line_index": 279,
      "inline_index": 0,
      "line_hash": "de552fec",
      "speaker": "ティティア",
      "ja": "お兄しゃんもびゅるびゅる～……しゅごいよぉ……んんんんっ！！♥♥",
      "zh": ""
    },
    {
      "key": "281.0",
      "line_index": 281,
      "inline_index": 0,
      "line_hash": "826cc137",
      "speaker": "",
      "ja": "ティティアは潮を何度も噴きだしながら、{G_PlayerName}の顔の上で全身を跳ねらせる。",
      "zh": ""
    },
    {
      "key": "282.0",
      "line_index": 282,
      "inline_index": 0,
      "line_hash": "db51fb0b",
      "speaker": "",
      "ja": "大量の愛液が{G_PlayerName}の口周りに垂れ落ちるが、そんなことを気にする余裕すら無くなる。",
      "zh": ""
    },
    {
      "key": "284.0",
      "line_index": 284,
      "inline_index": 0,
      "line_hash": "1349d7d4",
      "speaker": "",
      "ja": "絶頂の余韻にただただ酔いしれ、{G_PlayerName}に愛撫された喜びに打ち震えていた。",
      "zh": ""
    },
    {
      "key": "287.0",
      "line_index": 287,
      "inline_index": 0,
      "line_hash": "4b4b7d77",
      "speaker": "{G_PlayerName}",
      "ja": "ティティ、ア……うう゛！",
      "zh": ""
    },
    {
      "key": "290.0",
      "line_index": 290,
      "inline_index": 0,
      "line_hash": "c941b8ee",
      "speaker": "",
      "ja": "二人のしばらくの間、お互いの声と匂いで絶頂を繰り返す。",
      "zh": ""
    },
    {
      "key": "291.0",
      "line_index": 291,
      "inline_index": 0,
      "line_hash": "14e1154a",
      "speaker": "",
      "ja": "終わりの見えない絶頂にティティアは完全に溺れ、今自分がどのような状況でいるのか、それすらも理解できなくなってしまっているのであった。",
      "zh": ""
    }
  ]
}
