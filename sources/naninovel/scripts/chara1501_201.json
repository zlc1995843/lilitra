{
  "lines": [
    {
      "key": "22.0",
      "line_index": 22,
      "inline_index": 0,
      "line_hash": "57302311",
      "speaker": "{G_PlayerName}",
      "ja": "ルナ、またあとでな",
      "zh": ""
    },
    {
      "key": "34.0",
      "line_index": 34,
      "inline_index": 0,
      "line_hash": "4db840f2",
      "speaker": "",
      "ja": "俺の言葉にルナは頷くと足早に部屋に戻っていく。",
      "zh": ""
    },
    {
      "key": "35.0",
      "line_index": 35,
      "inline_index": 0,
      "line_hash": "f2654033",
      "speaker": "",
      "ja": "しかしスターは去っていくルナに言葉をかけることもなく、無言で後ろ姿をぼーっと見つめていた。",
      "zh": ""
    },
    {
      "key": "38.0",
      "line_index": 38,
      "inline_index": 0,
      "line_hash": "f4663495",
      "speaker": "{G_PlayerName}",
      "ja": "……スター？",
      "zh": ""
    },
    {
      "key": "42.1",
      "line_index": 42,
      "inline_index": 1,
      "line_hash": "71e3b7c7",
      "speaker": "スター",
      "ja": "…………",
      "zh": ""
    },
    {
      "key": "45.0",
      "line_index": 45,
      "inline_index": 0,
      "line_hash": "8e732ea9",
      "speaker": "{G_PlayerName}",
      "ja": "……スター……！",
      "zh": ""
    },
    {
      "key": "51.1",
      "line_index": 51,
      "inline_index": 1,
      "line_hash": "71bcae8a",
      "speaker": "スター",
      "ja": "──ふぇっ？　あ、な、何、兄くん……？",
      "zh": ""
    },
    {
      "key": "54.0",
      "line_index": 54,
      "inline_index": 0,
      "line_hash": "45637e16",
      "speaker": "{G_PlayerName}",
      "ja": "あ……いや、なんかぼーっとしてたみたいだからさ……何かあったのかなって思ってさ",
      "zh": ""
    },
    {
      "key": "58.1",
      "line_index": 58,
      "inline_index": 1,
      "line_hash": "91e684b2",
      "speaker": "スター",
      "ja": "だいじょうぶ……問題、無いから……",
      "zh": ""
    },
    {
      "key": "60.0",
      "line_index": 60,
      "inline_index": 0,
      "line_hash": "e0b145d",
      "speaker": "",
      "ja": "スターはか細い声で呟くようにそう言ってくる。",
      "zh": ""
    },
    {
      "key": "61.0",
      "line_index": 61,
      "inline_index": 0,
      "line_hash": "8bdf2b2a",
      "speaker": "",
      "ja": "何か様子がおかしい……そう考えた瞬間──",
      "zh": ""
    },
    {
      "key": "66.0",
      "line_index": 66,
      "inline_index": 0,
      "line_hash": "48e3d1d4",
      "speaker": "{G_PlayerName}",
      "ja": "──スターっ！？",
      "zh": ""
    },
    {
      "key": "69.0",
      "line_index": 69,
      "inline_index": 0,
      "line_hash": "b392c31",
      "speaker": "",
      "ja": "スターの小さな身体がグラっとよろめく。俺は慌てて支えるように抱きかかえると、予想外にスターの身体が熱くなっていた。",
      "zh": ""
    },
    {
      "key": "72.0",
      "line_index": 72,
      "inline_index": 0,
      "line_hash": "61d5d72d",
      "speaker": "{G_PlayerName}",
      "ja": "スター、身体が……もしかしてまた熱を持ってしまったのか……？",
      "zh": ""
    },
    {
      "key": "76.1",
      "line_index": 76,
      "inline_index": 1,
      "line_hash": "eb1994c2",
      "speaker": "スター",
      "ja": "そう、かも……緊急で冷却が必要、かも……",
      "zh": ""
    },
    {
      "key": "79.0",
      "line_index": 79,
      "inline_index": 0,
      "line_hash": "eac7aa9f",
      "speaker": "{G_PlayerName}",
      "ja": "冷却……それってまさか……ううっ！？",
      "zh": ""
    },
    {
      "key": "82.0",
      "line_index": 82,
      "inline_index": 0,
      "line_hash": "28a904e7",
      "speaker": "",
      "ja": "小さな手が俺の股間に触れ、以前にスターにフェラをされた時のことが脳裏を過ぎる。",
      "zh": ""
    },
    {
      "key": "84.0",
      "line_index": 84,
      "inline_index": 0,
      "line_hash": "e77c6d7b",
      "speaker": "",
      "ja": "身体が快感を思い出したかのように全身から汗が噴き出し、ドクンドクンと心音が大きな音を奏でる。",
      "zh": ""
    },
    {
      "key": "86.0",
      "line_index": 86,
      "inline_index": 0,
      "line_hash": "260c51",
      "speaker": "",
      "ja": "スターの小さなふにふにの手が精液を求めて股間をまさぐり、あっという間に俺の股間が勃起してしまった。",
      "zh": ""
    },
    {
      "key": "91.1",
      "line_index": 91,
      "inline_index": 1,
      "line_hash": "13842676",
      "speaker": "スター",
      "ja": "兄、くん……兄くんの精液、回収しなきゃ……♥",
      "zh": ""
    },
    {
      "key": "94.0",
      "line_index": 94,
      "inline_index": 0,
      "line_hash": "2f5edad",
      "speaker": "{G_PlayerName}",
      "ja": "ま、待って……！　ここじゃ人が……！！",
      "zh": ""
    },
    {
      "key": "110.0",
      "line_index": 110,
      "inline_index": 0,
      "line_hash": "c08e64fa",
      "speaker": "スター",
      "ja": "んはぁ～……♥　兄くんのおちんちん……くんくん……♥　良い匂い……はぁ～……♥",
      "zh": ""
    },
    {
      "key": "112.0",
      "line_index": 112,
      "inline_index": 0,
      "line_hash": "e8d87b24",
      "speaker": "",
      "ja": "スターは俺のズボンをズリ降ろすと、勃起した肉棒が解放されたように飛び出す。",
      "zh": ""
    },
    {
      "key": "114.0",
      "line_index": 114,
      "inline_index": 0,
      "line_hash": "6c686189",
      "speaker": "",
      "ja": "ぼーっとした表情で肉棒を眺め、スターに見られている恥ずかしさに全身がさらに熱くなっていく。",
      "zh": ""
    },
    {
      "key": "117.0",
      "line_index": 117,
      "inline_index": 0,
      "line_hash": "8fc09c92",
      "speaker": "{G_PlayerName}",
      "ja": "スター、本当に大丈夫か……？",
      "zh": ""
    },
    {
      "key": "121.0",
      "line_index": 121,
      "inline_index": 0,
      "line_hash": "9fb2fff6",
      "speaker": "スター",
      "ja": "冷却機能の低下を検知、直ちに……回復を……♥",
      "zh": ""
    },
    {
      "key": "123.0",
      "line_index": 123,
      "inline_index": 0,
      "line_hash": "b7d133c9",
      "speaker": "",
      "ja": "スターの息が陰茎にかすり、ゾクっとした快感に肉棒がビクンと大きく跳ねる。",
      "zh": ""
    },
    {
      "key": "125.0",
      "line_index": 125,
      "inline_index": 0,
      "line_hash": "350b65c4",
      "speaker": "",
      "ja": "スターにエッチなことをさせるなんて……そう思いながらも性的快感への期待から肉棒にさらに血が集まる。",
      "zh": ""
    },
    {
      "key": "127.0",
      "line_index": 127,
      "inline_index": 0,
      "line_hash": "28aabfa5",
      "speaker": "",
      "ja": "すぐに先端から透明な汁が溢れ始め、勃起しきった肉棒の様子にスターの表情が女を感じさせるように蕩けていった。",
      "zh": ""
    },
    {
      "key": "130.0",
      "line_index": 130,
      "inline_index": 0,
      "line_hash": "e4908f4a",
      "speaker": "スター",
      "ja": "精液……精液、回収……♥　兄くんの美味しい精液、回収……♥",
      "zh": ""
    },
    {
      "key": "137.0",
      "line_index": 137,
      "inline_index": 0,
      "line_hash": "cd7246f2",
      "speaker": "スター",
      "ja": "あむぅっ……ぢゅるっ！♥　ちゅ、ちゅ……んっ、んふぅっ！♥　ちゅ、ちゅぱっ、ちゅっ！♥",
      "zh": ""
    },
    {
      "key": "140.0",
      "line_index": 140,
      "inline_index": 0,
      "line_hash": "485ea8",
      "speaker": "{G_PlayerName}",
      "ja": "ううう……！！　スターっ……！　く、う……！！",
      "zh": ""
    },
    {
      "key": "143.0",
      "line_index": 143,
      "inline_index": 0,
      "line_hash": "36aa139d",
      "speaker": "",
      "ja": "スターは口を目いっぱい開くと、亀頭をぱくりと咥えこむ。",
      "zh": ""
    },
    {
      "key": "145.0",
      "line_index": 145,
      "inline_index": 0,
      "line_hash": "3a8261af",
      "speaker": "",
      "ja": "冷却機能が低下しているせいなのか、スターの口内は蕩けるような熱を持ち肉棒に伝わってくる。",
      "zh": ""
    },
    {
      "key": "147.0",
      "line_index": 147,
      "inline_index": 0,
      "line_hash": "bfd20b47",
      "speaker": "",
      "ja": "スターは小刻みに前後に頭を揺すり、柔らかな唇が亀頭を削ぎ、ゾクゾクした快感に両脚が震えるほど感じてしまった。",
      "zh": ""
    },
    {
      "key": "150.0",
      "line_index": 150,
      "inline_index": 0,
      "line_hash": "65aedb84",
      "speaker": "{G_PlayerName}",
      "ja": "うう、くっ……！　スターの口、気持ち、いいっ……！　うう、ううう……！！",
      "zh": ""
    },
    {
      "key": "154.0",
      "line_index": 154,
      "inline_index": 0,
      "line_hash": "dfcaac54",
      "speaker": "スター",
      "ja": "兄くんのおちんちんも……美味しい……ぢゅるっ、ちゅっ♥　いつでも、精液、出していいから……♥",
      "zh": ""
    },
    {
      "key": "157.0",
      "line_index": 157,
      "inline_index": 0,
      "line_hash": "f4e74061",
      "speaker": "スター",
      "ja": "ぐぽっ、んっ、ぢゅ！♥　ちゅる、ちゅっ……れる、れろっ、ぢゅる、ちゅううっ！！♥",
      "zh": ""
    },
    {
      "key": "159.0",
      "line_index": 159,
      "inline_index": 0,
      "line_hash": "9059109a",
      "speaker": "",
      "ja": "俺の感じる様子にスターも高ぶっているのか、口内の舌の動きがさらに活発になっていく。",
      "zh": ""
    },
    {
      "key": "161.0",
      "line_index": 161,
      "inline_index": 0,
      "line_hash": "1152e4ed",
      "speaker": "",
      "ja": "小さな舌が亀頭を舐め、先端が鈴口をくすぐるようになぞる。",
      "zh": ""
    },
    {
      "key": "163.0",
      "line_index": 163,
      "inline_index": 0,
      "line_hash": "ace6466e",
      "speaker": "",
      "ja": "ざらざらの柔らかな舌に何度も亀頭を舐められ、自分でも認識できるレベルで先走りがドクドクとスターの口内を汚していた。",
      "zh": ""
    },
    {
      "key": "166.0",
      "line_index": 166,
      "inline_index": 0,
      "line_hash": "e7ecc214",
      "speaker": "スター",
      "ja": "んふっ、んふぅっ♥　おちんちん、まだおっきくぅ……♥　兄くん、もっと、感じて……ちゅちゅ……ちゅっ！♥",
      "zh": ""
    },
    {
      "key": "169.0",
      "line_index": 169,
      "inline_index": 0,
      "line_hash": "91d13bde",
      "speaker": "スター",
      "ja": "お汁、いっぱい……でも冷却するのに足りない……♥　兄くん、もっと……もっと、もっと感じてぇ……♥",
      "zh": ""
    },
    {
      "key": "172.0",
      "line_index": 172,
      "inline_index": 0,
      "line_hash": "e30ef705",
      "speaker": "スター",
      "ja": "ちゅ、ぢゅるるっ！♥　ふ、んっ、んんっ！♥　ちゅちゅ……れるっ、れろ、ちゅ、ぢゅるるるっ！♥",
      "zh": ""
    },
    {
      "key": "175.0",
      "line_index": 175,
      "inline_index": 0,
      "line_hash": "428e28a7",
      "speaker": "{G_PlayerName}",
      "ja": "う、ぐぅ……！！　スター、そっ、それヤバい……！！",
      "zh": ""
    },
    {
      "key": "178.0",
      "line_index": 178,
      "inline_index": 0,
      "line_hash": "51b6868b",
      "speaker": "",
      "ja": "スターの顔の動きがさらに大きくなり、スターの唇が執拗にカリ首を擦り上げる。",
      "zh": ""
    },
    {
      "key": "180.0",
      "line_index": 180,
      "inline_index": 0,
      "line_hash": "7aac7f16",
      "speaker": "",
      "ja": "先走りを吸い出すように音を立てながら肉棒を吸われ、思わず腰がビクンと跳ねる。",
      "zh": ""
    },
    {
      "key": "182.0",
      "line_index": 182,
      "inline_index": 0,
      "line_hash": "73957d8",
      "speaker": "",
      "ja": "限界まで勃起した肉棒が強く脈動するのを感じ、俺は空を見上げながらひたすらに快感に喘いでいた。",
      "zh": ""
    },
    {
      "key": "185.0",
      "line_index": 185,
      "inline_index": 0,
      "line_hash": "1bde72d6",
      "speaker": "スター",
      "ja": "ぢゅる、ぢゅるっ♥　んふぅ、ふうう……！♥　兄くん……せーえきぃ……精液早く欲しいよぉ……！♥　ぢゅる、ちゅうううっ！！♥",
      "zh": ""
    },
    {
      "key": "188.0",
      "line_index": 188,
      "inline_index": 0,
      "line_hash": "fd2d1163",
      "speaker": "{G_PlayerName}",
      "ja": "うう……スター……うぅ……！",
      "zh": ""
    },
    {
      "key": "191.0",
      "line_index": 191,
      "inline_index": 0,
      "line_hash": "ac20a9b1",
      "speaker": "",
      "ja": "スターのおねだりするような激しい口淫に徐々に射精感が高まっていく。",
      "zh": ""
    },
    {
      "key": "193.0",
      "line_index": 193,
      "inline_index": 0,
      "line_hash": "ad711a73",
      "speaker": "",
      "ja": "スターにとっては必要な行動なのだが、それでも口の中に射精するのをためらい、俺は必死に射精を堪える。",
      "zh": ""
    },
    {
      "key": "195.0",
      "line_index": 195,
      "inline_index": 0,
      "line_hash": "47f61cb2",
      "speaker": "",
      "ja": "それでもスターのフェラは休むことなく続き、甘い吸い付きに両脚がガクガクと震えてしまう。",
      "zh": ""
    },
    {
      "key": "198.0",
      "line_index": 198,
      "inline_index": 0,
      "line_hash": "377463f5",
      "speaker": "スター",
      "ja": "出してぇ……せーえき飲ませてぇ……んんっ、んっ！！♥　ぢゅる、ぢゅる、ぢゅるうううっ！！♥",
      "zh": ""
    },
    {
      "key": "201.0",
      "line_index": 201,
      "inline_index": 0,
      "line_hash": "2e829bfc",
      "speaker": "{G_PlayerName}",
      "ja": "も、もうダメだ……！！　ごめんスター、出るっ……！！",
      "zh": ""
    },
    {
      "key": "205.0",
      "line_index": 205,
      "inline_index": 0,
      "line_hash": "5ca1198a",
      "speaker": "スター",
      "ja": "出して……！！　射精してぇ～っ！！♥",
      "zh": ""
    },
    {
      "key": "213.0",
      "line_index": 213,
      "inline_index": 0,
      "line_hash": "4d40dc4",
      "speaker": "スター",
      "ja": "んふっ！！♥　んんんんん～～～っ！♥　んふっ、ふううっ……！！♥　んぐ、んぐ、んぐっ……んちゅ……♥",
      "zh": ""
    },
    {
      "key": "215.0",
      "line_index": 215,
      "inline_index": 0,
      "line_hash": "4a7c38c8",
      "speaker": "",
      "ja": "俺は射精感を堪えきれず、スターの小さな口内にドロッとしたオスの欲望を一気に吐き出す。",
      "zh": ""
    },
    {
      "key": "217.0",
      "line_index": 217,
      "inline_index": 0,
      "line_hash": "91969020",
      "speaker": "",
      "ja": "スターは一瞬驚きの視線を俺に向けるが、ゴクゴクと喉を鳴らしながら精液を飲みこみ始める。",
      "zh": ""
    },
    {
      "key": "219.0",
      "line_index": 219,
      "inline_index": 0,
      "line_hash": "1756057a",
      "speaker": "",
      "ja": "スターにまた精飲させていることに俺の興奮がさらに高まり、欲望の赴くままに俺は何度も射精を繰り返した。",
      "zh": ""
    },
    {
      "key": "222.0",
      "line_index": 222,
      "inline_index": 0,
      "line_hash": "cabbc063",
      "speaker": "スター",
      "ja": "んふっ、んぐんぐ……♥　んっ……ふうう、んんっ……んぐ、んぐっ……！♥",
      "zh": ""
    },
    {
      "key": "225.0",
      "line_index": 225,
      "inline_index": 0,
      "line_hash": "964727b2",
      "speaker": "スター",
      "ja": "ぷはぁっ♥　はぁ、はぁぁ……♥　兄くんのせーえき、美味しい……♥　スター、兄くんのせーえき大好きぃ……♥",
      "zh": ""
    },
    {
      "key": "227.0",
      "line_index": 227,
      "inline_index": 0,
      "line_hash": "dc99f828",
      "speaker": "",
      "ja": "精液を飲みほしたスター。",
      "zh": ""
    },
    {
      "key": "228.0",
      "line_index": 228,
      "inline_index": 0,
      "line_hash": "59a94f13",
      "speaker": "",
      "ja": "口の端から真っ白な精液が垂れ、その姿に興奮してしまう。",
      "zh": ""
    },
    {
      "key": "230.0",
      "line_index": 230,
      "inline_index": 0,
      "line_hash": "4c392265",
      "speaker": "",
      "ja": "ビクンビクンと肉竿が何かを求めるように跳ね、スターは蕩けた視線で俺の肉棒を見つめていた。",
      "zh": ""
    },
    {
      "key": "233.0",
      "line_index": 233,
      "inline_index": 0,
      "line_hash": "3c100d6e",
      "speaker": "スター",
      "ja": "兄くん、もっと……♥　もっとせーえき欲しい～……兄くんのせーえきちょうだい……っ♥",
      "zh": ""
    },
    {
      "key": "240.0",
      "line_index": 240,
      "inline_index": 0,
      "line_hash": "cb578c90",
      "speaker": "スター",
      "ja": "あむっ♥　ぢゅる、ちゅっ、ちゅっ！！♥　んぅ、ぢゅる、れるぅ……ちゅちゅぅっ！！♥",
      "zh": ""
    },
    {
      "key": "243.0",
      "line_index": 243,
      "inline_index": 0,
      "line_hash": "eade51eb",
      "speaker": "{G_PlayerName}",
      "ja": "う゛う゛っ！！　スター、も、もう大丈夫じゃないのか！？",
      "zh": ""
    },
    {
      "key": "246.0",
      "line_index": 246,
      "inline_index": 0,
      "line_hash": "50f63d69",
      "speaker": "",
      "ja": "スターは再び肉棒を口に含むと、興奮に任せるように顔を前後に動かす。",
      "zh": ""
    },
    {
      "key": "248.0",
      "line_index": 248,
      "inline_index": 0,
      "line_hash": "306e0d4f",
      "speaker": "",
      "ja": "ぢゅぼしゅぼといやらしい音が周囲に響き、射精直後の過敏な亀頭をぷっくりした唇と柔らかな舌が襲う。",
      "zh": ""
    },
    {
      "key": "250.0",
      "line_index": 250,
      "inline_index": 0,
      "line_hash": "146e0712",
      "speaker": "",
      "ja": "快感のあまり思わず腰を引いてしまうが、スターは俺の腰に手を回すとさらに口の奥深くに肉棒を飲み込み始めた。",
      "zh": ""
    },
    {
      "key": "253.0",
      "line_index": 253,
      "inline_index": 0,
      "line_hash": "86a07173",
      "speaker": "スター",
      "ja": "んふぅっ♥　ぢゅる、ちゅ……れる、れるっ……ちゅっ！♥　スター、まだ冷却機能が回復していない……♥　もっと兄くんのせーえきが必要……♥",
      "zh": ""
    },
    {
      "key": "256.0",
      "line_index": 256,
      "inline_index": 0,
      "line_hash": "17cab17f",
      "speaker": "スター",
      "ja": "欲しいの、兄くんのせーえき欲しいのぉ……ぢゅるっ、ちゅちゅううっ！♥　ちゅぱ、ちゅううっ！！♥",
      "zh": ""
    },
    {
      "key": "259.0",
      "line_index": 259,
      "inline_index": 0,
      "line_hash": "2eef7e20",
      "speaker": "{G_PlayerName}",
      "ja": "スター、落ち着けって……ううう、ちょ、そ、そこ……ぐ、うううっ！！♥",
      "zh": ""
    },
    {
      "key": "262.0",
      "line_index": 262,
      "inline_index": 0,
      "line_hash": "209d15a2",
      "speaker": "",
      "ja": "スターは上目遣いに俺を見つめながら、裏筋に舌を擦りつける。",
      "zh": ""
    },
    {
      "key": "264.0",
      "line_index": 264,
      "inline_index": 0,
      "line_hash": "3383582a",
      "speaker": "",
      "ja": "腰の力が一気に抜け、俺は倒れないようにスターの頭部に手を置き必死に快感に堪える。",
      "zh": ""
    },
    {
      "key": "266.0",
      "line_index": 266,
      "inline_index": 0,
      "line_hash": "f6eb4510",
      "speaker": "",
      "ja": "俺が感じるほどにスターの興奮の度合いがどんどん強くなり、淫らになっていくスターが俺の興奮を煽ってきていた。",
      "zh": ""
    },
    {
      "key": "269.0",
      "line_index": 269,
      "inline_index": 0,
      "line_hash": "fda23124",
      "speaker": "スター",
      "ja": "んふふ、ふふっ♥　美味しいよぉ……兄くんのおちんちん、ずっとペロペロしていたいよぉ……♥",
      "zh": ""
    },
    {
      "key": "272.0",
      "line_index": 272,
      "inline_index": 0,
      "line_hash": "e88afda4",
      "speaker": "スター",
      "ja": "ぢゅるるっ、ぢゅるっ！♥　ぐぽっ、ちゅっ！！♥　ちゅちゅ、ぢゅる、ぢゅぱちゅぅぅ！！♥",
      "zh": ""
    },
    {
      "key": "275.0",
      "line_index": 275,
      "inline_index": 0,
      "line_hash": "edf4111c",
      "speaker": "{G_PlayerName}",
      "ja": "スター、マジでヤバいって……うう、ちょっと待って……ぐっ！！",
      "zh": ""
    },
    {
      "key": "278.0",
      "line_index": 278,
      "inline_index": 0,
      "line_hash": "fedab4b0",
      "speaker": "",
      "ja": "スターが唇を窄めるたびに俺は情けない喘ぎ声を口から漏らしてしまう。",
      "zh": ""
    },
    {
      "key": "280.0",
      "line_index": 280,
      "inline_index": 0,
      "line_hash": "49df8f3d",
      "speaker": "",
      "ja": "興奮が最高潮に達したスターはあそこを指で弄り始め、くちゅくちゅと卑猥な水音が俺の耳に入る。",
      "zh": ""
    },
    {
      "key": "282.0",
      "line_index": 282,
      "inline_index": 0,
      "line_hash": "e4bed332",
      "speaker": "",
      "ja": "スターのいやらしい姿に興奮で頭がクラクラしてくる。",
      "zh": ""
    },
    {
      "key": "283.0",
      "line_index": 283,
      "inline_index": 0,
      "line_hash": "3438ee0",
      "speaker": "",
      "ja": "俺はスターのもたらす快感に甘えるようにただただひたすらに悶え続けた。",
      "zh": ""
    },
    {
      "key": "286.0",
      "line_index": 286,
      "inline_index": 0,
      "line_hash": "6accd006",
      "speaker": "{G_PlayerName}",
      "ja": "ううう、こんなはげしいの、ムリ……うう、ま、また……ぐ、く、ううっ！！",
      "zh": ""
    },
    {
      "key": "290.0",
      "line_index": 290,
      "inline_index": 0,
      "line_hash": "8a8e8c2a",
      "speaker": "スター",
      "ja": "いいよぉ……またいっぱいびゅるるして……♥　スターのお口、兄くんのせーえきでいっぱいにして……♥",
      "zh": ""
    },
    {
      "key": "293.0",
      "line_index": 293,
      "inline_index": 0,
      "line_hash": "7188729c",
      "speaker": "スター",
      "ja": "スターが全部飲んであげるから……兄くんのせーし、飲ませてぇ……ぢゅるるるるっ！♥　ぢゅるっ！！♥",
      "zh": ""
    },
    {
      "key": "296.0",
      "line_index": 296,
      "inline_index": 0,
      "line_hash": "5fb5937e",
      "speaker": "{G_PlayerName}",
      "ja": "うう゛っ……！　スター、出る、出るっ……！！",
      "zh": ""
    },
    {
      "key": "300.0",
      "line_index": 300,
      "inline_index": 0,
      "line_hash": "1b31bdb1",
      "speaker": "スター",
      "ja": "らしてぇっ♥　口の中、兄くんのでいっぱいにしてぇ……！！♥♥",
      "zh": ""
    },
    {
      "key": "308.0",
      "line_index": 308,
      "inline_index": 0,
      "line_hash": "3e15adca",
      "speaker": "スター",
      "ja": "んんんっ！♥　んふっ、んぐ、んぐ、ごくっ……！！♥",
      "zh": ""
    },
    {
      "key": "311.0",
      "line_index": 311,
      "inline_index": 0,
      "line_hash": "7adc53dc",
      "speaker": "{G_PlayerName}",
      "ja": "うううう、スター……！　く、う、ううううっ！！",
      "zh": ""
    },
    {
      "key": "314.0",
      "line_index": 314,
      "inline_index": 0,
      "line_hash": "1afaffcb",
      "speaker": "",
      "ja": "俺はうなり声を上げながら、再びスターの小さな口内に射精する。",
      "zh": ""
    },
    {
      "key": "316.0",
      "line_index": 316,
      "inline_index": 0,
      "line_hash": "1ff71ff2",
      "speaker": "",
      "ja": "射精のたびに腰がビクンと跳ね、強烈すぎる快感に両脚がガクガクと震える。",
      "zh": ""
    },
    {
      "key": "318.0",
      "line_index": 318,
      "inline_index": 0,
      "line_hash": "21a74e2f",
      "speaker": "",
      "ja": "精液が陰茎を駆け上がるたびに口内は精液で満たされ、スターは勢いよく俺の精液を飲み干していく。",
      "zh": ""
    },
    {
      "key": "321.0",
      "line_index": 321,
      "inline_index": 0,
      "line_hash": "1b373947",
      "speaker": "スター",
      "ja": "んふっ、んっ、んぐんぐっ……んっ、んぅぅぅ……！♥　ごくんっ♥",
      "zh": ""
    },
    {
      "key": "324.0",
      "line_index": 324,
      "inline_index": 0,
      "line_hash": "492a0d05",
      "speaker": "スター",
      "ja": "ぷはぁっ！♥　はぁ、はぁ……兄くんのせーしぃ……れる、れるぅっ……♥",
      "zh": ""
    },
    {
      "key": "326.0",
      "line_index": 326,
      "inline_index": 0,
      "line_hash": "20b3b087",
      "speaker": "",
      "ja": "スターは精液をすべて飲み干したが、まだ欲しいのか亀頭をペロペロと舐めた。",
      "zh": ""
    },
    {
      "key": "328.0",
      "line_index": 328,
      "inline_index": 0,
      "line_hash": "e0b003f7",
      "speaker": "",
      "ja": "快感に背筋がゾクっと震え、睾丸から上がってきた精液がスターの顔を真っ白に汚していった。",
      "zh": ""
    },
    {
      "key": "331.0",
      "line_index": 331,
      "inline_index": 0,
      "line_hash": "331a73c2",
      "speaker": "スター",
      "ja": "んはぁぁ……♥　兄くんのおかげで……少しだけ元気になってきた……♥",
      "zh": ""
    },
    {
      "key": "334.0",
      "line_index": 334,
      "inline_index": 0,
      "line_hash": "6f020598",
      "speaker": "スター",
      "ja": "冷却機能の回復を検知……♥　はぁ、はぁぁ……んはぁぁ……♥",
      "zh": ""
    },
    {
      "key": "337.0",
      "line_index": 337,
      "inline_index": 0,
      "line_hash": "d0f7f61a",
      "speaker": "{G_PlayerName}",
      "ja": "そうか……それなら良かった……",
      "zh": ""
    },
    {
      "key": "340.0",
      "line_index": 340,
      "inline_index": 0,
      "line_hash": "c88b85a",
      "speaker": "",
      "ja": "俺はスターの頭をそっと撫でると、上目遣いに俺を見つめてくる。",
      "zh": ""
    },
    {
      "key": "341.0",
      "line_index": 341,
      "inline_index": 0,
      "line_hash": "c0665196",
      "speaker": "",
      "ja": "いやらしさに蕩けた視線に肉棒がビクンと大きく反応してしまった。",
      "zh": ""
    },
    {
      "key": "344.0",
      "line_index": 344,
      "inline_index": 0,
      "line_hash": "41ab08ca",
      "speaker": "スター",
      "ja": "兄くん……もう少しこのままで……♥　兄くんと二人っきりでいさせて……♥",
      "zh": ""
    },
    {
      "key": "346.0",
      "line_index": 346,
      "inline_index": 0,
      "line_hash": "aae9faf8",
      "speaker": "",
      "ja": "俺は無言でうなずくとスターはにっこりと微笑む。",
      "zh": ""
    },
    {
      "key": "347.0",
      "line_index": 347,
      "inline_index": 0,
      "line_hash": "fe2cf071",
      "speaker": "",
      "ja": "スターに感謝を伝えるように俺はいつまでも小さな頭を撫で、スターはうっとりと上目遣いに微笑み続けているのであった。",
      "zh": ""
    }
  ]
}
