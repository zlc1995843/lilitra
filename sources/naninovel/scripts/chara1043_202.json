{
  "lines": [
    {
      "key": "17.1",
      "line_index": 17,
      "inline_index": 1,
      "line_hash": "f54eb5c7",
      "speaker": "ルミナ",
      "ja": "はひ～……疲れた～……♥",
      "zh": ""
    },
    {
      "key": "19.0",
      "line_index": 19,
      "inline_index": 0,
      "line_hash": "88a2e025",
      "speaker": "",
      "ja": "足を動かし続けたルミナは疲れたのか、ベッドの上に寝転がる。",
      "zh": ""
    },
    {
      "key": "20.0",
      "line_index": 20,
      "inline_index": 0,
      "line_hash": "620e9010",
      "speaker": "",
      "ja": "帯が緩んでいたのか、それが解け、着物ががばっと開いてしまう。",
      "zh": ""
    },
    {
      "key": "23.1",
      "line_index": 23,
      "inline_index": 1,
      "line_hash": "ede021e",
      "speaker": "ルミナ",
      "ja": "ふ～あ～……♥　涼しい～……♥",
      "zh": ""
    },
    {
      "key": "25.0",
      "line_index": 25,
      "inline_index": 0,
      "line_hash": "c0768122",
      "speaker": "",
      "ja": "ルミナは着物がはだけたことを特に気にする様子はなかったが、俺はそうはいかず、一糸まとわぬルミナの裸体に完全に視線を奪われる。",
      "zh": ""
    },
    {
      "key": "28.0",
      "line_index": 28,
      "inline_index": 0,
      "line_hash": "c4f4d41b",
      "speaker": "{G_PlayerName}",
      "ja": "（ルミナの身体は綺麗だけど、今日はいつも以上に綺麗に感じる……。ピンク色の着物に、ルミナの白い肌が映えて……うう、ドキドキしてきた……）",
      "zh": ""
    },
    {
      "key": "31.0",
      "line_index": 31,
      "inline_index": 0,
      "line_hash": "9f2d88c2",
      "speaker": "",
      "ja": "先ほどルミナにあれだけ射精させてもらったにもかかわらず、",
      "zh": ""
    },
    {
      "key": "32.0",
      "line_index": 32,
      "inline_index": 0,
      "line_hash": "e46ca94e",
      "speaker": "",
      "ja": "もう肉棒が復活し、ムクムクと大きくなっていく。",
      "zh": ""
    },
    {
      "key": "35.1",
      "line_index": 35,
      "inline_index": 1,
      "line_hash": "18638d0e",
      "speaker": "ルミナ",
      "ja": "ん……？　どうしたの？　じっと見て……あ……♥　ふふ、あなたのおちんちん、もう大きくなってる……♥",
      "zh": ""
    },
    {
      "key": "38.0",
      "line_index": 38,
      "inline_index": 0,
      "line_hash": "2d6633d",
      "speaker": "{G_PlayerName}",
      "ja": "あー……うん……ルミナを見ていたら……",
      "zh": ""
    },
    {
      "key": "42.1",
      "line_index": 42,
      "inline_index": 1,
      "line_hash": "caf9789e",
      "speaker": "ルミナ",
      "ja": "ふふ……♥　私で興奮してくれて嬉しい……♥　それじゃあ今度はあなたのお雛様を気持ち良くしてくれる……？♥",
      "zh": ""
    },
    {
      "key": "44.0",
      "line_index": 44,
      "inline_index": 0,
      "line_hash": "d6f9f8fa",
      "speaker": "",
      "ja": "ルミナは俺を誘うようにパンツを脱ぐと、そっと脚を拡げアソコを見せてくる。",
      "zh": ""
    },
    {
      "key": "46.0",
      "line_index": 46,
      "inline_index": 0,
      "line_hash": "503336bf",
      "speaker": "",
      "ja": "真っ白な愛液が割れ目から溢れ、いやらしいルミナのあそこにさらに肉棒が硬くなり、物欲しそうに先走りが先端からトロトロト染み出す。",
      "zh": ""
    },
    {
      "key": "48.0",
      "line_index": 48,
      "inline_index": 0,
      "line_hash": "deff99e1",
      "speaker": "",
      "ja": "そんな俺の肉棒の様子にルミナは微笑みながら、エッチの準備ができたと告げるように両手を広げる。",
      "zh": ""
    },
    {
      "key": "51.1",
      "line_index": 51,
      "inline_index": 1,
      "line_hash": "8c17d7a9",
      "speaker": "ルミナ",
      "ja": "来て……♥　桃の節句の特別な日を、もっと特別なものにして……♥",
      "zh": ""
    },
    {
      "key": "54.0",
      "line_index": 54,
      "inline_index": 0,
      "line_hash": "32e6fef8",
      "speaker": "{G_PlayerName}",
      "ja": "ああ、わかった……今度は俺がルミナを気持ち良くするから……",
      "zh": ""
    },
    {
      "key": "58.0",
      "line_index": 58,
      "inline_index": 0,
      "line_hash": "c2506b9e",
      "speaker": "ルミナ",
      "ja": "ううん、それじゃあダメ……♥　二人で一緒に……ね？♥",
      "zh": ""
    },
    {
      "key": "61.0",
      "line_index": 61,
      "inline_index": 0,
      "line_hash": "81251a3e",
      "speaker": "{G_PlayerName}",
      "ja": "そう、だな……",
      "zh": ""
    },
    {
      "key": "76.0",
      "line_index": 76,
      "inline_index": 0,
      "line_hash": "db28cefb",
      "speaker": "ルミナ",
      "ja": "んぅぅ……♥　あなたの……さっきより熱くて、硬くなってる……♥　あれだけ射精したのに……すごいね♥",
      "zh": ""
    },
    {
      "key": "79.0",
      "line_index": 79,
      "inline_index": 0,
      "line_hash": "9883393d",
      "speaker": "{G_PlayerName}",
      "ja": "ルミナと一つになるなんて想像しただけでこんなになってしまうって。ルミナとなら何回だって……",
      "zh": ""
    },
    {
      "key": "83.0",
      "line_index": 83,
      "inline_index": 0,
      "line_hash": "94ee3833",
      "speaker": "ルミナ",
      "ja": "あうう……！♥　んぅぅ……♥　あ、あ……はぁぁ……♥",
      "zh": ""
    },
    {
      "key": "85.0",
      "line_index": 85,
      "inline_index": 0,
      "line_hash": "2461c748",
      "speaker": "",
      "ja": "割れ目に肉棒を押し当て、軽く擦るだけで、ルミナの口から甘い声が漏れる。",
      "zh": ""
    },
    {
      "key": "86.0",
      "line_index": 86,
      "inline_index": 0,
      "line_hash": "44e731a5",
      "speaker": "",
      "ja": "エッチで可愛らしいルミナの喘ぎ声に、俺の興奮がさらに高まり、痛みを感じるほど肉棒がぐいっと反り上がっていく。",
      "zh": ""
    },
    {
      "key": "89.0",
      "line_index": 89,
      "inline_index": 0,
      "line_hash": "ebb5e8e2",
      "speaker": "ルミナ",
      "ja": "ああ……♥　あそこの奥……きゅんきゅんしてる……♥　あなたの精液をいっぱいちょうだいっておねだりしてる……♥",
      "zh": ""
    },
    {
      "key": "92.0",
      "line_index": 92,
      "inline_index": 0,
      "line_hash": "dffe2a2f",
      "speaker": "ルミナ",
      "ja": "ねぇ、もう挿れて……♥　焦らされるとあそこがおかしくなっちゃいそう……♥",
      "zh": ""
    },
    {
      "key": "94.0",
      "line_index": 94,
      "inline_index": 0,
      "line_hash": "352a209",
      "speaker": "",
      "ja": "割れ目からはさらに大量の、真っ白な愛液が滴り、ルミナのあそこの匂いがどんどん強くなる。",
      "zh": ""
    },
    {
      "key": "96.0",
      "line_index": 96,
      "inline_index": 0,
      "line_hash": "bea529c5",
      "speaker": "",
      "ja": "ルミナは挿入を求めいやらしく腰を動かし、その姿が俺をさらにドキドキさせる。",
      "zh": ""
    },
    {
      "key": "98.0",
      "line_index": 98,
      "inline_index": 0,
      "line_hash": "29eb8981",
      "speaker": "",
      "ja": "もう挿入を我慢できない、俺はそう告げるように限界まで勃起した肉棒をそっと膣穴に押し当てた。",
      "zh": ""
    },
    {
      "key": "101.0",
      "line_index": 101,
      "inline_index": 0,
      "line_hash": "38783ff6",
      "speaker": "ルミナ",
      "ja": "挿れて……♥　二人でいっぱい気持ち良くなろうね……？♥",
      "zh": ""
    },
    {
      "key": "104.0",
      "line_index": 104,
      "inline_index": 0,
      "line_hash": "38392c40",
      "speaker": "{G_PlayerName}",
      "ja": "ああ……！　エッチで可愛い俺のお雛様",
      "zh": ""
    },
    {
      "key": "108.0",
      "line_index": 108,
      "inline_index": 0,
      "line_hash": "469d0aad",
      "speaker": "ルミナ",
      "ja": "来て……私のお内裏様……♥",
      "zh": ""
    },
    {
      "key": "115.0",
      "line_index": 115,
      "inline_index": 0,
      "line_hash": "7b1efc32",
      "speaker": "ルミナ",
      "ja": "ふううっ！♥　んぅ、んんっ……！♥　んあ、あああ……！！♥",
      "zh": ""
    },
    {
      "key": "117.0",
      "line_index": 117,
      "inline_index": 0,
      "line_hash": "2ad8ecfa",
      "speaker": "",
      "ja": "肉棒の先端を膣穴に押し当てると、吸い込まれるようにぬるりと挿ってしまう。",
      "zh": ""
    },
    {
      "key": "119.0",
      "line_index": 119,
      "inline_index": 0,
      "line_hash": "fec91e4",
      "speaker": "",
      "ja": "ヒクヒクと蠢く膣が肉棒を絶妙な加減で締め付け、挿入しただけで出してしまいそうな程の気持ち良さに襲われる。",
      "zh": ""
    },
    {
      "key": "122.0",
      "line_index": 122,
      "inline_index": 0,
      "line_hash": "d9d501c4",
      "speaker": "ルミナ",
      "ja": "あああ……♥　あなたの、大きくて、硬くて……は、あ、んぅ、んああぁっ！♥",
      "zh": ""
    },
    {
      "key": "124.0",
      "line_index": 124,
      "inline_index": 0,
      "line_hash": "abb3c731",
      "speaker": "",
      "ja": "腰をゆっくりと動かすと、狭い膣がさらにきゅっと締まり、膣奥が吸い付くように肉棒を引っ張る。",
      "zh": ""
    },
    {
      "key": "126.0",
      "line_index": 126,
      "inline_index": 0,
      "line_hash": "6801b62e",
      "speaker": "",
      "ja": "その抵抗に逆らうように肉棒を引き抜くと、ルミナは一際甲高い声を口から漏らす。",
      "zh": ""
    },
    {
      "key": "129.0",
      "line_index": 129,
      "inline_index": 0,
      "line_hash": "4db7185e",
      "speaker": "ルミナ",
      "ja": "あなたのおちんちん……すごく、気持ち良くて……ううっ！♥　も、もっとズボズボして……♥　おちんちんであそこ……掻き回して……んっ！♥",
      "zh": ""
    },
    {
      "key": "131.0",
      "line_index": 131,
      "inline_index": 0,
      "line_hash": "db3ab67e",
      "speaker": "",
      "ja": "ルミナの求めに応じるように、少しずつピストンを早める。",
      "zh": ""
    },
    {
      "key": "132.0",
      "line_index": 132,
      "inline_index": 0,
      "line_hash": "e2997db4",
      "speaker": "",
      "ja": "どんどん気持ち良さが強くなり、ルミナのあそこがもたらす気持ち良さにゾクゾクと背筋が震えあがる。",
      "zh": ""
    },
    {
      "key": "135.0",
      "line_index": 135,
      "inline_index": 0,
      "line_hash": "fc149c3c",
      "speaker": "ルミナ",
      "ja": "んっ♥　んんぅ！♥　中、擦れるぅ　これダメ……！♥　あなたのおちんちん、いつもよりも全然引っ掛かりが……！♥",
      "zh": ""
    },
    {
      "key": "138.0",
      "line_index": 138,
      "inline_index": 0,
      "line_hash": "f4e52b36",
      "speaker": "{G_PlayerName}",
      "ja": "それだけルミナに興奮しているのかも……うう……！でもルミナのあそこの動きもいつもより……！　くっ！",
      "zh": ""
    },
    {
      "key": "141.0",
      "line_index": 141,
      "inline_index": 0,
      "line_hash": "916e109c",
      "speaker": "",
      "ja": "膣ヒダが肉棒に絡みつき、まるで生きているように肉棒を刺激する。",
      "zh": ""
    },
    {
      "key": "142.0",
      "line_index": 142,
      "inline_index": 0,
      "line_hash": "7b4e92f3",
      "speaker": "",
      "ja": "油断するとすぐに出てしまいそうな快感を懸命に堪え、ルミナを少しでも気持ち良くさせようと腰の動きをどんどん早くしていく。",
      "zh": ""
    },
    {
      "key": "145.0",
      "line_index": 145,
      "inline_index": 0,
      "line_hash": "f1910816",
      "speaker": "ルミナ",
      "ja": "あっ！♥　あっ！♥　ダメぇ……！♥　そんなに早く、しちゃ……あうっ！♥　ああああ……！♥　気持ちぃのがいっぱいきて……んんんんっ！♥",
      "zh": ""
    },
    {
      "key": "147.0",
      "line_index": 147,
      "inline_index": 0,
      "line_hash": "e7dca663",
      "speaker": "",
      "ja": "奥まで肉棒を押し込み、そして一気に引き抜く。",
      "zh": ""
    },
    {
      "key": "148.0",
      "line_index": 148,
      "inline_index": 0,
      "line_hash": "9c854fea",
      "speaker": "",
      "ja": "ぐちゅぐちゅと卑猥な音がどんどん強くなり、その音に合わせるようにルミナのエッチな声も強くなる。",
      "zh": ""
    },
    {
      "key": "150.0",
      "line_index": 150,
      "inline_index": 0,
      "line_hash": "440fe3a8",
      "speaker": "",
      "ja": "どんどんルミナのあそこは熱くなり、膣奥から愛液がどんどん溢れる。",
      "zh": ""
    },
    {
      "key": "151.0",
      "line_index": 151,
      "inline_index": 0,
      "line_hash": "fab55636",
      "speaker": "",
      "ja": "掻き出された愛液がいやらしくルミナの下半身を濡らし、その卑猥な光景に、肉棒にさらに活力がみなぎる。",
      "zh": ""
    },
    {
      "key": "154.0",
      "line_index": 154,
      "inline_index": 0,
      "line_hash": "3f2b91b5",
      "speaker": "ルミナ",
      "ja": "あっ！♥　んああっ！♥　そ、そこ、良いのっ！♥　んんん！♥　もっと奥……子宮の入り口にあなたのおちんちんでいっぱいちゅーして……んっ！♥",
      "zh": ""
    },
    {
      "key": "157.0",
      "line_index": 157,
      "inline_index": 0,
      "line_hash": "2139d1ff",
      "speaker": "ルミナ",
      "ja": "はうううっ！♥　んぅぅ！♥　んあっ！　あっ！♥　あああーーっ！！♥",
      "zh": ""
    },
    {
      "key": "159.0",
      "line_index": 159,
      "inline_index": 0,
      "line_hash": "bf5ff960",
      "speaker": "",
      "ja": "ルミナの想いに応えようと、懸命に膣奥を突きあげる。",
      "zh": ""
    },
    {
      "key": "160.0",
      "line_index": 160,
      "inline_index": 0,
      "line_hash": "67f892fa",
      "speaker": "",
      "ja": "どちゅっとした音と共に、ルミナの表情がいやらしく蕩け、膣が精液を求めるように吸い付く。",
      "zh": ""
    },
    {
      "key": "162.0",
      "line_index": 162,
      "inline_index": 0,
      "line_hash": "2f870c",
      "speaker": "",
      "ja": "腰を突き動かすたびに確実に射精に近づき、それでも歯を食いしばりルミナを感じさせようと腰を動かし続ける。",
      "zh": ""
    },
    {
      "key": "165.0",
      "line_index": 165,
      "inline_index": 0,
      "line_hash": "cac26115",
      "speaker": "ルミナ",
      "ja": "はっ！♥　んはっ！♥　もう、私……うううっ！♥　イっちゃいそう……！♥",
      "zh": ""
    },
    {
      "key": "168.0",
      "line_index": 168,
      "inline_index": 0,
      "line_hash": "6c711a03",
      "speaker": "ルミナ",
      "ja": "あなたは……？♥　あなたも一緒にぃ！♥　はぁ、はぁっ！♥　んっ、んはぁっ！♥",
      "zh": ""
    },
    {
      "key": "171.0",
      "line_index": 171,
      "inline_index": 0,
      "line_hash": "93fc805",
      "speaker": "{G_PlayerName}",
      "ja": "俺ももう……！　ルミナがイクのに合わせるから……！だから好きな時にイってくれ……！！",
      "zh": ""
    },
    {
      "key": "175.0",
      "line_index": 175,
      "inline_index": 0,
      "line_hash": "20f39b99",
      "speaker": "ルミナ",
      "ja": "ふああああぁっ！♥　あああ、激しいぃぃぃっ！　んぅっ！♥　んんんっ！♥　イっちゃう！　イっちゃうよぉ！♥　ふ、ふあ、あああぁっ！♥",
      "zh": ""
    },
    {
      "key": "177.0",
      "line_index": 177,
      "inline_index": 0,
      "line_hash": "23295889",
      "speaker": "",
      "ja": "ルミナの膣の収縮がどんどん大きくなり、射精寸前の肉棒を強く締め付ける。",
      "zh": ""
    },
    {
      "key": "179.0",
      "line_index": 179,
      "inline_index": 0,
      "line_hash": "1854c57",
      "speaker": "",
      "ja": "ルミナの一番奥に……その想いを込め、腰を一気に前に突き出す。",
      "zh": ""
    },
    {
      "key": "182.0",
      "line_index": 182,
      "inline_index": 0,
      "line_hash": "d956bd21",
      "speaker": "ルミナ",
      "ja": "ああああぁっ！♥　イクっ！♥　イっちゃう！♥　ふあ、ああ、ああああぁっ！♥　イクイクっ！♥　ん、んっ！♥　んあ、あああぁぁぁ～～っ！！♥♥",
      "zh": ""
    },
    {
      "key": "190.0",
      "line_index": 190,
      "inline_index": 0,
      "line_hash": "eb80e225",
      "speaker": "ルミナ",
      "ja": "あううっ！♥　うあ、あ、ああああ～～っ！！♥♥",
      "zh": ""
    },
    {
      "key": "192.0",
      "line_index": 192,
      "inline_index": 0,
      "line_hash": "5b033de3",
      "speaker": "",
      "ja": "ルミナの子宮口が肉棒の先端に吸い付き、搾り取られるように一気に睾丸の中の熱いモノを吐き出す。",
      "zh": ""
    },
    {
      "key": "194.0",
      "line_index": 194,
      "inline_index": 0,
      "line_hash": "30674dfc",
      "speaker": "",
      "ja": "びゅるびゅると熱い塊が肉竿を駆け上がり、ルミナの子宮に注ぎ込まれ、俺が射精をするたびに、ルミナの甘い悲鳴が部屋中に響き渡る。",
      "zh": ""
    },
    {
      "key": "197.0",
      "line_index": 197,
      "inline_index": 0,
      "line_hash": "d7d20f56",
      "speaker": "ルミナ",
      "ja": "す、ごい……！♥　さっき二回も出したのに……こ、こんなに……あうっ！♥",
      "zh": ""
    },
    {
      "key": "199.0",
      "line_index": 199,
      "inline_index": 0,
      "line_hash": "9102614f",
      "speaker": "",
      "ja": "ルミナに種付けをする……それだけで俺はどこまでも昂り続け、睾丸から何度も精液を吐き出しルミナの子宮に注ぎ込み続けた。",
      "zh": ""
    },
    {
      "key": "202.0",
      "line_index": 202,
      "inline_index": 0,
      "line_hash": "8dc58026",
      "speaker": "ルミナ",
      "ja": "あそこの奥……あなたのでいっぱいだよぉ……♥　幸せ……はぁ～……♥",
      "zh": ""
    },
    {
      "key": "204.0",
      "line_index": 204,
      "inline_index": 0,
      "line_hash": "f7f2a9d",
      "speaker": "",
      "ja": "ルミナは口をだらしなく開け、とろんとした視線に俺の心臓が跳ね上がるようにドクンと大きく鳴る。",
      "zh": ""
    },
    {
      "key": "206.0",
      "line_index": 206,
      "inline_index": 0,
      "line_hash": "84655e17",
      "speaker": "",
      "ja": "三度目の射精でさすがにこれ以上は無理と思っていた肉棒が再び剛直し、そんな俺の肉棒にルミナは嬉しそうに微笑む。",
      "zh": ""
    },
    {
      "key": "209.0",
      "line_index": 209,
      "inline_index": 0,
      "line_hash": "f3eb0e44",
      "speaker": "ルミナ",
      "ja": "すごい、ね……♥　もう三回も射精しているのに……♥　まだまだエッチできそう……♥　ねぇ、もっとして……？♥",
      "zh": ""
    },
    {
      "key": "212.0",
      "line_index": 212,
      "inline_index": 0,
      "line_hash": "f1c99339",
      "speaker": "ルミナ",
      "ja": "あなたの逞しいおちんちんで、もっと私をイかせて……♥　あなたのおちんちんの形に変わってしまうくらい、あそこを掻き回して……♥",
      "zh": ""
    },
    {
      "key": "215.0",
      "line_index": 215,
      "inline_index": 0,
      "line_hash": "83bcbe70",
      "speaker": "{G_PlayerName}",
      "ja": "次はもっと激しくするかもしれない……今俺そのくらい興奮してる……それでも構わないか？",
      "zh": ""
    },
    {
      "key": "219.0",
      "line_index": 219,
      "inline_index": 0,
      "line_hash": "809cd3",
      "speaker": "ルミナ",
      "ja": "うん……♥　全然構わない……♥　だって私はあなたのお嫁さんで、お雛様だから……♥",
      "zh": ""
    },
    {
      "key": "221.0",
      "line_index": 221,
      "inline_index": 0,
      "line_hash": "d4424583",
      "speaker": "",
      "ja": "ルミナはそう言うと、そっと俺の腰に両脚を絡ませる。",
      "zh": ""
    },
    {
      "key": "224.0",
      "line_index": 224,
      "inline_index": 0,
      "line_hash": "31405a70",
      "speaker": "ルミナ",
      "ja": "今日のひな祭りをいつでも思い出せるように……いっぱいエッチして♥　あなたの想いで私の心と身体を満たして……♥",
      "zh": ""
    },
    {
      "key": "227.0",
      "line_index": 227,
      "inline_index": 0,
      "line_hash": "4d9eb10b",
      "speaker": "{G_PlayerName}",
      "ja": "わかった……今日を特別な思い出にするから……ルミナと俺だけの特別な思い出に……",
      "zh": ""
    },
    {
      "key": "231.0",
      "line_index": 231,
      "inline_index": 0,
      "line_hash": "d4ebfc64",
      "speaker": "ルミナ",
      "ja": "うん……♥　来て……♥",
      "zh": ""
    },
    {
      "key": "238.0",
      "line_index": 238,
      "inline_index": 0,
      "line_hash": "4ca9ee2",
      "speaker": "ルミナ",
      "ja": "んああぁっ！♥　あっ！♥　んはっ！♥　あぁぁんっ！♥",
      "zh": ""
    },
    {
      "key": "240.0",
      "line_index": 240,
      "inline_index": 0,
      "line_hash": "6c2902f9",
      "speaker": "",
      "ja": "興奮に身を任せるように全力でピストンし、肉棒でトロトロの膣を掻き回していく。",
      "zh": ""
    },
    {
      "key": "241.0",
      "line_index": 241,
      "inline_index": 0,
      "line_hash": "2a838f04",
      "speaker": "",
      "ja": "ぐちゅぐちゅと大きな音が響き、ルミナの膣が肉棒をぎゅっと締め付けてくる。",
      "zh": ""
    },
    {
      "key": "244.0",
      "line_index": 244,
      "inline_index": 0,
      "line_hash": "5a579fcf",
      "speaker": "{G_PlayerName}",
      "ja": "ルミナ……！　うう、おまんこ気持ち良いっ！",
      "zh": ""
    },
    {
      "key": "248.0",
      "line_index": 248,
      "inline_index": 0,
      "line_hash": "21966393",
      "speaker": "ルミナ",
      "ja": "んんぅぅっ！♥　あなたのおちんちんもすごく、イイ……！♥　おまんこイキっぱなしだよぉ……！♥　はうう、うあ、ああああぁっ！♥",
      "zh": ""
    },
    {
      "key": "250.0",
      "line_index": 250,
      "inline_index": 0,
      "line_hash": "14d4bb5e",
      "speaker": "",
      "ja": "俺が動くたびにルミナは小さな絶頂を繰り返し、腰を何度も大きく跳ねさせる。",
      "zh": ""
    },
    {
      "key": "251.0",
      "line_index": 251,
      "inline_index": 0,
      "line_hash": "929a285b",
      "speaker": "",
      "ja": "真っ白な愛液が膣奥から大量に溢れ、精液とともに肉棒から掻き出されるように溢れる。",
      "zh": ""
    },
    {
      "key": "253.0",
      "line_index": 253,
      "inline_index": 0,
      "line_hash": "daabd121",
      "speaker": "",
      "ja": "お姫様のルミナが男の、俺の肉棒に悶え喜ぶ……その姿が俺を激しく興奮させ、さらに力を込め、膣奥を押しつぶすようにルミナのあそこを掻き回していく。",
      "zh": ""
    },
    {
      "key": "256.0",
      "line_index": 256,
      "inline_index": 0,
      "line_hash": "bf273a2",
      "speaker": "ルミナ",
      "ja": "もっと♥　もっと突いてぇっ！♥　ふああ、ああ、あああぁぁんっ！♥",
      "zh": ""
    },
    {
      "key": "258.0",
      "line_index": 258,
      "inline_index": 0,
      "line_hash": "44902f8f",
      "speaker": "",
      "ja": "ルミナは脚に力を込め、俺の身体を引き込むように絡める。",
      "zh": ""
    },
    {
      "key": "259.0",
      "line_index": 259,
      "inline_index": 0,
      "line_hash": "44a94b11",
      "speaker": "",
      "ja": "性器の密着具合がより強くなり、ルミナのもっとも感じるポイントを執拗に小刻みに擦り上げていく。",
      "zh": ""
    },
    {
      "key": "262.0",
      "line_index": 262,
      "inline_index": 0,
      "line_hash": "2ab55cd6",
      "speaker": "ルミナ",
      "ja": "そこぉっ！♥　すごいっ！♥　腰っ、浮いちゃうぅっ！♥　はぁ、あああぁっ！♥　そ、そんなにされたら、私またイっちゃう！♥　あなたにイかされちゃうっ！♥",
      "zh": ""
    },
    {
      "key": "264.0",
      "line_index": 264,
      "inline_index": 0,
      "line_hash": "dd29f518",
      "speaker": "",
      "ja": "瞳にうっすらと涙を浮かべ、快感に溺れていくルミナ。",
      "zh": ""
    },
    {
      "key": "265.0",
      "line_index": 265,
      "inline_index": 0,
      "line_hash": "c4deb3c7",
      "speaker": "",
      "ja": "淫らになっていくルミナをもっと見たい、その一心で何度も腰を突き出し続けた。",
      "zh": ""
    },
    {
      "key": "268.0",
      "line_index": 268,
      "inline_index": 0,
      "line_hash": "173d2ed7",
      "speaker": "ルミナ",
      "ja": "あっ！♥　ああっ！♥　ダメ、ダメっ！♥　私だけイクのダメぇっ！♥　あなたも一緒に……！♥　中出しでイかせてっ！♥",
      "zh": ""
    },
    {
      "key": "271.0",
      "line_index": 271,
      "inline_index": 0,
      "line_hash": "f31d43e8",
      "speaker": "{G_PlayerName}",
      "ja": "俺もすぐにイクから……！",
      "zh": ""
    },
    {
      "key": "275.0",
      "line_index": 275,
      "inline_index": 0,
      "line_hash": "2a36e47",
      "speaker": "ルミナ",
      "ja": "んあああぁっ！♥　あっ！♥　んあ゛っ！♥　んう、んんんんっ！！♥",
      "zh": ""
    },
    {
      "key": "277.0",
      "line_index": 277,
      "inline_index": 0,
      "line_hash": "2f2748f",
      "speaker": "",
      "ja": "どんどん絶頂の高みへと近づいていく俺とルミナ。",
      "zh": ""
    },
    {
      "key": "278.0",
      "line_index": 278,
      "inline_index": 0,
      "line_hash": "3a9d4bc",
      "speaker": "",
      "ja": "ルミナの膣が震え始め、それを合図に俺の射精感も一気に高まる。",
      "zh": ""
    },
    {
      "key": "281.0",
      "line_index": 281,
      "inline_index": 0,
      "line_hash": "46c9713c",
      "speaker": "ルミナ",
      "ja": "イっちゃう！♥　またイっちゃう！♥　ああぁっ！♥　イクっ！♥　イクぅっ！♥",
      "zh": ""
    },
    {
      "key": "284.0",
      "line_index": 284,
      "inline_index": 0,
      "line_hash": "2bef3060",
      "speaker": "{G_PlayerName}",
      "ja": "ルミナ……！　また中に……！！",
      "zh": ""
    },
    {
      "key": "288.0",
      "line_index": 288,
      "inline_index": 0,
      "line_hash": "8c245e1e",
      "speaker": "ルミナ",
      "ja": "んあああぁっ！♥　イクっ！♥　んっ、んっ！♥　ふあ、あ、あっ……ん、んんんんんんっっ！！♥♥",
      "zh": ""
    },
    {
      "key": "296.0",
      "line_index": 296,
      "inline_index": 0,
      "line_hash": "cc4e8060",
      "speaker": "ルミナ",
      "ja": "あああぁああっ！♥　あ、熱いぃぃぃ……！♥　うあ、ああ……ふああああ～っ！♥♥",
      "zh": ""
    },
    {
      "key": "298.0",
      "line_index": 298,
      "inline_index": 0,
      "line_hash": "2f80cf58",
      "speaker": "",
      "ja": "俺は腰を小さく揺らし、何度もルミナの膣奥で射精を繰り返す。",
      "zh": ""
    },
    {
      "key": "299.0",
      "line_index": 299,
      "inline_index": 0,
      "line_hash": "dcb93148",
      "speaker": "",
      "ja": "射精するたびにルミナは絶頂し、腰を何度も大きく跳ねらせる。",
      "zh": ""
    },
    {
      "key": "302.0",
      "line_index": 302,
      "inline_index": 0,
      "line_hash": "c033d97a",
      "speaker": "ルミナ",
      "ja": "す、ごぃ……！♥　あなたの、たくさん……ふあああ……！♥　おまんこ蕩けるぅ……！♥　ふあああ、あああぁぁぁ……！！♥",
      "zh": ""
    },
    {
      "key": "305.0",
      "line_index": 305,
      "inline_index": 0,
      "line_hash": "1d9525d9",
      "speaker": "{G_PlayerName}",
      "ja": "もっと……もっと受け止めてくれ……！　ルミナ……！！",
      "zh": ""
    },
    {
      "key": "309.0",
      "line_index": 309,
      "inline_index": 0,
      "line_hash": "bc8905b9",
      "speaker": "ルミナ",
      "ja": "ふあああ……ああああーーっ！！♥♥",
      "zh": ""
    },
    {
      "key": "311.0",
      "line_index": 311,
      "inline_index": 0,
      "line_hash": "dad5f95d",
      "speaker": "",
      "ja": "俺はルミナの中にすべてを吐き出し、そしてルミナも今まで一番の絶頂に身体をビクンビクンと何度も大きく跳ねらせた。",
      "zh": ""
    },
    {
      "key": "314.0",
      "line_index": 314,
      "inline_index": 0,
      "line_hash": "3b5da4f1",
      "speaker": "ルミナ",
      "ja": "う、あ……♥　はぁ、はぁっ！♥　んぅぅぅ……！♥　しゅ、ごいぃ……♥　あそこ……子宮があなたのでいっぱい……♥",
      "zh": ""
    },
    {
      "key": "317.0",
      "line_index": 317,
      "inline_index": 0,
      "line_hash": "52fcb07e",
      "speaker": "ルミナ",
      "ja": "しあわせ……だよぉ……♥",
      "zh": ""
    },
    {
      "key": "319.0",
      "line_index": 319,
      "inline_index": 0,
      "line_hash": "530c1d26",
      "speaker": "",
      "ja": "ルミナは肩で激しく息をしながら、恍惚とした笑みを浮かべる。",
      "zh": ""
    },
    {
      "key": "320.0",
      "line_index": 320,
      "inline_index": 0,
      "line_hash": "e84c54fd",
      "speaker": "",
      "ja": "そんなルミナに惹きつけられるように、ルミナの小さな唇に自分の唇をそっと重ねる。",
      "zh": ""
    },
    {
      "key": "323.0",
      "line_index": 323,
      "inline_index": 0,
      "line_hash": "db94419d",
      "speaker": "ルミナ",
      "ja": "ん……♥　ちゅ……ちゅ……♥　ふあ……♥あああ……♥　今のキス……今まで一番いいかもぉ……♥　ふああぁ……♥",
      "zh": ""
    },
    {
      "key": "326.0",
      "line_index": 326,
      "inline_index": 0,
      "line_hash": "448097c3",
      "speaker": "ルミナ",
      "ja": "もっとちゅーして……♥　んっ……！♥　ちゅ……ちゅ……♥　ぢゅる……♥",
      "zh": ""
    },
    {
      "key": "329.0",
      "line_index": 329,
      "inline_index": 0,
      "line_hash": "aac87bd3",
      "speaker": "ルミナ",
      "ja": "はぁ～……♥　今日のエッチ、すごく素敵だった……♥　ますますあなたのこと好きになっちゃったかも……♥",
      "zh": ""
    },
    {
      "key": "332.0",
      "line_index": 332,
      "inline_index": 0,
      "line_hash": "475b1188",
      "speaker": "ルミナ",
      "ja": "今日のひな祭り私の中ですごく特別な日になったよ……♥　ありがとう、私とエッチしてくれて……♥",
      "zh": ""
    },
    {
      "key": "335.0",
      "line_index": 335,
      "inline_index": 0,
      "line_hash": "4a7a98ff",
      "speaker": "{G_PlayerName}",
      "ja": "俺の方こそ……ありがとう、ルミナ",
      "zh": ""
    },
    {
      "key": "338.0",
      "line_index": 338,
      "inline_index": 0,
      "line_hash": "18988c6d",
      "speaker": "",
      "ja": "俺達はしばらくお互いを見つめ合いながら、そして再び唇を重ねる。",
      "zh": ""
    },
    {
      "key": "339.0",
      "line_index": 339,
      "inline_index": 0,
      "line_hash": "2df14751",
      "speaker": "",
      "ja": "今の幸せを噛みしめるように、いつまでもキスをし続ける俺達であった。",
      "zh": ""
    }
  ]
}
