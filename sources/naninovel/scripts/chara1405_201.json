      "key": "343.0",
      "line_index": 343,
      "inline_index": 0,
      "line_hash": "d9bdd308",
      "speaker": "{G_PlayerName}",
      "ja": "そんなわけ……う゛う゛っ！",
      "zh": ""
    },
