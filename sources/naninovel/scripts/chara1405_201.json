    {
      "key": "243.0",
      "line_index": 243,
      "inline_index": 0,
      "line_hash": "c5a1fd41",
      "speaker": "セラ",
      "ja": "ちゅ、ちゅっ♥　れる、れろぉっ♥　ぢゅる、ちゅ……ちゅううっ、ちゅぱっ、ちゅちゅちゅっ！！♥",
      "zh": ""
    },
    {
      "key": "246.0",
      "line_index": 246,
      "inline_index": 0,
      "line_hash": "822e4e29",
      "speaker": "{G_PlayerName}",
      "ja": "セラ……！　マジでダメだって……こ、このままじゃ……！！",
      "zh": ""
    },
    {
      "key": "250.0",
      "line_index": 250,
      "inline_index": 0,
      "line_hash": "7251b95f",
      "speaker": "セラ",
      "ja": "ちゅ、ちゅぅっ♥　ならこのまま出して下さい……♥　ちゅ、ちゅうううっ！！♥",
      "zh": ""
    },
