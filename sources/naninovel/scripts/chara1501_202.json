{
  "lines": [
    {
      "key": "21.1",
      "line_index": 21,
      "inline_index": 1,
      "line_hash": "c6cc3c29",
      "speaker": "スター",
      "ja": "兄くん、本当にありがとう……兄くんのおかげで少し元気になった",
      "zh": ""
    },
    {
      "key": "23.0",
      "line_index": 23,
      "inline_index": 0,
      "line_hash": "71d59b62",
      "speaker": "",
      "ja": "スターは普段の落ち着きを取り戻したようにゆっくりと言葉を口にする。",
      "zh": ""
    },
    {
      "key": "25.0",
      "line_index": 25,
      "inline_index": 0,
      "line_hash": "fa506423",
      "speaker": "",
      "ja": "俺はスターの額に手を当てると、スターの言葉に嘘偽りなく、ほんのりと人肌の体温が手のひらに伝わってきた。",
      "zh": ""
    },
    {
      "key": "28.1",
      "line_index": 28,
      "inline_index": 1,
      "line_hash": "32210f31",
      "speaker": "スター",
      "ja": "兄くん、ごめんね……スターがエッチなことしちゃったから……兄くんのココがまだ……",
      "zh": ""
    },
    {
      "key": "31.0",
      "line_index": 31,
      "inline_index": 0,
      "line_hash": "ca72c832",
      "speaker": "{G_PlayerName}",
      "ja": "う゛っ……！",
      "zh": ""
    },
    {
      "key": "34.0",
      "line_index": 34,
      "inline_index": 0,
      "line_hash": "933489ea",
      "speaker": "",
      "ja": "スターの小さな手が股間に触れ、勃起した陰茎をパンツの上からさわさわと撫でる。",
      "zh": ""
    },
    {
      "key": "36.0",
      "line_index": 36,
      "inline_index": 0,
      "line_hash": "6e12b90f",
      "speaker": "",
      "ja": "俺が小さく声を上げると申し訳なさそうにスターはしょぼんとしてしまう。",
      "zh": ""
    },
    {
      "key": "38.0",
      "line_index": 38,
      "inline_index": 0,
      "line_hash": "5103ec41",
      "speaker": "",
      "ja": "俺は心配いらない、そう告げるように頭を撫でるがスターの機嫌が直ることはなかった。",
      "zh": ""
    },
    {
      "key": "41.1",
      "line_index": 41,
      "inline_index": 1,
      "line_hash": "5ae242f2",
      "speaker": "スター",
      "ja": "兄くんのおちんちん……硬くて熱いまま……どうしたらいいかな……？",
      "zh": ""
    },
    {
      "key": "44.0",
      "line_index": 44,
      "inline_index": 0,
      "line_hash": "daef5dfa",
      "speaker": "{G_PlayerName}",
      "ja": "い、いいよ、このままで……あとは自分でなんとかするから……俺のことは気にしなくてもいいからさ",
      "zh": ""
    },
    {
      "key": "48.1",
      "line_index": 48,
      "inline_index": 1,
      "line_hash": "f940897d",
      "speaker": "スター",
      "ja": "ダメ……ダメだよ……自分だけ兄くんに助けられるなんて……スターも何かお返しがしたい……",
      "zh": ""
    },
    {
      "key": "51.1",
      "line_index": 51,
      "inline_index": 1,
      "line_hash": "1d38422",
      "speaker": "スター",
      "ja": "兄くん、今度はスターが兄くんを助けるから……兄くんのおちんちん、元に戻してあげるから……",
      "zh": ""
    },
    {
      "key": "53.0",
      "line_index": 53,
      "inline_index": 0,
      "line_hash": "5abf0028",
      "speaker": "",
      "ja": "スターはそう呟くとベッドに横たわる。",
      "zh": ""
    },
    {
      "key": "54.0",
      "line_index": 54,
      "inline_index": 0,
      "line_hash": "caa9aef",
      "speaker": "",
      "ja": "そして水着の股間部分を自らまくり、閉じた割れ目を俺に見せてきた。",
      "zh": ""
    },
    {
      "key": "56.0",
      "line_index": 56,
      "inline_index": 0,
      "line_hash": "75760cca",
      "speaker": "",
      "ja": "スターのあそこを直視し、昂ぶりから心臓がドッドッドと激しく鳴り響く。",
      "zh": ""
    },
    {
      "key": "57.0",
      "line_index": 57,
      "inline_index": 0,
      "line_hash": "43efd011",
      "speaker": "",
      "ja": "息苦しさを感じるほどの高鳴りに肉棒がパンツの中で何度も大きく跳ねあがる。",
      "zh": ""
    },
    {
      "key": "60.1",
      "line_index": 60,
      "inline_index": 1,
      "line_hash": "4c28864e",
      "speaker": "スター",
      "ja": "兄くん……来て……♥　今度はスターのおまんこで気持ち良くなって……♥",
      "zh": ""
    },
    {
      "key": "63.1",
      "line_index": 63,
      "inline_index": 1,
      "line_hash": "70b0c1c0",
      "speaker": "スター",
      "ja": "いっぱい、いっぱい射精して……♥　大好きな兄くんのせーえき、全部受け止めるから……♥",
      "zh": ""
    },
    {
      "key": "81.0",
      "line_index": 81,
      "inline_index": 0,
      "line_hash": "a6a39cb3",
      "speaker": "スター",
      "ja": "あううっ！♥　兄くんの……挿ってぇ……あはぁっ！！♥",
      "zh": ""
    },
    {
      "key": "83.0",
      "line_index": 83,
      "inline_index": 0,
      "line_hash": "fa14508c",
      "speaker": "",
      "ja": "俺はスターの誘いに我を忘れた様に自らの欲望の塊を小さな膣にねじ込む。",
      "zh": ""
    },
    {
      "key": "85.0",
      "line_index": 85,
      "inline_index": 0,
      "line_hash": "dd21be22",
      "speaker": "",
      "ja": "明らかにスターの狭い膣には不釣り合いな肉棒。",
      "zh": ""
    },
    {
      "key": "86.0",
      "line_index": 86,
      "inline_index": 0,
      "line_hash": "b83eb12f",
      "speaker": "",
      "ja": "それを強引に押し込んだことで、スターの下腹部がボコっと膨らむ。",
      "zh": ""
    },
    {
      "key": "88.0",
      "line_index": 88,
      "inline_index": 0,
      "line_hash": "42da9898",
      "speaker": "",
      "ja": "それがスターと一つになっていることをより強く意識させ、俺の興奮をより高ぶらせていった。",
      "zh": ""
    },
    {
      "key": "91.0",
      "line_index": 91,
      "inline_index": 0,
      "line_hash": "6cc1c2b9",
      "speaker": "スター",
      "ja": "兄くんの……すごく熱い……♥　冷却が、必要……だね……♥",
      "zh": ""
    },
    {
      "key": "94.0",
      "line_index": 94,
      "inline_index": 0,
      "line_hash": "8f770cd7",
      "speaker": "{G_PlayerName}",
      "ja": "ああ……でもすぐに収まりそうにない……ごめんな、俺がスケベなばっかりにスターに負担を掛けてしまって……",
      "zh": ""
    },
    {
      "key": "98.0",
      "line_index": 98,
      "inline_index": 0,
      "line_hash": "f6e80051",
      "speaker": "スター",
      "ja": "謝らないで、兄くん……♥　兄くんと一つになれてスターも嬉しいから……♥",
      "zh": ""
    },
    {
      "key": "101.0",
      "line_index": 101,
      "inline_index": 0,
      "line_hash": "759d2e78",
      "speaker": "スター",
      "ja": "スターはAIだけど……でも兄くんとエッチしたいって心から思っているから……決してプログラム的なものじゃないから……♥",
      "zh": ""
    },
    {
      "key": "104.0",
      "line_index": 104,
      "inline_index": 0,
      "line_hash": "add3da76",
      "speaker": "{G_PlayerName}",
      "ja": "ありがとう、スター……そう言ってくれて……",
      "zh": ""
    },
    {
      "key": "107.0",
      "line_index": 107,
      "inline_index": 0,
      "line_hash": "1607ea0c",
      "speaker": "",
      "ja": "俺はそっとスターの頭を撫でる。",
      "zh": ""
    },
    {
      "key": "108.0",
      "line_index": 108,
      "inline_index": 0,
      "line_hash": "c49705a2",
      "speaker": "",
      "ja": "スターは嬉しそうに微笑むと、膣が生きているように蠢き始める。",
      "zh": ""
    },
    {
      "key": "110.0",
      "line_index": 110,
      "inline_index": 0,
      "line_hash": "49612113",
      "speaker": "",
      "ja": "思わぬ快感に小さく声を上げるとスターが嬉しそうに微笑んだ。",
      "zh": ""
    },
    {
      "key": "113.0",
      "line_index": 113,
      "inline_index": 0,
      "line_hash": "a1a3df6e",
      "speaker": "スター",
      "ja": "兄くん……どう？♥　スターの中、気持ち良い？♥",
      "zh": ""
    },
    {
      "key": "116.0",
      "line_index": 116,
      "inline_index": 0,
      "line_hash": "fe1aa07",
      "speaker": "{G_PlayerName}",
      "ja": "んぅぅ……スターの中、あったかくてぬるぬるで……ふう、ふう……",
      "zh": ""
    },
    {
      "key": "120.0",
      "line_index": 120,
      "inline_index": 0,
      "line_hash": "88c5c359",
      "speaker": "スター",
      "ja": "射精、できそう？♥",
      "zh": ""
    },
    {
      "key": "123.0",
      "line_index": 123,
      "inline_index": 0,
      "line_hash": "ee8c319f",
      "speaker": "{G_PlayerName}",
      "ja": "ああ、間違いなく射精できる……",
      "zh": ""
    },
    {
      "key": "127.0",
      "line_index": 127,
      "inline_index": 0,
      "line_hash": "84733835",
      "speaker": "スター",
      "ja": "あうっ……！♥　兄くんっ……んっ、おちんちん、ゴツゴツして……気持ち、良いっ……はぁぁっ♥",
      "zh": ""
    },
    {
      "key": "129.0",
      "line_index": 129,
      "inline_index": 0,
      "line_hash": "f69f372c",
      "speaker": "",
      "ja": "僅かに腰を揺すると、スターは甘い声を口から漏らしながら悶える。",
      "zh": ""
    },
    {
      "key": "131.0",
      "line_index": 131,
      "inline_index": 0,
      "line_hash": "39319b9d",
      "speaker": "",
      "ja": "膣がさらに怪しく蠢き、奥からどんどん愛液が溢れる。",
      "zh": ""
    },
    {
      "key": "132.0",
      "line_index": 132,
      "inline_index": 0,
      "line_hash": "27949f7e",
      "speaker": "",
      "ja": "動いてと言わんばかりに膣がぎゅっと締まり、俺の中の興奮がさらに大きなモノへとなっていった。",
      "zh": ""
    },
    {
      "key": "135.0",
      "line_index": 135,
      "inline_index": 0,
      "line_hash": "6637ef0d",
      "speaker": "{G_PlayerName}",
      "ja": "スター、もうガマンできない……動くぞ？",
      "zh": ""
    },
    {
      "key": "139.0",
      "line_index": 139,
      "inline_index": 0,
      "line_hash": "367c78c5",
      "speaker": "スター",
      "ja": "うん、来て……♥　スターでいっぱい気持ち良くなって♥",
      "zh": ""
    },
    {
      "key": "147.0",
      "line_index": 147,
      "inline_index": 0,
      "line_hash": "96907528",
      "speaker": "スター",
      "ja": "はうっ！♥　んあ、あっ、んんっ……うあ、あああぁっ！！♥",
      "zh": ""
    },
    {
      "key": "149.0",
      "line_index": 149,
      "inline_index": 0,
      "line_hash": "18312b91",
      "speaker": "",
      "ja": "俺は興奮を一切隠すことなく腰をピストンさせていく。",
      "zh": ""
    },
    {
      "key": "151.0",
      "line_index": 151,
      "inline_index": 0,
      "line_hash": "3727ade9",
      "speaker": "",
      "ja": "スターはいきなりの俺のピストンに驚いてはいたが、眉を下げ表情を緩ませる。",
      "zh": ""
    },
    {
      "key": "153.0",
      "line_index": 153,
      "inline_index": 0,
      "line_hash": "edf67fb4",
      "speaker": "",
      "ja": "狭い膣が肉棒を吸うように蠢き、亀頭を包み込むように絡みついてきた。",
      "zh": ""
    },
    {
      "key": "156.0",
      "line_index": 156,
      "inline_index": 0,
      "line_hash": "77291e73",
      "speaker": "スター",
      "ja": "んぅ、兄くんの、スターの奥に当たってぇ……♥　んぅ、何、これぇっ……はぁ、快感が……ううっ！！♥",
      "zh": ""
    },
    {
      "key": "159.0",
      "line_index": 159,
      "inline_index": 0,
      "line_hash": "2654de04",
      "speaker": "{G_PlayerName}",
      "ja": "ちんぽでそんないやらしい声を上げて……もうすっかりスケベなAIになってしまったな",
      "zh": ""
    },
    {
      "key": "163.0",
      "line_index": 163,
      "inline_index": 0,
      "line_hash": "232ebcc6",
      "speaker": "スター",
      "ja": "んんぅぅっ！♥　兄くんのおちんちんが……はうっ！♥　気持ち良すぎるんだよぉ……はぁ、はぁぁあんっ！！♥",
      "zh": ""
    },
    {
      "key": "166.0",
      "line_index": 166,
      "inline_index": 0,
      "line_hash": "d8d2a87f",
      "speaker": "{G_PlayerName}",
      "ja": "いーや、スターがエッチすぎるんだ。そんなエッチなスターにはお仕置きしないとなっ",
      "zh": ""
    },
    {
      "key": "170.0",
      "line_index": 170,
      "inline_index": 0,
      "line_hash": "b8073568",
      "speaker": "スター",
      "ja": "ひいいっ！？♥　兄くんっ、そ、そんな早く……だめぇっ！♥　ああああ、ああぁぁんっ！！♥",
      "zh": ""
    },
    {
      "key": "172.0",
      "line_index": 172,
      "inline_index": 0,
      "line_hash": "ba3020bd",
      "speaker": "",
      "ja": "俺はさらにピストンの速度を上げ、執拗に膣奥を押し潰していく。",
      "zh": ""
    },
    {
      "key": "174.0",
      "line_index": 174,
      "inline_index": 0,
      "line_hash": "59b645c9",
      "speaker": "",
      "ja": "スターは快感のあまり小さく首を横に振りながら、枕をぎゅっと掴み快感に悶える。",
      "zh": ""
    },
    {
      "key": "176.0",
      "line_index": 176,
      "inline_index": 0,
      "line_hash": "5cbc7c5d",
      "speaker": "",
      "ja": "瞳がさらにいやらしく蕩け、そんな瞳でじっと見つめられるだけで背筋がゾクゾクと震えてしまった。",
      "zh": ""
    },
    {
      "key": "179.0",
      "line_index": 179,
      "inline_index": 0,
      "line_hash": "f9300ddc",
      "speaker": "スター",
      "ja": "兄くん、これ、本当に、だめぇ……は、はあぁっ！♥　おまんこ、感じちゃうっ……はうっ！♥",
      "zh": ""
    },
    {
      "key": "181.0",
      "line_index": 181,
      "inline_index": 0,
      "line_hash": "1d044681",
      "speaker": "",
      "ja": "スターの喘ぐ仕草に俺の興奮が止まらない。",
      "zh": ""
    },
    {
      "key": "182.0",
      "line_index": 182,
      "inline_index": 0,
      "line_hash": "9961411d",
      "speaker": "",
      "ja": "動くほどに肉棒が気持ち良さに震え、ゾクゾクと何度も快感が背筋を駆ける。",
      "zh": ""
    },
    {
      "key": "184.0",
      "line_index": 184,
      "inline_index": 0,
      "line_hash": "66ce322c",
      "speaker": "",
      "ja": "こんな可愛くて小さな子とエッチしてもいいのか……そんな背徳感も俺の興奮を後押ししていく。",
      "zh": ""
    },
    {
      "key": "187.0",
      "line_index": 187,
      "inline_index": 0,
      "line_hash": "7400e569",
      "speaker": "スター",
      "ja": "んは、はぁっ♥　兄くん、瞳、すごくギラギラして……あああ……♥",
      "zh": ""
    },
    {
      "key": "190.0",
      "line_index": 190,
      "inline_index": 0,
      "line_hash": "251a811b",
      "speaker": "{G_PlayerName}",
      "ja": "怖い……？",
      "zh": ""
    },
    {
      "key": "194.0",
      "line_index": 194,
      "inline_index": 0,
      "line_hash": "a9aba932",
      "speaker": "スター",
      "ja": "ううん、怖くない……んんっ！！♥　なんだか嬉しくてぇ……はぁぁっ、あはぁっ！！♥",
      "zh": ""
    },
    {
      "key": "197.0",
      "line_index": 197,
      "inline_index": 0,
      "line_hash": "74f247e0",
      "speaker": "スター",
      "ja": "兄くんが喜んで……んっ！♥　スターも嬉しいっ♥　もっと、もっとスターで喜んで……気持ち良く、なってぇ……♥",
      "zh": ""
    },
    {
      "key": "200.0",
      "line_index": 200,
      "inline_index": 0,
      "line_hash": "137cb3c2",
      "speaker": "スター",
      "ja": "ひゃうっ！♥　ああぁっ！♥　兄くんっ、勢いが……はうっ、んっ！！♥　んあ、あああぁっ！！♥",
      "zh": ""
    },
    {
      "key": "202.0",
      "line_index": 202,
      "inline_index": 0,
      "line_hash": "7b2d5fb9",
      "speaker": "",
      "ja": "俺は腰をギリギリまで引くと、一気に膣奥目掛け腰を打ち付ける。",
      "zh": ""
    },
    {
      "key": "204.0",
      "line_index": 204,
      "inline_index": 0,
      "line_hash": "9aac579",
      "speaker": "",
      "ja": "スターの狭く浅い膣にすぐに肉棒の先端が奥に当たり、溢れた愛液がブシュっと結合部の隙間から噴き出す。",
      "zh": ""
    },
    {
      "key": "206.0",
      "line_index": 206,
      "inline_index": 0,
      "line_hash": "610e72e4",
      "speaker": "",
      "ja": "膣奥を突くたびに膣がぎゅっと締まり、肉棒を引き抜くのにもかなりの力がいる。",
      "zh": ""
    },
    {
      "key": "208.0",
      "line_index": 208,
      "inline_index": 0,
      "line_hash": "25b0d4bf",
      "speaker": "",
      "ja": "そんな吸引と締め付けを何度も敏感な亀頭で味わい、少しずつ射精の影が俺の脳裏を過ぎっていった。",
      "zh": ""
    },
    {
      "key": "211.0",
      "line_index": 211,
      "inline_index": 0,
      "line_hash": "ed6762ac",
      "speaker": "スター",
      "ja": "お゛っ♥　んっ、んっ！♥　兄くん、おまんこ気持ち良いぃっ！♥　うう、んぅぅぅっ！♥",
      "zh": ""
    },
    {
      "key": "214.0",
      "line_index": 214,
      "inline_index": 0,
      "line_hash": "e42adf0a",
      "speaker": "{G_PlayerName}",
      "ja": "うう、締まりが……も、もう出そうだ……！！",
      "zh": ""
    },
    {
      "key": "217.0",
      "line_index": 217,
      "inline_index": 0,
      "line_hash": "f0dec87b",
      "speaker": "",
      "ja": "射精がすぐそこまで迫っても腰の動きが一切止まらない。",
      "zh": ""
    },
    {
      "key": "219.0",
      "line_index": 219,
      "inline_index": 0,
      "line_hash": "197d9373",
      "speaker": "",
      "ja": "狭い膣の中でビクンと脈打ちながら、今にも爆発しそうな肉棒でスターの膣奥を突きまくっていく。",
      "zh": ""
    },
    {
      "key": "222.0",
      "line_index": 222,
      "inline_index": 0,
      "line_hash": "cc7ba059",
      "speaker": "スター",
      "ja": "うう゛っ！♥　いいよ、いつでも射精、してぇっ！♥　兄くんのせーえきでおまんこいっぱいにしてぇっ！♥",
      "zh": ""
    },
    {
      "key": "224.0",
      "line_index": 224,
      "inline_index": 0,
      "line_hash": "3f07182f",
      "speaker": "",
      "ja": "スターは喘ぎ悶えながらも俺をじっと見つめる。",
      "zh": ""
    },
    {
      "key": "225.0",
      "line_index": 225,
      "inline_index": 0,
      "line_hash": "52905615",
      "speaker": "",
      "ja": "蕩けた大きな瞳でじっと見られ、こみ上げてくる射精衝動をもう抑えきれない。",
      "zh": ""
    },
    {
      "key": "228.0",
      "line_index": 228,
      "inline_index": 0,
      "line_hash": "d5ff70e0",
      "speaker": "スター",
      "ja": "イって兄くんっ……！！♥　スターを……イかせてぇえ～～っ！！♥♥",
      "zh": ""
    },
    {
      "key": "237.0",
      "line_index": 237,
      "inline_index": 0,
      "line_hash": "795f1b10",
      "speaker": "スター",
      "ja": "んぉお゛っ！？♥　お゛っ！♥　ん゛ぅ、んんんんっ！！♥",
      "zh": ""
    },
    {
      "key": "239.0",
      "line_index": 239,
      "inline_index": 0,
      "line_hash": "f47ac4a3",
      "speaker": "",
      "ja": "俺は膣奥に肉棒を突き入れると、こみ上げてきたモノを一気にぶちまける。",
      "zh": ""
    },
    {
      "key": "241.0",
      "line_index": 241,
      "inline_index": 0,
      "line_hash": "1583c511",
      "speaker": "",
      "ja": "ぎゅっと締まる膣の中で肉棒がビクビクと跳ねながら射精を繰り返し、スターは甘い悲鳴を漏らしながら身体をビクンと震わせる。",
      "zh": ""
    },
    {
      "key": "243.0",
      "line_index": 243,
      "inline_index": 0,
      "line_hash": "a699b7a5",
      "speaker": "",
      "ja": "柔らかな膣が亀頭を何度も締め付け、俺は小刻みに腰を揺らしながら精液を注ぎ込み続けた。",
      "zh": ""
    },
    {
      "key": "246.0",
      "line_index": 246,
      "inline_index": 0,
      "line_hash": "db58ba",
      "speaker": "スター",
      "ja": "んぅぅ、兄くんの……すごぉ゛っ……！！♥　おまんこ、熱いので……いっぱいぃ……！！♥",
      "zh": ""
    },
    {
      "key": "249.0",
      "line_index": 249,
      "inline_index": 0,
      "line_hash": "5f33c9c1",
      "speaker": "スター",
      "ja": "うう゛……気持ち良くってぇ……エラー、起きちゃいそう……♥　あはぁ、はぁぁぁぁっ！！♥",
      "zh": ""
    },
    {
      "key": "252.0",
      "line_index": 252,
      "inline_index": 0,
      "line_hash": "66c190a1",
      "speaker": "{G_PlayerName}",
      "ja": "うううう……スター、ま、まだ……ぐっ！",
      "zh": ""
    },
    {
      "key": "256.0",
      "line_index": 256,
      "inline_index": 0,
      "line_hash": "3e15ba0",
      "speaker": "スター",
      "ja": "んひぃっ！♥　まだ、出てりゅぅ……あう゛！♥　奥に、ドクドクぅ……♥　フリーズするぅ……CPU止まっちゃいそうだよぉ……！♥",
      "zh": ""
    },
    {
      "key": "258.0",
      "line_index": 258,
      "inline_index": 0,
      "line_hash": "ccf0985d",
      "speaker": "",
      "ja": "プシャっと潮を何度も噴かせながらいつまでも絶頂を繰り返すスター。",
      "zh": ""
    },
    {
      "key": "260.0",
      "line_index": 260,
      "inline_index": 0,
      "line_hash": "524347b1",
      "speaker": "",
      "ja": "カワイイスターをここまでいやらしくさせたことに興奮してしまい、さらにスターを欲するように肉棒に再び血が集まっていく。",
      "zh": ""
    },
    {
      "key": "263.0",
      "line_index": 263,
      "inline_index": 0,
      "line_hash": "b083d079",
      "speaker": "{G_PlayerName}",
      "ja": "スター、もっと……",
      "zh": ""
    },
    {
      "key": "267.0",
      "line_index": 267,
      "inline_index": 0,
      "line_hash": "66003afd",
      "speaker": "スター",
      "ja": "へ……？　あ、んぅ！♥　兄くんっ！？♥　だ、だめ……少し、ま、待っ──",
      "zh": ""
    },
    {
      "key": "275.0",
      "line_index": 275,
      "inline_index": 0,
      "line_hash": "3ad75d5",
      "speaker": "スター",
      "ja": "──はおおっ！♥　お、お゛っ！！♥　兄くんっ！♥　らめ、らめぇっ！♥　んっ！♥　ん゛ん゛ん゛！！♥",
      "zh": ""
    },
    {
      "key": "277.0",
      "line_index": 277,
      "inline_index": 0,
      "line_hash": "4b9ced28",
      "speaker": "",
      "ja": "俺は収まらない興奮をスターにぶつけるように再び狭い膣を肉棒で掻き回していく。",
      "zh": ""
    },
    {
      "key": "279.0",
      "line_index": 279,
      "inline_index": 0,
      "line_hash": "3f4bc8e",
      "speaker": "",
      "ja": "スターは強烈な快感に耐え切れないのか身体を捩らせ逃げようとする。",
      "zh": ""
    },
    {
      "key": "281.0",
      "line_index": 281,
      "inline_index": 0,
      "line_hash": "f7c2f2fb",
      "speaker": "",
      "ja": "俺はスターの両足をぐっと抑えると、執拗に膣奥を小突くようにピストンを繰り返した。",
      "zh": ""
    },
    {
      "key": "284.0",
      "line_index": 284,
      "inline_index": 0,
      "line_hash": "56cd5cac",
      "speaker": "スター",
      "ja": "ふう、ふううっ！♥　おくっ、ずんずんっ、来て、るぅっ！♥　あああ、ダメ、らめぇっ！♥　エラー起きちゃうっ！！♥",
      "zh": ""
    },
    {
      "key": "287.0",
      "line_index": 287,
      "inline_index": 0,
      "line_hash": "9a2ffe1",
      "speaker": "スター",
      "ja": "あああああっ！♥　おまんこ、イ゛っ……！！♥　んんんっ！！♥　ふうう、ううううっ！！♥♥",
      "zh": ""
    },
    {
      "key": "289.0",
      "line_index": 289,
      "inline_index": 0,
      "line_hash": "9b6e94bf",
      "speaker": "",
      "ja": "肉棒を押し込むたびにスターの尿道から潮がプシャと噴き出す。",
      "zh": ""
    },
    {
      "key": "291.0",
      "line_index": 291,
      "inline_index": 0,
      "line_hash": "70c4201b",
      "speaker": "",
      "ja": "愛液と精液の混じり合ったいやらしい汁が隙間から溢れ、スターの下半身をいやらしく汚していく。",
      "zh": ""
    },
    {
      "key": "293.0",
      "line_index": 293,
      "inline_index": 0,
      "line_hash": "2ae27c3",
      "speaker": "",
      "ja": "柔膣がさらに怪しく蠢き、緩急を付けた締め付けにのめり込むように俺は何度も何度もスターの膣で肉棒を擦り上げた。",
      "zh": ""
    },
    {
      "key": "296.0",
      "line_index": 296,
      "inline_index": 0,
      "line_hash": "b49a875",
      "speaker": "スター",
      "ja": "兄くんっ、イってる、今イってるのぉっ！！♥　おおお、ま、また……ううう！！♥♥",
      "zh": ""
    },
    {
      "key": "299.0",
      "line_index": 299,
      "inline_index": 0,
      "line_hash": "45a5c3ef",
      "speaker": "スター",
      "ja": "おかしくなっちゃうぅっ！♥　はぁ、はぁぁぁっ！！♥　気持ち良いの、止まらないのぉっ！！♥",
      "zh": ""
    },
    {
      "key": "302.0",
      "line_index": 302,
      "inline_index": 0,
      "line_hash": "75c2c587",
      "speaker": "{G_PlayerName}",
      "ja": "止まらなくていいから……！　もっと俺で気持ち良くなってくれ、スター！",
      "zh": ""
    },
    {
      "key": "306.0",
      "line_index": 306,
      "inline_index": 0,
      "line_hash": "5f3c3921",
      "speaker": "スター",
      "ja": "んぎぃっ！！♥　兄くんっ、激しい、激しいよぉっ！♥　おおおおっ！！♥",
      "zh": ""
    },
    {
      "key": "308.0",
      "line_index": 308,
      "inline_index": 0,
      "line_hash": "d6885fe2",
      "speaker": "",
      "ja": "俺はスターの両足を掴むと、グイグイと小刻みにピストンを繰り返す。",
      "zh": ""
    },
    {
      "key": "310.0",
      "line_index": 310,
      "inline_index": 0,
      "line_hash": "1fa8bce4",
      "speaker": "",
      "ja": "スターの下腹部が肉棒によって歪に膨らみ、スターは悶絶するように悶える。",
      "zh": ""
    },
    {
      "key": "312.0",
      "line_index": 312,
      "inline_index": 0,
      "line_hash": "52881c5f",
      "speaker": "",
      "ja": "ヒダが亀頭に絡み、腰を動かすたびにゾクゾクした快感が俺の肉棒を刺激する。",
      "zh": ""
    },
    {
      "key": "314.0",
      "line_index": 314,
      "inline_index": 0,
      "line_hash": "2acb5a82",
      "speaker": "",
      "ja": "そんな甘く蕩けるような快感にのめり込むように濡れた膣の中を何度も肉棒を往復させていった。",
      "zh": ""
    },
    {
      "key": "317.0",
      "line_index": 317,
      "inline_index": 0,
      "line_hash": "a8b722eb",
      "speaker": "スター",
      "ja": "はぁ、あっ♥　んっ！♥　兄くん、だめ、またイって……んんっ♥　あふぅ、んは、あああっ！♥　おまんこ、気持ち良いっ！！♥",
      "zh": ""
    },
    {
      "key": "319.0",
      "line_index": 319,
      "inline_index": 0,
      "line_hash": "e9426b12",
      "speaker": "",
      "ja": "スターが悶えて大きな声で喘ぐたびに、膣がぎゅっと肉棒を締め上げる。",
      "zh": ""
    },
    {
      "key": "321.0",
      "line_index": 321,
      "inline_index": 0,
      "line_hash": "96043b1b",
      "speaker": "",
      "ja": "膣ヒダが肉棒にねっとりと絡み、そんな膣で締め付けられ続け俺にも限界が近づいてくるのを感じる。",
      "zh": ""
    },
    {
      "key": "324.0",
      "line_index": 324,
      "inline_index": 0,
      "line_hash": "58c9e1c7",
      "speaker": "スター",
      "ja": "兄くんっ、兄くんっ♥　だめだめ、またエラーおきちゃうっ！♥　んああ、ああああぁっ！！♥",
      "zh": ""
    },
    {
      "key": "327.0",
      "line_index": 327,
      "inline_index": 0,
      "line_hash": "b3b3c89a",
      "speaker": "スター",
      "ja": "イクっ、イクイク……！！♥　おまんこイっちゃうよぉっ！！♥",
      "zh": ""
    },
    {
      "key": "330.0",
      "line_index": 330,
      "inline_index": 0,
      "line_hash": "81b5b749",
      "speaker": "{G_PlayerName}",
      "ja": "スター……！　また出すぞ……！！　スターの一番奥に出すからっ！！",
      "zh": ""
    },
    {
      "key": "334.0",
      "line_index": 334,
      "inline_index": 0,
      "line_hash": "2bb7aa40",
      "speaker": "スター",
      "ja": "出してぇ～っ！！♥　せーえきいっぱいドクドクしてぇえっ！！♥♥",
      "zh": ""
    },
    {
      "key": "343.0",
      "line_index": 343,
      "inline_index": 0,
      "line_hash": "68af30bb",
      "speaker": "スター",
      "ja": "ううっ！♥　んお、おぉ……！！♥　お、お、んんっ！！♥",
      "zh": ""
    },
    {
      "key": "345.0",
      "line_index": 345,
      "inline_index": 0,
      "line_hash": "1371e1d0",
      "speaker": "",
      "ja": "膣奥を勢い良く突くと、スターが絶頂してしまう。",
      "zh": ""
    },
    {
      "key": "347.0",
      "line_index": 347,
      "inline_index": 0,
      "line_hash": "5311211b",
      "speaker": "",
      "ja": "絶頂に達した膣は俺の肉棒から精液を搾り取るようにぎゅっと締め上げてくる。",
      "zh": ""
    },
    {
      "key": "349.0",
      "line_index": 349,
      "inline_index": 0,
      "line_hash": "ef585ace",
      "speaker": "",
      "ja": "蕩け切った膣の感触に俺も射精してしまい、熱い欲望の塊が何度も陰茎を駆け抜けていった。",
      "zh": ""
    },
    {
      "key": "352.0",
      "line_index": 352,
      "inline_index": 0,
      "line_hash": "7780a75",
      "speaker": "スター",
      "ja": "んぅぅぅ、ふうううっ！！♥　兄くんの、また……いっぱいぃっ……♥　あお、おぉ……！！♥",
      "zh": ""
    },
    {
      "key": "355.0",
      "line_index": 355,
      "inline_index": 0,
      "line_hash": "6bf1e361",
      "speaker": "スター",
      "ja": "嬉しい……♥　兄くんが……スターで喜んでるぅ……あううううっ！！♥",
      "zh": ""
    },
    {
      "key": "357.0",
      "line_index": 357,
      "inline_index": 0,
      "line_hash": "a2b1081",
      "speaker": "",
      "ja": "スターの全身が何度も跳ね、その都度膣が肉棒を締め付ける。",
      "zh": ""
    },
    {
      "key": "358.0",
      "line_index": 358,
      "inline_index": 0,
      "line_hash": "105e99c2",
      "speaker": "",
      "ja": "終わらない射精に俺は呻き声を上げながら何度も射精を繰り返してしまう。",
      "zh": ""
    },
    {
      "key": "361.0",
      "line_index": 361,
      "inline_index": 0,
      "line_hash": "41d3bbe5",
      "speaker": "スター",
      "ja": "はー、はーっ♥　気持ち良すぎてぇ……エラー起きっぱなしぃ……♥　もう兄くんとエッチすることしか考えられなくなってるよぉ……♥",
      "zh": ""
    },
    {
      "key": "363.0",
      "line_index": 363,
      "inline_index": 0,
      "line_hash": "a31a6258",
      "speaker": "",
      "ja": "すっかり快楽に溺れたスターは恍惚とした笑みを浮かべ、潤んだ瞳で俺を見つめる。",
      "zh": ""
    },
    {
      "key": "365.0",
      "line_index": 365,
      "inline_index": 0,
      "line_hash": "65ac7af2",
      "speaker": "",
      "ja": "そんなエッチなスターに触発されるように肉棒に再び活力が戻り、狭すぎる膣の中でビクンと大きく跳ねあがる。",
      "zh": ""
    },
    {
      "key": "368.0",
      "line_index": 368,
      "inline_index": 0,
      "line_hash": "a93e7183",
      "speaker": "スター",
      "ja": "兄、くん……もっと……もっとおまんこ、ずぼずぼ、してぇ……♥　スターでもっと気持ち良くなってぇ……♥",
      "zh": ""
    },
    {
      "key": "370.0",
      "line_index": 370,
      "inline_index": 0,
      "line_hash": "163d9db7",
      "speaker": "",
      "ja": "スターは甘えるような声で俺を求めてくる。",
      "zh": ""
    },
    {
      "key": "371.0",
      "line_index": 371,
      "inline_index": 0,
      "line_hash": "81d0611",
      "speaker": "",
      "ja": "普段の真面目で口数の少ないスターはいなくなり、オスを求めるメスそのものになっていた。",
      "zh": ""
    },
    {
      "key": "374.0",
      "line_index": 374,
      "inline_index": 0,
      "line_hash": "9bcd76e",
      "speaker": "{G_PlayerName}",
      "ja": "わかった……もっとスターを感じさせるから……。でも一つだけ約束してくれ……無理はしないでくれよ？",
      "zh": ""
    },
    {
      "key": "378.0",
      "line_index": 378,
      "inline_index": 0,
      "line_hash": "eb20cc2c",
      "speaker": "スター",
      "ja": "うん……♥　ふあ、あああ、兄くんっ！♥　ふああ、あああぁぁ～～っ！！♥",
      "zh": ""
    },
    {
      "key": "380.0",
      "line_index": 380,
      "inline_index": 0,
      "line_hash": "40e224bb",
      "speaker": "",
      "ja": "スターの言葉を合図に俺は再び腰を前後させていく。",
      "zh": ""
    },
    {
      "key": "382.0",
      "line_index": 382,
      "inline_index": 0,
      "line_hash": "7374879a",
      "speaker": "",
      "ja": "俺とスターの愛の営みはいつまでも終わることなく続き、スターの全身が精液で真っ白に汚れるまで続くのであった。",
      "zh": ""
    }
  ]
}
