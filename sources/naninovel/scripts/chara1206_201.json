    {
      "key": "304.0",
      "line_index": 304,
      "inline_index": 0,
      "line_hash": "8b045e15",
      "speaker": "{G_PlayerName}",
      "ja": "うっ……またちんぽミルクでるぅ！　んんんんんっ！",
