{
  "lines": [
    {
      "key": "20.1",
      "line_index": 20,
      "inline_index": 1,
      "line_hash": "c8a18e23",
      "speaker": "コハル",
      "ja": "んっ……♥　んはぁ、そ、そこぉ……あうっ……！♥",
      "zh": ""
    },
    {
      "key": "22.0",
      "line_index": 22,
      "inline_index": 0,
      "line_hash": "7dbeb555",
      "speaker": "",
      "ja": "遠くに祭りの喧騒が耳に聞こえる中、俺はぐちゅぐちゅのコハルの膣を指で掻き回す。",
      "zh": ""
    },
    {
      "key": "24.0",
      "line_index": 24,
      "inline_index": 0,
      "line_hash": "dec9ade0",
      "speaker": "",
      "ja": "完全にスイッチが入り、もう一つになることしか考えられない。",
      "zh": ""
    },
    {
      "key": "26.0",
      "line_index": 26,
      "inline_index": 0,
      "line_hash": "8d28decc",
      "speaker": "",
      "ja": "コハルも同じに思っているのか、俺の愛撫を頬を赤らめながら受け止め、膣を掻き回すたびに甘い喘ぎ声が口から漏れ出していた。",
      "zh": ""
    },
    {
      "key": "28.0",
      "line_index": 28,
      "inline_index": 0,
      "line_hash": "7bcb38b2",
      "speaker": "",
      "ja": "露わになるコハルの真っ白で透き通るような裸体。あそこからはたらりと糸を引きながら愛液が垂れ落ち、地面に水たまりを作る。",
      "zh": ""
    },
    {
      "key": "44.0",
      "line_index": 44,
      "inline_index": 0,
      "line_hash": "972d027b",
      "speaker": "コハル",
      "ja": "あうっ！♥　はぁっ、あああぁっ！♥　いきなり動きすぎぃっ……！♥　ふぅ、んふぅっ！♥　ふあぁんっ！！♥",
      "zh": ""
    },
    {
      "key": "47.0",
      "line_index": 47,
      "inline_index": 0,
      "line_hash": "20a154eb",
      "speaker": "{G_PlayerName}",
      "ja": "コハル、本当にこんな体勢でいいのか？　辛くないか？",
      "zh": ""
    },
    {
      "key": "51.0",
      "line_index": 51,
      "inline_index": 0,
      "line_hash": "c4e688d6",
      "speaker": "コハル",
      "ja": "んっ！♥　んっ！♥　だって、しょうがないでしょぉっ♥　こうしないと浴衣汚れちゃうし……あんっ！♥",
      "zh": ""
    },
    {
      "key": "53.0",
      "line_index": 53,
      "inline_index": 0,
      "line_hash": "d036c82",
      "speaker": "",
      "ja": "コハルにとって今日のお祭りデートはそれだけ特別なことらしい。だったらこのまま……。",
      "zh": ""
    },
    {
      "key": "56.0",
      "line_index": 56,
      "inline_index": 0,
      "line_hash": "1496744b",
      "speaker": "コハル",
      "ja": "あっ♥　あんっ！♥　な、なんかさ……ううっ♥　いつもより、激しくてぇ……♥",
      "zh": ""
    },
    {
      "key": "59.0",
      "line_index": 59,
      "inline_index": 0,
      "line_hash": "e87cb4b9",
      "speaker": "コハル",
      "ja": "外でするの、興奮しちゃってる？♥　おちんちんもすっごく熱くなってるぅ……！♥",
      "zh": ""
    },
    {
      "key": "62.0",
      "line_index": 62,
      "inline_index": 0,
      "line_hash": "d79a8f0",
      "speaker": "{G_PlayerName}",
      "ja": "外で後ろからしているさ……なんていうか、コハルを無理やりしてるみたいに思えて、それで……",
      "zh": ""
    },
    {
      "key": "66.0",
      "line_index": 66,
      "inline_index": 0,
      "line_hash": "33743fa",
      "speaker": "コハル",
      "ja": "そう、なんだ……あんっ！♥　そう見えちゃうんだね……はぁ、んはぁっ！♥　んぅぅ、奥ぅ……ああ、奥ばっかり、だめだってぇ……！！♥",
      "zh": ""
    },
    {
      "key": "68.0",
      "line_index": 68,
      "inline_index": 0,
      "line_hash": "32a58323",
      "speaker": "",
      "ja": "興奮に身を任せ、俺は小さなお尻に下腹部を叩きつけるようにピストンを繰り返す。",
      "zh": ""
    },
    {
      "key": "70.0",
      "line_index": 70,
      "inline_index": 0,
      "line_hash": "15a2afba",
      "speaker": "",
      "ja": "俺の腰が動くたびにコハルは甘い悲鳴を口から漏らし、後ろからでもわかるほど汗を滴らせる。",
      "zh": ""
    },
    {
      "key": "72.0",
      "line_index": 72,
      "inline_index": 0,
      "line_hash": "e273c341",
      "speaker": "",
      "ja": "真っ白な愛液がプシュっと隙間から溢れ、コハルの汗を愛液が夏の夜の暑さでも蒸発せず水たまりを作っていた。",
      "zh": ""
    },
    {
      "key": "75.0",
      "line_index": 75,
      "inline_index": 0,
      "line_hash": "778ea037",
      "speaker": "コハル",
      "ja": "優しいあんたも好きだけどぉ……あうっ！♥　男の力強さを感じさせるあんたも好きぃっ♥",
      "zh": ""
    },
    {
      "key": "78.0",
      "line_index": 78,
      "inline_index": 0,
      "line_hash": "665a76e7",
      "speaker": "コハル",
      "ja": "愛されてるって感じる♥　だから……あうっ！♥　このまま続けてぇっ♥　おまんこもっと犯してぇっ♥",
      "zh": ""
    },
    {
      "key": "81.0",
      "line_index": 81,
      "inline_index": 0,
      "line_hash": "61000570",
      "speaker": "コハル",
      "ja": "はううううっ！♥　あっ、あっ！♥　これぇっ、イイっ！♥　ああ、もっと、もっとぉっ！！♥",
      "zh": ""
    },
    {
      "key": "83.0",
      "line_index": 83,
      "inline_index": 0,
      "line_hash": "ecf62bc2",
      "speaker": "",
      "ja": "ただでさえ締め付けの良いコハルの膣がじゅくじゅくと蠢きながら締まる。",
      "zh": ""
    },
    {
      "key": "85.0",
      "line_index": 85,
      "inline_index": 0,
      "line_hash": "16abc6f2",
      "speaker": "",
      "ja": "そんな膣を力任せに柔肉を肉棒で掻き分けながら押し入れる。",
      "zh": ""
    },
    {
      "key": "86.0",
      "line_index": 86,
      "inline_index": 0,
      "line_hash": "be089878",
      "speaker": "",
      "ja": "卑猥な水音とともに、肌と肌のぶつかる音がどんどん大きくなる。",
      "zh": ""
    },
    {
      "key": "88.0",
      "line_index": 88,
      "inline_index": 0,
      "line_hash": "8fb5c178",
      "speaker": "",
      "ja": "コハルの声と相まって、かなり遠くまで音が響いているがわかるが、それでも俺は腰を止められず動き続ける。",
      "zh": ""
    },
    {
      "key": "91.0",
      "line_index": 91,
      "inline_index": 0,
      "line_hash": "f1416328",
      "speaker": "コハル",
      "ja": "もう、だめっ♥　おまんこイっちゃう！♥　イっちゃうのっ！♥",
      "zh": ""
    },
    {
      "key": "94.0",
      "line_index": 94,
      "inline_index": 0,
      "line_hash": "85d56742",
      "speaker": "コハル",
      "ja": "あんたのおちんちんでイかせてっ！♥　中出しで気持ち良くさせてぇっ！♥",
      "zh": ""
    },
    {
      "key": "96.0",
      "line_index": 96,
      "inline_index": 0,
      "line_hash": "66ab27f9",
      "speaker": "",
      "ja": "コハルは小さなお尻を俺に押し付け、さらに二人の密着度合いが上がる。",
      "zh": ""
    },
    {
      "key": "98.0",
      "line_index": 98,
      "inline_index": 0,
      "line_hash": "2488a488",
      "speaker": "",
      "ja": "コハルの絶頂に合わせ小刻みに子宮口を叩くと、精液を欲する子宮口が肉棒をぢゅるっと吸引してくる。",
      "zh": ""
    },
    {
      "key": "101.0",
      "line_index": 101,
      "inline_index": 0,
      "line_hash": "c5f7310",
      "speaker": "コハル",
      "ja": "イクっ！♥　イクぅっ！♥　出してっ！♥　精液いっぱい出してぇ～～～っ！♥♥",
      "zh": ""
    },
    {
      "key": "109.0",
      "line_index": 109,
      "inline_index": 0,
      "line_hash": "f8c45303",
      "speaker": "コハル",
      "ja": "んあぁぁっ！？♥　あっ、あっ！♥　出て……るぅっ！♥　んぅぅ、んは、はっ♥　はぁぁぁんっ！！♥♥",
      "zh": ""
    },
    {
      "key": "111.0",
      "line_index": 111,
      "inline_index": 0,
      "line_hash": "a212bad9",
      "speaker": "",
      "ja": "絶頂で締まる膣の中で肉棒を跳ねらせながら射精をすると、コハルは歓喜の甘い悲鳴を口から漏らす。",
      "zh": ""
    },
    {
      "key": "113.0",
      "line_index": 113,
      "inline_index": 0,
      "line_hash": "2d56c3dc",
      "speaker": "",
      "ja": "柔らかな膣が蠢き、子宮口が精液を飲みこむように吸い付く。",
      "zh": ""
    },
    {
      "key": "115.0",
      "line_index": 115,
      "inline_index": 0,
      "line_hash": "9b0f3bcd",
      "speaker": "",
      "ja": "しかし俺はその刺激だけでは飽き足らず、腰を小刻みに揺すり精液を扱き出す。",
      "zh": ""
    },
    {
      "key": "118.0",
      "line_index": 118,
      "inline_index": 0,
      "line_hash": "81cb9ca",
      "speaker": "コハル",
      "ja": "んあ、ああ……ドクドク出てるぅ……！！♥　子宮が、いっぱいだよぉ……♥　あふぅぅ……！♥♥",
      "zh": ""
    },
    {
      "key": "120.0",
      "line_index": 120,
      "inline_index": 0,
      "line_hash": "7a9aefd8",
      "speaker": "",
      "ja": "精液が子宮口を叩くたびにコハルは絶頂し、小さな身体をビクンビクンと大きく跳ねらせる。",
      "zh": ""
    },
    {
      "key": "122.0",
      "line_index": 122,
      "inline_index": 0,
      "line_hash": "627d3e10",
      "speaker": "",
      "ja": "コハルを何度でも絶頂させたい、そう思ってはいたが射精は次第に緩やかなものになっていく。",
      "zh": ""
    },
    {
      "key": "123.0",
      "line_index": 123,
      "inline_index": 0,
      "line_hash": "7b0b7699",
      "speaker": "",
      "ja": "すべてを出し切った頃には俺もコハルも息を切らせ、二人の呼吸音だけが聞こえていた。",
      "zh": ""
    },
    {
      "key": "126.0",
      "line_index": 126,
      "inline_index": 0,
      "line_hash": "7f38a00e",
      "speaker": "コハル",
      "ja": "あへ、あへぇ……しゅごしゅぎぃ……♥　ますますあんたのことしゅきになっちゃうよぉ……♥",
      "zh": ""
    },
    {
      "key": "129.0",
      "line_index": 129,
      "inline_index": 0,
      "line_hash": "930691bb",
      "speaker": "{G_PlayerName}",
      "ja": "俺もだ……セックスするほどにコハルが愛しくなる、コハルが欲しくなる……コハルともっと愛し合いたいって思えてくる……",
      "zh": ""
    },
    {
      "key": "137.0",
      "line_index": 137,
      "inline_index": 0,
      "line_hash": "af6f7b45",
      "speaker": "コハル",
      "ja": "んぎぃっ！？♥　ひぃ、ひぃぃぃっ！♥　待ってぇっ！♥　イった、イったばかりだかりゃぁっ！♥　あひいいっ！♥",
      "zh": ""
    },
    {
      "key": "139.0",
      "line_index": 139,
      "inline_index": 0,
      "line_hash": "c6bd2c85",
      "speaker": "",
      "ja": "俺はコハルの耳元で囁くと同時に、腰をコハルの小さなお尻に再び叩きつける。",
      "zh": ""
    },
    {
      "key": "142.0",
      "line_index": 142,
      "inline_index": 0,
      "line_hash": "8fb332a5",
      "speaker": "コハル",
      "ja": "あひぃっ！？♥　らめっ、だめ、奥ぅっ！♥　入っちゃいけないとこに入ってるぅっ！♥　ああ、あああぁぁっ！！♥",
      "zh": ""
    },
    {
      "key": "145.0",
      "line_index": 145,
      "inline_index": 0,
      "line_hash": "94702135",
      "speaker": "{G_PlayerName}",
      "ja": "子宮には入ってないから……このまま続けるぞ……！",
      "zh": ""
    },
    {
      "key": "149.0",
      "line_index": 149,
      "inline_index": 0,
      "line_hash": "ed4ea2cd",
      "speaker": "コハル",
      "ja": "あうううっ！♥　あ、あっ！♥　入ってるってぇっ！♥　あああぁ、子宮直接犯してるぅっ！♥　あうううっ！！♥",
      "zh": ""
    },
    {
      "key": "151.0",
      "line_index": 151,
      "inline_index": 0,
      "line_hash": "26ca73e8",
      "speaker": "",
      "ja": "コハルはそう言うが、まだそこまで至ってはいない。",
      "zh": ""
    },
    {
      "key": "152.0",
      "line_index": 152,
      "inline_index": 0,
      "line_hash": "2d83668a",
      "speaker": "",
      "ja": "それでも俺の激しいピストンの勢いにそう感じているのかもしれない。",
      "zh": ""
    },
    {
      "key": "155.0",
      "line_index": 155,
      "inline_index": 0,
      "line_hash": "4018b9d1",
      "speaker": "{G_PlayerName}",
      "ja": "大丈夫だから……コハルは余計なこと考えずに感じてくれればいいから",
      "zh": ""
    },
    {
      "key": "158.0",
      "line_index": 158,
      "inline_index": 0,
      "line_hash": "56a90cbe",
      "speaker": "",
      "ja": "俺はコハルを起き上がらせると、背後からそっと抱きしめる。",
      "zh": ""
    },
    {
      "key": "160.0",
      "line_index": 160,
      "inline_index": 0,
      "line_hash": "4b07afe2",
      "speaker": "",
      "ja": "バチンバチンと肌のぶつかり合う音がさらに強くなり、結合部の隙間から大量の愛液と精液が糸を引きながら垂れ落ちる。",
      "zh": ""
    },
    {
      "key": "163.0",
      "line_index": 163,
      "inline_index": 0,
      "line_hash": "f5f08c76",
      "speaker": "コハル",
      "ja": "ふぅ、ふぅっ！♥　おまんこ、壊れちゃうぅぅ！♥　ぎもぢっ、いいよぉっ！♥　あうう、ああ、そこぉっ！♥　あひぃ、ひいいいいぃ！♥",
      "zh": ""
    },
    {
      "key": "166.0",
      "line_index": 166,
      "inline_index": 0,
      "line_hash": "2d3b27b0",
      "speaker": "コハル",
      "ja": "ふぅう、んふうううっ！♥　ああ、おっぱい、感じるぅっ！♥　乳首、もっと触ってぇっ……！♥　あぁ、んぅ、ふあ、ああううっ！！♥♥",
      "zh": ""
    },
    {
      "key": "168.0",
      "line_index": 168,
      "inline_index": 0,
      "line_hash": "bd4cab77",
      "speaker": "",
      "ja": "コハルの蕩け切った膣が肉棒をぎゅっと締め付け、思わず射精しそうになってしまう。",
      "zh": ""
    },
    {
      "key": "170.0",
      "line_index": 170,
      "inline_index": 0,
      "line_hash": "9228a1a7",
      "speaker": "",
      "ja": "とろとろの膣ヒダが精液を吐き出させようと甘く絡みつき、動くたびに射精が脳裏をチラつく。",
      "zh": ""
    },
    {
      "key": "172.0",
      "line_index": 172,
      "inline_index": 0,
      "line_hash": "1033e01f",
      "speaker": "",
      "ja": "それでも今はコハルを感じさせることだけを考え、射精感を心の奥に押し込める。",
      "zh": ""
    },
    {
      "key": "173.0",
      "line_index": 173,
      "inline_index": 0,
      "line_hash": "6e5b663c",
      "speaker": "",
      "ja": "興奮のままにピストンを繰り返し、狭く小さいコハルの膣を肉棒で執拗に掻き回し続けた。",
      "zh": ""
    },
    {
      "key": "176.0",
      "line_index": 176,
      "inline_index": 0,
      "line_hash": "de300956",
      "speaker": "コハル",
      "ja": "んぅぅっ！♥　もっと、パンパンしてぇっ♥　おまんこ、あんたのおちんちんの形にしてぇっ♥　もっと、もっと滅茶苦茶にぃっ……んんんっ！！♥",
      "zh": ""
    },
    {
      "key": "178.0",
      "line_index": 178,
      "inline_index": 0,
      "line_hash": "2a6301a6",
      "speaker": "",
      "ja": "隙間なく締め付ける膣をカリ首でごりごりと抉りながら、子宮口を執拗に亀頭で叩く。",
      "zh": ""
    },
    {
      "key": "180.0",
      "line_index": 180,
      "inline_index": 0,
      "line_hash": "2c271711",
      "speaker": "",
      "ja": "お漏らしをしたように真っ白な愛液が次々と溢れ、動くたびにねっとりとしたモノが肉棒に絡む。",
      "zh": ""
    },
    {
      "key": "182.0",
      "line_index": 182,
      "inline_index": 0,
      "line_hash": "a85efa52",
      "speaker": "",
      "ja": "愛液と精液まみれの膣で肉棒全体を扱かれる感覚が気持ち良すぎる。",
      "zh": ""
    },
    {
      "key": "183.0",
      "line_index": 183,
      "inline_index": 0,
      "line_hash": "99926a11",
      "speaker": "",
      "ja": "まるで心まで解け合うようなコハルとのセックス。",
      "zh": ""
    },
    {
      "key": "184.0",
      "line_index": 184,
      "inline_index": 0,
      "line_hash": "340d56e1",
      "speaker": "",
      "ja": "俺はそれを貪るようにさらに大きく腰をコハルのお尻に叩きつけた。",
      "zh": ""
    },
    {
      "key": "187.0",
      "line_index": 187,
      "inline_index": 0,
      "line_hash": "5dfa7f63",
      "speaker": "コハル",
      "ja": "んぅんっ！♥　ダメ、またイっちゃう！♥　あふぅっ！♥　ああ、んぅぅっ！♥　ああぁっ、んあああぁっ！！♥",
      "zh": ""
    },
    {
      "key": "190.0",
      "line_index": 190,
      "inline_index": 0,
      "line_hash": "b8b1044a",
      "speaker": "{G_PlayerName}",
      "ja": "また中に出すぞ……！　コハルのおまんこ、俺ので溢れさせてやる……！！",
      "zh": ""
    },
    {
      "key": "194.0",
      "line_index": 194,
      "inline_index": 0,
      "line_hash": "704ddfb8",
      "speaker": "コハル",
      "ja": "うん、うんっ！♥　出してっ！♥　あんたのでいっぱいにしてっ！♥　あんたの精液でイかせてぇ～っ！♥",
      "zh": ""
    },
    {
      "key": "196.0",
      "line_index": 196,
      "inline_index": 0,
      "line_hash": "d9462605",
      "speaker": "",
      "ja": "膣が怪しく蠢き、精液を搾り取ろうと絡みつく。",
      "zh": ""
    },
    {
      "key": "197.0",
      "line_index": 197,
      "inline_index": 0,
      "line_hash": "1bebc23e",
      "speaker": "",
      "ja": "俺はこみ上げてきたモノを吐き出そうと、執拗にコハルの膣奥を叩く。",
      "zh": ""
    },
    {
      "key": "200.0",
      "line_index": 200,
      "inline_index": 0,
      "line_hash": "cd897a0b",
      "speaker": "コハル",
      "ja": "んんんっ！♥　イっちゃ、イっちゃうっ！♥　イク、イクぅっ！♥　イっくぅぅっぅうぅ～～っ！！♥♥",
      "zh": ""
    },
    {
      "key": "209.0",
      "line_index": 209,
      "inline_index": 0,
      "line_hash": "529d12ef",
      "speaker": "コハル",
      "ja": "んあああぁぁっ！♥　イグぅ、イグぅっ、イぐうううぅ！♥　んんぅ、んあ、はっ、ああああぁっ！！♥♥",
      "zh": ""
    },
    {
      "key": "211.0",
      "line_index": 211,
      "inline_index": 0,
      "line_hash": "d14ec0cc",
      "speaker": "",
      "ja": "腰をギリギリまで押し付け、俺はこみ上げてきたモノを一気に膣奥に吐き出す。",
      "zh": ""
    },
    {
      "key": "213.0",
      "line_index": 213,
      "inline_index": 0,
      "line_hash": "5717aa6b",
      "speaker": "",
      "ja": "同時にコハルも絶頂し、甲高い悲鳴と共に、プシャっと勢いよく潮が噴き出す。",
      "zh": ""
    },
    {
      "key": "215.0",
      "line_index": 215,
      "inline_index": 0,
      "line_hash": "958dca42",
      "speaker": "",
      "ja": "潮がびちゃびちゃと地面に濡らし、その様子だけで俺は興奮から何度も射精をしてしまう。",
      "zh": ""
    },
    {
      "key": "218.0",
      "line_index": 218,
      "inline_index": 0,
      "line_hash": "8913ddeb",
      "speaker": "コハル",
      "ja": "は、はっ♥　うう、うう……！♥　んあ、と、止まらにゃいぃ……♥　まだ、まだ、出てぇ……あうっ！♥",
      "zh": ""
    },
    {
      "key": "221.0",
      "line_index": 221,
      "inline_index": 0,
      "line_hash": "eac524d2",
      "speaker": "コハル",
      "ja": "んぐぅ、んぅ♥　おまんこぉ、イキっぱなしだよぉ……♥　あひぃ、ひぃ、んひぃぃぃっ！！♥♥",
      "zh": ""
    },
    {
      "key": "223.0",
      "line_index": 223,
      "inline_index": 0,
      "line_hash": "35bb9132",
      "speaker": "",
      "ja": "止まらない絶頂に甘い悲鳴を上げ続けるコハル。",
      "zh": ""
    },
    {
      "key": "224.0",
      "line_index": 224,
      "inline_index": 0,
      "line_hash": "b5077aa3",
      "speaker": "",
      "ja": "さすがに少し心配になり、俺はぎゅっとコハルを抱きしめる。",
      "zh": ""
    },
    {
      "key": "226.0",
      "line_index": 226,
      "inline_index": 0,
      "line_hash": "5b905545",
      "speaker": "",
      "ja": "それで少し安心したのか、蕩けた表情が少しだけ和らぐ。",
      "zh": ""
    },
    {
      "key": "227.0",
      "line_index": 227,
      "inline_index": 0,
      "line_hash": "950d1aea",
      "speaker": "",
      "ja": "依然として絶頂を続けていたが、上手い具合に身体から力抜け、快感に瞳をとろんとさせていた。",
      "zh": ""
    },
    {
      "key": "230.0",
      "line_index": 230,
      "inline_index": 0,
      "line_hash": "2425be38",
      "speaker": "コハル",
      "ja": "あ、あ……♥　ダメ、出ちゃ……あ、あ……出ちゃ、う……♥",
      "zh": ""
    },
    {
      "key": "233.0",
      "line_index": 233,
      "inline_index": 0,
      "line_hash": "c680d918",
      "speaker": "{G_PlayerName}",
      "ja": "……コハル？",
      "zh": ""
    },
    {
      "key": "241.0",
      "line_index": 241,
      "inline_index": 0,
      "line_hash": "a44aded7",
      "speaker": "コハル",
      "ja": "んぅう……！♥　んふぅ、ふーっ！♥　ふーっ！♥　うぅぅ、らめぇ……おしっこ、出りゅぅ……♥　あううっ……♥",
      "zh": ""
    },
    {
      "key": "243.0",
      "line_index": 243,
      "inline_index": 0,
      "line_hash": "8f0d95bc",
      "speaker": "",
      "ja": "じょぼじょぼと勢いよく黄色い尿が漏れ出し、びちゃびちゃと地面に大きな水たまりを作る。",
      "zh": ""
    },
    {
      "key": "246.0",
      "line_index": 246,
      "inline_index": 0,
      "line_hash": "a14a26de",
      "speaker": "コハル",
      "ja": "あひぃ……出るの、ぎもぢいい～……♥　あうう、あううう……♥",
      "zh": ""
    },
    {
      "key": "248.0",
      "line_index": 248,
      "inline_index": 0,
      "line_hash": "5fc95568",
      "speaker": "",
      "ja": "気持ち良さそうな声を上げながらおしっこを漏らすコハル。",
      "zh": ""
    },
    {
      "key": "249.0",
      "line_index": 249,
      "inline_index": 0,
      "line_hash": "1592d8fc",
      "speaker": "",
      "ja": "ガクガクと足を震わせながら放尿している姿に、少しやり過ぎたかも、と考えてしまう。",
      "zh": ""
    },
    {
      "key": "252.0",
      "line_index": 252,
      "inline_index": 0,
      "line_hash": "6bba1e71",
      "speaker": "{G_PlayerName}",
      "ja": "すまん、コハル……俺夢中になってやり過ぎたかも……大丈夫か？",
      "zh": ""
    },
    {
      "key": "256.0",
      "line_index": 256,
      "inline_index": 0,
      "line_hash": "12c86d9b",
      "speaker": "コハル",
      "ja": "らい、じょーぶ……んへへ……♥　あんただから、こんなところも……見せられるんだよぉ……♥",
      "zh": ""
    },
    {
      "key": "258.0",
      "line_index": 258,
      "inline_index": 0,
      "line_hash": "77e2b1ca",
      "speaker": "",
      "ja": "コハルは幸せそうに俺に身体を預け、肩で大きく呼吸を繰り返す。",
      "zh": ""
    },
    {
      "key": "259.0",
      "line_index": 259,
      "inline_index": 0,
      "line_hash": "91a7f648",
      "speaker": "",
      "ja": "その表情は蕩けながらも幸せを感じさせる。",
      "zh": ""
    },
    {
      "key": "260.0",
      "line_index": 260,
      "inline_index": 0,
      "line_hash": "be7f732c",
      "speaker": "",
      "ja": "俺はそんなコハルをぎゅっと抱きしめ直すと、コハルは愛しそうな視線を俺に向ける。",
      "zh": ""
    },
    {
      "key": "263.0",
      "line_index": 263,
      "inline_index": 0,
      "line_hash": "3d232b43",
      "speaker": "コハル",
      "ja": "もっと、もっとおまんこズボズボして……♥　あんたのおちんちんで……もっとイかせて……♥",
      "zh": ""
    },
    {
      "key": "266.0",
      "line_index": 266,
      "inline_index": 0,
      "line_hash": "b4f2c84f",
      "speaker": "コハル",
      "ja": "おまんこにもっと精液ちょうだい……♥　力強いセックスであんたの幼馴染を幸せにして……♥",
      "zh": ""
    },
    {
      "key": "269.0",
      "line_index": 269,
      "inline_index": 0,
      "line_hash": "3115bc8e",
      "speaker": "{G_PlayerName}",
      "ja": "わかった……もっと気持ち良くなろう、お互いに",
      "zh": ""
    },
    {
      "key": "272.0",
      "line_index": 272,
      "inline_index": 0,
      "line_hash": "bfafc683",
      "speaker": "",
      "ja": "俺はコハルにそう囁くと、三度腰を動かしていく。",
      "zh": ""
    },
    {
      "key": "274.0",
      "line_index": 274,
      "inline_index": 0,
      "line_hash": "8bda6aae",
      "speaker": "",
      "ja": "遠くに聞こえる祭りの喧騒と花火の轟音。",
      "zh": ""
    },
    {
      "key": "275.0",
      "line_index": 275,
      "inline_index": 0,
      "line_hash": "e894a8b5",
      "speaker": "",
      "ja": "今日のお祭りをより特別なものにしようと、俺たちはいつまでもお互いを求めあい続けるのであった。",
      "zh": ""
    }
  ]
}
