    {
      "key": "415.1",
      "line_index": 415,
      "inline_index": 1,
      "line_hash": "f8ddd155",
      "speaker": "ブライダル",
      "ja": "大変申し訳ございません……宇宙酔いが発生するとは……",
      "zh": ""
