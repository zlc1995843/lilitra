    {
      "key": "284.0",
      "line_index": 284,
      "inline_index": 0,
      "line_hash": "61ec890b",
      "speaker": "{G_PlayerName}",
      "ja": "お、おう……大丈夫だと思う",
      "zh": ""
    },
    {
      "key": "297.1",
      "line_index": 297,
      "inline_index": 1,
      "line_hash": "7e047956",
      "speaker": "ブルーム",
      "ja": "なーに、あのクソザコ人間……死にかけの金魚みたい！",
      "zh": ""
