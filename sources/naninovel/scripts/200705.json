    {
      "key": "363.1",
      "line_index": 363,
      "inline_index": 1,
      "line_hash": "1447f2b8",
      "speaker": "コハル",
      "ja": "～～～～っ！！？　ちょ、ちょっと！？",
      "zh": ""
    },
    {
      "key": "370.1",
      "line_index": 370,
      "inline_index": 1,
      "line_hash": "6cb39bcc",
      "speaker": "ブライダル",
      "ja": "……わーお。こんな情熱的なお客様、見たことありませんね……素敵ですが、段取りが……",
      "zh": ""
    },
    {
      "key": "372.1",
      "line_index": 372,
      "inline_index": 1,
      "line_hash": "be7fc86b",
      "speaker": "コハル",
      "ja": "ちょ、ちょっと、{G_PlayerName}……！　う、嬉しいけど……！　みんなが見てるし、恥ずかしいって……！",
      "zh": ""
    },
    {
      "key": "374.0",
      "line_index": 374,
      "inline_index": 0,
      "line_hash": "a8232f2f",
      "speaker": "{G_PlayerName}",
      "ja": "き…………",
