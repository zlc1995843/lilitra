{
  "lines": [
    {
      "key": "9.0",
      "line_index": 9,
      "inline_index": 0,
      "line_hash": "6f56e214",
      "speaker": "",
      "ja": "数分前……",
      "zh": ""
    },
    {
      "key": "19.1",
      "line_index": 19,
      "inline_index": 1,
      "line_hash": "53b1798f",
      "speaker": "アイディル",
      "ja": "あ～～……お腹へった……ごはん、まだ～？",
      "zh": ""
    },
    {
      "key": "21.1",
      "line_index": 21,
      "inline_index": 1,
      "line_hash": "6790131c",
      "speaker": "マロウ",
      "ja": "も、もう限界ッス～……",
      "zh": ""
    },
    {
      "key": "28.1",
      "line_index": 28,
      "inline_index": 1,
      "line_hash": "84033a70",
      "speaker": "モル",
      "ja": "……宇宙もやし、焼きました",
      "zh": ""
    },
    {
      "key": "31.1",
      "line_index": 31,
      "inline_index": 1,
      "line_hash": "9d4b1dd",
      "speaker": "アイディル",
      "ja": "もう何日宇宙もやし生活～！？　もっと色々食べたいわよ～！",
      "zh": ""
    },
    {
      "key": "33.1",
      "line_index": 33,
      "inline_index": 1,
      "line_hash": "4b53c166",
      "speaker": "マロウ",
      "ja": "うちの船の設備、食料関係ショボいッスからねぇ……宇宙もやしくらいしか育てられないッス",
      "zh": ""
    },
    {
      "key": "35.1",
      "line_index": 35,
      "inline_index": 1,
      "line_hash": "2de181f",
      "speaker": "モル",
      "ja": "あの前襲った、宇宙船くらいの設備があれば……話は別ですが……",
      "zh": ""
    },
    {
      "key": "37.1",
      "line_index": 37,
      "inline_index": 1,
      "line_hash": "a70aef48",
      "speaker": "アイディル",
      "ja": "くそ～！　餓死する前にどっかの星に降りてバイトでもするしか……",
      "zh": ""
    },
    {
      "key": "39.1",
      "line_index": 39,
      "inline_index": 1,
      "line_hash": "6642b025",
      "speaker": "マロウ",
      "ja": "あれ？　ちょっと見てくださいッス！　あれって……",
      "zh": ""
    },
    {
      "key": "53.0",
      "line_index": 53,
      "inline_index": 0,
      "line_hash": "93de9b05",
      "speaker": "アイディル",
      "ja": "なんだい騒がしいね、あんなでけぇ船襲っても、こっちに勝ち目……ああ、助けを求めるのはアリか",
      "zh": ""
    },
    {
      "key": "55.0",
      "line_index": 55,
      "inline_index": 0,
      "line_hash": "f627d32e",
      "speaker": "マロウ",
      "ja": "そっちじゃなくて、横にいるちっちゃいやつッス！　ちっちゃいやつ！",
      "zh": ""
    },
    {
      "key": "57.0",
      "line_index": 57,
      "inline_index": 0,
      "line_hash": "2a891aaa",
      "speaker": "アイディル",
      "ja": "ちっちゃい……？",
      "zh": ""
    },
    {
      "key": "74.1",
      "line_index": 74,
      "inline_index": 1,
      "line_hash": "a79f5487",
      "speaker": "アイディル",
      "ja": "ああーっ！　あの船って！",
      "zh": ""
    },
    {
      "key": "76.1",
      "line_index": 76,
      "inline_index": 1,
      "line_hash": "c8021973",
      "speaker": "マロウ",
      "ja": "前に会ったムカつくヤツらの船ッス！",
      "zh": ""
    },
    {
      "key": "78.1",
      "line_index": 78,
      "inline_index": 1,
      "line_hash": "390963ad",
      "speaker": "アイディル",
      "ja": "あのド派手な戦艦は知らないけど、あたし達の獲物に手を出すとは！",
      "zh": ""
    },
    {
      "key": "81.1",
      "line_index": 81,
      "inline_index": 1,
      "line_hash": "60070673",
      "speaker": "マロウ",
      "ja": "横取りされる前に横取りするッスよ！",
      "zh": ""
    },
    {
      "key": "83.1",
      "line_index": 83,
      "inline_index": 1,
      "line_hash": "edb3f10e",
      "speaker": "モル",
      "ja": "あれって……襲われてるん……すかね",
      "zh": ""
    },
    {
      "key": "85.1",
      "line_index": 85,
      "inline_index": 1,
      "line_hash": "7ce844cb",
      "speaker": "マロウ",
      "ja": "どー見ても戦艦ッスよ！？　あんなカモ、襲われてるに決まってるッス！",
      "zh": ""
    },
    {
      "key": "87.1",
      "line_index": 87,
      "inline_index": 1,
      "line_hash": "ef024e7e",
      "speaker": "アイディル",
      "ja": "よーし、装備の差なんて今は関係ない！　助けに……もとい、ハイエナしに行くよ！　どーせふざけた見た目なんだから装備も大したことないでしょ！",
      "zh": ""
    },
    {
      "key": "89.1",
      "line_index": 89,
      "inline_index": 1,
      "line_hash": "b7cbf8b",
      "speaker": "モル",
      "ja": "……万が一の、時は……",
      "zh": ""
    },
    {
      "key": "91.1",
      "line_index": 91,
      "inline_index": 1,
      "line_hash": "2e99a0b8",
      "speaker": "マロウ",
      "ja": "遁走一択っスッ！",
      "zh": ""
    },
    {
      "key": "107.1",
      "line_index": 107,
      "inline_index": 1,
      "line_hash": "69be520a",
      "speaker": "アポロ",
      "ja": "……敵襲です！　ただちに迎撃準備を！",
      "zh": ""
    },
    {
      "key": "109.0",
      "line_index": 109,
      "inline_index": 0,
      "line_hash": "8f9566a4",
      "speaker": "{G_PlayerName}",
      "ja": "て……敵襲！？",
      "zh": ""
    },
    {
      "key": "111.1",
      "line_index": 111,
      "inline_index": 1,
      "line_hash": "727254ad",
      "speaker": "ルミナ",
      "ja": "また……！？",
      "zh": ""
    },
    {
      "key": "113.1",
      "line_index": 113,
      "inline_index": 1,
      "line_hash": "95790742",
      "speaker": "アポロ",
      "ja": "次は明確な攻撃の意思があると考えられます。ただちに迎撃準備を！",
      "zh": ""
    },
    {
      "key": "115.1",
      "line_index": 115,
      "inline_index": 1,
      "line_hash": "5066ec7b",
      "speaker": "トーリ",
      "ja": "どのような敵じゃ？",
      "zh": ""
    },
    {
      "key": "117.1",
      "line_index": 117,
      "inline_index": 1,
      "line_hash": "b8b032b1",
      "speaker": "アポロ",
      "ja": "……申し訳ございません。巨大戦艦に阻まれ、まだ正確な外見や規模はわかっていませんが……高速で接近する宇宙船のようです",
      "zh": ""
    },
    {
      "key": "125.1",
      "line_index": 125,
      "inline_index": 1,
      "line_hash": "efb4c841",
      "speaker": "コハル",
      "ja": "トーリの戦艦とは関係ないの！？",
      "zh": ""
    },
    {
      "key": "127.1",
      "line_index": 127,
      "inline_index": 1,
      "line_hash": "5c1b564e",
      "speaker": "トーリ",
      "ja": "し、知らん知らん！　わらわの艦に他の者はおらん！",
      "zh": ""
    },
    {
      "key": "129.1",
      "line_index": 129,
      "inline_index": 1,
      "line_hash": "3b2c782a",
      "speaker": "トーリ",
      "ja": "じゃが……これはチャンスかもしれんの",
      "zh": ""
    },
    {
      "key": "131.0",
      "line_index": 131,
      "inline_index": 0,
      "line_hash": "8f7bf5cb",
      "speaker": "{G_PlayerName}",
      "ja": "チャンス……？",
      "zh": ""
    },
    {
      "key": "133.1",
      "line_index": 133,
      "inline_index": 1,
      "line_hash": "3d20d6dd",
      "speaker": "トーリ",
      "ja": "わらわの船は、戦闘用の装備は数あれど活かした経験は少ない。常々勿体ないと思っておったのじゃ",
      "zh": ""
    },
    {
      "key": "136.1",
      "line_index": 136,
      "inline_index": 1,
      "line_hash": "68d188d3",
      "speaker": "トーリ",
      "ja": "とはいえ万一の備えじゃから、メンテナンスは怠っておらん！　桃姫戦艦の力、とくと見せてやろうではないか！",
      "zh": ""
    },
    {
      "key": "153.1",
      "line_index": 153,
      "inline_index": 1,
      "line_hash": "7bf11be7",
      "speaker": "マロウ",
      "ja": "距離、５０００！　まもなく攻撃射程内ッス！",
      "zh": ""
    },
    {
      "key": "155.1",
      "line_index": 155,
      "inline_index": 1,
      "line_hash": "8d972c32",
      "speaker": "アイディル",
      "ja": "よし、砲撃用……",
      "zh": ""
    },
    {
      "key": "172.1",
      "line_index": 172,
      "inline_index": 1,
      "line_hash": "de925e83",
      "speaker": "アイディル",
      "ja": "いいいいいっ！？",
      "zh": ""
    },
    {
      "key": "187.1",
      "line_index": 187,
      "inline_index": 1,
      "line_hash": "b68e8704",
      "speaker": "コハル",
      "ja": "い、いまのって……？　すっごいぶっとい光線が見えた気がするけど……",
      "zh": ""
    },
    {
      "key": "190.1",
      "line_index": 190,
      "inline_index": 1,
      "line_hash": "96a3dc75",
      "speaker": "トーリ",
      "ja": "桃姫艦隊の兵装の一端じゃ！　まだまだ、迎撃用の装備はごまんとあるぞ！",
      "zh": ""
    },
    {
      "key": "192.1",
      "line_index": 192,
      "inline_index": 1,
      "line_hash": "56c58a12",
      "speaker": "雫",
      "ja": "……というか、遠隔でも操作できるのですね……",
      "zh": ""
    },
    {
      "key": "194.0",
      "line_index": 194,
      "inline_index": 0,
      "line_hash": "af67cde9",
      "speaker": "{G_PlayerName}",
      "ja": "トーリが生まれた時の戦艦なんだろ……？　今の敵に通用するのか？",
      "zh": ""
    },
    {
      "key": "196.1",
      "line_index": 196,
      "inline_index": 1,
      "line_hash": "6d7ec1e5",
      "speaker": "トーリ",
      "ja": "人工知能だって成長するからのう！　定住はせんが、宇宙技術の発達した星の技術をダウンロードもしておるようじゃぞ！",
      "zh": ""
    },
    {
      "key": "198.0",
      "line_index": 198,
      "inline_index": 0,
      "line_hash": "548e14e6",
      "speaker": "{G_PlayerName}",
      "ja": "（ようじゃぞ、ってことは……やっぱりトーリはほとんど操作してないんだな）",
      "zh": ""
    },
    {
      "key": "200.1",
      "line_index": 200,
      "inline_index": 1,
      "line_hash": "8b0f22ef",
      "speaker": "コハル",
      "ja": "敵って何なのかもまだわかってないけど……いいのかしら？",
      "zh": ""
    },
    {
      "key": "202.0",
      "line_index": 202,
      "inline_index": 0,
      "line_hash": "dc22b1c0",
      "speaker": "{G_PlayerName}",
      "ja": "うーん……どうなんだろうな？",
      "zh": ""
    }
  ]
}
