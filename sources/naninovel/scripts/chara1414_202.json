{
  "lines": [
    {
      "key": "20.1",
      "line_index": 20,
      "inline_index": 1,
      "line_hash": "e9e13569",
      "speaker": "ロサナ",
      "ja": "あ……♥　にぃに……♥",
      "zh": ""
    },
    {
      "key": "22.0",
      "line_index": 22,
      "inline_index": 0,
      "line_hash": "abb4471d",
      "speaker": "",
      "ja": "俺を求めるロサナの欲情的な姿に興奮に歯止めが利かない。",
      "zh": ""
    },
    {
      "key": "23.0",
      "line_index": 23,
      "inline_index": 0,
      "line_hash": "2dd91065",
      "speaker": "",
      "ja": "メスを求めるオスの本能よろしく押し倒すと、ロサナの小さなお尻を乱暴気味にぐいっと持ち上げる。",
      "zh": ""
    },
    {
      "key": "25.0",
      "line_index": 25,
      "inline_index": 0,
      "line_hash": "6e8b3f23",
      "speaker": "",
      "ja": "限界以上に勃起している肉棒を膣穴に押し当てるが、僅かに残っていた理性が挿入を阻止してしまう。",
      "zh": ""
    },
    {
      "key": "28.1",
      "line_index": 28,
      "inline_index": 1,
      "line_hash": "98173202",
      "speaker": "ロサナ",
      "ja": "にぃに……？♥　エッチしないの……？♥",
      "zh": ""
    },
    {
      "key": "31.0",
      "line_index": 31,
      "inline_index": 0,
      "line_hash": "21dc3a6b",
      "speaker": "{G_PlayerName}",
      "ja": "今一つになったら俺もう止まれなくなるかもしれない……",
      "zh": ""
    },
    {
      "key": "35.1",
      "line_index": 35,
      "inline_index": 1,
      "line_hash": "81e928b0",
      "speaker": "ロサナ",
      "ja": "にぃに……そんなこと気にしないで……♥　にぃにの好きなようにして欲しい……です♥",
      "zh": ""
    },
    {
      "key": "38.1",
      "line_index": 38,
      "inline_index": 1,
      "line_hash": "42aba93f",
      "speaker": "ロサナ",
      "ja": "にぃににいっぱい愛して欲しい、です……♥",
      "zh": ""
    },
    {
      "key": "40.0",
      "line_index": 40,
      "inline_index": 0,
      "line_hash": "30b32566",
      "speaker": "",
      "ja": "ロサナは頬を真っ赤に染めながら、俺を求めるように潤んだ瞳でじっと見つめてくる。",
      "zh": ""
    },
    {
      "key": "42.0",
      "line_index": 42,
      "inline_index": 0,
      "line_hash": "fdd14414",
      "speaker": "",
      "ja": "ロサナの熱い眼差しにさらに股間に熱が集まり、肉棒がビクンと何度も大きく跳ねてしまう。",
      "zh": ""
    },
    {
      "key": "45.0",
      "line_index": 45,
      "inline_index": 0,
      "line_hash": "30d701c6",
      "speaker": "{G_PlayerName}",
      "ja": "わかった……今日を俺達二人の最高の思い出にしよう",
      "zh": ""
    },
    {
      "key": "49.1",
      "line_index": 49,
      "inline_index": 1,
      "line_hash": "4f5614ea",
      "speaker": "ロサナ",
      "ja": "はい……♥　ロサナたちの特別な聖夜に……♥",
      "zh": ""
    },
    {
      "key": "66.0",
      "line_index": 66,
      "inline_index": 0,
      "line_hash": "b6297c53",
      "speaker": "ロサナ",
      "ja": "んんぅぅっ！♥　は、あ、あっ！♥　にぃにの奥までぇ……あうっ！！♥",
      "zh": ""
    },
    {
      "key": "68.0",
      "line_index": 68,
      "inline_index": 0,
      "line_hash": "7de44238",
      "speaker": "",
      "ja": "俺はロサナの甘えた声に最後の理性が消し飛び、肉棒を膣の中に一気に押し込む。",
      "zh": ""
    },
    {
      "key": "70.0",
      "line_index": 70,
      "inline_index": 0,
      "line_hash": "ef3018c8",
      "speaker": "",
      "ja": "抑えきれない興奮が腰をいきなりピストンさせ、いきなりの刺激にロサナはびっくりしたような声を上げた。",
      "zh": ""
    },
    {
      "key": "73.0",
      "line_index": 73,
      "inline_index": 0,
      "line_hash": "270d51cb",
      "speaker": "ロサナ",
      "ja": "ふぅ、んふぅっ！♥　にぃにのおちんちんっ、気持ち良いぃっ！♥　はぁ、あああぁっ！♥　はう、そ、そこ……んっ！！♥",
      "zh": ""
    },
    {
      "key": "75.0",
      "line_index": 75,
      "inline_index": 0,
      "line_hash": "ccafafd7",
      "speaker": "",
      "ja": "ロサナは快感に悶えながらも腰を動かし、自らの気持ち良いところに肉棒を導く。",
      "zh": ""
    },
    {
      "key": "78.0",
      "line_index": 78,
      "inline_index": 0,
      "line_hash": "ee641a5",
      "speaker": "{G_PlayerName}",
      "ja": "自分から気持ち良い場所に誘導するなんて、今日のロサナは本当にエッチだな",
      "zh": ""
    },
    {
      "key": "82.0",
      "line_index": 82,
      "inline_index": 0,
      "line_hash": "54870042",
      "speaker": "ロサナ",
      "ja": "だってぇ……あうっ！♥　にぃにのおちんちん気持ち良すぎるんだもんっ♥　ふあ、はぁ、あはあぁっ！！♥",
      "zh": ""
    },
    {
      "key": "85.0",
      "line_index": 85,
      "inline_index": 0,
      "line_hash": "c69c984a",
      "speaker": "ロサナ",
      "ja": "気持ち良いところいっぱいぐちゅぐちゅして欲しいって……思っちゃうんだもんっ♥",
      "zh": ""
    },
    {
      "key": "88.0",
      "line_index": 88,
      "inline_index": 0,
      "line_hash": "1a967bb",
      "speaker": "ロサナ",
      "ja": "あひぃぃっ！♥　あう、あっ、あっ！♥　はげしぃっ！！♥　これ、ダメ……あう、おまんこ蕩けちゃうぅっ！！♥",
      "zh": ""
    },
    {
      "key": "90.0",
      "line_index": 90,
      "inline_index": 0,
      "line_hash": "e57acfe8",
      "speaker": "",
      "ja": "ロサナの瞳は完全に欲情し、絶えず甘い悲鳴を口から漏らす。",
      "zh": ""
    },
    {
      "key": "91.0",
      "line_index": 91,
      "inline_index": 0,
      "line_hash": "7ab6e40c",
      "speaker": "",
      "ja": "感じるほどに膣がきゅっと締まり、肉棒が吸い込まれるように引っ張られる。",
      "zh": ""
    },
    {
      "key": "93.0",
      "line_index": 93,
      "inline_index": 0,
      "line_hash": "2a32ecb8",
      "speaker": "",
      "ja": "俺はその吸い付きに逆らうように肉棒を強引に引き抜き、そして一気に腰を叩きつける。",
      "zh": ""
    },
    {
      "key": "94.0",
      "line_index": 94,
      "inline_index": 0,
      "line_hash": "97ea4b9",
      "speaker": "",
      "ja": "ぐちゅっと卑猥な水音と共にロサナの喘ぎがさらに大きくなり、とろとろの柔膣が肉棒を包み込んでいく。",
      "zh": ""
    },
    {
      "key": "97.0",
      "line_index": 97,
      "inline_index": 0,
      "line_hash": "eae569b7",
      "speaker": "ロサナ",
      "ja": "はげしいの、好きぃっ！♥　にぃに、もっと……パンパンしてぇ……♥　おまんこ掻き回してぇ……♥",
      "zh": ""
    },
    {
      "key": "100.0",
      "line_index": 100,
      "inline_index": 0,
      "line_hash": "3c78a7d8",
      "speaker": "ロサナ",
      "ja": "にぃにっ！♥　いい、いいのっ！♥　今日のにぃに、今までで一番素敵だよぉっ！♥　愛されているってすごく実感できちゃうよぉっ！！♥",
      "zh": ""
    },
    {
      "key": "103.0",
      "line_index": 103,
      "inline_index": 0,
      "line_hash": "b3eabb2f",
      "speaker": "{G_PlayerName}",
      "ja": "今日のロサナも最高にいいぞ……いつもよりも全然可愛くてエロくて……どこまでもロサナが欲しくなってしまう……！！",
      "zh": ""
    },
    {
      "key": "107.0",
      "line_index": 107,
      "inline_index": 0,
      "line_hash": "943eee03",
      "speaker": "ロサナ",
      "ja": "あうううっ！♥　ほ、欲しがってくださいぃっ！♥　ロサナのすべてを奪ってくださいぃっ！♥　身も心もにぃにのモノになりたいのっ♥",
      "zh": ""
    },
    {
      "key": "110.0",
      "line_index": 110,
      "inline_index": 0,
      "line_hash": "e6befed9",
      "speaker": "ロサナ",
      "ja": "ふあ、ふあああっ！！♥　そんなにおまんこの奥にちゅーしちゃダメぇっ♥　んっ、んあああぁぁっ！！♥",
      "zh": ""
    },
    {
      "key": "112.0",
      "line_index": 112,
      "inline_index": 0,
      "line_hash": "6d550a81",
      "speaker": "",
      "ja": "膣奥を突くたびにロサナの声は淫らになり、膣がぢゅるぢゅると肉棒を吸い上げる。",
      "zh": ""
    },
    {
      "key": "114.0",
      "line_index": 114,
      "inline_index": 0,
      "line_hash": "6e0ed1ae",
      "speaker": "",
      "ja": "ただでさえ狭い膣が肉棒にフィットし、腰をピストンさせるたびに強烈な快感が肉棒から全身へと流れる。",
      "zh": ""
    },
    {
      "key": "116.0",
      "line_index": 116,
      "inline_index": 0,
      "line_hash": "e0d7a73",
      "speaker": "",
      "ja": "狭い膣でビクンビクンと肉棒が何度も跳ね、射精感がどんどん強くなる。",
      "zh": ""
    },
    {
      "key": "117.0",
      "line_index": 117,
      "inline_index": 0,
      "line_hash": "1af5eca1",
      "speaker": "",
      "ja": "それでも俺は腰の動きを止めず、パンパンパンと肌のぶつかり合う音が部屋中に響き渡った。",
      "zh": ""
    },
    {
      "key": "120.0",
      "line_index": 120,
      "inline_index": 0,
      "line_hash": "204fc50c",
      "speaker": "ロサナ",
      "ja": "おまんこ気持ち良いっ！♥　気持ち良いの、止まらないぃっ！♥　あっ、はぁ、あぁんっ！！♥",
      "zh": ""
    },
    {
      "key": "123.0",
      "line_index": 123,
      "inline_index": 0,
      "line_hash": "fc7b3e86",
      "speaker": "{G_PlayerName}",
      "ja": "くう、締まりが……！！　うう、ダメだ、もう……！！",
      "zh": ""
    },
    {
      "key": "127.0",
      "line_index": 127,
      "inline_index": 0,
      "line_hash": "ed618a7b",
      "speaker": "ロサナ",
      "ja": "あひいぃっ！？♥　あっ、あっ！♥　んぅ、んふぅっ！♥　ふあ、はああぁっ！！♥",
      "zh": ""
    },
    {
      "key": "130.0",
      "line_index": 130,
      "inline_index": 0,
      "line_hash": "f203523f",
      "speaker": "ロサナ",
      "ja": "んあああっ！♥　も、もうっ♥　イっ、イっちゃ……♥　あ、あっ！♥　あはぁぁっ！！♥",
      "zh": ""
    },
    {
      "key": "133.0",
      "line_index": 133,
      "inline_index": 0,
      "line_hash": "62e20a68",
      "speaker": "ロサナ",
      "ja": "イクっ……イクっ！♥　おまんこっ、イっちゃうぅぅぅぅ～～～っ！！♥♥",
      "zh": ""
    },
    {
      "key": "142.0",
      "line_index": 142,
      "inline_index": 0,
      "line_hash": "15a195d9",
      "speaker": "ロサナ",
      "ja": "んんぅぅぅっ！！♥　ふあ、はあ、あああぁぁぁぁんっ！！♥♥",
      "zh": ""
    },
    {
      "key": "144.0",
      "line_index": 144,
      "inline_index": 0,
      "line_hash": "364fae0d",
      "speaker": "",
      "ja": "ロサナが絶頂した瞬間、俺は肉棒を乱暴に引き抜くとロサナの白い肌に精液をぶっかける。",
      "zh": ""
    },
    {
      "key": "146.0",
      "line_index": 146,
      "inline_index": 0,
      "line_hash": "ed548e5c",
      "speaker": "",
      "ja": "肉棒を扱きながら何度も射精を繰り返し、下腹部から割れ目、アナルを汚すように精液を扱き出し続けた。",
      "zh": ""
    },
    {
      "key": "149.0",
      "line_index": 149,
      "inline_index": 0,
      "line_hash": "2fc255e8",
      "speaker": "ロサナ",
      "ja": "あうう……♥　は、はぁぁ……にぃにの精液、あったかいぃ……♥　あはぁぁ……♥",
      "zh": ""
    },
    {
      "key": "152.0",
      "line_index": 152,
      "inline_index": 0,
      "line_hash": "c353c35d",
      "speaker": "ロサナ",
      "ja": "また私でいっぱい感じてくれてるぅ……♥　嬉しいよぉ……はぁぁ……♥　あふぅぅ……♥",
      "zh": ""
    },
    {
      "key": "154.0",
      "line_index": 154,
      "inline_index": 0,
      "line_hash": "875336fb",
      "speaker": "",
      "ja": "ロサナの表情が甘く蕩け、俺が射精をするたびに幸せそうな声を上げる。",
      "zh": ""
    },
    {
      "key": "156.0",
      "line_index": 156,
      "inline_index": 0,
      "line_hash": "918aa159",
      "speaker": "",
      "ja": "肌に刷り込むように下腹部の精液を指でくちゅくちゅと捏ねる。",
      "zh": ""
    },
    {
      "key": "157.0",
      "line_index": 157,
      "inline_index": 0,
      "line_hash": "dc964cdc",
      "speaker": "",
      "ja": "その光景に俺の肉棒に再び血が集まり、射精直後だというのにバキバキと硬くなってしまう。",
      "zh": ""
    },
    {
      "key": "160.0",
      "line_index": 160,
      "inline_index": 0,
      "line_hash": "79ee663c",
      "speaker": "ロサナ",
      "ja": "にぃに……次はロサナの中にちょうだい……♥",
      "zh": ""
    },
    {
      "key": "162.0",
      "line_index": 162,
      "inline_index": 0,
      "line_hash": "6f8b6202",
      "speaker": "",
      "ja": "ロサナはおねだりするように甘えた声をあげる。",
      "zh": ""
    },
    {
      "key": "163.0",
      "line_index": 163,
      "inline_index": 0,
      "line_hash": "7d421638",
      "speaker": "",
      "ja": "精液まみれの指を自らのあそこにねじ込み、ぐちゅぐちゅと音が聞こえるほどあそこを掻き回す。",
      "zh": ""
    },
    {
      "key": "166.0",
      "line_index": 166,
      "inline_index": 0,
      "line_hash": "e3cb985f",
      "speaker": "ロサナ",
      "ja": "にぃにから聖夜の特別なプレゼントが欲しいの……♥　赤ちゃんが欲しいの……♥　お願い、にぃに……♥",
      "zh": ""
    },
    {
      "key": "169.0",
      "line_index": 169,
      "inline_index": 0,
      "line_hash": "60de5ea9",
      "speaker": "{G_PlayerName}",
      "ja": "……わかった、次は子宮に出すから……ロサナを絶対孕ませるから",
      "zh": ""
    },
    {
      "key": "173.0",
      "line_index": 173,
      "inline_index": 0,
      "line_hash": "dc3749c7",
      "speaker": "ロサナ",
      "ja": "うん……ありがとう♥　来て、にぃに……ロサナのエッチなおまんこでまたおちんちん気持ち良くなって……♥",
      "zh": ""
    },
    {
      "key": "181.0",
      "line_index": 181,
      "inline_index": 0,
      "line_hash": "2fa52add",
      "speaker": "ロサナ",
      "ja": "あううううっ！♥　あっ、あはぁっ！♥　にぃにのおちんちんっ、またきたぁっ！♥　あはぁ、はぁぁんっ！！♥",
      "zh": ""
    },
    {
      "key": "183.0",
      "line_index": 183,
      "inline_index": 0,
      "line_hash": "c40795fe",
      "speaker": "",
      "ja": "俺は再び膣に肉棒を押し込むと、小刻みなピストンで膣奥を突く。",
      "zh": ""
    },
    {
      "key": "184.0",
      "line_index": 184,
      "inline_index": 0,
      "line_hash": "d2e5542d",
      "speaker": "",
      "ja": "ロサナの甲高い声が口から漏れ、膣奥を突くたびに腰をビクンと大きく跳ねらせる。",
      "zh": ""
    },
    {
      "key": "186.0",
      "line_index": 186,
      "inline_index": 0,
      "line_hash": "a964552a",
      "speaker": "",
      "ja": "膣奥からどぷりと大量の愛液が溢れ、掻き出されるようにどろっと結合部から垂れ落ちた。",
      "zh": ""
    },
    {
      "key": "189.0",
      "line_index": 189,
      "inline_index": 0,
      "line_hash": "ac4251dd",
      "speaker": "ロサナ",
      "ja": "にぃにの……あうっ！♥　さっきよりも硬くて、熱くてぇ……！♥　気持ち良いのっ！♥　はぁ、あぁぁん！！♥",
      "zh": ""
    },
    {
      "key": "192.0",
      "line_index": 192,
      "inline_index": 0,
      "line_hash": "50f6fce9",
      "speaker": "ロサナ",
      "ja": "にぃに、もっと、もっとロサナのおまんこ掻き回してぇっ！♥　おまんこっ、犯してぇっ……あうっ、は、はっ！♥　はあぁぁぁっ！！♥",
      "zh": ""
    },
    {
      "key": "194.0",
      "line_index": 194,
      "inline_index": 0,
      "line_hash": "886cfa38",
      "speaker": "",
      "ja": "ロサナは強烈な快感から逃げるように腰を捩らせ悶え喘ぐ。",
      "zh": ""
    },
    {
      "key": "195.0",
      "line_index": 195,
      "inline_index": 0,
      "line_hash": "b59c5943",
      "speaker": "",
      "ja": "俺はロサナのお尻をがっちりつかみ固定すると、執拗なまでに膣奥を突き上げる。",
      "zh": ""
    },
    {
      "key": "197.0",
      "line_index": 197,
      "inline_index": 0,
      "line_hash": "3beadb8d",
      "speaker": "",
      "ja": "俺のピストンにロサナの淫らな声がさらに大きくなる。",
      "zh": ""
    },
    {
      "key": "199.0",
      "line_index": 199,
      "inline_index": 0,
      "line_hash": "95a01e71",
      "speaker": "",
      "ja": "まるで交尾のような動物的なセックス。",
      "zh": ""
    },
    {
      "key": "200.0",
      "line_index": 200,
      "inline_index": 0,
      "line_hash": "b8653e7d",
      "speaker": "",
      "ja": "それが俺達をより興奮させ、快感に溺れるかのように声をあげながら快感を貪り合う。",
      "zh": ""
    },
    {
      "key": "203.0",
      "line_index": 203,
      "inline_index": 0,
      "line_hash": "40b9034e",
      "speaker": "ロサナ",
      "ja": "あふぅ、ふぅっ！♥　んぃっ！♥　子宮がっ……あうっ！♥　にぃにの精液欲しさに……降りてきちゃってるぅっ！！♥",
      "zh": ""
    },
    {
      "key": "206.0",
      "line_index": 206,
      "inline_index": 0,
      "line_hash": "d9fae9f4",
      "speaker": "ロサナ",
      "ja": "にぃにの……んはぁっ！♥　子供欲しいって……きゅんきゅんしてるのぉっ！♥　うう、ううううっ！！♥",
      "zh": ""
    },
    {
      "key": "209.0",
      "line_index": 209,
      "inline_index": 0,
      "line_hash": "e7b11a3e",
      "speaker": "ロサナ",
      "ja": "ダメダメダメぇっ！♥　気持ち良すぎておまんこヘンになるぅっ！！♥　気持ち良いの、止まらないよぉっ！！♥",
      "zh": ""
    },
    {
      "key": "211.0",
      "line_index": 211,
      "inline_index": 0,
      "line_hash": "c03be707",
      "speaker": "",
      "ja": "ロサナの子宮口が肉棒の先端に吸い付き、吸い込まれるように引っ張られる。",
      "zh": ""
    },
    {
      "key": "212.0",
      "line_index": 212,
      "inline_index": 0,
      "line_hash": "78fa7128",
      "speaker": "",
      "ja": "俺は強引に肉棒を引き抜き、そして子宮口を執拗に先端で押しつぶす。",
      "zh": ""
    },
    {
      "key": "214.0",
      "line_index": 214,
      "inline_index": 0,
      "line_hash": "5c365610",
      "speaker": "",
      "ja": "ぢゅぶりと粘り気の強い卑猥な水音がさらに大きくなり、濡れた膣全体で肉棒を扱く快感がすごく気持ちがいい。",
      "zh": ""
    },
    {
      "key": "216.0",
      "line_index": 216,
      "inline_index": 0,
      "line_hash": "2d8c246a",
      "speaker": "",
      "ja": "俺は夢中になるように腰を乱雑に振り乱し、オスの本懐を果たそうとロサナの膣を蹂躙し続けた。",
      "zh": ""
    },
    {
      "key": "219.0",
      "line_index": 219,
      "inline_index": 0,
      "line_hash": "c108a88a",
      "speaker": "ロサナ",
      "ja": "んは、あっ！♥　にぃに、私っ、もう……！♥　ふう、んぅ、んんんんんっ！！♥",
      "zh": ""
    },
    {
      "key": "222.0",
      "line_index": 222,
      "inline_index": 0,
      "line_hash": "33d54e33",
      "speaker": "{G_PlayerName}",
      "ja": "ああ、俺もすぐだから……！",
      "zh": ""
    },
    {
      "key": "226.0",
      "line_index": 226,
      "inline_index": 0,
      "line_hash": "130fa2d",
      "speaker": "ロサナ",
      "ja": "あうっ！♥　ふあ、は、あああっ！！♥　にぃに、にぃにっ！♥　あ、あ……イ、イっちゃ……あうっ！！♥",
      "zh": ""
    },
    {
      "key": "228.0",
      "line_index": 228,
      "inline_index": 0,
      "line_hash": "568fcd2f",
      "speaker": "",
      "ja": "ロサナの膣がさらに怪しく蠢き、肉棒に吸い付く。",
      "zh": ""
    },
    {
      "key": "229.0",
      "line_index": 229,
      "inline_index": 0,
      "line_hash": "bd52eeb4",
      "speaker": "",
      "ja": "膣がさらに愛液で溢れ、とろとろの膣で何度も締め付けられ、俺にも限界が近づいて来るのを感じる。",
      "zh": ""
    },
    {
      "key": "232.0",
      "line_index": 232,
      "inline_index": 0,
      "line_hash": "b969454e",
      "speaker": "ロサナ",
      "ja": "にぃにっ！♥　イっちゃう、イっちゃう！♥　おまんこまたイクっ！♥　ふあ、あああぁっ！！♥",
      "zh": ""
    },
    {
      "key": "235.0",
      "line_index": 235,
      "inline_index": 0,
      "line_hash": "599714c3",
      "speaker": "ロサナ",
      "ja": "中に出してぇええっ！！♥　にぃにのエッチなプレゼントくださいぃ～～～～っ！！♥♥",
      "zh": ""
    },
    {
      "key": "245.0",
      "line_index": 245,
      "inline_index": 0,
      "line_hash": "695e05cc",
      "speaker": "ロサナ",
      "ja": "んああぁっ！♥　んぅ、んは、はあぁぁ……♥　あはぁぁ、ああああぁぁぁ～～っ！！♥♥",
      "zh": ""
    },
    {
      "key": "247.0",
      "line_index": 247,
      "inline_index": 0,
      "line_hash": "4f5c50d6",
      "speaker": "",
      "ja": "絶頂に達したロサナの膣がぎゅっと締まり、子宮口が肉棒に先端に吸い付く。",
      "zh": ""
    },
    {
      "key": "249.0",
      "line_index": 249,
      "inline_index": 0,
      "line_hash": "33d4d7bd",
      "speaker": "",
      "ja": "俺は搾り取られるように射精し、熱いモノがロサナの子宮目掛け陰茎を何度も駆け上がってくる。",
      "zh": ""
    },
    {
      "key": "252.0",
      "line_index": 252,
      "inline_index": 0,
      "line_hash": "30cdedeb",
      "speaker": "ロサナ",
      "ja": "うあ、あああ……にぃにのせーえきぃ……♥　子種っ、いっぱいですぅ……！♥",
      "zh": ""
    },
    {
      "key": "255.0",
      "line_index": 255,
      "inline_index": 0,
      "line_hash": "1692e1d",
      "speaker": "ロサナ",
      "ja": "もっとぉ……もっとびゅるるしてくださいぃぃ……♥　ふああ、あああぁぁ～～っ！！♥　熱いの……子宮に溜まっていくぅ……あはぁ～っ！♥",
      "zh": ""
    },
    {
      "key": "257.0",
      "line_index": 257,
      "inline_index": 0,
      "line_hash": "7030fd8c",
      "speaker": "",
      "ja": "ロサナはすっかりと快楽に溺れ、絶頂に身体を震わせながら精液のおねだりを繰り返す。",
      "zh": ""
    },
    {
      "key": "259.0",
      "line_index": 259,
      "inline_index": 0,
      "line_hash": "e85ca347",
      "speaker": "",
      "ja": "しかし溺れるのは俺も同じで、オスの欲望をロサナで満たそうと腰を小刻みに振る。",
      "zh": ""
    },
    {
      "key": "260.0",
      "line_index": 260,
      "inline_index": 0,
      "line_hash": "24ae34c5",
      "speaker": "",
      "ja": "目の前がチカチカとするほど射精を繰り返し、快感に次ぐ快感に両脚がガクガクと震えてしまっていた。",
      "zh": ""
    },
    {
      "key": "263.0",
      "line_index": 263,
      "inline_index": 0,
      "line_hash": "3cb7318",
      "speaker": "ロサナ",
      "ja": "んは、はぁぁ……！♥　ああぁぁ、おまんこイキっぱなしぃ……♥　気持ち良くってぇ……しあわせぇ……はぁぁぁん♥",
      "zh": ""
    },
    {
      "key": "270.0",
      "line_index": 270,
      "inline_index": 0,
      "line_hash": "b281cdac",
      "speaker": "ロサナ",
      "ja": "あ……♥　今子宮トクンってぇ……ふぅ、ふぅ……♥　にぃにとの赤ちゃん、今デキちゃった……♥",
      "zh": ""
    },
    {
      "key": "273.0",
      "line_index": 273,
      "inline_index": 0,
      "line_hash": "c72be404",
      "speaker": "ロサナ",
      "ja": "えへへ……♥　嬉しい、嬉しいですぅ……♥　にぃにに素敵なプレゼントもらっちゃいましたぁ……♥",
      "zh": ""
    },
    {
      "key": "276.0",
      "line_index": 276,
      "inline_index": 0,
      "line_hash": "f31c7ef5",
      "speaker": "{G_PlayerName}",
      "ja": "それは俺も同じだって……ありがとう、俺との子供を望んでくれて……最高のプレゼントだよ",
      "zh": ""
    },
    {
      "key": "280.0",
      "line_index": 280,
      "inline_index": 0,
      "line_hash": "78216833",
      "speaker": "ロサナ",
      "ja": "にぃに、大好き……♥　エッチ、すごく気持ち良かったよ……♥",
      "zh": ""
    },
    {
      "key": "282.0",
      "line_index": 282,
      "inline_index": 0,
      "line_hash": "febb0d20",
      "speaker": "",
      "ja": "激しいセックスと絶頂のロサナの息は絶え絶え。",
      "zh": ""
    },
    {
      "key": "283.0",
      "line_index": 283,
      "inline_index": 0,
      "line_hash": "83db8331",
      "speaker": "",
      "ja": "それでも嬉しそうに下腹部を撫で幸せそうな笑みを見せてくる。",
      "zh": ""
    },
    {
      "key": "286.0",
      "line_index": 286,
      "inline_index": 0,
      "line_hash": "f9a43951",
      "speaker": "{G_PlayerName}",
      "ja": "俺も大好きだ、ロサナ……今日はずっとエッチしていような",
      "zh": ""
    },
    {
      "key": "290.0",
      "line_index": 290,
      "inline_index": 0,
      "line_hash": "b877b9b2",
      "speaker": "ロサナ",
      "ja": "うん……♥　でも次はゆっくりエッチして……♥　激しいのも好きだけど、にぃにの優しいエッチも大好きだから……♥",
      "zh": ""
    },
    {
      "key": "292.0",
      "line_index": 292,
      "inline_index": 0,
      "line_hash": "e9f986ca",
      "speaker": "",
      "ja": "ロサナの笑顔に俺の心が幸せで満ちていく。",
      "zh": ""
    },
    {
      "key": "293.0",
      "line_index": 293,
      "inline_index": 0,
      "line_hash": "f12df469",
      "speaker": "",
      "ja": "俺達はお互いの幸せを分け合うように身体を求め合い、一緒のベッドで夜を明かすのであった。",
      "zh": ""
    }
  ]
}
