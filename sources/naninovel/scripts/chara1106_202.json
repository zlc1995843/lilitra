    {
      "key": "254.0",
      "line_index": 254,
      "inline_index": 0,
      "line_hash": "a862ce8d",
      "speaker": "リズ",
      "ja": "あぉおお～～！？♥　しゅごっ♥　さっきとちがっ……！♥　あきゅううっ！？♥",
