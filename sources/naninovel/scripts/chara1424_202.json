{
  "lines": [
    {
      "key": "18.1",
      "line_index": 18,
      "inline_index": 1,
      "line_hash": "cff146ab",
      "speaker": "ポラリス",
      "ja": "お兄様……わたし、お兄様の……欲しくなってきました……♥",
      "zh": ""
    },
    {
      "key": "20.0",
      "line_index": 20,
      "inline_index": 0,
      "line_hash": "d2cb6000",
      "speaker": "",
      "ja": "{G_PlayerName}のおちんちんを舐め精液を味わったことで発情してしまったポラリスは、甘い声で求めてくる。",
      "zh": ""
    },
    {
      "key": "22.0",
      "line_index": 22,
      "inline_index": 0,
      "line_hash": "f08f51bd",
      "speaker": "",
      "ja": "その言葉に{G_PlayerName}はドキッとしてしまい二回も射精した陰茎が、また硬く大きくなっていった。",
      "zh": ""
    },
    {
      "key": "25.1",
      "line_index": 25,
      "inline_index": 1,
      "line_hash": "34b2459e",
      "speaker": "ポラリス",
      "ja": "お兄様……♥　今度はそのおちんちんで……♥　わたしのおまんこを突いてください♥",
      "zh": ""
    },
    {
      "key": "28.0",
      "line_index": 28,
      "inline_index": 0,
      "line_hash": "2f476b47",
      "speaker": "{G_PlayerName}",
      "ja": "ポラリス……",
      "zh": ""
    },
    {
      "key": "31.0",
      "line_index": 31,
      "inline_index": 0,
      "line_hash": "5392dd27",
      "speaker": "",
      "ja": "また勃起してきたおちんちんを見て更に興奮が高まったポラリスが淫らな言葉で求めると、{G_PlayerName}は我慢できなくなってしまい彼女をベッドに押し倒すが、そこで動きが止まる。",
      "zh": ""
    },
    {
      "key": "34.1",
      "line_index": 34,
      "inline_index": 1,
      "line_hash": "1636e3ad",
      "speaker": "ポラリス",
      "ja": "お兄様……？",
      "zh": ""
    },
    {
      "key": "37.0",
      "line_index": 37,
      "inline_index": 0,
      "line_hash": "76f9f553",
      "speaker": "{G_PlayerName}",
      "ja": "……",
      "zh": ""
    },
    {
      "key": "40.0",
      "line_index": 40,
      "inline_index": 0,
      "line_hash": "82cf5",
      "speaker": "",
      "ja": "一線を越えてしまうことに抵抗感があった{G_PlayerName}はポラリスを押し倒したまま黙り込んでしまっていた。",
      "zh": ""
    },
    {
      "key": "43.1",
      "line_index": 43,
      "inline_index": 1,
      "line_hash": "a589498",
      "speaker": "ポラリス",
      "ja": "（あっ……やっぱり、わたしじゃ代わりにもなれないのかな……。）",
      "zh": ""
    },
    {
      "key": "45.0",
      "line_index": 45,
      "inline_index": 0,
      "line_hash": "16965912",
      "speaker": "",
      "ja": "止まったままの{G_PlayerName}を見てポラリスは切ない気持ちになってしまう。",
      "zh": ""
    },
    {
      "key": "47.0",
      "line_index": 47,
      "inline_index": 0,
      "line_hash": "f5d17a63",
      "speaker": "",
      "ja": "しかし次の瞬間、{G_PlayerName}は真面目な顔でポラリスに囁きかけた。",
      "zh": ""
    },
    {
      "key": "50.0",
      "line_index": 50,
      "inline_index": 0,
      "line_hash": "7feed907",
      "speaker": "{G_PlayerName}",
      "ja": "ポラリス、俺……お前のこと……",
      "zh": ""
    },
    {
      "key": "53.0",
      "line_index": 53,
      "inline_index": 0,
      "line_hash": "d56d488d",
      "speaker": "",
      "ja": "何かを匂わせるような台詞を口にすると{G_PlayerName}は勃起した陰茎を割れ目へと押し当てていく。",
      "zh": ""
    },
    {
      "key": "68.0",
      "line_index": 68,
      "inline_index": 0,
      "line_hash": "e770457d",
      "speaker": "ポラリス",
      "ja": "お兄様……？♥",
      "zh": ""
    },
    {
      "key": "70.0",
      "line_index": 70,
      "inline_index": 0,
      "line_hash": "5a8e5470",
      "speaker": "",
      "ja": "{G_PlayerName}の意味深な言葉に緊張しつつも割れ目に擦り付けられる硬い陰茎の感触にドキドキしながらポラリスは次の言葉を待っていた。",
      "zh": ""
    },
    {
      "key": "73.0",
      "line_index": 73,
      "inline_index": 0,
      "line_hash": "656463dd",
      "speaker": "{G_PlayerName}",
      "ja": "いや……なんでもない……気持ちよくなろうな",
      "zh": ""
    },
    {
      "key": "76.0",
      "line_index": 76,
      "inline_index": 0,
      "line_hash": "b0e9b451",
      "speaker": "",
      "ja": "{G_PlayerName}は気恥ずかしさからか、ついつい言葉を濁しつつ割れ目をなぞるように亀頭を上下させていく。",
      "zh": ""
    },
    {
      "key": "79.0",
      "line_index": 79,
      "inline_index": 0,
      "line_hash": "7661961f",
      "speaker": "ポラリス",
      "ja": "ああっ♥　お兄様……♥",
      "zh": ""
    },
    {
      "key": "82.0",
      "line_index": 82,
      "inline_index": 0,
      "line_hash": "b51478cf",
      "speaker": "ポラリス",
      "ja": "（お兄様、今なに言ってくれようとしてたのかな……？　ひょっとしてお兄様もわたしのこと……。）",
      "zh": ""
    },
    {
      "key": "84.0",
      "line_index": 84,
      "inline_index": 0,
      "line_hash": "5c9cc206",
      "speaker": "",
      "ja": "濡れたおまんこを刺激され興奮が高まったポラリスは、そんな期待を抱きながら気持ちよさに身を委ねた。",
      "zh": ""
    },
    {
      "key": "86.0",
      "line_index": 86,
      "inline_index": 0,
      "line_hash": "2ede7a5",
      "speaker": "",
      "ja": "そんなポラリスに{G_PlayerName}は割れ目に擦り付けていたおちんちんを濡れた膣内へと挿入していく。",
      "zh": ""
    },
    {
      "key": "95.0",
      "line_index": 95,
      "inline_index": 0,
      "line_hash": "890ced",
      "speaker": "ポラリス",
      "ja": "あっ♥　ああっ♥　くるっ……お兄様が……わたしの中に……♥　んっ、んんんんっ♥",
      "zh": ""
    },
    {
      "key": "97.0",
      "line_index": 97,
      "inline_index": 0,
      "line_hash": "dc6fac62",
      "speaker": "",
      "ja": "ずぶずぶと肉ヒダをめくりながら陰茎が入り込んでいくと、ポラリスは気持ちよさそうな声を上げた。",
      "zh": ""
    },
    {
      "key": "99.0",
      "line_index": 99,
      "inline_index": 0,
      "line_hash": "a0f78958",
      "speaker": "",
      "ja": "そのまま{G_PlayerName}が奥までおちんちんを挿入するとポラリスの膣が強く吸いついてくる。",
      "zh": ""
    },
    {
      "key": "102.0",
      "line_index": 102,
      "inline_index": 0,
      "line_hash": "2e81f5c6",
      "speaker": "{G_PlayerName}",
      "ja": "くっ……せ、狭くて……締め付けが……あっ……ああっ……",
      "zh": ""
    },
    {
      "key": "105.0",
      "line_index": 105,
      "inline_index": 0,
      "line_hash": "34ee1d04",
      "speaker": "",
      "ja": "あまりの快感に{G_PlayerName}が気持ちよさそうな声を漏らすと、ポラリスも表情を蕩けさせながら甘い声で呟いた。",
      "zh": ""
    },
    {
      "key": "108.0",
      "line_index": 108,
      "inline_index": 0,
      "line_hash": "36762f59",
      "speaker": "ポラリス",
      "ja": "あっ♥　あぁっ♥　お兄様のおちんちん、気持ちいい……♥",
      "zh": ""
    },
    {
      "key": "111.0",
      "line_index": 111,
      "inline_index": 0,
      "line_hash": "d6c8de71",
      "speaker": "{G_PlayerName}",
      "ja": "お、俺も……すごく気持ちいいよ……あっ……ううっ……",
      "zh": ""
    },
    {
      "key": "114.0",
      "line_index": 114,
      "inline_index": 0,
      "line_hash": "900fae67",
      "speaker": "",
      "ja": "{G_PlayerName}は快感にすぐさま腰を前後に振りポラリスのおまんこを深々と貫いていく。",
      "zh": ""
    },
    {
      "key": "116.0",
      "line_index": 116,
      "inline_index": 0,
      "line_hash": "4722f530",
      "speaker": "",
      "ja": "その抽送にポラリスは可愛らしい声で喘ぎ始めた。",
      "zh": ""
    },
    {
      "key": "119.0",
      "line_index": 119,
      "inline_index": 0,
      "line_hash": "bf034d07",
      "speaker": "ポラリス",
      "ja": "あんっ♥　あんっ♥　お、お兄様っ♥　んんんっ♥　そんな……ずんずんされると……あふっ♥　はあぁんっ♥",
      "zh": ""
    },
    {
      "key": "121.0",
      "line_index": 121,
      "inline_index": 0,
      "line_hash": "53db4af7",
      "speaker": "",
      "ja": "二度の潮吹きですっかり蕩けきったおまんこは、肉竿をくいくいと締め付けながら波打つように蠢いている。",
      "zh": ""
    },
    {
      "key": "123.0",
      "line_index": 123,
      "inline_index": 0,
      "line_hash": "bb7cd8e0",
      "speaker": "",
      "ja": "その締め付けに{G_PlayerName}は快感を覚え激しく興奮してしまった。",
      "zh": ""
    },
    {
      "key": "126.0",
      "line_index": 126,
      "inline_index": 0,
      "line_hash": "d628aa87",
      "speaker": "{G_PlayerName}",
      "ja": "す、すごい……こ、こんな……うっ……うぅぅっ……",
      "zh": ""
    },
    {
      "key": "129.0",
      "line_index": 129,
      "inline_index": 0,
      "line_hash": "e81f9c63",
      "speaker": "",
      "ja": "あまりの心地よさに{G_PlayerName}はピストンを繰り返し、濡れた柔ヒダが擦れる感覚を味わっていく。",
      "zh": ""
    },
    {
      "key": "131.0",
      "line_index": 131,
      "inline_index": 0,
      "line_hash": "8ef7d01",
      "speaker": "",
      "ja": "ポラリスも膣奥を強く叩かれる衝撃にどんどん気持ちが高ぶっていった。",
      "zh": ""
    },
    {
      "key": "134.0",
      "line_index": 134,
      "inline_index": 0,
      "line_hash": "729807",
      "speaker": "ポラリス",
      "ja": "お、お兄様っ……も、もっと激しく突いて……大丈夫ですよ？♥",
      "zh": ""
    },
    {
      "key": "137.0",
      "line_index": 137,
      "inline_index": 0,
      "line_hash": "10153672",
      "speaker": "{G_PlayerName}",
      "ja": "本当か？　無理とか……していないか？",
      "zh": ""
    },
    {
      "key": "141.0",
      "line_index": 141,
      "inline_index": 0,
      "line_hash": "80ffa9c",
      "speaker": "ポラリス",
      "ja": "ああ……お兄様……わたしのことをそんなに気づかってくれるなんて……♥",
      "zh": ""
    },
    {
      "key": "144.0",
      "line_index": 144,
      "inline_index": 0,
      "line_hash": "3f02db93",
      "speaker": "ポラリス",
      "ja": "（だめ、立場なんか忘れて、もっと好きになっちゃう……♥）",
      "zh": ""
    },
    {
      "key": "146.0",
      "line_index": 146,
      "inline_index": 0,
      "line_hash": "36ffaad1",
      "speaker": "",
      "ja": "{G_PlayerName}に対する気持ちが大きくなる程、こうして愛されていることにポラリスは興奮していく。",
      "zh": ""
    },
    {
      "key": "148.0",
      "line_index": 148,
      "inline_index": 0,
      "line_hash": "c02198a3",
      "speaker": "",
      "ja": "すでに濡れきっている膣は更に熱くなって、ねっとりとした汁をどんどん溢れさせた。",
      "zh": ""
    },
    {
      "key": "151.0",
      "line_index": 151,
      "inline_index": 0,
      "line_hash": "849922ed",
      "speaker": "{G_PlayerName}",
      "ja": "おまんこの中が、どんどんぐちょぐちょになってきてる……はぁ……はぁ……",
      "zh": ""
    },
    {
      "key": "155.0",
      "line_index": 155,
      "inline_index": 0,
      "line_hash": "75372fbe",
      "speaker": "ポラリス",
      "ja": "だ、だって……お兄様のおちんちんが……奥まで届いて……♥　んっ♥　んんっ♥　ぐりぐりされるの気持ちいいんですぅ♥",
      "zh": ""
    },
    {
      "key": "157.0",
      "line_index": 157,
      "inline_index": 0,
      "line_hash": "f2630fed",
      "speaker": "",
      "ja": "甘えるような感じでそう言いながらポラリスは体を小刻みに震わせる。",
      "zh": ""
    },
    {
      "key": "159.0",
      "line_index": 159,
      "inline_index": 0,
      "line_hash": "74ceb7cc",
      "speaker": "",
      "ja": "その動きに合わせるように陰茎を咥え込んだ濡れた膣もびゅくびゅくと蠢いてきた。",
      "zh": ""
    },
    {
      "key": "162.0",
      "line_index": 162,
      "inline_index": 0,
      "line_hash": "5f4d073",
      "speaker": "{G_PlayerName}",
      "ja": "俺も……ポラリスのおまんこ……すごく狭くて……強く吸いついてくるから……気持ちいいよ……",
      "zh": ""
    },
    {
      "key": "166.0",
      "line_index": 166,
      "inline_index": 0,
      "line_hash": "4f3814ff",
      "speaker": "ポラリス",
      "ja": "はぁぁ……♥　お兄様がわたしのおまんこで気持ちよくなってくれているのがすごく嬉しいです♥",
      "zh": ""
    },
    {
      "key": "168.0",
      "line_index": 168,
      "inline_index": 0,
      "line_hash": "36eae15e",
      "speaker": "",
      "ja": "そんな会話をしていくうちにポラリスと{G_PlayerName}の気持ちはどんどん高ぶっていく。",
      "zh": ""
    },
    {
      "key": "170.0",
      "line_index": 170,
      "inline_index": 0,
      "line_hash": "f4900e43",
      "speaker": "",
      "ja": "そのせいで{G_PlayerName}の腰の動きが徐々に激しくなっていった。",
      "zh": ""
    },
    {
      "key": "173.0",
      "line_index": 173,
      "inline_index": 0,
      "line_hash": "a8ebe0f9",
      "speaker": "{G_PlayerName}",
      "ja": "ふぅ……ふぅ……ああ……気持ちいいよ……ポラリス……はぁ……はぁ……",
      "zh": ""
    },
    {
      "key": "177.0",
      "line_index": 177,
      "inline_index": 0,
      "line_hash": "79381e89",
      "speaker": "ポラリス",
      "ja": "あっ♥　あああっ♥　そんなに激しくずぼずぼされると……んんんっ♥　いいっ♥　イっちゃう……イっちゃうぅ♥",
      "zh": ""
    },
    {
      "key": "179.0",
      "line_index": 179,
      "inline_index": 0,
      "line_hash": "db30e681",
      "speaker": "",
      "ja": "ポラリスの絶頂が近づく程に膣の締まりは強くなり、まるでおまんこに吸われているような感覚に{G_PlayerName}の快感は大きくなっていく。",
      "zh": ""
    },
    {
      "key": "181.0",
      "line_index": 181,
      "inline_index": 0,
      "line_hash": "afb098f8",
      "speaker": "",
      "ja": "その気持ちよさに{G_PlayerName}は射精に向かって更にピストンを加速させていった。",
      "zh": ""
    },
    {
      "key": "184.0",
      "line_index": 184,
      "inline_index": 0,
      "line_hash": "78aa9204",
      "speaker": "{G_PlayerName}",
      "ja": "ああ……ポラリス……んっ……んんっ……はぁ……はぁ……",
      "zh": ""
    },
    {
      "key": "188.0",
      "line_index": 188,
      "inline_index": 0,
      "line_hash": "9a359ed7",
      "speaker": "ポラリス",
      "ja": "あんっ♥　あぁんっ♥　お兄様ぁ♥　も、もうだめですぅ♥　わ、わたしっ……わたしっ……んんんっ♥　はあぁぁんっ♥",
      "zh": ""
    },
    {
      "key": "190.0",
      "line_index": 190,
      "inline_index": 0,
      "line_hash": "59b297fd",
      "speaker": "",
      "ja": "何度も強くおまんこの奥を突かれたポラリスは唇を震わせながら小さく腰を跳ねさせ出入りするおちんちんを搾るように締め付けてくる。",
      "zh": ""
    },
    {
      "key": "193.0",
      "line_index": 193,
      "inline_index": 0,
      "line_hash": "11c06a15",
      "speaker": "{G_PlayerName}",
      "ja": "あうぅ……どんどん締まりが強くなって……うっ……んんっ……",
      "zh": ""
    },
    {
      "key": "196.0",
      "line_index": 196,
      "inline_index": 0,
      "line_hash": "84cd0e23",
      "speaker": "",
      "ja": "込み上げてくる感覚は一突き毎に強くなってポラリスの中で陰茎が激しく上下に跳ねた。",
      "zh": ""
    },
    {
      "key": "198.0",
      "line_index": 198,
      "inline_index": 0,
      "line_hash": "69097d6",
      "speaker": "",
      "ja": "その動きはまるでおまんこの中を激しく掻き回すような感じで、ポラリスを一気に高まらせていく。",
      "zh": ""
    },
    {
      "key": "201.0",
      "line_index": 201,
      "inline_index": 0,
      "line_hash": "6a886752",
      "speaker": "ポラリス",
      "ja": "お兄様っ♥　お兄様ぁぁぁっ♥　んんんっ♥　いいっ♥　すごく気持ちいいですっ♥　わ、わたしっ……あっ、はぁんっ♥　あんっ♥　ああぁぁんっ♥",
      "zh": ""
    },
    {
      "key": "203.0",
      "line_index": 203,
      "inline_index": 0,
      "line_hash": "2c1740fb",
      "speaker": "",
      "ja": "{G_PlayerName}のおちんちんが深々と貫く程にポラリスのおまんこはねっとりとした汁を溢れさせながら強く締まってきた。",
      "zh": ""
    },
    {
      "key": "205.0",
      "line_index": 205,
      "inline_index": 0,
      "line_hash": "6a06bde0",
      "speaker": "",
      "ja": "それでもピストンを繰り返しているうちに、{G_PlayerName}は止められない程の射精衝動に襲われてしまう。",
      "zh": ""
    },
    {
      "key": "208.0",
      "line_index": 208,
      "inline_index": 0,
      "line_hash": "2fb32041",
      "speaker": "{G_PlayerName}",
      "ja": "うっ……くっ……で、出る……っ",
      "zh": ""
    },
    {
      "key": "211.0",
      "line_index": 211,
      "inline_index": 0,
      "line_hash": "1d0f3c4",
      "speaker": "",
      "ja": "強い締まりに堪えきれなくなった{G_PlayerName}は膣の奥まで脈打つおちんちんを押し込むと、そのまま熱い精液をほとばしらせた。",
      "zh": ""
    },
    {
      "key": "220.0",
      "line_index": 220,
      "inline_index": 0,
      "line_hash": "b11ed8ed",
      "speaker": "ポラリス",
      "ja": "んはぁぁぁぁ♥　おちんちん暴れてるぅ♥　奥に熱いのがドピュドピュ出てますぅ♥",
      "zh": ""
    },
    {
      "key": "222.0",
      "line_index": 222,
      "inline_index": 0,
      "line_hash": "8ef0a70c",
      "speaker": "",
      "ja": "おまんこに注ぎ込まれる熱い感覚にポラリスはうっとりとした表情を浮かべ甘い声を漏らす。",
      "zh": ""
    },
    {
      "key": "224.0",
      "line_index": 224,
      "inline_index": 0,
      "line_hash": "243effe7",
      "speaker": "",
      "ja": "そんなポラリスの中に{G_PlayerName}は何度も精液を放ち全てを注ぎ込んで果てた。",
      "zh": ""
    },
    {
      "key": "227.0",
      "line_index": 227,
      "inline_index": 0,
      "line_hash": "e0487307",
      "speaker": "ポラリス",
      "ja": "あっ♥　あっ♥　あああっ♥　こ、こんなにいっぱい……熱いの……おまんこに……んはぁぁぁ♥",
      "zh": ""
    },
    {
      "key": "230.0",
      "line_index": 230,
      "inline_index": 0,
      "line_hash": "cb6ee7d9",
      "speaker": "{G_PlayerName}",
      "ja": "はぁ……はぁ……はぁ……はぁ……",
      "zh": ""
    },
    {
      "key": "233.0",
      "line_index": 233,
      "inline_index": 0,
      "line_hash": "87b3989c",
      "speaker": "",
      "ja": "射精を終えた{G_PlayerName}はすっかり息が切れてしまっていて、体にはじっとりと汗が浮かんでいる。",
      "zh": ""
    },
    {
      "key": "235.0",
      "line_index": 235,
      "inline_index": 0,
      "line_hash": "28bff0d",
      "speaker": "",
      "ja": "ポラリスはまだ肩で息をしている{G_PlayerName}を潤んだ目で見つめながら甘えるような声で求めてきた。",
      "zh": ""
    },
    {
      "key": "238.0",
      "line_index": 238,
      "inline_index": 0,
      "line_hash": "cb0fb324",
      "speaker": "ポラリス",
      "ja": "お兄様っ♥　もっとしてくれませんか……？♥　わたし、まだ……♥",
      "zh": ""
    },
    {
      "key": "241.0",
      "line_index": 241,
      "inline_index": 0,
      "line_hash": "f4fe3598",
      "speaker": "{G_PlayerName}",
      "ja": "ポ、ポラリス……",
      "zh": ""
    },
    {
      "key": "244.0",
      "line_index": 244,
      "inline_index": 0,
      "line_hash": "8b5e9a73",
      "speaker": "",
      "ja": "快感ですっかり緩みきった顔をしたポラリスは、舌を出してよだれまで垂らしてしまっている。",
      "zh": ""
    },
    {
      "key": "246.0",
      "line_index": 246,
      "inline_index": 0,
      "line_hash": "322bdce9",
      "speaker": "",
      "ja": "それでもまだ物足りないという感じで{G_PlayerName}におねだりをしてきた。",
      "zh": ""
    },
    {
      "key": "249.0",
      "line_index": 249,
      "inline_index": 0,
      "line_hash": "c2ec023d",
      "speaker": "ポラリス",
      "ja": "もっと突いてくださいっ♥　もっと愛しあいましょう……♥",
      "zh": ""
    },
    {
      "key": "252.0",
      "line_index": 252,
      "inline_index": 0,
      "line_hash": "c0cc1274",
      "speaker": "{G_PlayerName}",
      "ja": "あっ……ああっ……",
      "zh": ""
    },
    {
      "key": "255.0",
      "line_index": 255,
      "inline_index": 0,
      "line_hash": "3fbc4fa",
      "speaker": "",
      "ja": "淫らな表情と可愛らしい声とのギャップに{G_PlayerName}の興奮は煽られて果てたばかりの陰茎がまた硬く反り返ってくる。",
      "zh": ""
    },
    {
      "key": "257.0",
      "line_index": 257,
      "inline_index": 0,
      "line_hash": "b0f783fc",
      "speaker": "",
      "ja": "そして{G_PlayerName}は再び腰を振り始め、ポラリスの小さな膣を突き上げていった。",
      "zh": ""
    },
    {
      "key": "264.0",
      "line_index": 264,
      "inline_index": 0,
      "line_hash": "24fbf09f",
      "speaker": "ポラリス",
      "ja": "あっ♥　あっ♥　ああぁんっ♥　いいっ♥　またおちんちんが奥をずんずんしてきてますぅ♥　こ、これ……たまらないですぅ♥",
      "zh": ""
    },
    {
      "key": "266.0",
      "line_index": 266,
      "inline_index": 0,
      "line_hash": "f179cbb4",
      "speaker": "",
      "ja": "再度ピストンが始まるとポラリスは気持ちよさそうな声で喘ぎ腰を震わせながら悶えていく。",
      "zh": ""
    },
    {
      "key": "268.0",
      "line_index": 268,
      "inline_index": 0,
      "line_hash": "aeaf3a21",
      "speaker": "",
      "ja": "そんな淫らな姿に興奮を煽られた{G_PlayerName}は、一定のリズムで何度もおまんこの奥を亀頭で突き上げていった。",
      "zh": ""
    },
    {
      "key": "271.0",
      "line_index": 271,
      "inline_index": 0,
      "line_hash": "9f9c882c",
      "speaker": "{G_PlayerName}",
      "ja": "はぁ……はぁ……ど、どうだ？　ポラリス……いいか？",
      "zh": ""
    },
    {
      "key": "274.0",
      "line_index": 274,
      "inline_index": 0,
      "line_hash": "17dda804",
      "speaker": "",
      "ja": "腰を振りながらそう尋ねると、快感ですっかり理性が飛んでしまったポラリスはついつい本音を口にしてしまう。",
      "zh": ""
    },
    {
      "key": "277.0",
      "line_index": 277,
      "inline_index": 0,
      "line_hash": "2ffb676c",
      "speaker": "ポラリス",
      "ja": "んぁ～～～～～っ♥　お兄様しゅきですっ♥　もっと突いてぇ！！！♥",
      "zh": ""
    },
    {
      "key": "280.0",
      "line_index": 280,
      "inline_index": 0,
      "line_hash": "d8d4c5ca",
      "speaker": "{G_PlayerName}",
      "ja": "ポラリス……っ！",
      "zh": ""
    },
    {
      "key": "283.0",
      "line_index": 283,
      "inline_index": 0,
      "line_hash": "557d0206",
      "speaker": "",
      "ja": "好きと言われたことで{G_PlayerName}の興奮も一気に高まって、腰の動きが徐々に激しさを増してきた。",
      "zh": ""
    },
    {
      "key": "286.0",
      "line_index": 286,
      "inline_index": 0,
      "line_hash": "f934862a",
      "speaker": "ポラリス",
      "ja": "んっ♥　んんっ♥　あふぅぅ♥　あっ♥　んはぁぁ♥　いいっ♥　すごく気持ちいいですぅ♥　おふぅ♥　おっ♥　おほぉぉぉ♥",
      "zh": ""
    },
    {
      "key": "288.0",
      "line_index": 288,
      "inline_index": 0,
      "line_hash": "e315ea57",
      "speaker": "",
      "ja": "強い突き上げにポラリスの口からは淫らな声が漏れ出て、精液を注がれたおまんこからは、ぐちゅぐちゅといういやらしい水音が鳴っている。",
      "zh": ""
    },
    {
      "key": "290.0",
      "line_index": 290,
      "inline_index": 0,
      "line_hash": "cc2cd",
      "speaker": "",
      "ja": "その音とポラリスの可愛らしい喘ぎ声に{G_PlayerName}は興奮を高めてしまい息を切らしながらピストンを続けた。",
      "zh": ""
    },
    {
      "key": "293.0",
      "line_index": 293,
      "inline_index": 0,
      "line_hash": "85992ccb",
      "speaker": "{G_PlayerName}",
      "ja": "ほらほらっ……ポラリス……こうやっていっぱい突いてあげればいいんだろ？",
      "zh": ""
    },
    {
      "key": "297.0",
      "line_index": 297,
      "inline_index": 0,
      "line_hash": "8cb63569",
      "speaker": "ポラリス",
      "ja": "お兄様っ♥　すごいですぅ♥　おちんちんがおまんこの奥をノックしてっ♥　あふぅ♥　あっ♥　またイキそうですぅ♥",
      "zh": ""
    },
    {
      "key": "299.0",
      "line_index": 299,
      "inline_index": 0,
      "line_hash": "48773166",
      "speaker": "",
      "ja": "高まる快感にポラリスは体を震わせながら身をよじる。",
      "zh": ""
    },
    {
      "key": "301.0",
      "line_index": 301,
      "inline_index": 0,
      "line_hash": "bdd9b0ca",
      "speaker": "",
      "ja": "突き上げられる膣はびゅくびゅくと蠢いて、出入りを繰り返すおちんちんを締め上げてきた。",
      "zh": ""
    },
    {
      "key": "304.0",
      "line_index": 304,
      "inline_index": 0,
      "line_hash": "43f6aa72",
      "speaker": "{G_PlayerName}",
      "ja": "ああ……どんどん狭くなってきて……ヒダが……擦れる……うぅっ……",
      "zh": ""
    },
    {
      "key": "307.0",
      "line_index": 307,
      "inline_index": 0,
      "line_hash": "baa71837",
      "speaker": "",
      "ja": "絡みつきながらしごいてくる濡れた柔ヒダの刺激に{G_PlayerName}はまた強く込み上げてくる感覚に襲われ始める。",
      "zh": ""
    },
    {
      "key": "309.0",
      "line_index": 309,
      "inline_index": 0,
      "line_hash": "ea30c551",
      "speaker": "",
      "ja": "その感覚に煽られたかのように{G_PlayerName}はラストスパートをかける感じで腰の動きをどんどん速めていった。",
      "zh": ""
    },
    {
      "key": "312.0",
      "line_index": 312,
      "inline_index": 0,
      "line_hash": "4d9dccbe",
      "speaker": "{G_PlayerName}",
      "ja": "ほらっ！　ほらっ！　ほらっ！　ほらっ！",
      "zh": ""
    },
    {
      "key": "316.0",
      "line_index": 316,
      "inline_index": 0,
      "line_hash": "5cb9feba",
      "speaker": "ポラリス",
      "ja": "あはぁぁんっ♥　激しいですぅ♥　お、お兄様ぁぁ♥　で、でも気持ちいいですっ♥　はあぁぁんっ♥　おまんこいいっ♥",
      "zh": ""
    },
    {
      "key": "318.0",
      "line_index": 318,
      "inline_index": 0,
      "line_hash": "438a79d5",
      "speaker": "",
      "ja": "淫らな言葉を口にしながらポラリスは激しい快感に腰を何度も跳ねさせて喘ぐ。",
      "zh": ""
    },
    {
      "key": "320.0",
      "line_index": 320,
      "inline_index": 0,
      "line_hash": "1aa1e464",
      "speaker": "",
      "ja": "抽送が速くなる程におまんこの痙攣は激しくなって締め付けも強くなってきた。",
      "zh": ""
    },
    {
      "key": "323.0",
      "line_index": 323,
      "inline_index": 0,
      "line_hash": "316be3c",
      "speaker": "{G_PlayerName}",
      "ja": "お、おまんこが……吸いついてきて……はぁ……あぁぁ……",
      "zh": ""
    },
    {
      "key": "327.0",
      "line_index": 327,
      "inline_index": 0,
      "line_hash": "6a5a8e66",
      "speaker": "ポラリス",
      "ja": "おちんちんがおまんこの奥をずんずんしてきて♥　イクっ♥　イっちゃいますっ♥　ああっ、お兄様ぁぁぁ♥",
      "zh": ""
    },
    {
      "key": "330.0",
      "line_index": 330,
      "inline_index": 0,
      "line_hash": "caaa28bb",
      "speaker": "{G_PlayerName}",
      "ja": "ポラリス……俺もそろそろ……が、我慢できない……うっ……うぅぅっ",
      "zh": ""
    },
    {
      "key": "333.0",
      "line_index": 333,
      "inline_index": 0,
      "line_hash": "97f8f62c",
      "speaker": "",
      "ja": "くいくい締め付けてくる膣の中で、反り返った陰茎が脈打ちながら何度も激しく上下に跳ねる。",
      "zh": ""
    },
    {
      "key": "335.0",
      "line_index": 335,
      "inline_index": 0,
      "line_hash": "648e4dbf",
      "speaker": "",
      "ja": "まるでおまんこをえぐられるような刺激に、ポラリスは大きく体をのけ反らせながら大きな声で喘いだ。",
      "zh": ""
    },
    {
      "key": "338.0",
      "line_index": 338,
      "inline_index": 0,
      "line_hash": "6e38b2ad",
      "speaker": "ポラリス",
      "ja": "気持ちよくてわたしまた……♥　イっ、イっちゃいますっ♥　あっ、はあぁぁぁんっ♥",
      "zh": ""
    },
    {
      "key": "341.0",
      "line_index": 341,
      "inline_index": 0,
      "line_hash": "a0c5ffcc",
      "speaker": "{G_PlayerName}",
      "ja": "俺も……そろそろ……で、出そうだ……あうぅ……",
      "zh": ""
    },
    {
      "key": "344.0",
      "line_index": 344,
      "inline_index": 0,
      "line_hash": "e22073c2",
      "speaker": "",
      "ja": "搾り出すようにそう呟くと{G_PlayerName}は射精に向かって腰の動きを更に加速させ、強くポラリスのおまんこを貫いていった。",
      "zh": ""
    },
    {
      "key": "347.0",
      "line_index": 347,
      "inline_index": 0,
      "line_hash": "61e440e2",
      "speaker": "ポラリス",
      "ja": "んああっ♥　あっ♥　あああっ♥　そ、そんなに激しくおまんこをずんずんされたらっ♥　イクっ♥　イクっ♥　んふぅぅっ♥",
      "zh": ""
    },
    {
      "key": "349.0",
      "line_index": 349,
      "inline_index": 0,
      "line_hash": "b5044cfe",
      "speaker": "",
      "ja": "ゾロリゾロリと擦れる肉ヒダの刺激に強く込み上げてくる感覚に襲われた{G_PlayerName}は、怒張したおちんちんを強く脈動させながら呻き声を漏らす。",
      "zh": ""
    },
    {
      "key": "352.0",
      "line_index": 352,
      "inline_index": 0,
      "line_hash": "e29d9e97",
      "speaker": "{G_PlayerName}",
      "ja": "くっ！　うっ！　うううぅぅっ！",
      "zh": ""
    },
    {
      "key": "355.0",
      "line_index": 355,
      "inline_index": 0,
      "line_hash": "af62ebd4",
      "speaker": "",
      "ja": "{G_PlayerName}は衝動のまま大きく腰を突き出すと奥までおちんちんを挿入して、そのまま勢いよく射精した。",
      "zh": ""
    },
    {
      "key": "365.0",
      "line_index": 365,
      "inline_index": 0,
      "line_hash": "e88f428e",
      "speaker": "ポラリス",
      "ja": "んはぁぁぁぁぁぁっ♥　お兄様のおちんちんでイッグゥ～～～～～～～～っ！！！♥",
      "zh": ""
    },
    {
      "key": "367.0",
      "line_index": 367,
      "inline_index": 0,
      "line_hash": "de8c6093",
      "speaker": "",
      "ja": "どくんどくんと脈打ちながら精液が放たれる感触に、ポラリスも大きな声で喘ぎながらイってしまう。",
      "zh": ""
    },
    {
      "key": "369.0",
      "line_index": 369,
      "inline_index": 0,
      "line_hash": "7f666f98",
      "speaker": "",
      "ja": "その瞬間まるで{G_PlayerName}の陰茎から精液を搾り取ろうとするかのように、ポラリスのおまんこが強く吸いついてきた。",
      "zh": ""
    },
    {
      "key": "372.0",
      "line_index": 372,
      "inline_index": 0,
      "line_hash": "92ea5f7c",
      "speaker": "{G_PlayerName}",
      "ja": "で、出るっ！　うううっ！　まだ出るっ！　あっ……あああっ！",
      "zh": ""
    },
    {
      "key": "375.0",
      "line_index": 375,
      "inline_index": 0,
      "line_hash": "f82d4a",
      "speaker": "",
      "ja": "どぴゅどぴゅと膣内に出される熱い精液の感触にポラリスは大きな快感と幸せを感じてしまう。",
      "zh": ""
    },
    {
      "key": "378.0",
      "line_index": 378,
      "inline_index": 0,
      "line_hash": "9286e926",
      "speaker": "ポラリス",
      "ja": "あっ♥　ああっ♥　出して下さいっ♥　お兄様の精子いっぱいくださいっ♥　あはぁぁぁぁんっ♥",
      "zh": ""
    },
    {
      "key": "381.0",
      "line_index": 381,
      "inline_index": 0,
      "line_hash": "5f6571a3",
      "speaker": "{G_PlayerName}",
      "ja": "ポラリスっ……うっ……くぅぅっ！",
      "zh": ""
    },
    {
      "key": "384.0",
      "line_index": 384,
      "inline_index": 0,
      "line_hash": "7b88cb3e",
      "speaker": "",
      "ja": "そのまま{G_PlayerName}はポラリスの膣奥に大量の精液を出し切って果てた。",
      "zh": ""
    },
    {
      "key": "387.0",
      "line_index": 387,
      "inline_index": 0,
      "line_hash": "ef49b609",
      "speaker": "ポラリス",
      "ja": "あふぅぅ♥　いっぱい……いっぱいお腹に♥　あっ、あつぅぅい♥　おふぅぅぅ♥",
      "zh": ""
    },
    {
      "key": "389.0",
      "line_index": 389,
      "inline_index": 0,
      "line_hash": "171d6fcc",
      "speaker": "",
      "ja": "大量に精液を注がれたポラリスは恍惚の表情を浮かべながら満足げにそう呟く。",
      "zh": ""
    },
    {
      "key": "392.0",
      "line_index": 392,
      "inline_index": 0,
      "line_hash": "cb6ee7d9",
      "speaker": "{G_PlayerName}",
      "ja": "はぁ……はぁ……はぁ……はぁ……",
      "zh": ""
    },
    {
      "key": "395.0",
      "line_index": 395,
      "inline_index": 0,
      "line_hash": "52746ee3",
      "speaker": "",
      "ja": "{G_PlayerName}の方は果てたおちんちんを挿入したまま、荒い息を漏らしていた。",
      "zh": ""
    },
    {
      "key": "397.0",
      "line_index": 397,
      "inline_index": 0,
      "line_hash": "6d7c933b",
      "speaker": "",
      "ja": "そして絶頂の余韻を味わっているポラリスは薄れゆく意識の中で思う。",
      "zh": ""
    },
    {
      "key": "400.0",
      "line_index": 400,
      "inline_index": 0,
      "line_hash": "d110fc8d",
      "speaker": "ポラリス",
      "ja": "（いつか、あなたのこと……本当に振り向かせられますか……？）",
      "zh": ""
    }
  ]
}
