{
  "lines": [
    {
      "key": "20.1",
      "line_index": 20,
      "inline_index": 1,
      "line_hash": "dad58b87",
      "speaker": "メイズ",
      "ja": "（一人で艦内歩いててもつまらないな……）",
      "zh": ""
    },
    {
      "key": "22.0",
      "line_index": 22,
      "inline_index": 0,
      "line_hash": "352f2c1f",
      "speaker": "",
      "ja": "あたしは一時グレアの元を離れ、機械士と行動を共にしていた。",
      "zh": ""
    },
    {
      "key": "24.0",
      "line_index": 24,
      "inline_index": 0,
      "line_hash": "e0c39a53",
      "speaker": "",
      "ja": "機械士をルミナ様の船に送った後、直帰するのもどうかと思い一人艦内を散策する。",
      "zh": ""
    },
    {
      "key": "25.0",
      "line_index": 25,
      "inline_index": 0,
      "line_hash": "7a0848f",
      "speaker": "",
      "ja": "しかし特に変わったものがあるわけでもなく、すぐに散策するのも飽きてしまっていた。",
      "zh": ""
    },
    {
      "key": "28.1",
      "line_index": 28,
      "inline_index": 1,
      "line_hash": "8178e499",
      "speaker": "メイズ",
      "ja": "（そろそろ帰るか……あ、最後にお兄さんに挨拶くらいしとこ）",
      "zh": ""
    },
    {
      "key": "31.1",
      "line_index": 31,
      "inline_index": 1,
      "line_hash": "b448bd77",
      "speaker": "メイズ",
      "ja": "（また会うかもだし、少しくらい印象良くしといた方が良いよね）",
      "zh": ""
    },
    {
      "key": "42.1",
      "line_index": 42,
      "inline_index": 1,
      "line_hash": "73a4e0de",
      "speaker": "メイズ",
      "ja": "こんちゃ～♪　って、あれれ？　あれ～？　お兄さん寝てる？",
      "zh": ""
    },
    {
      "key": "45.1",
      "line_index": 45,
      "inline_index": 1,
      "line_hash": "307135e",
      "speaker": "メイズ",
      "ja": "ついさっき別れたばっかりなのに、よほどお疲れだったんだね～",
      "zh": ""
    },
    {
      "key": "50.1",
      "line_index": 50,
      "inline_index": 1,
      "line_hash": "a6c6b376",
      "speaker": "メイズ",
      "ja": "こら～……起きろ～♥　メイズちゃんが挨拶にきたんだぞ～？♥　起きろ～♥　ふぅ～っ♥",
      "zh": ""
    },
    {
      "key": "53.0",
      "line_index": 53,
      "inline_index": 0,
      "line_hash": "48a37ab4",
      "speaker": "{G_PlayerName}",
      "ja": "ん……んぅぅぅ……",
      "zh": ""
    },
    {
      "key": "57.1",
      "line_index": 57,
      "inline_index": 1,
      "line_hash": "4dff5d0f",
      "speaker": "メイズ",
      "ja": "ありゃ……耳元で囁いても効果無し？　こんな美少女と二人っきりだって言うのに……ピクリともしないなんて……ちょっとショック～……",
      "zh": ""
    },
    {
      "key": "60.1",
      "line_index": 60,
      "inline_index": 1,
      "line_hash": "2570aa81",
      "speaker": "メイズ",
      "ja": "ふふん♥　それでもあたしに不可能は無いのだよ♥　特に男に関しては♥",
      "zh": ""
    },
    {
      "key": "63.1",
      "line_index": 63,
      "inline_index": 1,
      "line_hash": "a0bd14ff",
      "speaker": "メイズ",
      "ja": "こーんな無防備で寝ちゃってるんだし、少しくらい可愛がってあげなきゃね♥　くすくすっ♥",
      "zh": ""
    },
    {
      "key": "79.0",
      "line_index": 79,
      "inline_index": 0,
      "line_hash": "884d8b77",
      "speaker": "{G_PlayerName}",
      "ja": "──んんんっ！？　メイズ！？　な、何して……！？",
      "zh": ""
    },
    {
      "key": "83.0",
      "line_index": 83,
      "inline_index": 0,
      "line_hash": "624c4f43",
      "speaker": "メイズ",
      "ja": "ありゃ？♥　起きたんだ？♥　まだ何もしてないのに♥",
      "zh": ""
    },
    {
      "key": "86.0",
      "line_index": 86,
      "inline_index": 0,
      "line_hash": "759b38c0",
      "speaker": "{G_PlayerName}",
      "ja": "な、何言って……ううっ！　擦るなって……！！",
      "zh": ""
    },
    {
      "key": "89.0",
      "line_index": 89,
      "inline_index": 0,
      "line_hash": "15218f6c",
      "speaker": "",
      "ja": "メイズは肉棒を優しく擦り、半分寝ぼけていた思考が一気に目覚めていく。",
      "zh": ""
    },
    {
      "key": "92.0",
      "line_index": 92,
      "inline_index": 0,
      "line_hash": "2ff92058",
      "speaker": "メイズ",
      "ja": "んー……でもあんま硬くなってないね～……半勃起って感じ？♥　こういう場合疲れマラとかでガチガチになってるんじゃないの？♥",
      "zh": ""
    },
    {
      "key": "95.0",
      "line_index": 95,
      "inline_index": 0,
      "line_hash": "3c94df61",
      "speaker": "{G_PlayerName}",
      "ja": "そ、そんなこと言われても……ってぇ！？　ちょっと！　お、おい！！　その棒、何するつもりなんだよ！！　まさか俺のちんぽに……！？",
      "zh": ""
    },
    {
      "key": "99.0",
      "line_index": 99,
      "inline_index": 0,
      "line_hash": "40124272",
      "speaker": "メイズ",
      "ja": "ふふ♥　察しがいいね♥　これでお兄さんのおちんちんのおしっこの穴に……ずっぶ～って入れて掻き回すの♥",
      "zh": ""
    },
    {
      "key": "102.0",
      "line_index": 102,
      "inline_index": 0,
      "line_hash": "dfd11b16",
      "speaker": "{G_PlayerName}",
      "ja": "いちいち言わんでもいい！",
      "zh": ""
    },
    {
      "key": "106.0",
      "line_index": 106,
      "inline_index": 0,
      "line_hash": "b992ab8b",
      "speaker": "メイズ",
      "ja": "あんっ♥　逃げちゃダメ～♥",
      "zh": ""
    },
    {
      "key": "109.0",
      "line_index": 109,
      "inline_index": 0,
      "line_hash": "f1d56af9",
      "speaker": "{G_PlayerName}",
      "ja": "は、離せ……！！　そんなん痛いに決まってるだろ……！　なんてこと考えてんだよ！",
      "zh": ""
    },
    {
      "key": "113.0",
      "line_index": 113,
      "inline_index": 0,
      "line_hash": "b1fc8352",
      "speaker": "メイズ",
      "ja": "痛いのは最初だけだって♥　尿道くちゅくちゅされて悶絶する男は何人も見てきたし、安心してあたしに任せてよ♥",
      "zh": ""
    },
    {
      "key": "116.0",
      "line_index": 116,
      "inline_index": 0,
      "line_hash": "e693478d",
      "speaker": "{G_PlayerName}",
      "ja": "み、見てきた……？　まさかしょっちゅうやってるのか……？",
      "zh": ""
    },
    {
      "key": "120.0",
      "line_index": 120,
      "inline_index": 0,
      "line_hash": "a0046acd",
      "speaker": "メイズ",
      "ja": "ま、それなりに、ね？♥　あ、今の話みんなに内緒ね？♥　お姫様のボディガードが男遊びしているってバレたら色々面倒だしさ♥",
      "zh": ""
    },
    {
      "key": "123.0",
      "line_index": 123,
      "inline_index": 0,
      "line_hash": "692b4cf5",
      "speaker": "{G_PlayerName}",
      "ja": "お、俺には知られていいのかよ……",
      "zh": ""
    },
    {
      "key": "127.0",
      "line_index": 127,
      "inline_index": 0,
      "line_hash": "5b497af3",
      "speaker": "メイズ",
      "ja": "お兄さんは誰にも言えなくなるよ？♥　欲に溺れた男ってみーんな口が堅くなっちゃうんだから♥",
      "zh": ""
    },
    {
      "key": "133.0",
      "line_index": 133,
      "inline_index": 0,
      "line_hash": "63f23e8b",
      "speaker": "{G_PlayerName}",
      "ja": "うううっ！？　ぐ、うっ……！　や、やめろぉ……！　お、おおっ……！！",
      "zh": ""
    },
    {
      "key": "136.0",
      "line_index": 136,
      "inline_index": 0,
      "line_hash": "aedf513a",
      "speaker": "",
      "ja": "メイズは俺の言葉に一切の躊躇もなく棒の先端を鈴口の奥へと押し込んでいく。",
      "zh": ""
    },
    {
      "key": "138.0",
      "line_index": 138,
      "inline_index": 0,
      "line_hash": "265052e4",
      "speaker": "",
      "ja": "異物が入ってくる違和感と恐怖から逃げるように腰をねじるが、メイズが俺を抑えつけ身動きが取れない。",
      "zh": ""
    },
    {
      "key": "139.0",
      "line_index": 139,
      "inline_index": 0,
      "line_hash": "927a71f5",
      "speaker": "",
      "ja": "子供のように足をジタバタと暴れさせ、喉の奥から搾り出したような声が勝手に漏れてしまう。",
      "zh": ""
    },
    {
      "key": "142.0",
      "line_index": 142,
      "inline_index": 0,
      "line_hash": "33e9fa1",
      "speaker": "メイズ",
      "ja": "こらこら、暴れないの♥　おちんちんの中傷ついちゃうよ？♥",
      "zh": ""
    },
    {
      "key": "145.0",
      "line_index": 145,
      "inline_index": 0,
      "line_hash": "17c99c65",
      "speaker": "{G_PlayerName}",
      "ja": "あうっ！　だ、だったらそんなの入れるなぁ……！！　一体何考えてんだよっ……！！",
      "zh": ""
    },
    {
      "key": "149.0",
      "line_index": 149,
      "inline_index": 0,
      "line_hash": "4d7501bf",
      "speaker": "メイズ",
      "ja": "お兄さんを気持ち良くしてあげることしか考えていないよ？♥　でもおちんちんの中グリグリしたおかげかな？♥　もうカチコチになってきた♥",
      "zh": ""
    },
    {
      "key": "152.0",
      "line_index": 152,
      "inline_index": 0,
      "line_hash": "d503bdcd",
      "speaker": "メイズ",
      "ja": "実は尿道くちゅくちゅされるの、心のどこかで望んでいたんじゃない？♥　んふふふっ♥",
      "zh": ""
    },
    {
      "key": "155.0",
      "line_index": 155,
      "inline_index": 0,
      "line_hash": "8d32837b",
      "speaker": "{G_PlayerName}",
      "ja": "そんなの、誰が望むかぁ……！　あああ、ダメだって！　これ以上奥に入れるなぁっ！！　うう、うううううっ！！",
      "zh": ""
    },
    {
      "key": "159.0",
      "line_index": 159,
      "inline_index": 0,
      "line_hash": "392c17e3",
      "speaker": "メイズ",
      "ja": "だから暴れないでって♥　怖いのは今だけだからさ♥　ほら、おちんちんヒクヒクしてきた♥　カウパーもどっぱどっぱ出てきてるよ♥",
      "zh": ""
    },
    {
      "key": "162.0",
      "line_index": 162,
      "inline_index": 0,
      "line_hash": "5e23739b",
      "speaker": "メイズ",
      "ja": "もう痛くないはずだから……♥　いっぱい気持ち良くなってね、お兄さんっ♥",
      "zh": ""
    },
    {
      "key": "165.0",
      "line_index": 165,
      "inline_index": 0,
      "line_hash": "e982fdd2",
      "speaker": "{G_PlayerName}",
      "ja": "う゛っ、うう……！　うあ、くすぐったい……！！　ヘンな感じ……も、もうやめてくれってぇ……！！",
      "zh": ""
    },
    {
      "key": "168.0",
      "line_index": 168,
      "inline_index": 0,
      "line_hash": "1a7d4b3d",
      "speaker": "",
      "ja": "メイズは棒を上下にゆっくりと動かし、尿道を掻き回していく。",
      "zh": ""
    },
    {
      "key": "170.0",
      "line_index": 170,
      "inline_index": 0,
      "line_hash": "969c63e0",
      "speaker": "",
      "ja": "くすぐったさと恐怖の入り混じった不思議な感覚に思考が混乱しっぱなし。",
      "zh": ""
    },
    {
      "key": "171.0",
      "line_index": 171,
      "inline_index": 0,
      "line_hash": "88f175b6",
      "speaker": "",
      "ja": "初めての刺激にどう対処していいのかわからず、俺はひたすらに声を上げ続けることしかできずにいた。",
      "zh": ""
    },
    {
      "key": "174.0",
      "line_index": 174,
      "inline_index": 0,
      "line_hash": "f0863e74",
      "speaker": "メイズ",
      "ja": "たまらないでしょ？♥　この感覚♥　男の人って中を攻められる経験ってほぼ無いみたいだからね～♥",
      "zh": ""
    },
    {
      "key": "177.0",
      "line_index": 177,
      "inline_index": 0,
      "line_hash": "6d5958f0",
      "speaker": "メイズ",
      "ja": "どんなにいい女を抱いても尿道を穿られる快感は味わえないよ？♥　尿道ホジホジがクセになっちゃうとさ……オナニーじゃ絶対に満足できなくなるんだって♥",
      "zh": ""
    },
    {
      "key": "180.0",
      "line_index": 180,
      "inline_index": 0,
      "line_hash": "220d2ece",
      "speaker": "メイズ",
      "ja": "快感欲しさに自分で尿道ホジホジしちゃうようになるんだよ♥　病みつきになっちゃうんだよ♥",
      "zh": ""
    },
    {
      "key": "183.0",
      "line_index": 183,
      "inline_index": 0,
      "line_hash": "67749f78",
      "speaker": "メイズ",
      "ja": "そのくらい未知の快感なんだろうね～♥　あたしはされた経験無いからわからないけどさぁ～♥",
      "zh": ""
    },
    {
      "key": "186.0",
      "line_index": 186,
      "inline_index": 0,
      "line_hash": "77657320",
      "speaker": "{G_PlayerName}",
      "ja": "あぎいいっ！！　奥、奥にぃっ！　やめ……あ゛っ！　う、ううう……！！　ぐう、うううう……！！",
      "zh": ""
    },
    {
      "key": "189.0",
      "line_index": 189,
      "inline_index": 0,
      "line_hash": "7c88e9c6",
      "speaker": "",
      "ja": "メリメリと尿道を広げながら棒が奥に奥にと入ってくる。",
      "zh": ""
    },
    {
      "key": "190.0",
      "line_index": 190,
      "inline_index": 0,
      "line_hash": "88bb58f1",
      "speaker": "",
      "ja": "両脚がガクガクと勝手に震え、異質な快感が尿道から全身へと広がる。",
      "zh": ""
    },
    {
      "key": "192.0",
      "line_index": 192,
      "inline_index": 0,
      "line_hash": "d735c1da",
      "speaker": "",
      "ja": "止めさせようとメイズの手を掴むが、身体に上手く力が入らない。",
      "zh": ""
    },
    {
      "key": "193.0",
      "line_index": 193,
      "inline_index": 0,
      "line_hash": "6171cf77",
      "speaker": "",
      "ja": "メイズは巧みに俺から力を抜くように棒を動かし、鈍く重い快感が少しずつ大きくなっていく。",
      "zh": ""
    },
    {
      "key": "196.0",
      "line_index": 196,
      "inline_index": 0,
      "line_hash": "91a0e62c",
      "speaker": "メイズ",
      "ja": "カウパーすっご……♥　隙間から溢れてきちゃってるよ♥　ほら、ぐちゅぐちゅぐちゅ～♥　これお兄さんのおちんちん穴の音っ♥",
      "zh": ""
    },
    {
      "key": "199.0",
      "line_index": 199,
      "inline_index": 0,
      "line_hash": "e53d9982",
      "speaker": "メイズ",
      "ja": "すごくエッチだよねぇ～……♥　お兄さんの感じてる姿にあたしのおまんこも濡れてきちゃってるよ……♥",
      "zh": ""
    },
    {
      "key": "202.0",
      "line_index": 202,
      "inline_index": 0,
      "line_hash": "e29d9a4e",
      "speaker": "{G_PlayerName}",
      "ja": "お、お前、いつの間にパンツ脱いで……うううっ！！",
      "zh": ""
    },
    {
      "key": "205.0",
      "line_index": 205,
      "inline_index": 0,
      "line_hash": "93458101",
      "speaker": "",
      "ja": "メイズの言葉に思わず下半身に目を向けてしまう。",
      "zh": ""
    },
    {
      "key": "206.0",
      "line_index": 206,
      "inline_index": 0,
      "line_hash": "e454f0b8",
      "speaker": "",
      "ja": "わずかに開いたピンク色のあそこが視界に入り、思わずガン見してしまう。",
      "zh": ""
    },
    {
      "key": "209.0",
      "line_index": 209,
      "inline_index": 0,
      "line_hash": "b09a3ada",
      "speaker": "メイズ",
      "ja": "え～……♥　最初から脱いでたよ？♥　女の子が下半身丸出しにしてたのに気づかないなんて……ヒドイ人だねっ♥",
      "zh": ""
    },
    {
      "key": "212.0",
      "line_index": 212,
      "inline_index": 0,
      "line_hash": "182ed0f0",
      "speaker": "{G_PlayerName}",
      "ja": "ひぎいいいっ！？　や、やめ……そんな出し入れ……あああ！！　勢いよくしないでくれぇええっ！！",
      "zh": ""
    },
    {
      "key": "215.0",
      "line_index": 215,
      "inline_index": 0,
      "line_hash": "c773a56b",
      "speaker": "",
      "ja": "メイズの手がさらに大きく動き、尿道の根元から先端まで棒状の物が何度も往復を繰り返す。",
      "zh": ""
    },
    {
      "key": "217.0",
      "line_index": 217,
      "inline_index": 0,
      "line_hash": "53dbcf08",
      "speaker": "",
      "ja": "棒の凹凸が尿道をグリグリと刺激し、快感のあまり俺は天井を見上げる。",
      "zh": ""
    },
    {
      "key": "218.0",
      "line_index": 218,
      "inline_index": 0,
      "line_hash": "22350b99",
      "speaker": "",
      "ja": "息をするのを忘れるほど悲鳴のように喘ぎ声を上げ、快感に次ぐ快感に首をぶんぶんと激しく振り乱す。",
      "zh": ""
    },
    {
      "key": "220.0",
      "line_index": 220,
      "inline_index": 0,
      "line_hash": "e74aee48",
      "speaker": "",
      "ja": "そんな俺の行動が面白いのかメイズの表情がさらに笑顔になり、尿道を攻める手がさらに大きく大胆になっていく。",
      "zh": ""
    },
    {
      "key": "223.0",
      "line_index": 223,
      "inline_index": 0,
      "line_hash": "d99fbcd",
      "speaker": "メイズ",
      "ja": "ねぇねぇ、そろそろ射精近いんじゃない？♥　隠してもムダだよ？♥　おちんちんの動き見てればそんなのすぐに分かっちゃうんだからさぁ♥",
      "zh": ""
    },
    {
      "key": "226.0",
      "line_index": 226,
      "inline_index": 0,
      "line_hash": "40b983da",
      "speaker": "メイズ",
      "ja": "でも普段のように上手に射精できるかなぁ？♥　出したくなったらいつでもせーしびゅっびゅしていいからね～っ♥",
      "zh": ""
    },
    {
      "key": "229.0",
      "line_index": 229,
      "inline_index": 0,
      "line_hash": "9132db6b",
      "speaker": "{G_PlayerName}",
      "ja": "お゛っお゛っ！！　ぐ、ぐううう……！！　ううう……おぐぅ……だめだってぇ……ぐ、ぐうううっ！！",
      "zh": ""
    },
    {
      "key": "233.0",
      "line_index": 233,
      "inline_index": 0,
      "line_hash": "318b6128",
      "speaker": "メイズ",
      "ja": "くすっ♥　せーし上がってきてるでしょ？♥　出しちゃえ♥　お兄さんの情けな～い姿、あたしに見せてよ♥",
      "zh": ""
    },
    {
      "key": "236.0",
      "line_index": 236,
      "inline_index": 0,
      "line_hash": "8e46408",
      "speaker": "メイズ",
      "ja": "ほら、ほらっ♥　おちんぽ穴ズボズボされて……イっちゃえっ！♥",
      "zh": ""
    },
    {
      "key": "246.0",
      "line_index": 246,
      "inline_index": 0,
      "line_hash": "e65417cd",
      "speaker": "{G_PlayerName}",
      "ja": "うう゛っ！！　うう、ぐう、うあ、あ゛あ゛あ゛……んあああっ！！",
      "zh": ""
    },
    {
      "key": "249.0",
      "line_index": 249,
      "inline_index": 0,
      "line_hash": "9050c97c",
      "speaker": "",
      "ja": "睾丸から上がってきた熱いモノを吐き出そうと俺は腰に力を入れる。",
      "zh": ""
    },
    {
      "key": "250.0",
      "line_index": 250,
      "inline_index": 0,
      "line_hash": "655ffe5b",
      "speaker": "",
      "ja": "しかし尿道を塞がれているせいで普段の勢いのある射精とは違い、どぷっと漏れ出す程度。",
      "zh": ""
    },
    {
      "key": "252.0",
      "line_index": 252,
      "inline_index": 0,
      "line_hash": "9abaff09",
      "speaker": "",
      "ja": "ほとんどの精液は行き場を無くし、睾丸の中へ戻されてしまった。",
      "zh": ""
    },
    {
      "key": "255.0",
      "line_index": 255,
      "inline_index": 0,
      "line_hash": "d5634cd0",
      "speaker": "メイズ",
      "ja": "あはははっ♥　おちんぽ穴ズボズボでイっちゃったね～っ♥　嫌がってきたクセに身体は……おちんぽはしょーじきだねぇ～♥",
      "zh": ""
    },
    {
      "key": "258.0",
      "line_index": 258,
      "inline_index": 0,
      "line_hash": "e100f24",
      "speaker": "メイズ",
      "ja": "うり、うりっ♥　こんな少ししか出ない射精じゃお兄さんも満足できないでしょ？♥　びゅーびゅー出しなよ♥　あははははっ♥",
      "zh": ""
    },
    {
      "key": "261.0",
      "line_index": 261,
      "inline_index": 0,
      "line_hash": "59dd9009",
      "speaker": "{G_PlayerName}",
      "ja": "んぎ、ぎぃぃぃっ！！　棒、棒抜いてくれぇええっ！！　あおおおおっ！！",
      "zh": ""
    },
    {
      "key": "264.0",
      "line_index": 264,
      "inline_index": 0,
      "line_hash": "8d02aff",
      "speaker": "",
      "ja": "メイズは俺を揶揄う様に尿道を穿り、再び熱いモノが睾丸からこみ上げる。",
      "zh": ""
    },
    {
      "key": "265.0",
      "line_index": 265,
      "inline_index": 0,
      "line_hash": "988d8ae4",
      "speaker": "",
      "ja": "しかし今度は少しも精液が出ず、またも睾丸に精液が戻っていってしまう。",
      "zh": ""
    },
    {
      "key": "267.0",
      "line_index": 267,
      "inline_index": 0,
      "line_hash": "c3cb2c20",
      "speaker": "",
      "ja": "射精できない苦しみに悶絶し、どうにか精液を吐き出そうと腰に力を入れる。",
      "zh": ""
    },
    {
      "key": "268.0",
      "line_index": 268,
      "inline_index": 0,
      "line_hash": "7c892110",
      "speaker": "",
      "ja": "しかしメイズは陰茎の根元をぎゅっと握りしめ、完全に射精できなくしてくる。",
      "zh": ""
    },
    {
      "key": "271.0",
      "line_index": 271,
      "inline_index": 0,
      "line_hash": "bdb0e13e",
      "speaker": "メイズ",
      "ja": "悶絶するお兄さん、かっわい～っ♥　もっとお兄さんのおちんぽ気持ち良くしてあげる♥",
      "zh": ""
    },
    {
      "key": "274.0",
      "line_index": 274,
      "inline_index": 0,
      "line_hash": "fea466",
      "speaker": "メイズ",
      "ja": "お兄さんのおちんぽ、あたしじゃなきゃ射精できないようにしてあげるから♥",
      "zh": ""
    },
    {
      "key": "280.0",
      "line_index": 280,
      "inline_index": 0,
      "line_hash": "3b4c99b8",
      "speaker": "{G_PlayerName}",
      "ja": "ぐぅぅっ！？　うう、メイズ、やめ゛っ……！！　ぐ、ぐうう、ううううぅっ！！",
      "zh": ""
    },
    {
      "key": "283.0",
      "line_index": 283,
      "inline_index": 0,
      "line_hash": "34da408c",
      "speaker": "",
      "ja": "メイズは尿道へのピストンを再開すると同時に、カリ首を手のひらで擦り始める。",
      "zh": ""
    },
    {
      "key": "285.0",
      "line_index": 285,
      "inline_index": 0,
      "line_hash": "3dbda13",
      "speaker": "",
      "ja": "中と外から同時に違う快感が広がり、追いつかない思考がさらにパニックになっていく。",
      "zh": ""
    },
    {
      "key": "287.0",
      "line_index": 287,
      "inline_index": 0,
      "line_hash": "8ff17d9d",
      "speaker": "",
      "ja": "もう完全に身体には力が入らず、快感のみが俺の心と身体を支配する。",
      "zh": ""
    },
    {
      "key": "288.0",
      "line_index": 288,
      "inline_index": 0,
      "line_hash": "dd01946e",
      "speaker": "",
      "ja": "抵抗する意思はわずかに残っていたが、身動きできない身体でひたすらに悲鳴を漏らし続けた。",
      "zh": ""
    },
    {
      "key": "291.0",
      "line_index": 291,
      "inline_index": 0,
      "line_hash": "6d8d33e7",
      "speaker": "メイズ",
      "ja": "おちんぽの中と外……同時に責められるのってどんな感じ？♥　ほらほら、教えてよ～っ♥",
      "zh": ""
    },
    {
      "key": "294.0",
      "line_index": 294,
      "inline_index": 0,
      "line_hash": "cfd0fcb0",
      "speaker": "{G_PlayerName}",
      "ja": "ぎ、んぎっ！　ふう、ふううっ……う゛っ！　く、ぐう、んんん……！！",
      "zh": ""
    },
    {
      "key": "297.0",
      "line_index": 297,
      "inline_index": 0,
      "line_hash": "5e88e193",
      "speaker": "",
      "ja": "棒をピストンさせるたびに射精に似た快感が走る。",
      "zh": ""
    },
    {
      "key": "298.0",
      "line_index": 298,
      "inline_index": 0,
      "line_hash": "b10cb808",
      "speaker": "",
      "ja": "メイズはニヤニヤしながら手慣れた手つきで執拗にカリ首を扱き上げる。",
      "zh": ""
    },
    {
      "key": "301.0",
      "line_index": 301,
      "inline_index": 0,
      "line_hash": "5a26bf9d",
      "speaker": "メイズ",
      "ja": "カウパーすっご……♥　こんなに出る人初めて見たかも♥　ほらぁ、おちんぽどんだけ濡れているか自分でもわかるでしょ？♥",
      "zh": ""
    },
    {
      "key": "304.0",
      "line_index": 304,
      "inline_index": 0,
      "line_hash": "5c0636",
      "speaker": "メイズ",
      "ja": "ぬるぬるのカウパーとせーしをぬりぬりぬり～っ♥",
      "zh": ""
    },
    {
      "key": "306.0",
      "line_index": 306,
      "inline_index": 0,
      "line_hash": "cb1c2e98",
      "speaker": "",
      "ja": "メイズは指で輪を作ると、カリを沿うように指を回転させる。",
      "zh": ""
    },
    {
      "key": "307.0",
      "line_index": 307,
      "inline_index": 0,
      "line_hash": "99eabda0",
      "speaker": "",
      "ja": "あまりの快感に腰が勝手に浮かび上がり、喉の奥から搾り出したような声が漏れる。",
      "zh": ""
    },
    {
      "key": "309.0",
      "line_index": 309,
      "inline_index": 0,
      "line_hash": "71257b36",
      "speaker": "",
      "ja": "その間も尿道を穿る手は止まらず、頭の中が真っ白に混濁していく。",
      "zh": ""
    },
    {
      "key": "310.0",
      "line_index": 310,
      "inline_index": 0,
      "line_hash": "8e52bc5f",
      "speaker": "",
      "ja": "ぼやけていく視界に今が現実なのか、それとも夢なのか……その判断すらつかなくなりつつあった。",
      "zh": ""
    },
    {
      "key": "313.0",
      "line_index": 313,
      "inline_index": 0,
      "line_hash": "5a1042a0",
      "speaker": "メイズ",
      "ja": "おちんぽホジホジも良いけどさぁ、やっぱ一番感じるのはココだよね～♥　でもこういう感覚はお兄さん慣れているでしょ？♥",
      "zh": ""
    },
    {
      "key": "316.0",
      "line_index": 316,
      "inline_index": 0,
      "line_hash": "a4708316",
      "speaker": "メイズ",
      "ja": "経験豊富そうだからねぇ～……♥　ねぇ、今までどれだけの女の子を抱いてきたのかな？♥　幼馴染のコハルちゃんは当然として、もうルミナ様は食べちゃったのかな？♥",
      "zh": ""
    },
    {
      "key": "319.0",
      "line_index": 319,
      "inline_index": 0,
      "line_hash": "92594458",
      "speaker": "メイズ",
      "ja": "お付きの雫ともヤっちゃった？♥　ねぇねぇ、教えてよ～っ♥　減るもんじゃないんだからさぁ～っ♥",
      "zh": ""
    },
    {
      "key": "322.0",
      "line_index": 322,
      "inline_index": 0,
      "line_hash": "73952e0b",
      "speaker": "{G_PlayerName}",
      "ja": "そ、そんなこと……おうっ！　す、するはずが……あうううっ！",
      "zh": ""
    },
    {
      "key": "326.0",
      "line_index": 326,
      "inline_index": 0,
      "line_hash": "d6522cdb",
      "speaker": "メイズ",
      "ja": "ウソついちゃダメだよっ♥　宇宙船の中に男女がいて何もしないはずないじゃんっ♥　お兄さんをラブラブに慕ってるルミナ様に、好き好きオーラ全開のコハルちゃん♥",
      "zh": ""
    },
    {
      "key": "329.0",
      "line_index": 329,
      "inline_index": 0,
      "line_hash": "fcba81a0",
      "speaker": "メイズ",
      "ja": "その二人を相手に手を出さないなんて男としてありえないって♥　ほらぁ、言っちゃえよ～っ♥　どんくらいヤったの？♥　どっちのセックスが良かったの？♥",
      "zh": ""
    },
    {
      "key": "332.0",
      "line_index": 332,
      "inline_index": 0,
      "line_hash": "59d88217",
      "speaker": "メイズ",
      "ja": "あっ……♥　なんだかおちんぽさらにおっきくなってきてるような……？♥　二人とエッチするの思い出しちゃったのかな？♥",
      "zh": ""
    },
    {
      "key": "335.0",
      "line_index": 335,
      "inline_index": 0,
      "line_hash": "4c7f83ae",
      "speaker": "メイズ",
      "ja": "でもさぁ……二人はこんな感じにおちんぽホジホジしてくれないでしょ？♥　今よりも気持ち良いって思えないでしょ？♥",
      "zh": ""
    },
    {
      "key": "338.0",
      "line_index": 338,
      "inline_index": 0,
      "line_hash": "a068bb7f",
      "speaker": "メイズ",
      "ja": "とーぜんだよね～♥　だって男の一番弱いところイジメてんだもん♥　どんな屈強な男でもこの快感には抗えないんだよ♥",
      "zh": ""
    },
    {
      "key": "341.0",
      "line_index": 341,
      "inline_index": 0,
      "line_hash": "dc16a3f",
      "speaker": "{G_PlayerName}",
      "ja": "好き勝手に……いいやがってぇ……ぐうううっ！？　うう、おぐ、おぐうううっ！　やめっ、あうううっ！！",
      "zh": ""
    },
    {
      "key": "345.0",
      "line_index": 345,
      "inline_index": 0,
      "line_hash": "c6320a17",
      "speaker": "メイズ",
      "ja": "くすっ♥　ここがおちんぽの一番奥♥　うりうりっ♥　感じろ感じろぉっ♥　ぐりぐりぐり～～っ！！♥",
      "zh": ""
    },
    {
      "key": "348.0",
      "line_index": 348,
      "inline_index": 0,
      "line_hash": "f446737d",
      "speaker": "{G_PlayerName}",
      "ja": "うう゛っ！！　うううううっ！！　ぐう、ぐうっ、う、ううううーーーっ！！",
      "zh": ""
    },
    {
      "key": "351.0",
      "line_index": 351,
      "inline_index": 0,
      "line_hash": "1f775e",
      "speaker": "",
      "ja": "尿道の最奥を執拗に穿られ、腰がビクンと何度も跳ね上がる。",
      "zh": ""
    },
    {
      "key": "352.0",
      "line_index": 352,
      "inline_index": 0,
      "line_hash": "a14dea52",
      "speaker": "",
      "ja": "メイズはさらに手コキの速度を早め、ぐちゅぐちゅと卑猥な音がどんどん大きくなる。",
      "zh": ""
    },
    {
      "key": "355.0",
      "line_index": 355,
      "inline_index": 0,
      "line_hash": "28721294",
      "speaker": "{G_PlayerName}",
      "ja": "ううっ！！　も、もう……ううううっ！！　うぐっ！　んぅ、んんんんっ！！",
      "zh": ""
    },
    {
      "key": "359.0",
      "line_index": 359,
      "inline_index": 0,
      "line_hash": "aa616733",
      "speaker": "メイズ",
      "ja": "くすっ♥　もう限界みたいだねぇ～っ♥　それじゃあそろそろ出そうか？♥　次はちゃんとぴゅっぴゅできるといいね～♥",
      "zh": ""
    },
    {
      "key": "362.0",
      "line_index": 362,
      "inline_index": 0,
      "line_hash": "4a84c5a5",
      "speaker": "メイズ",
      "ja": "ほら、イけっ♥　ルミナ様にもコハルちゃんにも見せられない、一番ダサくて情けないしゃせーをあたしに見せちゃえっ！！♥",
      "zh": ""
    },
    {
      "key": "369.0",
      "line_index": 369,
      "inline_index": 0,
      "line_hash": "18bac39d",
      "speaker": "{G_PlayerName}",
      "ja": "お゛っ！　おおっ！　んおおおおおっ！！",
      "zh": ""
    },
    {
      "key": "372.0",
      "line_index": 372,
      "inline_index": 0,
      "line_hash": "3e3d9e83",
      "speaker": "",
      "ja": "目の前がチカチカとして睾丸に疼きを感じた瞬間、塞がれている尿道から精液が噴き出す。",
      "zh": ""
    },
    {
      "key": "374.0",
      "line_index": 374,
      "inline_index": 0,
      "line_hash": "a7415b6",
      "speaker": "",
      "ja": "今まで感じたことの無い鈍くて重い絶頂の快感。",
      "zh": ""
    },
    {
      "key": "375.0",
      "line_index": 375,
      "inline_index": 0,
      "line_hash": "1718c776",
      "speaker": "",
      "ja": "俺は獣のように悲鳴を上げながら、ビクビクと痙攣しながら射精を繰り返した。",
      "zh": ""
    },
    {
      "key": "378.0",
      "line_index": 378,
      "inline_index": 0,
      "line_hash": "ed858325",
      "speaker": "メイズ",
      "ja": "おお～っ♥　すごいすごいっ♥　まるで噴水みたいに噴き出しちゃってるねぇ～っ♥",
      "zh": ""
    },
    {
      "key": "381.0",
      "line_index": 381,
      "inline_index": 0,
      "line_hash": "2191d21",
      "speaker": "メイズ",
      "ja": "尿道塞がれているのにこんなに出しちゃって……お兄さんって実はすごい？♥",
      "zh": ""
    },
    {
      "key": "384.0",
      "line_index": 384,
      "inline_index": 0,
      "line_hash": "1c346d25",
      "speaker": "{G_PlayerName}",
      "ja": "うううううっ！　やめ……おお、あおおおっ！！",
      "zh": ""
    },
    {
      "key": "387.0",
      "line_index": 387,
      "inline_index": 0,
      "line_hash": "4e6c1f63",
      "speaker": "",
      "ja": "メイズは執拗にカリ首をグリグリと捏ね精液を搾り取る。",
      "zh": ""
    },
    {
      "key": "388.0",
      "line_index": 388,
      "inline_index": 0,
      "line_hash": "d4bad233",
      "speaker": "",
      "ja": "しかし先ほどの勢いもなく、扱き出された精液が強制的に睾丸へと戻されていく。",
      "zh": ""
    },
    {
      "key": "390.0",
      "line_index": 390,
      "inline_index": 0,
      "line_hash": "c15ca3b2",
      "speaker": "",
      "ja": "出せない苦しみに悶絶するように俺は両脚をバタつかせる。",
      "zh": ""
    },
    {
      "key": "391.0",
      "line_index": 391,
      "inline_index": 0,
      "line_hash": "33bbfe7",
      "speaker": "",
      "ja": "それが面白いのかメイズの表情はさらにいやらしくなり、尿道をぐちゅぐちゅと穿り続けた。",
      "zh": ""
    },
    {
      "key": "394.0",
      "line_index": 394,
      "inline_index": 0,
      "line_hash": "1d01db5c",
      "speaker": "メイズ",
      "ja": "またまた中途半端なしゃせーだね～っ♥　次は頑張ってもっとびゅーびゅーしよっか～？♥",
      "zh": ""
    },
    {
      "key": "397.0",
      "line_index": 397,
      "inline_index": 0,
      "line_hash": "c5eacb70",
      "speaker": "{G_PlayerName}",
      "ja": "も、もうやめてくれぇ……ああああぁっ！！　だめだってぇええ……うう、ぐうっ！！",
      "zh": ""
    },
    {
      "key": "400.0",
      "line_index": 400,
      "inline_index": 0,
      "line_hash": "d2890b3f",
      "speaker": "",
      "ja": "メイズは再び尿道とカリ首を攻め、強烈すぎる快感に意識が飛び飛びになってしまう。",
      "zh": ""
    },
    {
      "key": "402.0",
      "line_index": 402,
      "inline_index": 0,
      "line_hash": "a515b5b3",
      "speaker": "",
      "ja": "俺の悲鳴などメイズの耳には一切入らない。",
      "zh": ""
    },
    {
      "key": "403.0",
      "line_index": 403,
      "inline_index": 0,
      "line_hash": "a6660093",
      "speaker": "",
      "ja": "俺はもうどうすることもできず、執拗なメイズの攻めにただ悶絶し続けるのであった。",
      "zh": ""
    }
  ]
}
