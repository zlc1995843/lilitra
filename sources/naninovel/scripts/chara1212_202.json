{
  "lines": [
    {
      "key": "17.1",
      "line_index": 17,
      "inline_index": 1,
      "line_hash": "73e17ce6",
      "speaker": "マロウ",
      "ja": "んお゛っ！♥　またぁ……あううううっ！！♥♥　んふぅーっ！♥　ふーっ！♥　ふうううっ！！♥♥",
      "zh": ""
    },
    {
      "key": "19.0",
      "line_index": 19,
      "inline_index": 0,
      "line_hash": "db2cdd40",
      "speaker": "",
      "ja": "完全にタガが外れた俺たちは交尾し合うケモノのようにお互いを求めた。",
      "zh": ""
    },
    {
      "key": "21.0",
      "line_index": 21,
      "inline_index": 0,
      "line_hash": "1e298b21",
      "speaker": "",
      "ja": "もうマロウのあそこに何度中出ししたのか自分でもわからない。",
      "zh": ""
    },
    {
      "key": "22.0",
      "line_index": 22,
      "inline_index": 0,
      "line_hash": "81f9ca11",
      "speaker": "",
      "ja": "子宮はすでにパンパンになるほど白濁したモノを注ぎ込み、収まり切れない精液が小さな膣穴から大量に溢れる。",
      "zh": ""
    },
    {
      "key": "24.0",
      "line_index": 24,
      "inline_index": 0,
      "line_hash": "6167e80a",
      "speaker": "",
      "ja": "マロウに種付けをしている、その事実だけで俺の肉棒はたぎり、睾丸は無尽蔵に精液を作り出す。",
      "zh": ""
    },
    {
      "key": "26.0",
      "line_index": 26,
      "inline_index": 0,
      "line_hash": "6623d8ef",
      "speaker": "",
      "ja": "でもどれだけマロウと行為を重ねても一向に満足できない。",
      "zh": ""
    },
    {
      "key": "27.0",
      "line_index": 27,
      "inline_index": 0,
      "line_hash": "7b6a5252",
      "speaker": "",
      "ja": "すればするほどマロウが愛しくなり、マロウもどんどん女として発情していく。",
      "zh": ""
    },
    {
      "key": "30.1",
      "line_index": 30,
      "inline_index": 1,
      "line_hash": "36e6b36f",
      "speaker": "マロウ",
      "ja": "はぁ、はぁ♥　機械師、すごいっす……♥　おちんちんずっとカチカチのままっす……♥",
      "zh": ""
    },
    {
      "key": "33.0",
      "line_index": 33,
      "inline_index": 0,
      "line_hash": "cc252a4a",
      "speaker": "{G_PlayerName}",
      "ja": "マロウがエロ可愛すぎてもう収まりがつかねえ……いったいいつになったら俺の元に戻るんだ……",
      "zh": ""
    },
    {
      "key": "37.1",
      "line_index": 37,
      "inline_index": 1,
      "line_hash": "7db32521",
      "speaker": "マロウ",
      "ja": "一生戻る必要なんてないっす……♥　マロウは今の方が幸せでたまらないっすよ……♥",
      "zh": ""
    },
    {
      "key": "39.0",
      "line_index": 39,
      "inline_index": 0,
      "line_hash": "e268c979",
      "speaker": "",
      "ja": "マロウは俺の睾丸に鼻をくっつけ、くんくんと匂いを嗅ぐ。",
      "zh": ""
    },
    {
      "key": "40.0",
      "line_index": 40,
      "inline_index": 0,
      "line_hash": "4c4f7fe6",
      "speaker": "",
      "ja": "なんともいやらしい光景に俺の肉竿がビクンと跳ね、睾丸の中がぐつぐつと煮えたぎっていくのが自分でもはっきりとわかってしまう。",
      "zh": ""
    },
    {
      "key": "43.1",
      "line_index": 43,
      "inline_index": 1,
      "line_hash": "c8b247f0",
      "speaker": "マロウ",
      "ja": "アンタのおちんちん、二人のエッチなのが混ざって……エロエロな匂いっす……♥　匂いを嗅いでいるだけであそこが疼いて……♥",
      "zh": ""
    },
    {
      "key": "57.0",
      "line_index": 57,
      "inline_index": 0,
      "line_hash": "44659764",
      "speaker": "マロウ",
      "ja": "はぁ、はぁ……この匂いたまらないっす……♥　自分がこんなに男を欲しがってしまうなんて思ってもいなかったっす……♥",
      "zh": ""
    },
    {
      "key": "59.0",
      "line_index": 59,
      "inline_index": 0,
      "line_hash": "9f63a111",
      "speaker": "",
      "ja": "マロウは睾丸の匂いを嗅ぎ、俺は気恥ずかしさとなんとも言えない快感にゾクゾクと身体を震わせる。",
      "zh": ""
    },
    {
      "key": "62.0",
      "line_index": 62,
      "inline_index": 0,
      "line_hash": "9d59f5f5",
      "speaker": "マロウ",
      "ja": "くんくん……この匂い、マジヤバいっす……♥　マロウ、完全に機械師にメロメロっす……♥　一番大切な宝物を見つけてしまったみたいっすよ♥",
      "zh": ""
    },
    {
      "key": "64.0",
      "line_index": 64,
      "inline_index": 0,
      "line_hash": "534e4d7f",
      "speaker": "",
      "ja": "マロウが睾丸の匂いを嗅ぐたびに目を細め、身体をゾクゾクと震わせる。",
      "zh": ""
    },
    {
      "key": "66.0",
      "line_index": 66,
      "inline_index": 0,
      "line_hash": "89164eb4",
      "speaker": "",
      "ja": "まるでマロウにマーキングをしているように錯覚してし、マロウに奉仕させているようにすら思えてきてしまう。",
      "zh": ""
    },
    {
      "key": "67.0",
      "line_index": 67,
      "inline_index": 0,
      "line_hash": "5cba32c4",
      "speaker": "",
      "ja": "それだけマロウは俺の中のオスを刺激し、肉棒がいつまでも勃起し続けてしまっていた。",
      "zh": ""
    },
    {
      "key": "70.0",
      "line_index": 70,
      "inline_index": 0,
      "line_hash": "8fb9202f",
      "speaker": "マロウ",
      "ja": "なんだか機械師のおちんちん、さらにすごくなってきてるっす……♥　血管とか何本も浮き上がって……マロウを征服してやるぞって言っているみたいっす♥",
      "zh": ""
    },
    {
      "key": "73.0",
      "line_index": 73,
      "inline_index": 0,
      "line_hash": "703d6b89",
      "speaker": "{G_PlayerName}",
      "ja": "正直に言えばそう思ってるよ……マロウのすべてを俺のモノにしてやるって、奪ってやるって……マロウの心も身体もすべて征服してやるって……",
      "zh": ""
    },
    {
      "key": "77.0",
      "line_index": 77,
      "inline_index": 0,
      "line_hash": "be23a326",
      "speaker": "マロウ",
      "ja": "ふふふ……なんだかアンタの方が海賊らしいっすね……♥　でもそう言われるの、すごく嬉しいっす……♥",
      "zh": ""
    },
    {
      "key": "80.0",
      "line_index": 80,
      "inline_index": 0,
      "line_hash": "ccf6e8d3",
      "speaker": "マロウ",
      "ja": "でも勘違いしないでほしいっす♥　マロウもアンタを征服してやるっす♥　アンタの人生、海賊らしくマロウがすべて奪ってやるっす♥",
      "zh": ""
    },
    {
      "key": "83.0",
      "line_index": 83,
      "inline_index": 0,
      "line_hash": "61f49ad8",
      "speaker": "マロウ",
      "ja": "誰にもアンタのこと渡さないっす……お姫様にも幼馴染にも、おやびんにだって……♥",
      "zh": ""
    },
    {
      "key": "89.0",
      "line_index": 89,
      "inline_index": 0,
      "line_hash": "1ea5e081",
      "speaker": "マロウ",
      "ja": "れるぅ……れろっ♥　れろれろ……♥　れちゅ、れるんっ♥",
      "zh": ""
    },
    {
      "key": "92.0",
      "line_index": 92,
      "inline_index": 0,
      "line_hash": "8f953e5b",
      "speaker": "{G_PlayerName}",
      "ja": "ああ、いくらでも……んぅ、奪ってくれ……く……！！　うう……！！",
      "zh": ""
    },
    {
      "key": "95.0",
      "line_index": 95,
      "inline_index": 0,
      "line_hash": "6818fd4f",
      "speaker": "",
      "ja": "マロウの小さな舌が睾丸に触れ、中の精巣をレロレロと舐め始める。",
      "zh": ""
    },
    {
      "key": "96.0",
      "line_index": 96,
      "inline_index": 0,
      "line_hash": "c248b07d",
      "speaker": "",
      "ja": "ゾクっとした快感と甘い快感が同時に起き、何よりもマロウが俺の舐めている、その事実だけで心が興奮と幸せで満ちていく。",
      "zh": ""
    },
    {
      "key": "98.0",
      "line_index": 98,
      "inline_index": 0,
      "line_hash": "da16f2f5",
      "speaker": "",
      "ja": "先ほどまでのような求めあう激しさは無い、それでも心は充実し、それがより強い快感となっていく。",
      "zh": ""
    },
    {
      "key": "101.0",
      "line_index": 101,
      "inline_index": 0,
      "line_hash": "b2dc2a78",
      "speaker": "マロウ",
      "ja": "ふふふ……♥　機械師もそんなカワイイ声出せるんすね♥　んぅ、んぅ、おちんちんも、たまたまもお疲れっす……♥",
      "zh": ""
    },
    {
      "key": "104.0",
      "line_index": 104,
      "inline_index": 0,
      "line_hash": "129291e4",
      "speaker": "マロウ",
      "ja": "でもまだまだ働いてもらうっすからね♥　海賊の世界はハードなんすから♥　れろぉ、れろ、れる……ちゅちゅ、れるううっ！♥",
      "zh": ""
    },
    {
      "key": "106.0",
      "line_index": 106,
      "inline_index": 0,
      "line_hash": "8c234c3",
      "speaker": "",
      "ja": "マロウの舌の動きがどんどん大きくなり、中の精巣を転がすように舌が蠢く。",
      "zh": ""
    },
    {
      "key": "107.0",
      "line_index": 107,
      "inline_index": 0,
      "line_hash": "9a04b3a9",
      "speaker": "",
      "ja": "唇を押し当てタマを吸われるたびに喉の奥からヘンな声が溢れ、睾丸を揉む指の動きもどんどん大きくなる。",
      "zh": ""
    },
    {
      "key": "109.0",
      "line_index": 109,
      "inline_index": 0,
      "line_hash": "110ee5b2",
      "speaker": "",
      "ja": "搾り出されるように先走りがどぷりと肉竿の先端から溢れ、マロウの綺麗な髪がネトネトになっていく。",
      "zh": ""
    },
    {
      "key": "112.0",
      "line_index": 112,
      "inline_index": 0,
      "line_hash": "b0fd88b7",
      "speaker": "マロウ",
      "ja": "でも、改めて見ると、とんでもない量の精液出されたっすね……♥　これ絶対に受精してるっすよ……♥",
      "zh": ""
    },
    {
      "key": "115.0",
      "line_index": 115,
      "inline_index": 0,
      "line_hash": "3416b1f",
      "speaker": "マロウ",
      "ja": "マロウ、はっきりとわかるっす……アンタの子種がビチビチ元気に跳ねて、マロウの卵子に突撃してきてるのが……♥",
      "zh": ""
    },
    {
      "key": "118.0",
      "line_index": 118,
      "inline_index": 0,
      "line_hash": "fe19138f",
      "speaker": "マロウ",
      "ja": "本当にいけないおちんちんっす……♥　女の子にこんなに中出しして……あむぅっ♥",
      "zh": ""
    },
    {
      "key": "121.0",
      "line_index": 121,
      "inline_index": 0,
      "line_hash": "51013128",
      "speaker": "{G_PlayerName}",
      "ja": "あおおぅ！？　ぐう、マロウ……！！　ああ、それいい……！！　く、ううう……！！",
      "zh": ""
    },
    {
      "key": "124.0",
      "line_index": 124,
      "inline_index": 0,
      "line_hash": "3d733bd1",
      "speaker": "",
      "ja": "マロウは唇で睾丸を甘噛みし、強烈な快感に両足がガクガクと勝手に震える。",
      "zh": ""
    },
    {
      "key": "125.0",
      "line_index": 125,
      "inline_index": 0,
      "line_hash": "32b8881f",
      "speaker": "",
      "ja": "俺の反応に気を良くしたのか、睾丸を吸い、舐め、そして転がす。",
      "zh": ""
    },
    {
      "key": "126.0",
      "line_index": 126,
      "inline_index": 0,
      "line_hash": "3f82ab07",
      "speaker": "",
      "ja": "リズミカルな唇と舌の動きに俺は翻弄され、もっとしてくれと催促するようにマロウの頭をそっと撫でていく。",
      "zh": ""
    },
    {
      "key": "129.0",
      "line_index": 129,
      "inline_index": 0,
      "line_hash": "ba9093dc",
      "speaker": "マロウ",
      "ja": "精液、たくさん作るっす……♥　もっとマロウを愛して欲しいっす……♥　れる、れるぅ♥　マロウのすべてを真っ白にして欲しいっすよ……ちゅっ♥　ちゅううっ♥",
      "zh": ""
    },
    {
      "key": "132.0",
      "line_index": 132,
      "inline_index": 0,
      "line_hash": "bd4cd653",
      "speaker": "{G_PlayerName}",
      "ja": "ううう……！！　マロウ、ヤバイ……！！　また出る……！！",
      "zh": ""
    },
    {
      "key": "136.0",
      "line_index": 136,
      "inline_index": 0,
      "line_hash": "1b5e2d56",
      "speaker": "マロウ",
      "ja": "いいっすよ♥　このまま出すっす♥　マロウがタマタマから搾り出してやるっす♥　れろぉっ！♥　れるれるれるんっ♥",
      "zh": ""
    },
    {
      "key": "139.0",
      "line_index": 139,
      "inline_index": 0,
      "line_hash": "9b122d12",
      "speaker": "{G_PlayerName}",
      "ja": "マロウ……！！　くっ、うう、出るぅっ！！",
      "zh": ""
    },
    {
      "key": "149.0",
      "line_index": 149,
      "inline_index": 0,
      "line_hash": "a2837157",
      "speaker": "マロウ",
      "ja": "あふぅっ！♥　ふあ、あああ、また出てるっすぅ♥　子種いっぱい……♥　うれしいっす……♥　あむぅっ！♥",
      "zh": ""
    },
    {
      "key": "152.0",
      "line_index": 152,
      "inline_index": 0,
      "line_hash": "11ae87c",
      "speaker": "{G_PlayerName}",
      "ja": "ぐ、ううう！！　ああぁ、それダメだってぇ……！　うううう！！",
      "zh": ""
    },
    {
      "key": "155.0",
      "line_index": 155,
      "inline_index": 0,
      "line_hash": "8447d57a",
      "speaker": "",
      "ja": "ドピュンとはじけ飛ぶように精液が溢れ、マロウの綺麗な髪を真っ白に汚していく。",
      "zh": ""
    },
    {
      "key": "156.0",
      "line_index": 156,
      "inline_index": 0,
      "line_hash": "ca917f5f",
      "speaker": "",
      "ja": "びちゃびちゃとシャワーのように精液が降り注ぎ、真っ白に汚されていくことにうっとりとした視線を向ける。",
      "zh": ""
    },
    {
      "key": "158.0",
      "line_index": 158,
      "inline_index": 0,
      "line_hash": "47839f17",
      "speaker": "",
      "ja": "しかしそれでは全然物足りないのか、マロウは睾丸を甘噛みし続け、指を動かし精液を強制的に外へと押し出していく。",
      "zh": ""
    },
    {
      "key": "161.0",
      "line_index": 161,
      "inline_index": 0,
      "line_hash": "b2fd2fad",
      "speaker": "マロウ",
      "ja": "ああぁぁ……♥　精液の匂い嗅いでいたら、またおまんこきゅんきゅん鳴いてるっす……♥　もう子宮パンパンなのにまだ精液欲しがってるっす……♥",
      "zh": ""
    },
    {
      "key": "164.0",
      "line_index": 164,
      "inline_index": 0,
      "line_hash": "8a97a079",
      "speaker": "{G_PlayerName}",
      "ja": "強欲、だな……さすが海賊だよ……",
      "zh": ""
    },
    {
      "key": "168.0",
      "line_index": 168,
      "inline_index": 0,
      "line_hash": "95420d05",
      "speaker": "マロウ",
      "ja": "アンタも人のこと言えないっすよ……♥　堅気にしておくには惜しいくらい独占欲が強い男っす……♥",
      "zh": ""
    },
    {
      "key": "171.0",
      "line_index": 171,
      "inline_index": 0,
      "line_hash": "c259ba0a",
      "speaker": "マロウ",
      "ja": "マロウを汚したいってタマタマがまた精液作ってるっす……♥　もっと……もっと出すっすよ♥　アンタの匂いが取れなくなるくらい、マロウを汚すっす……♥",
      "zh": ""
    },
    {
      "key": "177.0",
      "line_index": 177,
      "inline_index": 0,
      "line_hash": "4e7bf0dc",
      "speaker": "マロウ",
      "ja": "んっ……！♥　んふぅ、んちゅるぅっ！♥　れるれるっ♥　れろぉ、れちゅ、ちゅうううっ！！♥",
      "zh": ""
    },
    {
      "key": "179.0",
      "line_index": 179,
      "inline_index": 0,
      "line_hash": "14eafc1",
      "speaker": "",
      "ja": "マロウは再び睾丸を唇と舌で転がし、手のひらで睾丸を揉み解す。",
      "zh": ""
    },
    {
      "key": "180.0",
      "line_index": 180,
      "inline_index": 0,
      "line_hash": "6d101d16",
      "speaker": "",
      "ja": "自分自身も我慢できなくなったのか、精液まみれのあそこを指でぐちゅぐちゅと弄る。",
      "zh": ""
    },
    {
      "key": "182.0",
      "line_index": 182,
      "inline_index": 0,
      "line_hash": "61126807",
      "speaker": "",
      "ja": "睾丸を舐めるちゅぱちゅぱ音、精液と愛液を掻き回すいやらしい水音、二つの卑猥な音が部屋中に響き、その音にすら俺は興奮してしまう。",
      "zh": ""
    },
    {
      "key": "185.0",
      "line_index": 185,
      "inline_index": 0,
      "line_hash": "b348659d",
      "speaker": "マロウ",
      "ja": "受精まんこ、ぐちゅぐちゅするの気持ち良いっす……！♥　今までのどんなオナニーよりも感じてしまうっす……！♥",
      "zh": ""
    },
    {
      "key": "188.0",
      "line_index": 188,
      "inline_index": 0,
      "line_hash": "7dd40050",
      "speaker": "{G_PlayerName}",
      "ja": "うう……！　オナニー……マロウが、オナニー……うう……！！",
      "zh": ""
    },
    {
      "key": "192.0",
      "line_index": 192,
      "inline_index": 0,
      "line_hash": "c4c0bec3",
      "speaker": "マロウ",
      "ja": "んぅ、んぅ♥　何を妄想しているっすか♥　いやらしい男っすね♥　でもマロウも人のこと言えないっすね♥",
      "zh": ""
    },
    {
      "key": "195.0",
      "line_index": 195,
      "inline_index": 0,
      "line_hash": "5553cd3e",
      "speaker": "マロウ",
      "ja": "アンタに愛されまくって、マロウも淫乱になってしまったす……♥　アンタ無しじゃもう生きて行けそうにないくらい必要としてしまっているっす♥",
      "zh": ""
    },
    {
      "key": "198.0",
      "line_index": 198,
      "inline_index": 0,
      "line_hash": "dbb0178f",
      "speaker": "{G_PlayerName}",
      "ja": "んぅぅ……！　俺も同じだから……マロウのいない世界なんて考えられない……。生きるのも死ぬのもマロウと一緒が良い……離れるなんて、絶対に……くっ！！",
      "zh": ""
    },
    {
      "key": "201.0",
      "line_index": 201,
      "inline_index": 0,
      "line_hash": "b555158c",
      "speaker": "",
      "ja": "俺が言葉を口にしていてもマロウの睾丸への愛撫は止まらず、より激しさを増していく。",
      "zh": ""
    },
    {
      "key": "203.0",
      "line_index": 203,
      "inline_index": 0,
      "line_hash": "c4a43d0a",
      "speaker": "",
      "ja": "あそこを弄る指がどんどん激しくなり、掻き出された精液がどろりと溢れる。",
      "zh": ""
    },
    {
      "key": "204.0",
      "line_index": 204,
      "inline_index": 0,
      "line_hash": "cebd0c4",
      "speaker": "",
      "ja": "アナルまで精液が垂れ落ち、見ているだけで興奮で全身から汗が噴き出してしまう。",
      "zh": ""
    },
    {
      "key": "207.0",
      "line_index": 207,
      "inline_index": 0,
      "line_hash": "9c588e01",
      "speaker": "マロウ",
      "ja": "やっぱりもう指だけじゃ物足りないっす♥　アンタのこんなに大きなおちんちんで愛されまくって、マロウのおまんこ、完全にアンタのおちんちんの形になってるっす♥",
      "zh": ""
    },
    {
      "key": "210.0",
      "line_index": 210,
      "inline_index": 0,
      "line_hash": "5e18f6bc",
      "speaker": "{G_PlayerName}",
      "ja": "そうなるように……ぐっ！　掻き回しまくったからな……ああ、それいい……もっとグニグニ揉んでくれぇ……！！",
      "zh": ""
    },
    {
      "key": "214.0",
      "line_index": 214,
      "inline_index": 0,
      "line_hash": "f0cf232",
      "speaker": "マロウ",
      "ja": "わかったっす……♥　あぁ、タマタマのコリコリ、なんだかクセになる柔らかさっす……♥　ちゅ、ぢゅるぅ、ちゅちゅちゅぅ、ぢゅるるうううっ！！♥",
      "zh": ""
    },
    {
      "key": "216.0",
      "line_index": 216,
      "inline_index": 0,
      "line_hash": "9de46a43",
      "speaker": "",
      "ja": "マロウは睾丸に愛撫をし続け、俺の感じるところを把握したのか、的確に、かつ絶妙な加減で睾丸を愛撫する。",
      "zh": ""
    },
    {
      "key": "217.0",
      "line_index": 217,
      "inline_index": 0,
      "line_hash": "300bd647",
      "speaker": "",
      "ja": "俺の肉竿も睾丸も完全にマロウの手と唇と舌、そしてあそこに支配され、それ以外で射精しようとは微塵も思えなくなる。",
      "zh": ""
    },
    {
      "key": "219.0",
      "line_index": 219,
      "inline_index": 0,
      "line_hash": "672f0a54",
      "speaker": "",
      "ja": "肉竿は射精を求めビクンと大きく跳ね、大量の先走りをどろどろと先端から溢れさせる。",
      "zh": ""
    },
    {
      "key": "220.0",
      "line_index": 220,
      "inline_index": 0,
      "line_hash": "f6a75d33",
      "speaker": "",
      "ja": "また射精感がこみ上げ始め、俺は喉の奥から搾り出したような声を口から漏らし続けていた。",
      "zh": ""
    },
    {
      "key": "223.0",
      "line_index": 223,
      "inline_index": 0,
      "line_hash": "10689c64",
      "speaker": "マロウ",
      "ja": "アンタの感じている声、ゾクゾクするっす……♥　はぁ、はぁ♥　好きな人に奉仕するのがこんなにも気持ち良くてドキドキするものだなんて思ってもいなかったっす……♥",
      "zh": ""
    },
    {
      "key": "226.0",
      "line_index": 226,
      "inline_index": 0,
      "line_hash": "48d521bb",
      "speaker": "マロウ",
      "ja": "もっとマロウで感じるっすよ……♥　アンタを一番気持ち良くさせられるのは宇宙でマロウだけっす♥　ぢゅぢゅぢゅっ♥　ぢゅるうううっ！！♥",
      "zh": ""
    },
    {
      "key": "229.0",
      "line_index": 229,
      "inline_index": 0,
      "line_hash": "8e45f10f",
      "speaker": "{G_PlayerName}",
      "ja": "マロウ……！　うう、うううう……！！",
      "zh": ""
    },
    {
      "key": "232.0",
      "line_index": 232,
      "inline_index": 0,
      "line_hash": "bb9d612e",
      "speaker": "",
      "ja": "目の前がチカチカとし始め、思考が完全に射精一色へと変わっていく。",
      "zh": ""
    },
    {
      "key": "235.0",
      "line_index": 235,
      "inline_index": 0,
      "line_hash": "82874fc2",
      "speaker": "マロウ",
      "ja": "いいっすよ、また出すっす♥　マロウにいっぱいぶっかけるっす♥　マロウをいっぱいの精液で汚すっすよっ♥",
      "zh": ""
    },
    {
      "key": "244.0",
      "line_index": 244,
      "inline_index": 0,
      "line_hash": "ac116b77",
      "speaker": "{G_PlayerName}",
      "ja": "くうう、マロウ……！！　出るっ！！",
      "zh": ""
    },
    {
      "key": "248.0",
      "line_index": 248,
      "inline_index": 0,
      "line_hash": "c65fcbd9",
      "speaker": "マロウ",
      "ja": "ふあっ！♥　ああ、またいっぱい出てるっすぅ……！♥　すごい、真っ白なのがいっぱい～……！♥",
      "zh": ""
    },
    {
      "key": "250.0",
      "line_index": 250,
      "inline_index": 0,
      "line_hash": "76a614cf",
      "speaker": "",
      "ja": "俺は睾丸からせり上がってきたものを一気に吐き出し、再びマロウを精液で汚していく。",
      "zh": ""
    },
    {
      "key": "252.0",
      "line_index": 252,
      "inline_index": 0,
      "line_hash": "942ae311",
      "speaker": "",
      "ja": "俺はさらにマロウを汚そうと、肉竿を手に持ち、顔、胸、そして精液溢れるあそこへと精液をぶっかける。",
      "zh": ""
    },
    {
      "key": "253.0",
      "line_index": 253,
      "inline_index": 0,
      "line_hash": "5b8f7dd1",
      "speaker": "",
      "ja": "マロウにマーキングをしている……そのことが異様なまでの快感を呼び、脳まで蕩けそうな気持ち良さが俺を襲う。",
      "zh": ""
    },
    {
      "key": "256.0",
      "line_index": 256,
      "inline_index": 0,
      "line_hash": "b39094a",
      "speaker": "マロウ",
      "ja": "あふぅ、ふぅ♥　もっと……もっと出すっす……れるぅ、れるぅ……♥　もっとマロウに精液ぶっかけるっすよぉ……♥　ちゅちゅ、ちゅぅ……！♥",
      "zh": ""
    },
    {
      "key": "258.0",
      "line_index": 258,
      "inline_index": 0,
      "line_hash": "42ec9d93",
      "speaker": "",
      "ja": "マロウは自ら俺に汚されることを望むように射精しているにも関わらず、睾丸への愛撫を止めない。",
      "zh": ""
    },
    {
      "key": "259.0",
      "line_index": 259,
      "inline_index": 0,
      "line_hash": "82d2580e",
      "speaker": "",
      "ja": "精液が手と唇によって押し出され、頭の中が完全に真っ白になるほど俺は射精を繰り返していた。",
      "zh": ""
    },
    {
      "key": "262.0",
      "line_index": 262,
      "inline_index": 0,
      "line_hash": "40921bb3",
      "speaker": "マロウ",
      "ja": "はぁーっ♥　はぁ～っ♥　アンタ色に染め上げられる……たまらなく良い気分っすよぉ……♥　でもマロウのおまんこはイけないままっす……♥",
      "zh": ""
    },
    {
      "key": "265.0",
      "line_index": 265,
      "inline_index": 0,
      "line_hash": "f69892e4",
      "speaker": "マロウ",
      "ja": "もうもどかしくてヘンになりそうっす……♥　アンタのおちんちんで慰めてほしいっすよ……♥",
      "zh": ""
    },
    {
      "key": "268.0",
      "line_index": 268,
      "inline_index": 0,
      "line_hash": "e1ba2f52",
      "speaker": "{G_PlayerName}",
      "ja": "もちろんだ、まだまだ俺の性欲は尽きそうにない。いくらでも愛してあげるよ",
      "zh": ""
    },
    {
      "key": "271.0",
      "line_index": 271,
      "inline_index": 0,
      "line_hash": "bcf595e7",
      "speaker": "",
      "ja": "そっとマロウの頭を撫でると、嬉しそうに目を細める。",
      "zh": ""
    },
    {
      "key": "272.0",
      "line_index": 272,
      "inline_index": 0,
      "line_hash": "64f00e93",
      "speaker": "",
      "ja": "そして射精を労わるように睾丸にキスを繰り返し、それが新たな活力となり肉棒を勃起させ続ける。",
      "zh": ""
    },
    {
      "key": "275.0",
      "line_index": 275,
      "inline_index": 0,
      "line_hash": "bde73c63",
      "speaker": "マロウ",
      "ja": "さぁもっと愛するっすよ……♥　マロウがいくらでも機械師を満足させてやるっすから……♥",
      "zh": ""
    },
    {
      "key": "277.0",
      "line_index": 277,
      "inline_index": 0,
      "line_hash": "90027a23",
      "speaker": "",
      "ja": "二人の熱い夜はまだまだ終わりそうにない。",
      "zh": ""
    },
    {
      "key": "278.0",
      "line_index": 278,
      "inline_index": 0,
      "line_hash": "fcec9662",
      "speaker": "",
      "ja": "そして今日を境に俺たちの関係は確実に変わる、そう確信しながら俺は再びマロウを求めるのであった。",
      "zh": ""
    }
  ]
}
