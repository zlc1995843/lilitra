{
  "lines": [
    {
      "key": "15.1",
      "line_index": 15,
      "inline_index": 1,
      "line_hash": "ff269447",
      "speaker": "トーリ",
      "ja": "はぁ……♥　はぁ……♥　はぁぁ……♥　あふぅぅぅ♥",
      "zh": ""
    },
    {
      "key": "17.0",
      "line_index": 17,
      "inline_index": 0,
      "line_hash": "f4c86288",
      "speaker": "",
      "ja": "散々愛撫でイかされたトーリは、息を荒げながらグッタリしてしまっていた。",
      "zh": ""
    },
    {
      "key": "19.0",
      "line_index": 19,
      "inline_index": 0,
      "line_hash": "1e703c9f",
      "speaker": "",
      "ja": "そのおまんこはすっかり蕩けきっていて愛液と潮でビチャビチャに濡れている。",
      "zh": ""
    },
    {
      "key": "21.0",
      "line_index": 21,
      "inline_index": 0,
      "line_hash": "61da764f",
      "speaker": "",
      "ja": "そんなトーリの姿に我慢出来なくなった{G_PlayerName}は服を脱ぎ捨てて勃起した陰茎を露わにさせた。",
      "zh": ""
    },
    {
      "key": "23.0",
      "line_index": 23,
      "inline_index": 0,
      "line_hash": "55f73cc6",
      "speaker": "",
      "ja": "それを見たトーリは{G_PlayerName}に甘えるような声で訴える。",
      "zh": ""
    },
    {
      "key": "26.1",
      "line_index": 26,
      "inline_index": 1,
      "line_hash": "abfc4610",
      "speaker": "トーリ",
      "ja": "服を……脱がして欲しいのじゃ……♥",
      "zh": ""
    },
    {
      "key": "29.0",
      "line_index": 29,
      "inline_index": 0,
      "line_hash": "a47012d9",
      "speaker": "{G_PlayerName}",
      "ja": "ああ、わかったよ……",
      "zh": ""
    },
    {
      "key": "32.0",
      "line_index": 32,
      "inline_index": 0,
      "line_hash": "fbf2d5a9",
      "speaker": "",
      "ja": "トーリの求めに応じるように、{G_PlayerName}はゆっくりと優しく服を脱がせていった。",
      "zh": ""
    },
    {
      "key": "34.0",
      "line_index": 34,
      "inline_index": 0,
      "line_hash": "669e29e6",
      "speaker": "",
      "ja": "そして互いに全裸になると{G_PlayerName}はトーリを抱きかかえるようにして自らの上へと導く。",
      "zh": ""
    },
    {
      "key": "37.1",
      "line_index": 37,
      "inline_index": 1,
      "line_hash": "def04e2d",
      "speaker": "トーリ",
      "ja": "んっ♥　あっ……うぬのマラが……わらわのほとに擦れて……あふぅ♥",
      "zh": ""
    },
    {
      "key": "39.0",
      "line_index": 39,
      "inline_index": 0,
      "line_hash": "d5335692",
      "speaker": "",
      "ja": "勃起したおちんちんが割れ目を擦り上げるとトーリの口から熱い吐息と共に喘ぎ声が漏れた。",
      "zh": ""
    },
    {
      "key": "41.0",
      "line_index": 41,
      "inline_index": 0,
      "line_hash": "2a7d74b",
      "speaker": "",
      "ja": "{G_PlayerName}は小さく腰を振って陰茎で濡れた割れ目を擦りつつ、そっと耳元で囁きかける。",
      "zh": ""
    },
    {
      "key": "44.0",
      "line_index": 44,
      "inline_index": 0,
      "line_hash": "93d5965d",
      "speaker": "{G_PlayerName}",
      "ja": "入れても……いいか？",
      "zh": ""
    },
    {
      "key": "48.1",
      "line_index": 48,
      "inline_index": 1,
      "line_hash": "4de143ff",
      "speaker": "トーリ",
      "ja": "ん……っ♥",
      "zh": ""
    },
    {
      "key": "50.0",
      "line_index": 50,
      "inline_index": 0,
      "line_hash": "deabced1",
      "speaker": "",
      "ja": "トーリは{G_PlayerName}の言葉に小さく頷いて答える。",
      "zh": ""
    },
    {
      "key": "52.0",
      "line_index": 52,
      "inline_index": 0,
      "line_hash": "ee7a6b88",
      "speaker": "",
      "ja": "それを見て{G_PlayerName}は亀頭を膣口へと押し当てると、そのままゆっくりと挿入していった。",
      "zh": ""
    },
    {
      "key": "66.0",
      "line_index": 66,
      "inline_index": 0,
      "line_hash": "61accc1",
      "speaker": "トーリ",
      "ja": "んっ……♥　んんっ♥　くるぅ♥　入って……あっ♥　あぁぁっ♥",
      "zh": ""
    },
    {
      "key": "68.0",
      "line_index": 68,
      "inline_index": 0,
      "line_hash": "d98837d9",
      "speaker": "",
      "ja": "すっかり蕩けたトーリのおまんこは、すんなりと{G_PlayerName}の勃起したおちんちんを呑み込んでしまう。",
      "zh": ""
    },
    {
      "key": "70.0",
      "line_index": 70,
      "inline_index": 0,
      "line_hash": "f24ccb58",
      "speaker": "",
      "ja": "奥まで挿入されたトーリは、繋がった事への喜びを感じながら笑みを浮かべて呟いた。",
      "zh": ""
    },
    {
      "key": "73.0",
      "line_index": 73,
      "inline_index": 0,
      "line_hash": "22e06dda",
      "speaker": "トーリ",
      "ja": "ふふっ♥　おぬしがわらわのおまんこを、ぐちゃぐちゃにしたから……すぐに奥まで入ってしまったのう……♥",
      "zh": ""
    },
    {
      "key": "76.0",
      "line_index": 76,
      "inline_index": 0,
      "line_hash": "fa512232",
      "speaker": "{G_PlayerName}",
      "ja": "ホント……ヌルヌルの襞がすごく気持ちいいよ……",
      "zh": ""
    },
    {
      "key": "79.0",
      "line_index": 79,
      "inline_index": 0,
      "line_hash": "9e27ffc2",
      "speaker": "",
      "ja": "互いに抱き合いながらそんなことを囁きあうと、しばらく繋がった感触を味わう。",
      "zh": ""
    },
    {
      "key": "81.0",
      "line_index": 81,
      "inline_index": 0,
      "line_hash": "cab2cd73",
      "speaker": "",
      "ja": "そして{G_PlayerName}は興奮した感じでトーリの耳元で囁きかけた。",
      "zh": ""
    },
    {
      "key": "84.0",
      "line_index": 84,
      "inline_index": 0,
      "line_hash": "ea5feea0",
      "speaker": "{G_PlayerName}",
      "ja": "動いて……いいか？",
      "zh": ""
    },
    {
      "key": "87.0",
      "line_index": 87,
      "inline_index": 0,
      "line_hash": "c3b2a889",
      "speaker": "",
      "ja": "その問いかけにトーリは少し恥ずかしそうな表情を浮かべながら小さく頷く。",
      "zh": ""
    },
    {
      "key": "90.0",
      "line_index": 90,
      "inline_index": 0,
      "line_hash": "c03e359c",
      "speaker": "トーリ",
      "ja": "もちろん構わぬぞ♥　わらわのおまんこを……奥まで突いてくれ♥",
      "zh": ""
    },
    {
      "key": "92.0",
      "line_index": 92,
      "inline_index": 0,
      "line_hash": "8be98f0c",
      "speaker": "",
      "ja": "そう言われた{G_PlayerName}はトーリを下から突き上げるように、ゆっくりと腰を動かし始めた。",
      "zh": ""
    },
    {
      "key": "99.0",
      "line_index": 99,
      "inline_index": 0,
      "line_hash": "1d7b46f2",
      "speaker": "トーリ",
      "ja": "んちゅっ♥　ぢゅるっ♥　ちゅっ♥　んぁぁ……腹の奥までずんずんくるぞ……♥",
      "zh": ""
    },
    {
      "key": "101.0",
      "line_index": 101,
      "inline_index": 0,
      "line_hash": "954b53db",
      "speaker": "",
      "ja": "{G_PlayerName}の抽送に興奮したトーリは舌を突き出しキスをしながら、うっとりとした感じでそう呟く。",
      "zh": ""
    },
    {
      "key": "103.0",
      "line_index": 103,
      "inline_index": 0,
      "line_hash": "e5f8245",
      "speaker": "",
      "ja": "それに応えるように{G_PlayerName}も舌を絡めつつ、リズミカルにピストンを繰り返していった。",
      "zh": ""
    },
    {
      "key": "106.0",
      "line_index": 106,
      "inline_index": 0,
      "line_hash": "3d8a9e1a",
      "speaker": "トーリ",
      "ja": "んっ♥　んっ♥　んふぅんっ♥　んはぁぁ♥　い、いいっ……おまんこの奥に当たって……ぢゅるるっ♥　すごくいいっ♥",
      "zh": ""
    },
    {
      "key": "108.0",
      "line_index": 108,
      "inline_index": 0,
      "line_hash": "9a969c",
      "speaker": "",
      "ja": "蕩けきった膣を陰茎が深々と貫く度に、グチュグチュという淫らな水音が響き渡る。",
      "zh": ""
    },
    {
      "key": "110.0",
      "line_index": 110,
      "inline_index": 0,
      "line_hash": "b1559dec",
      "speaker": "",
      "ja": "それにトーリの喘ぎ声が重なって{G_PlayerName}の興奮を煽った。",
      "zh": ""
    },
    {
      "key": "113.0",
      "line_index": 113,
      "inline_index": 0,
      "line_hash": "e2cb5e9",
      "speaker": "{G_PlayerName}",
      "ja": "うっ……ああっ……トーリ……",
      "zh": ""
    },
    {
      "key": "116.0",
      "line_index": 116,
      "inline_index": 0,
      "line_hash": "1fbbdb62",
      "speaker": "",
      "ja": "何度も下から突き上げる度にトーリのおまんこはヒクヒクと蠢き、出入りする勃起したおちんちんに強く吸いついていく。",
      "zh": ""
    },
    {
      "key": "118.0",
      "line_index": 118,
      "inline_index": 0,
      "line_hash": "7f93f080",
      "speaker": "",
      "ja": "そして濡れた柔襞が陰茎をしごき上げ、{G_PlayerName}に強い快感を与えた。",
      "zh": ""
    },
    {
      "key": "120.0",
      "line_index": 120,
      "inline_index": 0,
      "line_hash": "c4c14aaa",
      "speaker": "",
      "ja": "その快感に突き動かされるように{G_PlayerName}はキスをしながら徐々に激しくトーリの体を突き上げていく。",
      "zh": ""
    },
    {
      "key": "123.0",
      "line_index": 123,
      "inline_index": 0,
      "line_hash": "5c8d950e",
      "speaker": "トーリ",
      "ja": "はぁ♥　はぁ♥　あむぅぅ♥　んぢゅるぅ♥　んっ、んんんっ♥　あふぅぅ……あっ、あはぁぁんっ♥",
      "zh": ""
    },
    {
      "key": "125.0",
      "line_index": 125,
      "inline_index": 0,
      "line_hash": "8a035ae",
      "speaker": "",
      "ja": "熱い吐息と喘ぎ声を漏らしながら、トーリは{G_PlayerName}とのキスに夢中になっていた。",
      "zh": ""
    },
    {
      "key": "127.0",
      "line_index": 127,
      "inline_index": 0,
      "line_hash": "9a28ecc2",
      "speaker": "",
      "ja": "激しく舌を舐め合い唇の感触を味わいながらウットリとした表情を浮かべる。",
      "zh": ""
    },
    {
      "key": "130.0",
      "line_index": 130,
      "inline_index": 0,
      "line_hash": "2f914bdd",
      "speaker": "トーリ",
      "ja": "も、もっとぉ♥　もっといっぱいキスするのじゃ♥　あむぅぅ♥　んぢゅるぅ♥　んっ、むぅぅ♥　ぢゅるぢゅる♥",
      "zh": ""
    },
    {
      "key": "132.0",
      "line_index": 132,
      "inline_index": 0,
      "line_hash": "458d012c",
      "speaker": "",
      "ja": "唾液を交換するような濃厚なキスにトーリも{G_PlayerName}もすっかり盛り上がっていった。",
      "zh": ""
    },
    {
      "key": "134.0",
      "line_index": 134,
      "inline_index": 0,
      "line_hash": "38fbdb15",
      "speaker": "",
      "ja": "下からの突き上げはどんどん強く激しくなり、トーリの体が{G_PlayerName}の上で弾む。",
      "zh": ""
    },
    {
      "key": "136.0",
      "line_index": 136,
      "inline_index": 0,
      "line_hash": "eccc0dc2",
      "speaker": "",
      "ja": "その度に子宮を押し上げられて、トーリは強い快楽に呑み込まれていった。",
      "zh": ""
    },
    {
      "key": "139.0",
      "line_index": 139,
      "inline_index": 0,
      "line_hash": "3269902f",
      "speaker": "トーリ",
      "ja": "んんんっ♥　んふぅぅぅ♥　はぁ……♥　はぁ……♥　こんなに気持ちいいと……もうおかしくなってしまいそうじゃ♥",
      "zh": ""
    },
    {
      "key": "142.0",
      "line_index": 142,
      "inline_index": 0,
      "line_hash": "c07c3663",
      "speaker": "{G_PlayerName}",
      "ja": "お、俺も……んんんぅ……うっ……むぅぅ……",
      "zh": ""
    },
    {
      "key": "145.0",
      "line_index": 145,
      "inline_index": 0,
      "line_hash": "fd740de0",
      "speaker": "",
      "ja": "激しい抽送とキスを繰り返しているうちに、{G_PlayerName}は込み上げてくる感覚に襲われていく。",
      "zh": ""
    },
    {
      "key": "147.0",
      "line_index": 147,
      "inline_index": 0,
      "line_hash": "80366520",
      "speaker": "",
      "ja": "それはあまりにも強い衝動で堪えることができない。",
      "zh": ""
    },
    {
      "key": "150.0",
      "line_index": 150,
      "inline_index": 0,
      "line_hash": "8a380c3d",
      "speaker": "{G_PlayerName}",
      "ja": "くぅぅ……で、出る……っ",
      "zh": ""
    },
    {
      "key": "153.0",
      "line_index": 153,
      "inline_index": 0,
      "line_hash": "be415d4c",
      "speaker": "",
      "ja": "{G_PlayerName}は低く呻きながらそう呟くと、トーリの膣内に熱い精液をほとばしらせた。",
      "zh": ""
    },
    {
      "key": "162.0",
      "line_index": 162,
      "inline_index": 0,
      "line_hash": "5aee355f",
      "speaker": "トーリ",
      "ja": "はふっ、んぁ♥　だ、出しすぎじゃ、ばかもの♥",
      "zh": ""
    },
    {
      "key": "164.0",
      "line_index": 164,
      "inline_index": 0,
      "line_hash": "da9bafc0",
      "speaker": "",
      "ja": "そう言いつつもトーリはまんざらでもない表情を浮かべている。",
      "zh": ""
    },
    {
      "key": "166.0",
      "line_index": 166,
      "inline_index": 0,
      "line_hash": "a5b795af",
      "speaker": "",
      "ja": "どくんどくんと注ぎ込まれる大量の射精にトーリは眉を下げて涙を浮かべながらその感触を味わっていた。",
      "zh": ""
    },
    {
      "key": "169.0",
      "line_index": 169,
      "inline_index": 0,
      "line_hash": "cda878bd",
      "speaker": "トーリ",
      "ja": "んんんっ♥　まだ出ておるっ♥　おっ、ほおぉ♥",
      "zh": ""
    },
    {
      "key": "171.0",
      "line_index": 171,
      "inline_index": 0,
      "line_hash": "1358c4d3",
      "speaker": "",
      "ja": "全ての熱い精液を膣で受け止めたトーリはすっかり感じてしまっている。",
      "zh": ""
    },
    {
      "key": "173.0",
      "line_index": 173,
      "inline_index": 0,
      "line_hash": "bd79607c",
      "speaker": "",
      "ja": "しかし一度の射精ぐらいでは満足出来ないのか、射精を終えても{G_PlayerName}の陰茎は萎える気配がなかった。",
      "zh": ""
    },
    {
      "key": "176.0",
      "line_index": 176,
      "inline_index": 0,
      "line_hash": "1ce4cbe2",
      "speaker": "トーリ",
      "ja": "なんじゃ……まだし足りないのか？♥　こんなに出したのに……仕方のない奴じゃの♥",
      "zh": ""
    },
    {
      "key": "178.0",
      "line_index": 178,
      "inline_index": 0,
      "line_hash": "b66e9451",
      "speaker": "",
      "ja": "そう言いつつもトーリはまだまだ終わらない事に嬉しさを覚える。",
      "zh": ""
    },
    {
      "key": "180.0",
      "line_index": 180,
      "inline_index": 0,
      "line_hash": "547466c1",
      "speaker": "",
      "ja": "治まらない興奮に{G_PlayerName}は再び腰を突き出しトーリのおまんこを深く貫いていった。",
      "zh": ""
    },
    {
      "key": "186.0",
      "line_index": 186,
      "inline_index": 0,
      "line_hash": "fc04c331",
      "speaker": "トーリ",
      "ja": "あっ、あうぅ♥　ま、待て……そんなに激しくされるとキスできぬじゃろっ♥　んちゅぅぅ♥",
      "zh": ""
    },
    {
      "key": "188.0",
      "line_index": 188,
      "inline_index": 0,
      "line_hash": "dbe0eb9f",
      "speaker": "",
      "ja": "再開された抽送に翻弄されつつも、トーリは必死にキスをしながら甘い声で喘ぐ。",
      "zh": ""
    },
    {
      "key": "190.0",
      "line_index": 190,
      "inline_index": 0,
      "line_hash": "2a7f1ca",
      "speaker": "",
      "ja": "{G_PlayerName}はトーリのキスに応じながらも力強く下からズンズンと突き上げていった。",
      "zh": ""
    },
    {
      "key": "193.0",
      "line_index": 193,
      "inline_index": 0,
      "line_hash": "13e717bb",
      "speaker": "トーリ",
      "ja": "あむぅぅ♥　んぐんぐぅ♥　んぢゅるぅぅ♥　ぢゅぽぢゅぽ♥　おっ♥　おふぅぅ♥　んんんんんっ♥",
      "zh": ""
    },
    {
      "key": "196.0",
      "line_index": 196,
      "inline_index": 0,
      "line_hash": "3715b57",
      "speaker": "{G_PlayerName}",
      "ja": "はぁ……はぁ……トーリ……んむぅぅ……ぢゅるるぅ……んちゅっ、んむぅぅ……",
      "zh": ""
    },
    {
      "key": "199.0",
      "line_index": 199,
      "inline_index": 0,
      "line_hash": "7712464f",
      "speaker": "",
      "ja": "激しく舌を絡めながらの抽送にトーリも{G_PlayerName}もすっかり夢中になってしまう。",
      "zh": ""
    },
    {
      "key": "201.0",
      "line_index": 201,
      "inline_index": 0,
      "line_hash": "af15227f",
      "speaker": "",
      "ja": "部屋の中にはいやらしい水音と二人の荒い息づかいが響き渡っていた。",
      "zh": ""
    },
    {
      "key": "204.0",
      "line_index": 204,
      "inline_index": 0,
      "line_hash": "45878dc6",
      "speaker": "トーリ",
      "ja": "んむぅぅ♥　も、もっとぉ♥　もっとおぬしの亀頭でわらわの子宮口にキスをしておくれぇ♥　子宮をもっと強く突き上げてぇ♥　うむぅぅぅ♥",
      "zh": ""
    },
    {
      "key": "206.0",
      "line_index": 206,
      "inline_index": 0,
      "line_hash": "cf953e5f",
      "speaker": "",
      "ja": "そう言いながらトーリは自らも腰を振り、更に深くまで{G_PlayerName}の勃起したおちんちんを咥え込んでいく。",
      "zh": ""
    },
    {
      "key": "209.0",
      "line_index": 209,
      "inline_index": 0,
      "line_hash": "310945d7",
      "speaker": "トーリ",
      "ja": "おっ♥　おぉぉっ♥　し、子宮に響くぅ♥　あううっ♥　こ、これっ……すごいっ♥　んふぅぅ♥　あっ、はあぁんっ♥",
      "zh": ""
    },
    {
      "key": "211.0",
      "line_index": 211,
      "inline_index": 0,
      "line_hash": "90bbc570",
      "speaker": "",
      "ja": "トーリが淫らに喘ぐ程に陰茎を咥え込んだおまんこが、波立つように蠢きながら締め付けていった。",
      "zh": ""
    },
    {
      "key": "213.0",
      "line_index": 213,
      "inline_index": 0,
      "line_hash": "7cd61b76",
      "speaker": "",
      "ja": "そんな吸いついてくる肉襞を掻き分けながら、{G_PlayerName}のおちんちんが擦り上げる。",
      "zh": ""
    },
    {
      "key": "216.0",
      "line_index": 216,
      "inline_index": 0,
      "line_hash": "d3c329fa",
      "speaker": "トーリ",
      "ja": "んんんっ♥　んはぁぁぁ♥　気持ちいいっ♥　おぬしのマラ……熱くて硬くて……あむぅぅ♥　わらわのほとをごりごり掻いて……すごくいいっ♥",
      "zh": ""
    },
    {
      "key": "218.0",
      "line_index": 218,
      "inline_index": 0,
      "line_hash": "a15ce873",
      "speaker": "",
      "ja": "快感が高まると同時に濡れたおまんこが締まり、咥え込んだ陰茎に強く吸いついた。",
      "zh": ""
    },
    {
      "key": "220.0",
      "line_index": 220,
      "inline_index": 0,
      "line_hash": "1db1527e",
      "speaker": "",
      "ja": "それはまるで射精を催促するかのようで、{G_PlayerName}はまた込み上げてくる感覚に襲われてしまう。",
      "zh": ""
    },
    {
      "key": "222.0",
      "line_index": 222,
      "inline_index": 0,
      "line_hash": "37f182da",
      "speaker": "",
      "ja": "それでも{G_PlayerName}は腰の動きを止めず、それどころかラストスパートをかけるように更に激しくトーリを突き上げていった。",
      "zh": ""
    },
    {
      "key": "225.0",
      "line_index": 225,
      "inline_index": 0,
      "line_hash": "51193810",
      "speaker": "トーリ",
      "ja": "あんっ♥　あぁんっ♥　イくぅ♥　んっ、んむぅぅ♥　んぢゅるぅ♥　ちゅっ♥　ちゅるぅ♥",
      "zh": ""
    },
    {
      "key": "227.0",
      "line_index": 227,
      "inline_index": 0,
      "line_hash": "1fe07b10",
      "speaker": "",
      "ja": "トーリも絶頂が近づいてきているのを感じつつも激しいキスを繰り返していく。",
      "zh": ""
    },
    {
      "key": "229.0",
      "line_index": 229,
      "inline_index": 0,
      "line_hash": "c788dd1b",
      "speaker": "",
      "ja": "そのまま{G_PlayerName}とトーリはどんどん高まっていき腰が小さく跳ねた。",
      "zh": ""
    },
    {
      "key": "232.0",
      "line_index": 232,
      "inline_index": 0,
      "line_hash": "b8eea4e2",
      "speaker": "{G_PlayerName}",
      "ja": "ま、また……出る……くっ……うぅぅ",
      "zh": ""
    },
    {
      "key": "235.0",
      "line_index": 235,
      "inline_index": 0,
      "line_hash": "261b7f13",
      "speaker": "",
      "ja": "込み上げてきた感覚を抑えきれなくなった{G_PlayerName}は勃起したおちんちんを深々と挿入して射精してしまう。",
      "zh": ""
    },
    {
      "key": "244.0",
      "line_index": 244,
      "inline_index": 0,
      "line_hash": "32631700",
      "speaker": "トーリ",
      "ja": "んおぉ♥　またこんなにいっぱい……んっ♥　んんんっ♥",
      "zh": ""
    },
    {
      "key": "246.0",
      "line_index": 246,
      "inline_index": 0,
      "line_hash": "fcda1809",
      "speaker": "",
      "ja": "どくんどくんと注がれた精液がトーリの子宮をパンパンに満たしていった。",
      "zh": ""
    },
    {
      "key": "248.0",
      "line_index": 248,
      "inline_index": 0,
      "line_hash": "a6841b07",
      "speaker": "",
      "ja": "その感覚にトーリは目を細め眉を下げながら呟く。",
      "zh": ""
    },
    {
      "key": "251.0",
      "line_index": 251,
      "inline_index": 0,
      "line_hash": "ad402175",
      "speaker": "トーリ",
      "ja": "へっ♥　へっ♥　んぢゅ♥　くちゅっ♥　こ、こんなに出しおって……♥　こんなに出されたら妊娠してしまうじゃろうが……♥",
      "zh": ""
    },
    {
      "key": "253.0",
      "line_index": 253,
      "inline_index": 0,
      "line_hash": "8033ca75",
      "speaker": "",
      "ja": "嬉しそうにそう言いながらトーリは{G_PlayerName}の唇に自らの唇を重ね、舌を突き出して絡めていった。",
      "zh": ""
    },
    {
      "key": "255.0",
      "line_index": 255,
      "inline_index": 0,
      "line_hash": "aefbb99e",
      "speaker": "",
      "ja": "それに応えるように{G_PlayerName}もトーリの舌を舐め回していく。",
      "zh": ""
    },
    {
      "key": "258.0",
      "line_index": 258,
      "inline_index": 0,
      "line_hash": "5c2ce3a1",
      "speaker": "トーリ",
      "ja": "あむぅぅ♥　んぢゅるぅ♥　ぢゅっ、ぢゅるぢゅるぅ♥　んふぅぅ……んっ、んんんっ♥",
      "zh": ""
    },
    {
      "key": "260.0",
      "line_index": 260,
      "inline_index": 0,
      "line_hash": "3764a78a",
      "speaker": "",
      "ja": "そのままトーリと{G_PlayerName}は何度もキスを繰り返し、繋がったまま絶頂の余韻に浸り続けていた。",
      "zh": ""
    }
  ]
}
