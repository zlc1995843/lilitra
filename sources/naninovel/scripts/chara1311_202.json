{
  "lines": [
    {
      "key": "15.0",
      "line_index": 15,
      "inline_index": 0,
      "line_hash": "9ca04ba4",
      "speaker": "{G_PlayerName}",
      "ja": "はぁ～……そろそろ時間か……",
      "zh": ""
    },
    {
      "key": "18.0",
      "line_index": 18,
      "inline_index": 0,
      "line_hash": "283c8ae1",
      "speaker": "",
      "ja": "ユースに屈してしまったあの日。あの日から俺とユースの関係は今までと違うものになった。",
      "zh": ""
    },
    {
      "key": "20.0",
      "line_index": 20,
      "inline_index": 0,
      "line_hash": "e694461c",
      "speaker": "",
      "ja": "あの日からユースは同じ時間に部屋に現れ、夫婦の営みと称してオナホで俺と行為に及ぶ。",
      "zh": ""
    },
    {
      "key": "21.0",
      "line_index": 21,
      "inline_index": 0,
      "line_hash": "60369e0d",
      "speaker": "",
      "ja": "最初のうちは拒絶するが、それでもユースに中出しする快感に最後は快楽に呑まれてしまう。",
      "zh": ""
    },
    {
      "key": "23.0",
      "line_index": 23,
      "inline_index": 0,
      "line_hash": "2e0fda58",
      "speaker": "",
      "ja": "そして今も期待からか肉棒がムクムクと大きくなり、自分の節操のない性欲に溜息をつきながら呆れてしまっていた。",
      "zh": ""
    },
    {
      "key": "30.1",
      "line_index": 30,
      "inline_index": 1,
      "line_hash": "1d8f0c9e",
      "speaker": "ユース",
      "ja": "お兄さ～んっ♥　今日も夫婦のお勤め……たくさんしましょうね♥",
      "zh": ""
    },
    {
      "key": "32.0",
      "line_index": 32,
      "inline_index": 0,
      "line_hash": "7e97ce2d",
      "speaker": "",
      "ja": "毎回突然俺の横に現れるユース。",
      "zh": ""
    },
    {
      "key": "33.0",
      "line_index": 33,
      "inline_index": 0,
      "line_hash": "312f672",
      "speaker": "",
      "ja": "しかし現れる時間が同じなので今はもう驚かなくなっていた。",
      "zh": ""
    },
    {
      "key": "36.1",
      "line_index": 36,
      "inline_index": 1,
      "line_hash": "51a52e74",
      "speaker": "ユース",
      "ja": "あれれ？♥　お兄さん、あんま元気ない？♥　それじゃあいっぱい気持ち良くなってスッキリ元気にならないとねーっ♥",
      "zh": ""
    },
    {
      "key": "39.0",
      "line_index": 39,
      "inline_index": 0,
      "line_hash": "2ccdb04",
      "speaker": "{G_PlayerName}",
      "ja": "お前は毎日元気だな……俺たちのやってることって正直健全とは思えないし、少しは悩んだりしないのか？",
      "zh": ""
    },
    {
      "key": "43.1",
      "line_index": 43,
      "inline_index": 1,
      "line_hash": "767469c2",
      "speaker": "ユース",
      "ja": "お兄さん悩んでるの？♥　びゅるるる～するだけなのに？♥　おかしなお兄さんだね♥　あははははっ♥",
      "zh": ""
    },
    {
      "key": "46.0",
      "line_index": 46,
      "inline_index": 0,
      "line_hash": "7df9d915",
      "speaker": "{G_PlayerName}",
      "ja": "まったく……お前は悩みとかなさそうでいいよな……",
      "zh": ""
    },
    {
      "key": "50.1",
      "line_index": 50,
      "inline_index": 1,
      "line_hash": "bd75ccf1",
      "speaker": "ユース",
      "ja": "何その言い方～……ちょ～～～っとだけカチンときちゃうんだけどぉ？♥　ユースちゃんだって悩みの一つや二つ──",
      "zh": ""
    },
    {
      "key": "53.1",
      "line_index": 53,
      "inline_index": 1,
      "line_hash": "17eb6fc7",
      "speaker": "ユース",
      "ja": "──あっ！？♥　むふふふ、お兄さん、真面目な顔してるけど、おちんちんはいつも通りおっきくなっちゃってるね～っ♥",
      "zh": ""
    },
    {
      "key": "58.1",
      "line_index": 58,
      "inline_index": 1,
      "line_hash": "dcf38f52",
      "speaker": "ユース",
      "ja": "口ではそんなこと言ってやる気満々っ♥　あははははは♥　おっかしぃ～っ♥　あははははっ♥",
      "zh": ""
    },
    {
      "key": "60.0",
      "line_index": 60,
      "inline_index": 0,
      "line_hash": "3c12ad4a",
      "speaker": "",
      "ja": "俺を煽るようにユースは大笑いし、少しずつ怒りに似た何かがこみ上げてくる。",
      "zh": ""
    },
    {
      "key": "63.0",
      "line_index": 63,
      "inline_index": 0,
      "line_hash": "ccd8b368",
      "speaker": "{G_PlayerName}",
      "ja": "……………",
      "zh": ""
    },
    {
      "key": "67.1",
      "line_index": 67,
      "inline_index": 1,
      "line_hash": "942ca0d",
      "speaker": "ユース",
      "ja": "ん……？♥　なになに、お兄さん？♥",
      "zh": ""
    },
    {
      "key": "69.0",
      "line_index": 69,
      "inline_index": 0,
      "line_hash": "239e54a",
      "speaker": "",
      "ja": "俺は無言で立ち上がると、きょとんとした顔で俺を見るユース。",
      "zh": ""
    },
    {
      "key": "70.0",
      "line_index": 70,
      "inline_index": 0,
      "line_hash": "580a5c84",
      "speaker": "",
      "ja": "俺を信頼しているのか完全に無防備、今ならユースを──",
      "zh": ""
    },
    {
      "key": "73.1",
      "line_index": 73,
      "inline_index": 1,
      "line_hash": "f274c062",
      "speaker": "ユース",
      "ja": "ひゃぁぁっ！？♥　お兄さんっ！？！？♥♥",
      "zh": ""
    },
    {
      "key": "75.0",
      "line_index": 75,
      "inline_index": 0,
      "line_hash": "36700fcd",
      "speaker": "",
      "ja": "俺はそう考えた瞬間、ユースをベッドの上に押し倒してしまっていた。",
      "zh": ""
    },
    {
      "key": "78.1",
      "line_index": 78,
      "inline_index": 1,
      "line_hash": "ef59809",
      "speaker": "ユース",
      "ja": "なになに～？♥　もしかして今日は攻めの気分だったりする？♥　それともオナホ越しにぴゅっぴゅするの飽きちゃった？♥",
      "zh": ""
    },
    {
      "key": "80.0",
      "line_index": 80,
      "inline_index": 0,
      "line_hash": "f7823165",
      "speaker": "",
      "ja": "ユースは押し倒した時は一瞬慌てていたが、またいつもの調子で余裕の笑みに戻る。",
      "zh": ""
    },
    {
      "key": "81.0",
      "line_index": 81,
      "inline_index": 0,
      "line_hash": "865141ff",
      "speaker": "",
      "ja": "そして俺を煽るようにおもむろにパンツを脱ぎだし、ピッタリ閉じた割れ目を拡げるように両足を持ち上げる。",
      "zh": ""
    },
    {
      "key": "83.0",
      "line_index": 83,
      "inline_index": 0,
      "line_hash": "221ad019",
      "speaker": "",
      "ja": "アナルまで見えてしまうユースの行為に俺の心臓がドクンと大きく跳ねる。",
      "zh": ""
    },
    {
      "key": "84.0",
      "line_index": 84,
      "inline_index": 0,
      "line_hash": "2004cc62",
      "speaker": "",
      "ja": "そして俺もおもむろにズボンを脱ぎ捨てると、限界まで勃起していた肉棒をユースに見せつけるように小さな身体に覆いかぶさる。",
      "zh": ""
    },
    {
      "key": "87.1",
      "line_index": 87,
      "inline_index": 1,
      "line_hash": "2017b6fd",
      "speaker": "ユース",
      "ja": "くすくす……いつにも増してやる気でみなぎっちゃってるね～♥　お前のこと犯してやるって瞳が言ってるよ？♥　くすくすくす♥",
      "zh": ""
    },
    {
      "key": "90.0",
      "line_index": 90,
      "inline_index": 0,
      "line_hash": "1fe182bc",
      "speaker": "{G_PlayerName}",
      "ja": "そう思っているクセに慌てないんだな？　まさか俺がそんなことしないとでも考えているんじゃないか？",
      "zh": ""
    },
    {
      "key": "93.0",
      "line_index": 93,
      "inline_index": 0,
      "line_hash": "c688e1f2",
      "speaker": "",
      "ja": "俺は脅すようにユースの顔に自分の顔をぐいっと寄せる。",
      "zh": ""
    },
    {
      "key": "94.0",
      "line_index": 94,
      "inline_index": 0,
      "line_hash": "67dfc72c",
      "speaker": "",
      "ja": "それでもユースは余裕の笑みを崩さず、大きな瞳でじっと俺のことを見つめ続ける。",
      "zh": ""
    },
    {
      "key": "97.1",
      "line_index": 97,
      "inline_index": 1,
      "line_hash": "76dd8ba",
      "speaker": "ユース",
      "ja": "ガチ恋距離で迫るなんて……だ・い・た・ん……♥",
      "zh": ""
    },
    {
      "key": "100.0",
      "line_index": 100,
      "inline_index": 0,
      "line_hash": "a312c72e",
      "speaker": "{G_PlayerName}",
      "ja": "まったく……これは俺のこと今日まで好き勝手にしたお仕置きだ……しっかりおまんこで反省させてやる……！",
      "zh": ""
    },
    {
      "key": "116.0",
      "line_index": 116,
      "inline_index": 0,
      "line_hash": "5993293b",
      "speaker": "ユース",
      "ja": "はおおおっ！♥　んぅぅぅっ！♥　いきなり奥にぃ……！！♥　ふあ、あ、んぅ……んあ、あああ……！！♥",
      "zh": ""
    },
    {
      "key": "118.0",
      "line_index": 118,
      "inline_index": 0,
      "line_hash": "9a85a381",
      "speaker": "",
      "ja": "俺はロクに愛撫もせず、いきり立っていた肉棒を膣穴に押し込む。",
      "zh": ""
    },
    {
      "key": "120.0",
      "line_index": 120,
      "inline_index": 0,
      "line_hash": "36452d7c",
      "speaker": "",
      "ja": "狭い膣が一瞬反発するすように肉棒を押し戻すが、俺は腰に力を入れメリメリとこじ開けながら狭い膣を蹂躙するうように入れていく。",
      "zh": ""
    },
    {
      "key": "123.0",
      "line_index": 123,
      "inline_index": 0,
      "line_hash": "3ea69622",
      "speaker": "ユース",
      "ja": "んんぅ……！♥　久々の本物おちんちん……♥　ずっとこれ待ってたんだよ？♥",
      "zh": ""
    },
    {
      "key": "126.0",
      "line_index": 126,
      "inline_index": 0,
      "line_hash": "7f5a76e3",
      "speaker": "ユース",
      "ja": "煽って煽って、そそのかして……でもお兄さんは受け身のまま……♥　でもやっとお兄さんから手を出してくれた……♥",
      "zh": ""
    },
    {
      "key": "129.0",
      "line_index": 129,
      "inline_index": 0,
      "line_hash": "292f0cb9",
      "speaker": "{G_PlayerName}",
      "ja": "結局犯して欲しかったのか……！　なら望み通りにしてやるから……！",
      "zh": ""
    },
    {
      "key": "133.0",
      "line_index": 133,
      "inline_index": 0,
      "line_hash": "c971a7bc",
      "speaker": "ユース",
      "ja": "んんっ、んんんっ！♥　あ、あっ！♥　はげしいぃっ！♥　これヤバイっ！♥　おちんちん気持ち良いっ！♥　んんんんんっ！！♥",
      "zh": ""
    },
    {
      "key": "135.0",
      "line_index": 135,
      "inline_index": 0,
      "line_hash": "b54ff4ab",
      "speaker": "",
      "ja": "俺は腰を打ち付けるようにピストンすると、ぐちゅぐちゅといやらしい水音が響く。",
      "zh": ""
    },
    {
      "key": "136.0",
      "line_index": 136,
      "inline_index": 0,
      "line_hash": "9391b28b",
      "speaker": "",
      "ja": "ユースの甘えるような喘ぎ声も大きくなり、余裕を見せていた笑みが少しずつ消えていく。",
      "zh": ""
    },
    {
      "key": "138.0",
      "line_index": 138,
      "inline_index": 0,
      "line_hash": "733e162b",
      "speaker": "",
      "ja": "瞳は快感に蕩け、頬を紅く染め、そんなユースを見ているだけで興奮が滾る。",
      "zh": ""
    },
    {
      "key": "139.0",
      "line_index": 139,
      "inline_index": 0,
      "line_hash": "192fa9c0",
      "speaker": "",
      "ja": "俺はその興奮をユースにぶつけるようにペースなど一切考えず、濡れる膣を掻き回す。",
      "zh": ""
    },
    {
      "key": "142.0",
      "line_index": 142,
      "inline_index": 0,
      "line_hash": "d5abba9",
      "speaker": "ユース",
      "ja": "んぅぅっ！♥　お兄ちゃん、子宮、きゅんきゅんしてるよぉ……！♥　毎日毎日精液で満たしていたのに、まだおねだりしてるのっ♥",
      "zh": ""
    },
    {
      "key": "145.0",
      "line_index": 145,
      "inline_index": 0,
      "line_hash": "430011",
      "speaker": "{G_PlayerName}",
      "ja": "まったくエロガキめ……！",
      "zh": ""
    },
    {
      "key": "149.0",
      "line_index": 149,
      "inline_index": 0,
      "line_hash": "76dabb5d",
      "speaker": "ユース",
      "ja": "ひぃっ！？♥　乳首だめぇっ！♥　あああ、ダメ、同時になんてずるいぃっ！♥　あ、んあっ！♥　んんんっ！！♥",
      "zh": ""
    },
    {
      "key": "151.0",
      "line_index": 151,
      "inline_index": 0,
      "line_hash": "dca7d6cf",
      "speaker": "",
      "ja": "快感に悶えるユースの身体を抑えるように乳房に手を置くと、ピンク色の突起物を指で捏ねる。",
      "zh": ""
    },
    {
      "key": "153.0",
      "line_index": 153,
      "inline_index": 0,
      "line_hash": "31c23497",
      "speaker": "",
      "ja": "それだけで信じられないほど膣がうねり、肉棒を引き込むように吸い上げる。",
      "zh": ""
    },
    {
      "key": "155.0",
      "line_index": 155,
      "inline_index": 0,
      "line_hash": "8780c3e3",
      "speaker": "",
      "ja": "膣奥からどんどん愛液が溢れ、ねっとりと肉棒に絡む。",
      "zh": ""
    },
    {
      "key": "156.0",
      "line_index": 156,
      "inline_index": 0,
      "line_hash": "689bd15f",
      "speaker": "",
      "ja": "蕩け始めた柔膣と膣ヒダが肉棒を舐め上げ、あまりの気持ち良さに俺の腰が勝手にピストンを繰り返してしまう。",
      "zh": ""
    },
    {
      "key": "159.0",
      "line_index": 159,
      "inline_index": 0,
      "line_hash": "4723c411",
      "speaker": "ユース",
      "ja": "お兄ちゃん、これ、だめっ……！♥　ガチセックス気持ち良すぎて……んんんっ！♥　もうイっちゃいそうだよぉっ！！♥",
      "zh": ""
    },
    {
      "key": "162.0",
      "line_index": 162,
      "inline_index": 0,
      "line_hash": "d029d83f",
      "speaker": "{G_PlayerName}",
      "ja": "もう根を上げたのか……！　それならイかせてやる……！　子宮に精液ぶっこんで確実に孕ませてやる……もう後戻りできないからな、俺もお前も……！！",
      "zh": ""
    },
    {
      "key": "166.0",
      "line_index": 166,
      "inline_index": 0,
      "line_hash": "522588ab",
      "speaker": "ユース",
      "ja": "んぎぃっ！？♥　んんっ！！♥　おぐぅっ！♥　おぐにぃっ！！♥　あ、ああぁっ！！♥　ぐ、うううう！！♥",
      "zh": ""
    },
    {
      "key": "168.0",
      "line_index": 168,
      "inline_index": 0,
      "line_hash": "74ff6a97",
      "speaker": "",
      "ja": "俺は吸い付く子宮口をこじ開けるように亀頭の先端を押し付ける。",
      "zh": ""
    },
    {
      "key": "169.0",
      "line_index": 169,
      "inline_index": 0,
      "line_hash": "3260976c",
      "speaker": "",
      "ja": "グリグリと腰を回転させるように腰を打ち付け、ユースの可愛らしいと汚らしさ混じった声が口から漏れ出す。",
      "zh": ""
    },
    {
      "key": "172.0",
      "line_index": 172,
      "inline_index": 0,
      "line_hash": "55ceae92",
      "speaker": "{G_PlayerName}",
      "ja": "入ったぞ、ユースの子宮に……！　今度はオナホ越しじゃない、本当の意味で直接種付けしてやる……！！",
      "zh": ""
    },
    {
      "key": "176.0",
      "line_index": 176,
      "inline_index": 0,
      "line_hash": "1063db5",
      "speaker": "ユース",
      "ja": "んぅぅぅ、ふぅ、ふうううっ！！♥　ああ、出されちゃう……！♥　今度は本当に孕んじゃう……！♥　お兄ちゃんの赤ちゃん妊娠しちゃうぅっ！♥",
      "zh": ""
    },
    {
      "key": "179.0",
      "line_index": 179,
      "inline_index": 0,
      "line_hash": "cb025ded",
      "speaker": "{G_PlayerName}",
      "ja": "そうして欲しいんだろ！？　なら黙ってオスの欲望のすべてを子宮で受け止めろっ！",
      "zh": ""
    },
    {
      "key": "183.0",
      "line_index": 183,
      "inline_index": 0,
      "line_hash": "2b37bb00",
      "speaker": "ユース",
      "ja": "ひぃぃっ！♥　もう、だめぇっ！♥　イク、イクぅ！！♥　イクイクイク……イっぐぅぅぅ～～～～～っ！！♥♥",
      "zh": ""
    },
    {
      "key": "192.0",
      "line_index": 192,
      "inline_index": 0,
      "line_hash": "477481d9",
      "speaker": "ユース",
      "ja": "んぐぅ～～～～っ！！♥　せーし出てるぅっ！♥　子宮に出ちゃってりゅぅ♥　んぉ、お゛っお゛～……！！♥♥",
      "zh": ""
    },
    {
      "key": "194.0",
      "line_index": 194,
      "inline_index": 0,
      "line_hash": "163335a8",
      "speaker": "",
      "ja": "子宮の中で肉棒を跳ねらせながら射精すると、その刺激でユースは歓喜の悲鳴を上げながら絶頂する。",
      "zh": ""
    },
    {
      "key": "196.0",
      "line_index": 196,
      "inline_index": 0,
      "line_hash": "c67897b9",
      "speaker": "",
      "ja": "柔膣が蠢くように肉棒を締め付け、無数の舌で舐められているような刺激に俺は腰を何度も突き出し子宮に精液を注ぎ込む。",
      "zh": ""
    },
    {
      "key": "199.0",
      "line_index": 199,
      "inline_index": 0,
      "line_hash": "46c8e31d",
      "speaker": "ユース",
      "ja": "オナホよりっ……いっぱい出てりゅぅ……！♥　もう子宮がいっぱいだよぉ……ぐう……！！♥",
      "zh": ""
    },
    {
      "key": "202.0",
      "line_index": 202,
      "inline_index": 0,
      "line_hash": "3385d25d",
      "speaker": "{G_PlayerName}",
      "ja": "こんなもんで満足できるわけないだろ……！　もっと受け取れ……！　オスの……俺の欲望はこんなものじゃ足りないぞ……！！",
      "zh": ""
    },
    {
      "key": "206.0",
      "line_index": 206,
      "inline_index": 0,
      "line_hash": "6f7bbfec",
      "speaker": "ユース",
      "ja": "んぐぅ、う、んぅぅぅ！♥　ふぉ、おお゛……！！♥　押し込まれるぅ……！！♥　お兄ちゃんの、しゅごすぎぃ……♥　んぎぃぃぃ……！！♥♥",
      "zh": ""
    },
    {
      "key": "208.0",
      "line_index": 208,
      "inline_index": 0,
      "line_hash": "c400c987",
      "speaker": "",
      "ja": "オスの本能が子宮で肉棒を小刻みに扱き、子宮に収まり切れないほどの精液を吐き出す。",
      "zh": ""
    },
    {
      "key": "209.0",
      "line_index": 209,
      "inline_index": 0,
      "line_hash": "23d67dee",
      "speaker": "",
      "ja": "いつまでも射精できる、そう思っていたが、やがてそれも収まり始め、俺もユースも完全に息を切らせていた。",
      "zh": ""
    },
    {
      "key": "212.0",
      "line_index": 212,
      "inline_index": 0,
      "line_hash": "17351574",
      "speaker": "ユース",
      "ja": "「ふぅ、ふぅ……お兄ちゃん、激しすぎだよぉ……♥　はぁ、はぁ……でも、これでスッキリできた……？♥　もう出ないよね……？♥　はー、はー……♥",
      "zh": ""
    },
    {
      "key": "215.0",
      "line_index": 215,
      "inline_index": 0,
      "line_hash": "e9e18881",
      "speaker": "{G_PlayerName}",
      "ja": "何一人で勝手に終わろうとしているんだ？　こんなもんじゃ俺の性欲を満たせないぞ……！！",
      "zh": ""
    },
    {
      "key": "222.0",
      "line_index": 222,
      "inline_index": 0,
      "line_hash": "63dcf38",
      "speaker": "ユース",
      "ja": "んひぃっ！？♥　お兄ちゃん、らめぇっ！♥　もう子宮いっぱいだからぁっ！！♥",
      "zh": ""
    },
    {
      "key": "225.0",
      "line_index": 225,
      "inline_index": 0,
      "line_hash": "ae737b7e",
      "speaker": "{G_PlayerName}",
      "ja": "それがどうし……うおっ！？　お前、母乳出てるぞ……！？",
      "zh": ""
    },
    {
      "key": "229.0",
      "line_index": 229,
      "inline_index": 0,
      "line_hash": "431b8b50",
      "speaker": "ユース",
      "ja": "ふえぇぇっ！？♥　なっ、なんでぇ……！！♥　なんでおっぱい出てぇ……うううう……！！♥",
      "zh": ""
    },
    {
      "key": "231.0",
      "line_index": 231,
      "inline_index": 0,
      "line_hash": "a2567a19",
      "speaker": "",
      "ja": "俺が再び腰を振り乱すと、ほぼ同時に乳首から母乳が噴き出す。",
      "zh": ""
    },
    {
      "key": "232.0",
      "line_index": 232,
      "inline_index": 0,
      "line_hash": "727c85d8",
      "speaker": "",
      "ja": "俺は一瞬我に返るも、ユースをセックスをしたいオスの欲望が再び俺を快楽に突き落とす。",
      "zh": ""
    },
    {
      "key": "235.0",
      "line_index": 235,
      "inline_index": 0,
      "line_hash": "188a55fe",
      "speaker": "{G_PlayerName}",
      "ja": "このエロガキめ……！　母乳を出しながら感じやがって……！　もっと気持ち良くなりやがれっ！",
      "zh": ""
    },
    {
      "key": "239.0",
      "line_index": 239,
      "inline_index": 0,
      "line_hash": "b7a4ca9",
      "speaker": "ユース",
      "ja": "おふぅっ！♥　お、おっ！♥　んぉぉ……ほぉおおおお！♥　らめええっ！♥　うぐぅぅっ！！♥　母乳っ、搾らないでぇ……！！♥",
      "zh": ""
    },
    {
      "key": "241.0",
      "line_index": 241,
      "inline_index": 0,
      "line_hash": "75ca188e",
      "speaker": "",
      "ja": "俺はピストンをしながら乳首を捏ね、母乳を搾り出す。",
      "zh": ""
    },
    {
      "key": "242.0",
      "line_index": 242,
      "inline_index": 0,
      "line_hash": "b0a9a4b2",
      "speaker": "",
      "ja": "ユースの快感の悲鳴と共に膣が千切れそうに思えるほど締まり、精液を押し出すように愛液が噴き出す。",
      "zh": ""
    },
    {
      "key": "244.0",
      "line_index": 244,
      "inline_index": 0,
      "line_hash": "e83a492e",
      "speaker": "",
      "ja": "ユースは胸とあそこを真っ白に汚し、いやらしすぎる姿が俺の興奮をさらに焚きつけた。",
      "zh": ""
    },
    {
      "key": "247.0",
      "line_index": 247,
      "inline_index": 0,
      "line_hash": "96c597ae",
      "speaker": "{G_PlayerName}",
      "ja": "まったく……お前はエロすぎだ……もっとエロくしてやる……あむっ！",
      "zh": ""
    },
    {
      "key": "251.0",
      "line_index": 251,
      "inline_index": 0,
      "line_hash": "a56e9041",
      "speaker": "ユース",
      "ja": "んひぃぃっ！♥　ひぃ、す、吸われるぅっ！♥　らめらめらめぇえっ！♥　ぎもぢ、良いっ！♥　吸われるの、感じすぎちゃうぅ～～～っ！！♥",
      "zh": ""
    },
    {
      "key": "253.0",
      "line_index": 253,
      "inline_index": 0,
      "line_hash": "ea0803f2",
      "speaker": "",
      "ja": "俺はガマンできずユースの乳首に吸い付くと、喉を鳴らしながら母乳を飲み込む。",
      "zh": ""
    },
    {
      "key": "254.0",
      "line_index": 254,
      "inline_index": 0,
      "line_hash": "a3ed87de",
      "speaker": "",
      "ja": "口の中広がるユースの甘い母乳の味にテンションが最高潮に達する。",
      "zh": ""
    },
    {
      "key": "256.0",
      "line_index": 256,
      "inline_index": 0,
      "line_hash": "412dbf53",
      "speaker": "",
      "ja": "勢いよく母乳を飲むが、それでも俺の腰は止まらず次の射精を求めひたすらに子宮と膣で肉棒を扱き続けていた。",
      "zh": ""
    },
    {
      "key": "259.0",
      "line_index": 259,
      "inline_index": 0,
      "line_hash": "f49495dc",
      "speaker": "ユース",
      "ja": "んふぅ、んひぃっ！♥　そんなにぃ、吸っちゃダメぇっ！♥　枯れちゃう、おっぱい出なくなっちゃう～っ！！♥",
      "zh": ""
    },
    {
      "key": "262.0",
      "line_index": 262,
      "inline_index": 0,
      "line_hash": "4e6f1a8d",
      "speaker": "{G_PlayerName}",
      "ja": "毎日人から枯れるまで精液搾り取っておいて何言ってんだ、これは因果応報ってヤツだ……！",
      "zh": ""
    },
    {
      "key": "266.0",
      "line_index": 266,
      "inline_index": 0,
      "line_hash": "a71ec2c6",
      "speaker": "{G_PlayerName}",
      "ja": "でも飲んだ礼はちゃんとしてやる……！　ぱんっぱんの子宮にちんぽミルクを無理やり押し込んでやる……！",
      "zh": ""
    },
    {
      "key": "270.0",
      "line_index": 270,
      "inline_index": 0,
      "line_hash": "5b29e741",
      "speaker": "ユース",
      "ja": "んぎっ！♥　ふぅ、ふぅっ！♥　も、もう子宮で飲めないぃ……！♥　もう限界なのぉ……！♥　これ以上出されたら子宮おかしくなっぢゃう～～っ！♥",
      "zh": ""
    },
    {
      "key": "273.0",
      "line_index": 273,
      "inline_index": 0,
      "line_hash": "32f64435",
      "speaker": "ユース",
      "ja": "おふぅぅぅっ！♥　搾らないでぇぇ～～～っ！♥　あああ、ダメダメ……らめぇええっ！♥　あはぁ、はぁ、あああぁぁんっ！！♥",
      "zh": ""
    },
    {
      "key": "275.0",
      "line_index": 275,
      "inline_index": 0,
      "line_hash": "d589f66b",
      "speaker": "",
      "ja": "小さな乳房をグニグニと揉み、どんどん乳首から母乳が噴き出す。",
      "zh": ""
    },
    {
      "key": "276.0",
      "line_index": 276,
      "inline_index": 0,
      "line_hash": "9629723",
      "speaker": "",
      "ja": "飲みきれない母乳が口の端から大量に溢れ、ユースの綺麗な胸が真っ白に汚れる。",
      "zh": ""
    },
    {
      "key": "278.0",
      "line_index": 278,
      "inline_index": 0,
      "line_hash": "621642af",
      "speaker": "",
      "ja": "ユースは全身が汗と母乳と精液で塗れ、ユースを汚している、その事実が俺のドス黒いオスの欲望をより一層強くしていった。",
      "zh": ""
    },
    {
      "key": "281.0",
      "line_index": 281,
      "inline_index": 0,
      "line_hash": "a81e9b7",
      "speaker": "ユース",
      "ja": "ふぎぃ、あぎぃっ！♥　ふお、お゛おっ！♥　おほぉおお！♥　らめ、ま、またイっちゃう♥　またイかされちゃうっっ！！♥",
      "zh": ""
    },
    {
      "key": "284.0",
      "line_index": 284,
      "inline_index": 0,
      "line_hash": "8abd65ab",
      "speaker": "ユース",
      "ja": "お兄ちゃんおちんちんでイっちゃうよぉ～～～っ！！♥",
      "zh": ""
    },
    {
      "key": "287.0",
      "line_index": 287,
      "inline_index": 0,
      "line_hash": "c40de5d2",
      "speaker": "{G_PlayerName}",
      "ja": "イケイケイケ！　イっちまえ……！！",
      "zh": ""
    },
    {
      "key": "291.0",
      "line_index": 291,
      "inline_index": 0,
      "line_hash": "10c8c5cf",
      "speaker": "ユース",
      "ja": "ああぁ！♥　イグイグっ！♥　イっぢゃう！♥　イ、イっ……！♥　おまんこっ、イっぢゃう～～～～っ！！♥♥",
      "zh": ""
    },
    {
      "key": "300.0",
      "line_index": 300,
      "inline_index": 0,
      "line_hash": "63ccfb09",
      "speaker": "ユース",
      "ja": "ふぅっ！♥　んぅぅぅっ！♥　はぁ、あはぁぁぁ～～～っ！！♥♥",
      "zh": ""
    },
    {
      "key": "303.0",
      "line_index": 303,
      "inline_index": 0,
      "line_hash": "c3d95d86",
      "speaker": "ユース",
      "ja": "んぅうう、ふあぁぁ、はぁぁっ！♥　ザーメン、押し込まれるぅ……んぅぅぅぅ！！♥♥",
      "zh": ""
    },
    {
      "key": "305.0",
      "line_index": 305,
      "inline_index": 0,
      "line_hash": "718afbab",
      "speaker": "",
      "ja": "俺は後先考えない無責任な射精で、再びユースの子宮をオスの欲望で溢れさせる。",
      "zh": ""
    },
    {
      "key": "307.0",
      "line_index": 307,
      "inline_index": 0,
      "line_hash": "753501b6",
      "speaker": "",
      "ja": "絶頂に達したユースは母乳を噴き出しながら身体を何度もビクビクと跳ねらせる。",
      "zh": ""
    },
    {
      "key": "308.0",
      "line_index": 308,
      "inline_index": 0,
      "line_hash": "141696e",
      "speaker": "",
      "ja": "膣が俺の肉棒から精液を搾り取るように強く締め付け、その締め付けに何度も射精を繰り返してしまった。",
      "zh": ""
    },
    {
      "key": "311.0",
      "line_index": 311,
      "inline_index": 0,
      "line_hash": "7fbf50c8",
      "speaker": "ユース",
      "ja": "す、っごぉ……♥　まだ、まだせーえき出ちゃってるぅ……んんん……！！♥",
      "zh": ""
    },
    {
      "key": "314.0",
      "line_index": 314,
      "inline_index": 0,
      "line_hash": "90af000",
      "speaker": "ユース",
      "ja": "もう、しぎゅういっぱいぃ……入らないよぉ……あひぃぃぃ……！♥",
      "zh": ""
    },
    {
      "key": "320.0",
      "line_index": 320,
      "inline_index": 0,
      "line_hash": "ace56679",
      "speaker": "ユース",
      "ja": "あふぅぅ……！♥　はぁ、はぁーっ！♥　んは、はぁぁぁっ！♥",
      "zh": ""
    },
    {
      "key": "322.0",
      "line_index": 322,
      "inline_index": 0,
      "line_hash": "41fe5f6",
      "speaker": "",
      "ja": "俺は射精を終え肉棒を乱暴に引き抜くと、膣の中には精液で水たまりができていた。",
      "zh": ""
    },
    {
      "key": "324.0",
      "line_index": 324,
      "inline_index": 0,
      "line_hash": "c73a8262",
      "speaker": "",
      "ja": "ユースを徹底的に汚した……しかしそれで俺の興奮は収まることはなく、さらにユース欲しさに肉棒は勃起したままだった。",
      "zh": ""
    },
    {
      "key": "327.0",
      "line_index": 327,
      "inline_index": 0,
      "line_hash": "dbe8153d",
      "speaker": "ユース",
      "ja": "ふぅ、ふぅ……♥　お兄さん、出しすぎぃ……♥　絶対赤ちゃんデキちゃったよぉ……♥　はぁ、はぁぁ……♥",
      "zh": ""
    },
    {
      "key": "330.0",
      "line_index": 330,
      "inline_index": 0,
      "line_hash": "641bd483",
      "speaker": "{G_PlayerName}",
      "ja": "そうかもな……でもこの程度で終わらないからな？　まだヤリ足りない……もっとユースのおまんこで射精してやるから……",
      "zh": ""
    },
    {
      "key": "334.0",
      "line_index": 334,
      "inline_index": 0,
      "line_hash": "eda8c671",
      "speaker": "ユース",
      "ja": "お兄さん、鬼畜ぅ～……♥　でも、ユースはお兄ちゃんのお嫁さんだから……♥　だからユースのおまんこ、壊れるまで犯していいよ……♥",
      "zh": ""
    },
    {
      "key": "337.0",
      "line_index": 337,
      "inline_index": 0,
      "line_hash": "370b9679",
      "speaker": "ユース",
      "ja": "ん……♥　ちゅ……ちゅ……♥　んはぁ……どうしたの？♥　いきなりキスなんてぇ……♥　心地よくてちょっとだけイっちゃったよぉ……♥",
      "zh": ""
    },
    {
      "key": "340.0",
      "line_index": 340,
      "inline_index": 0,
      "line_hash": "82350393",
      "speaker": "{G_PlayerName}",
      "ja": "壊れるまでなんてしないよ、ユースは俺の大事なお嫁さんだから……でもお仕置きセックスはまだ続けるからな",
      "zh": ""
    },
    {
      "key": "344.0",
      "line_index": 344,
      "inline_index": 0,
      "line_hash": "44b567e0",
      "speaker": "ユース",
      "ja": "うん……♥　悪いお嫁さんをおちんちんでいっぱいお仕置きして……♥",
      "zh": ""
    },
    {
      "key": "346.0",
      "line_index": 346,
      "inline_index": 0,
      "line_hash": "877fb05e",
      "speaker": "",
      "ja": "ユースに淫靡に誘われ、俺は三度ユースに襲い掛かる。",
      "zh": ""
    },
    {
      "key": "347.0",
      "line_index": 347,
      "inline_index": 0,
      "line_hash": "12b7aaf3",
      "speaker": "",
      "ja": "お互いに完全に収まりがつかなくなり、お仕置きと称して一晩中子作りセックスを続けるのであった。",
      "zh": ""
    }
  ]
}
