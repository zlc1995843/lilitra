{
  "lines": [
    {
      "key": "14.1",
      "line_index": 14,
      "inline_index": 1,
      "line_hash": "2f02e401",
      "speaker": "ブロワー",
      "ja": "へへ……すごい目だぜ♥　もう完全に不安が消し飛んだみたいだな♥",
      "zh": ""
    },
    {
      "key": "17.0",
      "line_index": 17,
      "inline_index": 0,
      "line_hash": "fea55470",
      "speaker": "{G_PlayerName}",
      "ja": "そんなことはないって。まだ不安だからさ……",
      "zh": ""
    },
    {
      "key": "20.0",
      "line_index": 20,
      "inline_index": 0,
      "line_hash": "fcbe6ef4",
      "speaker": "",
      "ja": "そう耳元で囁くと、ブロワーの小さな身体をそっと抱き寄せる。",
      "zh": ""
    },
    {
      "key": "23.1",
      "line_index": 23,
      "inline_index": 1,
      "line_hash": "23bf9c3d",
      "speaker": "ブロワー",
      "ja": "ウソつくなって♥　おいらのおまんこにおちんぽ突っ込みたいから、そんなこと言ってんだろ♥",
      "zh": ""
    },
    {
      "key": "26.1",
      "line_index": 26,
      "inline_index": 1,
      "line_hash": "39d46a39",
      "speaker": "ブロワー",
      "ja": "さっきも言ったけど、あんちゃんなら全然構わねーから……でもその代わり──んっ♥",
      "zh": ""
    },
    {
      "key": "29.0",
      "line_index": 29,
      "inline_index": 0,
      "line_hash": "98ccba66",
      "speaker": "{G_PlayerName}",
      "ja": "──んんっ！？♥",
      "zh": ""
    },
    {
      "key": "32.0",
      "line_index": 32,
      "inline_index": 0,
      "line_hash": "9812e4cc",
      "speaker": "",
      "ja": "ブロワーの可愛い顔が近くに、そう思った瞬間、俺達の唇が重なり合う。",
      "zh": ""
    },
    {
      "key": "35.1",
      "line_index": 35,
      "inline_index": 1,
      "line_hash": "b2caccc3",
      "speaker": "ブロワー",
      "ja": "ちゅ……♥　んぅ……♥　ちゅ……ちゅぅ……はぁ～♥　ちゃんとおいらのことをあんちゃんの一番の女にしてくれよ？♥",
      "zh": ""
    },
    {
      "key": "38.0",
      "line_index": 38,
      "inline_index": 0,
      "line_hash": "fcf7abb5",
      "speaker": "{G_PlayerName}",
      "ja": "安心しろって、初めて出会った時からずっと、俺の中でブロワーは一番の女の子なんだからさ",
      "zh": ""
    },
    {
      "key": "41.0",
      "line_index": 41,
      "inline_index": 0,
      "line_hash": "dce5ef83",
      "speaker": "",
      "ja": "今の言葉に嘘偽りはない、その意思を込めるようにじっとブロワーの大きな瞳をみつめる。",
      "zh": ""
    },
    {
      "key": "44.1",
      "line_index": 44,
      "inline_index": 1,
      "line_hash": "ae152707",
      "speaker": "ブロワー",
      "ja": "へへ……♥　なんだか照れちまうぜ……♥じゃあほら、そろそろしようぜ？♥",
      "zh": ""
    },
    {
      "key": "47.1",
      "line_index": 47,
      "inline_index": 1,
      "line_hash": "a8d6bcbd",
      "speaker": "ブロワー",
      "ja": "お前のおちんぽでおいらのこといっぱい愛してくれ♥　ちゅ、ちゅぅ♥",
      "zh": ""
    },
    {
      "key": "62.0",
      "line_index": 62,
      "inline_index": 0,
      "line_hash": "fc91024c",
      "speaker": "ブロワー",
      "ja": "ふぅぅぅ！？♥　んぅ……♥　ちゅ……れるぅ♥　んんんんんっ！！♥",
      "zh": ""
    },
    {
      "key": "64.0",
      "line_index": 64,
      "inline_index": 0,
      "line_hash": "df474e54",
      "speaker": "",
      "ja": "ブロワーが唇を重ねたタイミングに合わせ、そそり立つ肉棒を小さな膣の中に押し込む。",
      "zh": ""
    },
    {
      "key": "67.0",
      "line_index": 67,
      "inline_index": 0,
      "line_hash": "ba04a46",
      "speaker": "ブロワー",
      "ja": "ふあ♥　ああ、あんちゃんの挿って……んぅぅぅっ♥　あんちゃんのすんごい大きかったから挿るか少し不安だったんだけど……♥",
      "zh": ""
    },
    {
      "key": "70.0",
      "line_index": 70,
      "inline_index": 0,
      "line_hash": "f3aeb7d4",
      "speaker": "{G_PlayerName}",
      "ja": "ああ、これなら何も問題は無いな。すっぽり俺のを飲み込んでしまってるよ。いやらしいオマンコだな",
      "zh": ""
    },
    {
      "key": "74.0",
      "line_index": 74,
      "inline_index": 0,
      "line_hash": "6cbd8ce2",
      "speaker": "ブロワー",
      "ja": "へへ……♥　あんちゃんのおちんぽだってドスケベすぎだろ♥　おいらのおまんこみっちみちだ♥　ああ……あんちゃんのすげぇ熱いぃ♥",
      "zh": ""
    },
    {
      "key": "76.0",
      "line_index": 76,
      "inline_index": 0,
      "line_hash": "a8564269",
      "speaker": "",
      "ja": "根本まで肉棒を飲み込んだブロワーの膣。",
      "zh": ""
    },
    {
      "key": "77.0",
      "line_index": 77,
      "inline_index": 0,
      "line_hash": "5a4ddea7",
      "speaker": "",
      "ja": "しかし体格差のせいか中はギチギチになってしまい、まともに動かせそうにない。",
      "zh": ""
    },
    {
      "key": "79.0",
      "line_index": 79,
      "inline_index": 0,
      "line_hash": "d2054594",
      "speaker": "",
      "ja": "肉棒を押し返すようにブロワーの膣肉が蠢き、抜けてしまわないようにそっとブロワーの腰を掴む。",
      "zh": ""
    },
    {
      "key": "82.0",
      "line_index": 82,
      "inline_index": 0,
      "line_hash": "1d76d746",
      "speaker": "ブロワー",
      "ja": "それじゃあそろそろパコパコしてくれよ♥　おちんぽでいっぱい気持ち良くしてくれ♥",
      "zh": ""
    },
    {
      "key": "85.0",
      "line_index": 85,
      "inline_index": 0,
      "line_hash": "f172e939",
      "speaker": "{G_PlayerName}",
      "ja": "ああ、たくさん感じさせてやるから",
      "zh": ""
    },
    {
      "key": "93.0",
      "line_index": 93,
      "inline_index": 0,
      "line_hash": "7fd0d853",
      "speaker": "ブロワー",
      "ja": "うあ……んっ！♥　ちゅ……れるぅ……れろれろぉ♥　んんんっ！♥",
      "zh": ""
    },
    {
      "key": "96.0",
      "line_index": 96,
      "inline_index": 0,
      "line_hash": "b10d52e4",
      "speaker": "ブロワー",
      "ja": "ふへへ……♥　あんちゃん結構鬼畜だな♥　おいらの腰を……んっ！♥　物みたいに扱って……あうっ！♥",
      "zh": ""
    },
    {
      "key": "99.0",
      "line_index": 99,
      "inline_index": 0,
      "line_hash": "ce8c8d8c",
      "speaker": "{G_PlayerName}",
      "ja": "チンポ抜けちゃうのイヤだろ？　だからこの形がベストなんだよ",
      "zh": ""
    },
    {
      "key": "105.0",
      "line_index": 105,
      "inline_index": 0,
      "line_hash": "bec2c098",
      "speaker": "ブロワー",
      "ja": "そっか……ふっ！♥　あんちゃんがやりやすいなら……それが一番だな♥　それじゃあおいらはあんちゃんの唇好きにさせてもらうから♥",
      "zh": ""
    },
    {
      "key": "107.0",
      "line_index": 107,
      "inline_index": 0,
      "line_hash": "1009caaa",
      "speaker": "",
      "ja": "ブロワーは唇を重ねると、そっと舌を口の中に差し込んでくる。",
      "zh": ""
    },
    {
      "key": "108.0",
      "line_index": 108,
      "inline_index": 0,
      "line_hash": "afdfa6e8",
      "speaker": "",
      "ja": "俺はその小さな舌を迎え入れるようにそっと自身の舌を絡ませていく。",
      "zh": ""
    },
    {
      "key": "110.0",
      "line_index": 110,
      "inline_index": 0,
      "line_hash": "29a4ea47",
      "speaker": "",
      "ja": "その間もブロワーの腰を上下に動かし続け、徐々に拡がりつつあるブロワーの小さな膣。",
      "zh": ""
    },
    {
      "key": "112.0",
      "line_index": 112,
      "inline_index": 0,
      "line_hash": "7bb593fa",
      "speaker": "",
      "ja": "動きが少しずつスムーズになっていき、ぐちゅぐちゅといやらしい音が坑道内に反響する。",
      "zh": ""
    },
    {
      "key": "115.0",
      "line_index": 115,
      "inline_index": 0,
      "line_hash": "e3b78ad",
      "speaker": "ブロワー",
      "ja": "ぷはぁっ！♥　あんちゃん♥　あんちゃん♥　おちんぽ気持ち良いっ♥　セックスすごい……指と大違い……あんっ♥",
      "zh": ""
    },
    {
      "key": "118.0",
      "line_index": 118,
      "inline_index": 0,
      "line_hash": "3bb47981",
      "speaker": "ブロワー",
      "ja": "あんちゃん、おいらのおまんこ気持ちぃ？♥　感じてくれてる？♥",
      "zh": ""
    },
    {
      "key": "121.0",
      "line_index": 121,
      "inline_index": 0,
      "line_hash": "e456e11a",
      "speaker": "{G_PlayerName}",
      "ja": "ああ、すごく気持ち良いよ……油断するとすぐに出ちゃいそうなくらい感じちゃってる",
      "zh": ""
    },
    {
      "key": "125.0",
      "line_index": 125,
      "inline_index": 0,
      "line_hash": "e2fff1",
      "speaker": "ブロワー",
      "ja": "へへ……そっか♥　でも……んっ！♥　ガマンしなくてもいいぞ？♥　いつでもイっていいから……あんちゃんのイキ顔見せてくれよ♥",
      "zh": ""
    },
    {
      "key": "128.0",
      "line_index": 128,
      "inline_index": 0,
      "line_hash": "e551eff1",
      "speaker": "{G_PlayerName}",
      "ja": "ブロワーのイキ顔もなっ",
      "zh": ""
    },
    {
      "key": "132.0",
      "line_index": 132,
      "inline_index": 0,
      "line_hash": "7fc27e8f",
      "speaker": "ブロワー",
      "ja": "ひううっ！♥　奥ぅ！♥　ああ、これダメ……あうっ！♥",
      "zh": ""
    },
    {
      "key": "134.0",
      "line_index": 134,
      "inline_index": 0,
      "line_hash": "e0ecf093",
      "speaker": "",
      "ja": "子宮口をこじ開けるように、ぐりぐりとブロワーの腰を動かす。",
      "zh": ""
    },
    {
      "key": "136.0",
      "line_index": 136,
      "inline_index": 0,
      "line_hash": "8c2fe227",
      "speaker": "",
      "ja": "ブロワーが甘い声を上げるたびに膣が肉棒を締め付け、その気持ち良さに腰が震えあがる。",
      "zh": ""
    },
    {
      "key": "138.0",
      "line_index": 138,
      "inline_index": 0,
      "line_hash": "71f941bc",
      "speaker": "",
      "ja": "そしてブロワーは自分の気持ち良さを少しでも俺に伝えようとしているのか、快感に悶えながらも何度も唇を重ねてくる。",
      "zh": ""
    },
    {
      "key": "140.0",
      "line_index": 140,
      "inline_index": 0,
      "line_hash": "44cfe939",
      "speaker": "",
      "ja": "キスの心地良い気持ち良さと、セックスの強烈な快感が混ざり合い、思考が真っ白になるほど気持ち良くなってしまう。",
      "zh": ""
    },
    {
      "key": "143.0",
      "line_index": 143,
      "inline_index": 0,
      "line_hash": "38d19d2",
      "speaker": "ブロワー",
      "ja": "んぅぅぅ♥　あんちゃん♥　あうっ！♥　も、もうおいら……んっ！♥　すごいの……クる♥　あ、ああああぁっ！♥",
      "zh": ""
    },
    {
      "key": "146.0",
      "line_index": 146,
      "inline_index": 0,
      "line_hash": "149db574",
      "speaker": "ブロワー",
      "ja": "あんちゃんも一緒に……一緒にぃぃぃっ！！♥",
      "zh": ""
    },
    {
      "key": "149.0",
      "line_index": 149,
      "inline_index": 0,
      "line_hash": "28d72036",
      "speaker": "{G_PlayerName}",
      "ja": "ああ！　このままブロワーの中に射精すぞ……！！",
      "zh": ""
    },
    {
      "key": "153.0",
      "line_index": 153,
      "inline_index": 0,
      "line_hash": "b7e801d",
      "speaker": "ブロワー",
      "ja": "ふあああぁっ！♥　ああ、おちんぽビクビクぅ！♥　もうイクっ……イっちゃう！♥　あんちゃんのおちんぽでイクぅっ！！♥♥",
      "zh": ""
    },
    {
      "key": "161.0",
      "line_index": 161,
      "inline_index": 0,
      "line_hash": "3118fc02",
      "speaker": "ブロワー",
      "ja": "んおおっ！♥　奥っ！♥　出て、るぅ！♥　ふ、あっ、んんんんっ！♥♥",
      "zh": ""
    },
    {
      "key": "163.0",
      "line_index": 163,
      "inline_index": 0,
      "line_hash": "12abb736",
      "speaker": "",
      "ja": "ブロワーの身体がビクンと跳ね、膣が強烈に締まる。",
      "zh": ""
    },
    {
      "key": "164.0",
      "line_index": 164,
      "inline_index": 0,
      "line_hash": "94197cf1",
      "speaker": "",
      "ja": "そのタイミングでこみ上げてきた熱いモノを一気にブロワーの中に射精する。",
      "zh": ""
    },
    {
      "key": "167.0",
      "line_index": 167,
      "inline_index": 0,
      "line_hash": "3c9be451",
      "speaker": "ブロワー",
      "ja": "すごい勢い……まだびゅるびゅるしてるぅ♥　あぁ～♥　あそこ蕩けるぅ♥",
      "zh": ""
    },
    {
      "key": "169.0",
      "line_index": 169,
      "inline_index": 0,
      "line_hash": "4d3088ce",
      "speaker": "",
      "ja": "甘い悲鳴を上げながら、何度も全身を震わせるブロワー。",
      "zh": ""
    },
    {
      "key": "170.0",
      "line_index": 170,
      "inline_index": 0,
      "line_hash": "6171366e",
      "speaker": "",
      "ja": "大きな瞳がとろんと蕩け、そのイキ顔を見ているだけで何度も熱いモノがこみ上げてくる。",
      "zh": ""
    },
    {
      "key": "173.0",
      "line_index": 173,
      "inline_index": 0,
      "line_hash": "67d9037e",
      "speaker": "ブロワー",
      "ja": "お腹の奥……あんちゃんのでいっぱい……♥　気持ちいぃ……♥　はぁ～♥",
      "zh": ""
    },
    {
      "key": "176.0",
      "line_index": 176,
      "inline_index": 0,
      "line_hash": "4d3025b8",
      "speaker": "ブロワー",
      "ja": "んん……？♥　あんちゃんのおちんぽ……な、何だかまた硬くなってきて……♥　お、おい、何でまた硬くなってるんだ？♥　おいらじゃ満足できなかったのか？♥",
      "zh": ""
    },
    {
      "key": "179.0",
      "line_index": 179,
      "inline_index": 0,
      "line_hash": "73473505",
      "speaker": "{G_PlayerName}",
      "ja": "ああ、まだ満足できない……欲しい、ブロワーがもっと欲しい",
      "zh": ""
    },
    {
      "key": "183.0",
      "line_index": 183,
      "inline_index": 0,
      "line_hash": "68d63109",
      "speaker": "ブロワー",
      "ja": "ちょ、ちょっとタンマ……！♥　イったばっかりだから……！♥",
      "zh": ""
    },
    {
      "key": "186.0",
      "line_index": 186,
      "inline_index": 0,
      "line_hash": "a09e5974",
      "speaker": "{G_PlayerName}",
      "ja": "ブロワー、もっとだ、もっと俺で気持ち良くなってくれっ",
      "zh": ""
    },
    {
      "key": "190.0",
      "line_index": 190,
      "inline_index": 0,
      "line_hash": "d2394060",
      "speaker": "ブロワー",
      "ja": "まっ、待ってぇ！♥　ダメぇぇっ！♥",
      "zh": ""
    },
    {
      "key": "197.0",
      "line_index": 197,
      "inline_index": 0,
      "line_hash": "3a746035",
      "speaker": "ブロワー",
      "ja": "ふぎぃぃっ！♥　うあ、あああぁっ！♥　んああああーーっ！！♥♥",
      "zh": ""
    },
    {
      "key": "199.0",
      "line_index": 199,
      "inline_index": 0,
      "line_hash": "586e1a53",
      "speaker": "",
      "ja": "興奮の赴くままにブロワーの腰を上下に激しく動かし、再び性器同士を擦り合わせる。",
      "zh": ""
    },
    {
      "key": "201.0",
      "line_index": 201,
      "inline_index": 0,
      "line_hash": "b49c4143",
      "speaker": "",
      "ja": "ブロワーは強烈な快感から逃れるように身を捩らせる。",
      "zh": ""
    },
    {
      "key": "202.0",
      "line_index": 202,
      "inline_index": 0,
      "line_hash": "85edcc09",
      "speaker": "",
      "ja": "しかし腰をがっちりと掴み、膣奥を押しつぶすようにブロワーの身体を揺さぶる。",
      "zh": ""
    },
    {
      "key": "207.0",
      "line_index": 207,
      "inline_index": 0,
      "line_hash": "1b5f0669",
      "speaker": "ブロワー",
      "ja": "んあぁっ！♥　イってる！♥　おまんこまたイってるぅぅぅっ！♥　待って！♥　ああ、また……んうぅ！♥　ふ、ふあ、ああああ～っ！！♥♥",
      "zh": ""
    },
    {
      "key": "210.0",
      "line_index": 210,
      "inline_index": 0,
      "line_hash": "9be8fcf0",
      "speaker": "{G_PlayerName}",
      "ja": "ああ……！　イってるブロワー最高に可愛いよっ。もっとイってくれ！　もっと俺のチンポで喜んでくれっ！",
      "zh": ""
    },
    {
      "key": "214.0",
      "line_index": 214,
      "inline_index": 0,
      "line_hash": "f8f51cd5",
      "speaker": "ブロワー",
      "ja": "ひうっ！♥　快感しゅごすぎぃ！♥　おまんこヘンになるぅぅっ！♥",
      "zh": ""
    },
    {
      "key": "216.0",
      "line_index": 216,
      "inline_index": 0,
      "line_hash": "cb802c08",
      "speaker": "",
      "ja": "ブロワーは身体をのけ反らし、甘い悲鳴を何度も口から漏らす。",
      "zh": ""
    },
    {
      "key": "217.0",
      "line_index": 217,
      "inline_index": 0,
      "line_hash": "6b478907",
      "speaker": "",
      "ja": "肉棒を咥えこんだ膣はぢゅるぢゅると吸いつく。",
      "zh": ""
    },
    {
      "key": "219.0",
      "line_index": 219,
      "inline_index": 0,
      "line_hash": "be339a26",
      "speaker": "",
      "ja": "奥まで狭く締まる膣を掻き回し、今さっき中出しした精液が淫らな音と共に掻き出される。",
      "zh": ""
    },
    {
      "key": "221.0",
      "line_index": 221,
      "inline_index": 0,
      "line_hash": "30fbd4a9",
      "speaker": "",
      "ja": "先ほどまで純潔だったブロワーが俺ので汚れる……",
      "zh": ""
    },
    {
      "key": "222.0",
      "line_index": 222,
      "inline_index": 0,
      "line_hash": "dcf7be3f",
      "speaker": "",
      "ja": "それが異様なまでに気分を高ぶらせ、無我夢中に性器を擦り合わせてしまう。",
      "zh": ""
    },
    {
      "key": "225.0",
      "line_index": 225,
      "inline_index": 0,
      "line_hash": "66f13d8b",
      "speaker": "ブロワー",
      "ja": "ああああっ！♥　おまんこイキっぱなしぃ！♥　おちんぽ気持ち良い……気持ち良いよぉっ！♥　ふあぁぁんっ♥",
      "zh": ""
    },
    {
      "key": "227.0",
      "line_index": 227,
      "inline_index": 0,
      "line_hash": "c1fe3d3f",
      "speaker": "",
      "ja": "ブロワーは快感の連続に全身の力が抜け落ちる。",
      "zh": ""
    },
    {
      "key": "228.0",
      "line_index": 228,
      "inline_index": 0,
      "line_hash": "7e7e4505",
      "speaker": "",
      "ja": "それでも潤んだ瞳はじっと俺だけを見つめ、そして俺もその瞳を見つめ続ける。",
      "zh": ""
    },
    {
      "key": "230.0",
      "line_index": 230,
      "inline_index": 0,
      "line_hash": "cafcba3c",
      "speaker": "",
      "ja": "もはや頭の中はブロワーのことしか考えられなくなり、貪るようにブロワーを求め続けた。",
      "zh": ""
    },
    {
      "key": "233.0",
      "line_index": 233,
      "inline_index": 0,
      "line_hash": "4d5d199b",
      "speaker": "ブロワー",
      "ja": "うう、おちんぽ震えて……またイク？♥　イっちゃう？♥",
      "zh": ""
    },
    {
      "key": "236.0",
      "line_index": 236,
      "inline_index": 0,
      "line_hash": "d61f37d2",
      "speaker": "{G_PlayerName}",
      "ja": "ああ……またすごいのが出そうだ……！また一番奥で出すから……全部受け止めてくれっ",
      "zh": ""
    },
    {
      "key": "240.0",
      "line_index": 240,
      "inline_index": 0,
      "line_hash": "e922c750",
      "speaker": "ブロワー",
      "ja": "やぁっ！♥　おぐぅぅぅっ！♥　ふ、ふうううっ！♥",
      "zh": ""
    },
    {
      "key": "243.0",
      "line_index": 243,
      "inline_index": 0,
      "line_hash": "8cf58d98",
      "speaker": "ブロワー",
      "ja": "ああ、またすごいの迫って来るぅ！♥　ねぇっ！♥　ちゅーしてぇ！♥　ちゅーしながらイかせてぇぇっ！♥　お願いだよぉっ！♥",
      "zh": ""
    },
    {
      "key": "246.0",
      "line_index": 246,
      "inline_index": 0,
      "line_hash": "a1e76501",
      "speaker": "ブロワー",
      "ja": "──ふぐっ！♥　んちゅ……んぢゅるっ！♥　ちゅ、ちゅぅぅぅっ！♥",
      "zh": ""
    },
    {
      "key": "248.0",
      "line_index": 248,
      "inline_index": 0,
      "line_hash": "c4c7058",
      "speaker": "",
      "ja": "ブロワーのおねだりに応えるように唇を重ね、そして舌を乱暴に捻じ込む。",
      "zh": ""
    },
    {
      "key": "250.0",
      "line_index": 250,
      "inline_index": 0,
      "line_hash": "442eb552",
      "speaker": "",
      "ja": "ブロワーの小さな舌が俺の舌に絡みつき、その心地良さに堪えていた熱いモノが一気に肉竿を駆け上る。",
      "zh": ""
    },
    {
      "key": "253.0",
      "line_index": 253,
      "inline_index": 0,
      "line_hash": "55a95ed",
      "speaker": "ブロワー",
      "ja": "い、ぐぅ……！♥　んっ！♥　んぢゅ……ちゅぅぅ！♥　んっ！♥　んぅぅ、ふううぅぅぅぅぅっ！！♥♥",
      "zh": ""
    },
    {
      "key": "261.0",
      "line_index": 261,
      "inline_index": 0,
      "line_hash": "9f21769",
      "speaker": "ブロワー",
      "ja": "ふっ♥　んぅ！♥　んぅぅぅ……♥　んぅぅぅぅっ！♥♥",
      "zh": ""
    },
    {
      "key": "263.0",
      "line_index": 263,
      "inline_index": 0,
      "line_hash": "f4fde561",
      "speaker": "",
      "ja": "舌を絡ませ合いながら、膣奥に吐き出すように射精をする。",
      "zh": ""
    },
    {
      "key": "265.0",
      "line_index": 265,
      "inline_index": 0,
      "line_hash": "fcf76ccb",
      "speaker": "",
      "ja": "中に出された反動でブロワーも絶頂するが、それでも舌を絡ませ続け、その心地良さが肉棒から何度も精液を搾り取っていく。",
      "zh": ""
    },
    {
      "key": "268.0",
      "line_index": 268,
      "inline_index": 0,
      "line_hash": "e9e9bafb",
      "speaker": "ブロワー",
      "ja": "ぷはぁっ！♥　はーっ！♥　んはーっ！♥　ああ……しゅごい……さっきよりいっぱいぃ♥　んっ♥　ちゅ……ぢゅるっ♥",
      "zh": ""
    },
    {
      "key": "270.0",
      "line_index": 270,
      "inline_index": 0,
      "line_hash": "b6b1029",
      "speaker": "",
      "ja": "ブロワーは喜びを伝えようと再度唇を重ね、俺は応えるように舌を絡ませる。",
      "zh": ""
    },
    {
      "key": "272.0",
      "line_index": 272,
      "inline_index": 0,
      "line_hash": "90201a02",
      "speaker": "",
      "ja": "舌を絡ませ合うたびに俺達は小さな絶頂を繰り返し、その心地良さと気持ち良さに溺れるように、何度もキスを繰り返した。",
      "zh": ""
    },
    {
      "key": "275.0",
      "line_index": 275,
      "inline_index": 0,
      "line_hash": "ab87f05",
      "speaker": "ブロワー",
      "ja": "ぷはぁ～♥　はー……♥　すんごい気持ち良かった……♥　あんちゃんはどうなんだ？♥　おいらのおまんこ気持ち良かったか？♥",
      "zh": ""
    },
    {
      "key": "278.0",
      "line_index": 278,
      "inline_index": 0,
      "line_hash": "893843",
      "speaker": "{G_PlayerName}",
      "ja": "ああ……最高だ。でもおまんこだけじゃない、ブロワーのすべてが俺には最高過ぎる",
      "zh": ""
    },
    {
      "key": "282.0",
      "line_index": 282,
      "inline_index": 0,
      "line_hash": "f25ef6fe",
      "speaker": "{G_PlayerName}",
      "ja": "もうブロワーのことしか目に入らないよ……これから先もずっと……",
      "zh": ""
    },
    {
      "key": "285.0",
      "line_index": 285,
      "inline_index": 0,
      "line_hash": "1d6c5c20",
      "speaker": "",
      "ja": "あれだけ大量に射精したにも関わらず、ブロワーの潤んだ大きな瞳にみつめられ、再び肉棒に活力が戻っていく。",
      "zh": ""
    },
    {
      "key": "288.0",
      "line_index": 288,
      "inline_index": 0,
      "line_hash": "fdcc82f7",
      "speaker": "ブロワー",
      "ja": "ふひひ……♥　あんちゃんのまた大きくなってきてる♥　まだまだ助けは来そうにないし……もう一回だけ……いいよな？♥",
      "zh": ""
    },
    {
      "key": "291.0",
      "line_index": 291,
      "inline_index": 0,
      "line_hash": "c8249101",
      "speaker": "ブロワー",
      "ja": "またギラギラした目でおいらのことイかせて……♥",
      "zh": ""
    },
    {
      "key": "293.0",
      "line_index": 293,
      "inline_index": 0,
      "line_hash": "d1c32364",
      "speaker": "",
      "ja": "どちらからともなく唇を重ね、舌を絡ませ合う。",
      "zh": ""
    },
    {
      "key": "294.0",
      "line_index": 294,
      "inline_index": 0,
      "line_hash": "91b2bf29",
      "speaker": "",
      "ja": "助けが来るその時までお互いを求め愛し合い続けるのであった。",
      "zh": ""
    }
  ]
}
