{
  "lines": [
    {
      "key": "16.1",
      "line_index": 16,
      "inline_index": 1,
      "line_hash": "6ad126ba",
      "speaker": "カルーア",
      "ja": "これが本番オプションの金額です……ほんの少しだけ高いですけどぉ……♥",
      "zh": ""
    },
    {
      "key": "19.0",
      "line_index": 19,
      "inline_index": 0,
      "line_hash": "a73ab900",
      "speaker": "{G_PlayerName}",
      "ja": "うあっ！？　な、なんだこの値段っ！？　高すぎないか！？",
      "zh": ""
    },
    {
      "key": "23.1",
      "line_index": 23,
      "inline_index": 1,
      "line_hash": "e83194f5",
      "speaker": "カルーア",
      "ja": "で、ですよねぇ……でもでも、お金を出してくれればあたしに何してもいいんだよ……？♥",
      "zh": ""
    },
    {
      "key": "26.1",
      "line_index": 26,
      "inline_index": 1,
      "line_hash": "1777e4f5",
      "speaker": "カルーア",
      "ja": "本番でも何でも時間が許すまで……あ、で、でもアナルだけはダメですからね？♥　これはお店のルールで禁止ですからぁ……♥",
      "zh": ""
    },
    {
      "key": "29.0",
      "line_index": 29,
      "inline_index": 0,
      "line_hash": "d1b6089f",
      "speaker": "{G_PlayerName}",
      "ja": "本番でも何でも……",
      "zh": ""
    },
    {
      "key": "32.0",
      "line_index": 32,
      "inline_index": 0,
      "line_hash": "8245d36c",
      "speaker": "",
      "ja": "俺はその言葉に思わず生唾を飲み込んでしまう。",
      "zh": ""
    },
    {
      "key": "33.0",
      "line_index": 33,
      "inline_index": 0,
      "line_hash": "62d7dad9",
      "speaker": "",
      "ja": "発情しているであろうカルーアを見ていると、ムラムラした気持ちがさらに強くなる。",
      "zh": ""
    },
    {
      "key": "35.0",
      "line_index": 35,
      "inline_index": 0,
      "line_hash": "a975c272",
      "speaker": "",
      "ja": "カルーアとセックスできるなら、このくらいの金額大したことない、そうとすら思い始めてきてしまっていた。",
      "zh": ""
    },
    {
      "key": "38.1",
      "line_index": 38,
      "inline_index": 1,
      "line_hash": "5bfe6d5",
      "speaker": "カルーア",
      "ja": "お願いしますぅ……♥　本番オプション付けてくれたら、来月のノルマもクリアできるんですぅ……♥",
      "zh": ""
    },
    {
      "key": "41.0",
      "line_index": 41,
      "inline_index": 0,
      "line_hash": "af63a58b",
      "speaker": "{G_PlayerName}",
      "ja": "そ、そっちが本命かよっ！",
      "zh": ""
    },
    {
      "key": "45.1",
      "line_index": 45,
      "inline_index": 1,
      "line_hash": "d89cef97",
      "speaker": "カルーア",
      "ja": "ち、違いますぅ……あ、いや、違わなくはないですけどぉ……♥　人助けと思って本番オプション付けてください～……♥",
      "zh": ""
    },
    {
      "key": "48.1",
      "line_index": 48,
      "inline_index": 1,
      "line_hash": "f12fc08e",
      "speaker": "カルーア",
      "ja": "それに……ほら、あたしのおまんこ、もうこんなになっていますぅ……♥",
      "zh": ""
    },
    {
      "key": "50.0",
      "line_index": 50,
      "inline_index": 0,
      "line_hash": "4eec4bf",
      "speaker": "",
      "ja": "カルーアは割れ目を指で拡げ、膣の中を見せてくる。",
      "zh": ""
    },
    {
      "key": "51.0",
      "line_index": 51,
      "inline_index": 0,
      "line_hash": "644bdf37",
      "speaker": "",
      "ja": "ぐっしょりと真っ白な愛液で満たされ、膣ヒダが何かを求めるように蠢いていた。",
      "zh": ""
    },
    {
      "key": "54.0",
      "line_index": 54,
      "inline_index": 0,
      "line_hash": "d458b739",
      "speaker": "{G_PlayerName}",
      "ja": "……本当に何してもいいんだな？",
      "zh": ""
    },
    {
      "key": "58.1",
      "line_index": 58,
      "inline_index": 1,
      "line_hash": "ccc47ab3",
      "speaker": "カルーア",
      "ja": "はいぃ……何しても……あ、そうそう、ゴムはしてくださいね？♥　一応お店のルールだから……♥",
      "zh": ""
    },
    {
      "key": "60.0",
      "line_index": 60,
      "inline_index": 0,
      "line_hash": "7e9353ec",
      "speaker": "",
      "ja": "カルーアはコンドームを差し出し、俺はそれを無言で受け取る。",
      "zh": ""
    },
    {
      "key": "63.1",
      "line_index": 63,
      "inline_index": 1,
      "line_hash": "3f7f8e95",
      "speaker": "カルーア",
      "ja": "えへへ……♥　本番オプション付けてくれるってことでいいんですよね……？♥",
      "zh": ""
    },
    {
      "key": "65.0",
      "line_index": 65,
      "inline_index": 0,
      "line_hash": "77d13f9",
      "speaker": "",
      "ja": "俺はカルーアの言葉に頷くと、はやる気持ちを抑えながら肉棒にゴムを付けた。",
      "zh": ""
    },
    {
      "key": "68.1",
      "line_index": 68,
      "inline_index": 1,
      "line_hash": "b989a6e0",
      "speaker": "カルーア",
      "ja": "それじゃあ機械士くん、じっとして……きゃっ！？♥　えっ、えっ！？♥　機械士くんっ！？♥",
      "zh": ""
    },
    {
      "key": "83.0",
      "line_index": 83,
      "inline_index": 0,
      "line_hash": "228d5f2",
      "speaker": "カルーア",
      "ja": "んぃぃっ！？♥　いっ、いきなり、あうっ！♥　ピストンは、反則っ！♥　だめぇっ！♥　あうううっ！！♥",
      "zh": ""
    },
    {
      "key": "85.0",
      "line_index": 85,
      "inline_index": 0,
      "line_hash": "c8ef92b2",
      "speaker": "",
      "ja": "俺は興奮を抑えきれず、押し倒すと同時に肉棒を押し込む。",
      "zh": ""
    },
    {
      "key": "86.0",
      "line_index": 86,
      "inline_index": 0,
      "line_hash": "33590d1",
      "speaker": "",
      "ja": "本能のままに腰をピストンさせ、俺の行動にカルーアは戸惑いの悲鳴を口から漏らしていた。",
      "zh": ""
    },
    {
      "key": "89.0",
      "line_index": 89,
      "inline_index": 0,
      "line_hash": "16f3f4bc",
      "speaker": "カルーア",
      "ja": "んんんっ！♥　何やっても……あうっ！♥　良いって言いましたけどぉ！♥　こ、これは……あひぃっ！♥",
      "zh": ""
    },
    {
      "key": "92.0",
      "line_index": 92,
      "inline_index": 0,
      "line_hash": "461b2f1f",
      "speaker": "{G_PlayerName}",
      "ja": "高い金払ってんだ、このくらいはいいだろ？",
      "zh": ""
    },
    {
      "key": "96.0",
      "line_index": 96,
      "inline_index": 0,
      "line_hash": "3a07e0e6",
      "speaker": "カルーア",
      "ja": "そうかも、ですけどぉ……んんんっ！♥　うあ、んぅぅぅ！♥　奥まで、届いちゃってるぅっ！♥　これ、すごすぎ……だめぇっ！♥",
      "zh": ""
    },
    {
      "key": "99.0",
      "line_index": 99,
      "inline_index": 0,
      "line_hash": "1e654fc",
      "speaker": "カルーア",
      "ja": "（機械士くんの、大きすぎるぅ……♥　あそこ、メリメリ拡がってるぅ……一番奥までおちんちん届いちゃってるよぉ♥）",
      "zh": ""
    },
    {
      "key": "101.0",
      "line_index": 101,
      "inline_index": 0,
      "line_hash": "b9bac931",
      "speaker": "",
      "ja": "快感から逃げるようにもがくカルーアの太ももを掴み、俺は一心不乱に腰を突き動かす。",
      "zh": ""
    },
    {
      "key": "103.0",
      "line_index": 103,
      "inline_index": 0,
      "line_hash": "8cd12ccf",
      "speaker": "",
      "ja": "膣奥を突くたびにカルーアの口から卑猥な悲鳴が漏れ、愛液が奥からドプリと溢れる。",
      "zh": ""
    },
    {
      "key": "104.0",
      "line_index": 104,
      "inline_index": 0,
      "line_hash": "23b56f48",
      "speaker": "",
      "ja": "愛液が狭い膣でぐちゅぐちゅと掻き回され、掻き出された愛液が肉棒とカルーアの下半身をいやらしく汚していった。",
      "zh": ""
    },
    {
      "key": "107.0",
      "line_index": 107,
      "inline_index": 0,
      "line_hash": "39f5b0a9",
      "speaker": "カルーア",
      "ja": "んあああっ！♥　機械士、さんっ！♥　もっと、もっとゆっくりぃ……あうっ！♥　おまんこ壊れちゃうよぉっ！♥",
      "zh": ""
    },
    {
      "key": "110.0",
      "line_index": 110,
      "inline_index": 0,
      "line_hash": "a5bf1f6",
      "speaker": "カルーア",
      "ja": "ひいいっ！？♥　あっ！♥　あっ！♥　そ、そこダメっ！♥　あああ、声、出ちゃうっ！♥　おまんこ余計に感じちゃうぅっ！！♥",
      "zh": ""
    },
    {
      "key": "113.0",
      "line_index": 113,
      "inline_index": 0,
      "line_hash": "93425598",
      "speaker": "{G_PlayerName}",
      "ja": "ココか？　ココがいいのか？　それならもっとしてやる……俺のちんぽで死ぬほど感じさせてやるから！",
      "zh": ""
    },
    {
      "key": "117.0",
      "line_index": 117,
      "inline_index": 0,
      "line_hash": "2a628d1f",
      "speaker": "カルーア",
      "ja": "んぎぃぃぃっ！♥　死ぬほどなんて、イヤですぅっ！♥　あうううっ！♥　ほどほどが良いんですぅっ！♥　んんんんっ！！♥",
      "zh": ""
    },
    {
      "key": "119.0",
      "line_index": 119,
      "inline_index": 0,
      "line_hash": "267d9c41",
      "speaker": "",
      "ja": "俺はカルーアの抗議の声を無視するようにGスポットを執拗に肉棒で擦る。",
      "zh": ""
    },
    {
      "key": "121.0",
      "line_index": 121,
      "inline_index": 0,
      "line_hash": "6d2136ae",
      "speaker": "",
      "ja": "表情がどんどんいやらしく蕩け、膣が快感に喜ぶように肉棒をぎゅっと締め上げる。",
      "zh": ""
    },
    {
      "key": "122.0",
      "line_index": 122,
      "inline_index": 0,
      "line_hash": "d7b489fc",
      "speaker": "",
      "ja": "肉棒を突き入れるたびに無数の膣ヒダが絡み、快感と射精を求めるように俺の腰の動きが勝手に早くなってしまう。",
      "zh": ""
    },
    {
      "key": "125.0",
      "line_index": 125,
      "inline_index": 0,
      "line_hash": "86e5bcff",
      "speaker": "カルーア",
      "ja": "機械士くんっ、お願い、もっと……あうっ！♥　ゆっくりぃっ！♥",
      "zh": ""
    },
    {
      "key": "128.0",
      "line_index": 128,
      "inline_index": 0,
      "line_hash": "701508af",
      "speaker": "{G_PlayerName}",
      "ja": "カルーアのおまんこ気持ち良すぎて……止められそうにない……！！　このまま続けさせてくれっ",
      "zh": ""
    },
    {
      "key": "132.0",
      "line_index": 132,
      "inline_index": 0,
      "line_hash": "64d2ea5",
      "speaker": "カルーア",
      "ja": "うううううっ！♥　鬼いぃっ！♥　あうっ！♥　あっ、あっ！♥　んぅ、ふぅ、ふあ、あああぁぁんっ！！♥",
      "zh": ""
    },
    {
      "key": "134.0",
      "line_index": 134,
      "inline_index": 0,
      "line_hash": "6860bbc5",
      "speaker": "",
      "ja": "コンドーム越しでも十分すぎるほどの快感に俺の興奮が止まらない。",
      "zh": ""
    },
    {
      "key": "135.0",
      "line_index": 135,
      "inline_index": 0,
      "line_hash": "b4afc069",
      "speaker": "",
      "ja": "俺の肉棒が狭すぎるカルーアの膣の中でビクンビクンと脈打ちながら跳ね、動くたびに射精が近づくのを実感する。",
      "zh": ""
    },
    {
      "key": "138.0",
      "line_index": 138,
      "inline_index": 0,
      "line_hash": "5789e9d1",
      "speaker": "カルーア",
      "ja": "（機械士くんがこんなに激しいエッチする人だったなんてぇ……♥　淡泊そうだったから本番お願いしたのにぃ……♥）",
      "zh": ""
    },
    {
      "key": "141.0",
      "line_index": 141,
      "inline_index": 0,
      "line_hash": "cae3f08c",
      "speaker": "カルーア",
      "ja": "（でも、でも……こういう機械士くんも結構イイ、かもぉ……♥　感じすぎて辛いけど、もっとして欲しいって思っちゃってるよぉ……♥）",
      "zh": ""
    },
    {
      "key": "144.0",
      "line_index": 144,
      "inline_index": 0,
      "line_hash": "60c054ac",
      "speaker": "カルーア",
      "ja": "ふあ、ふあぁっ！♥　機械士くんっ、このままじゃ……あうっ！♥",
      "zh": ""
    },
    {
      "key": "147.0",
      "line_index": 147,
      "inline_index": 0,
      "line_hash": "4049a460",
      "speaker": "{G_PlayerName}",
      "ja": "もうイキそうなのか？　いつイってもいいぞ……カルーアの絶頂に合わせるから……フンっ！",
      "zh": ""
    },
    {
      "key": "151.0",
      "line_index": 151,
      "inline_index": 0,
      "line_hash": "c940a9d5",
      "speaker": "カルーア",
      "ja": "はうううっ！♥　お、奥ダメですってぇっ！♥　こ、これ、感じすぎちゃうんですぅっ！♥　うう、んぅ、ふぅ、ふうううっ！！♥",
      "zh": ""
    },
    {
      "key": "154.0",
      "line_index": 154,
      "inline_index": 0,
      "line_hash": "40bfa3",
      "speaker": "カルーア",
      "ja": "あ、あっ！♥　波が……あうっ！♥　あああ、イ、イっちゃう、おまんこイっちゃう！♥　んぅ、んんんんっ！！♥",
      "zh": ""
    },
    {
      "key": "156.0",
      "line_index": 156,
      "inline_index": 0,
      "line_hash": "55fb623d",
      "speaker": "",
      "ja": "俺はオスの本能を剥き出しに執拗に膣奥を突き上げる。",
      "zh": ""
    },
    {
      "key": "157.0",
      "line_index": 157,
      "inline_index": 0,
      "line_hash": "fc21d1c4",
      "speaker": "",
      "ja": "コンドームが邪魔をして子宮に精液は注ぎ込めないものの、それでもカルーアを孕ませる勢いで俺はひたすらにピストンを繰り返す。",
      "zh": ""
    },
    {
      "key": "160.0",
      "line_index": 160,
      "inline_index": 0,
      "line_hash": "d99a043d",
      "speaker": "カルーア",
      "ja": "イぐっ、イぐぅぅっ！♥　イっちゃう！！♥　イっちゃいますぅぅっぅぅ～～～～～っ！！♥♥",
      "zh": ""
    },
    {
      "key": "169.0",
      "line_index": 169,
      "inline_index": 0,
      "line_hash": "c20c7bc1",
      "speaker": "カルーア",
      "ja": "あうううううっ！♥　んぅぅぅ、んは、はあぁぁぁぁんっ！！♥♥",
      "zh": ""
    },
    {
      "key": "171.0",
      "line_index": 171,
      "inline_index": 0,
      "line_hash": "6f7a40fb",
      "speaker": "",
      "ja": "カルーアが甲高い悲鳴を上げながら果て、俺も同時に絶頂する。",
      "zh": ""
    },
    {
      "key": "172.0",
      "line_index": 172,
      "inline_index": 0,
      "line_hash": "342c74a3",
      "speaker": "",
      "ja": "柔らかい膣肉が肉棒をぎゅっと締め上げ、吸い付く感触に俺は何度も射精を繰り返す。",
      "zh": ""
    },
    {
      "key": "175.0",
      "line_index": 175,
      "inline_index": 0,
      "line_hash": "5a4e4790",
      "speaker": "カルーア",
      "ja": "（うう……す、ご……♥　ゴム越しでも出てるのはっきりわかる……♥　さっきより全然出ちゃってる……♥）",
      "zh": ""
    },
    {
      "key": "178.0",
      "line_index": 178,
      "inline_index": 0,
      "line_hash": "bc325ff5",
      "speaker": "カルーア",
      "ja": "（三度目の射精なのに……機械士くん凄すぎぃ……♥）",
      "zh": ""
    },
    {
      "key": "181.0",
      "line_index": 181,
      "inline_index": 0,
      "line_hash": "1e869e18",
      "speaker": "{G_PlayerName}",
      "ja": "ううう……！　カルーア、まだ……！　ぐっ！",
      "zh": ""
    },
    {
      "key": "185.0",
      "line_index": 185,
      "inline_index": 0,
      "line_hash": "753d975e",
      "speaker": "カルーア",
      "ja": "んんっ！♥　ま、まだ出てるっ？♥　中でゴム、膨らんでるぅ……！♥　あうっ！！♥",
      "zh": ""
    },
    {
      "key": "188.0",
      "line_index": 188,
      "inline_index": 0,
      "line_hash": "3d4d6f75",
      "speaker": "カルーア",
      "ja": "機械士くん、絶倫過ぎぃ……♥　こんなのゴムなかったら確実にデキちゃっていますぅ……♥",
      "zh": ""
    },
    {
      "key": "195.0",
      "line_index": 195,
      "inline_index": 0,
      "line_hash": "a67a9dc4",
      "speaker": "カルーア",
      "ja": "はぁ、はぁ……♥　機械士くん……まだおちんちんカチカチなんですかぁ……？♥　濃ゆいの三回も出しているのにぃ……♥",
      "zh": ""
    },
    {
      "key": "198.0",
      "line_index": 198,
      "inline_index": 0,
      "line_hash": "a485b92d",
      "speaker": "カルーア",
      "ja": "おちんちん、元気いっぱい過ぎですよぉ……♥",
      "zh": ""
    },
    {
      "key": "200.0",
      "line_index": 200,
      "inline_index": 0,
      "line_hash": "dc0dd2ff",
      "speaker": "",
      "ja": "カルーアは蕩けた視線で勃起したままの肉棒を見つめる。",
      "zh": ""
    },
    {
      "key": "201.0",
      "line_index": 201,
      "inline_index": 0,
      "line_hash": "3e1d705f",
      "speaker": "",
      "ja": "その視線にムラっとしてしまい、ぱっくり開いた割れ目に肉棒を擦りつける。",
      "zh": ""
    },
    {
      "key": "204.0",
      "line_index": 204,
      "inline_index": 0,
      "line_hash": "2bb429df",
      "speaker": "カルーア",
      "ja": "あ……♥　い、入れるのはダメですからね？♥　生えっちはダメですからぁ……♥",
      "zh": ""
    },
    {
      "key": "207.0",
      "line_index": 207,
      "inline_index": 0,
      "line_hash": "aac60da4",
      "speaker": "{G_PlayerName}",
      "ja": "これで終わりなんて絶対にダメだ。高い金払ってんだ、料金分はきっちり満足させてくれ",
      "zh": ""
    },
    {
      "key": "211.0",
      "line_index": 211,
      "inline_index": 0,
      "line_hash": "dfbdfb90",
      "speaker": "カルーア",
      "ja": "あひぃっ！？♥　あ、あっ！♥　ちょ、ちょっとぉっ！？♥　生はダメなんですってばぁっ……！♥",
      "zh": ""
    },
    {
      "key": "214.0",
      "line_index": 214,
      "inline_index": 0,
      "line_hash": "7de5a9c5",
      "speaker": "カルーア",
      "ja": "ゴムもうありませんし、お口でしますからぁっ♥",
      "zh": ""
    },
    {
      "key": "217.0",
      "line_index": 217,
      "inline_index": 0,
      "line_hash": "b8d19296",
      "speaker": "{G_PlayerName}",
      "ja": "カルーアが黙っててくれれば生でしても問題はないだろ？",
      "zh": ""
    },
    {
      "key": "221.0",
      "line_index": 221,
      "inline_index": 0,
      "line_hash": "b474aa59",
      "speaker": "カルーア",
      "ja": "それはそうかもですけどぉ……♥　でもバレたらクビになってしまいますぅ……♥　せっかく来月分までのノルマ達成できましたのにぃ……♥",
      "zh": ""
    },
    {
      "key": "223.0",
      "line_index": 223,
      "inline_index": 0,
      "line_hash": "565d856d",
      "speaker": "",
      "ja": "口では抵抗しているカルーアだったが、膣穴に押し当てた肉棒を濡らすように真っ白な愛液がどろどろと溢れる。",
      "zh": ""
    },
    {
      "key": "226.0",
      "line_index": 226,
      "inline_index": 0,
      "line_hash": "e331cd82",
      "speaker": "{G_PlayerName}",
      "ja": "生の方がさらに気持ち良くなれるんだ、カルーアももっと気持ち良くなりたいだろ？",
      "zh": ""
    },
    {
      "key": "230.0",
      "line_index": 230,
      "inline_index": 0,
      "line_hash": "7cc89a",
      "speaker": "カルーア",
      "ja": "それは……あっ！？♥　ダメ、ダメっ！♥　ダメです、機械士くんっ！♥　入っちゃう！♥　生おちんちん入っちゃうよぉっ！♥",
      "zh": ""
    },
    {
      "key": "237.0",
      "line_index": 237,
      "inline_index": 0,
      "line_hash": "b327e7a4",
      "speaker": "カルーア",
      "ja": "はうううっ！♥　入っちゃったぁっ♥　生、ダメなのにぃっ♥　んんっ！♥　ふあ、あ、ああぁぁんっ！！♥",
      "zh": ""
    },
    {
      "key": "239.0",
      "line_index": 239,
      "inline_index": 0,
      "line_hash": "d4215e8d",
      "speaker": "",
      "ja": "俺は興奮を抑えきれず、愛液溢れるカルーアの膣の中に肉棒を押し込む。",
      "zh": ""
    },
    {
      "key": "240.0",
      "line_index": 240,
      "inline_index": 0,
      "line_hash": "722760dc",
      "speaker": "",
      "ja": "ゴム越しとは比べ物にならないくらいの熱くとろとろの膣の感触に腰が勝手に震えてしまう。",
      "zh": ""
    },
    {
      "key": "242.0",
      "line_index": 242,
      "inline_index": 0,
      "line_hash": "c2b48b20",
      "speaker": "",
      "ja": "膣ヒダの一つ一つが絡むのがはっきりと伝わり、本当の意味でカルーアと一つになれたことに喜びを覚える。",
      "zh": ""
    },
    {
      "key": "244.0",
      "line_index": 244,
      "inline_index": 0,
      "line_hash": "7e0b750c",
      "speaker": "",
      "ja": "俺はその興奮と喜びをカルーアに伝えるように腰をピストンさせ、狭い膣を乱雑に押し広げていった。",
      "zh": ""
    },
    {
      "key": "247.0",
      "line_index": 247,
      "inline_index": 0,
      "line_hash": "66005774",
      "speaker": "カルーア",
      "ja": "はぁ、はぁっ！♥　生の、おちんちんっ、気持ち良すぎぃ……！♥　機械士くん、もっとゆっくりしてぇ……あうっ！♥",
      "zh": ""
    },
    {
      "key": "250.0",
      "line_index": 250,
      "inline_index": 0,
      "line_hash": "cf64a8d1",
      "speaker": "{G_PlayerName}",
      "ja": "こんな気持ちいいおまんこ、ゆっくりなんてできるわけないだろ……！",
      "zh": ""
    },
    {
      "key": "254.0",
      "line_index": 254,
      "inline_index": 0,
      "line_hash": "2d1ed3c3",
      "speaker": "カルーア",
      "ja": "あひぃっ！♥　ううう、中引っ掻かれるぅ♥　これダメっ、感じすぎちゃうっ♥　あう、うう、んぅ、んああぁぁっ！！♥",
      "zh": ""
    },
    {
      "key": "257.0",
      "line_index": 257,
      "inline_index": 0,
      "line_hash": "9f08c803",
      "speaker": "カルーア",
      "ja": "うううう……機械士くん、中にだけは、絶対に、絶対に出さないでくださいっ♥　赤ちゃんデキちゃいますからぁっ♥",
      "zh": ""
    },
    {
      "key": "260.0",
      "line_index": 260,
      "inline_index": 0,
      "line_hash": "518fa331",
      "speaker": "{G_PlayerName}",
      "ja": "上の口はそう言ってるけど、下の口は違うみたいだぞ？　精液欲しさにすげぇ締め付けてきてる",
      "zh": ""
    },
    {
      "key": "264.0",
      "line_index": 264,
      "inline_index": 0,
      "line_hash": "2e360187",
      "speaker": "カルーア",
      "ja": "いやぁ、そんなこと、言わないでぇ……あうっ！♥　生のおちんちん挿れられて、おまんこが勝手に喜んでいるだけだからぁっ♥",
      "zh": ""
    },
    {
      "key": "267.0",
      "line_index": 267,
      "inline_index": 0,
      "line_hash": "9a30bf49",
      "speaker": "カルーア",
      "ja": "うあ、ああぁんっ！♥　生えっちがこんなにすごいなんてぇ……んぅぅぅ！♥　気持ち良いの、止まらないぃ……あんっ！♥",
      "zh": ""
    },
    {
      "key": "270.0",
      "line_index": 270,
      "inline_index": 0,
      "line_hash": "6b7af525",
      "speaker": "カルーア",
      "ja": "も、もっとぉ……もっと……掻き回してぇ……んんっ！！♥",
      "zh": ""
    },
    {
      "key": "272.0",
      "line_index": 272,
      "inline_index": 0,
      "line_hash": "f3e778e4",
      "speaker": "",
      "ja": "快感にガマンしきれなかったのか、徐々に快楽に溺れ始めるカルーア。",
      "zh": ""
    },
    {
      "key": "273.0",
      "line_index": 273,
      "inline_index": 0,
      "line_hash": "7ced662f",
      "speaker": "",
      "ja": "俺はそんなカルーアの期待に応えるように腰を深々と突き落とす。",
      "zh": ""
    },
    {
      "key": "275.0",
      "line_index": 275,
      "inline_index": 0,
      "line_hash": "69a37ac7",
      "speaker": "",
      "ja": "押し出された愛液が隙間からブシュっと溢れる。",
      "zh": ""
    },
    {
      "key": "276.0",
      "line_index": 276,
      "inline_index": 0,
      "line_hash": "dc2198ee",
      "speaker": "",
      "ja": "泡立つ愛液がいやらしく俺たちを濡らし、カルーアが本気で感じていることに俺の心が喜びと興奮で満ちていく。",
      "zh": ""
    },
    {
      "key": "279.0",
      "line_index": 279,
      "inline_index": 0,
      "line_hash": "4de4770",
      "speaker": "カルーア",
      "ja": "あひいいいっ！？♥　あっ、んあっ！♥　そこダメですってぇ♥　あっ、ああああぁっ！！♥",
      "zh": ""
    },
    {
      "key": "282.0",
      "line_index": 282,
      "inline_index": 0,
      "line_hash": "a551d37f",
      "speaker": "{G_PlayerName}",
      "ja": "カルーアはGスポット弱いんだな……それならもっとしてやるから。生のちんぽでいくらでも気持ち良くしてやるからっ♥",
      "zh": ""
    },
    {
      "key": "286.0",
      "line_index": 286,
      "inline_index": 0,
      "line_hash": "39edfe1c",
      "speaker": "カルーア",
      "ja": "ううううっ！♥　らめぇっ！♥　おまんこおかしくなりゅぅっ！♥　おちんちん気持ち良い、生おちんちん気持ち良いよぉっ♥",
      "zh": ""
    },
    {
      "key": "289.0",
      "line_index": 289,
      "inline_index": 0,
      "line_hash": "1b5c24f",
      "speaker": "カルーア",
      "ja": "あっ……！♥　機械士しゃんっ、らめ……あ、あ、あっ！！♥",
      "zh": ""
    },
    {
      "key": "291.0",
      "line_index": 291,
      "inline_index": 0,
      "line_hash": "b5ee6ac0",
      "speaker": "",
      "ja": "カルーアの小さな悲鳴と共に、プシャっと僅かに潮が噴き出す。",
      "zh": ""
    },
    {
      "key": "292.0",
      "line_index": 292,
      "inline_index": 0,
      "line_hash": "be4e4c09",
      "speaker": "",
      "ja": "腰を突き入れるたびに潮が噴き出し、大量の愛液が押し出される。",
      "zh": ""
    },
    {
      "key": "294.0",
      "line_index": 294,
      "inline_index": 0,
      "line_hash": "d960b11c",
      "speaker": "",
      "ja": "カルーアのいやらしく汚れていく姿に俺の興奮が止まらない。",
      "zh": ""
    },
    {
      "key": "295.0",
      "line_index": 295,
      "inline_index": 0,
      "line_hash": "cdb70e66",
      "speaker": "",
      "ja": "濡れそぼった膣全体で肉棒を扱かれる快感が気持ち良い。",
      "zh": ""
    },
    {
      "key": "297.0",
      "line_index": 297,
      "inline_index": 0,
      "line_hash": "8d0f84fb",
      "speaker": "",
      "ja": "怪しく蠢くヒダがさらにはげしく絡み、徐々に絶頂の二文字が脳裏に浮かび始めてきた。",
      "zh": ""
    },
    {
      "key": "300.0",
      "line_index": 300,
      "inline_index": 0,
      "line_hash": "50acd087",
      "speaker": "カルーア",
      "ja": "ふううっ！♥　ふううっ！♥　んぅ、んはぁっ！♥　機械士しゃん、まら、まらイっぢゃう！♥　おまんこイっちゃうよぉっ！！♥",
      "zh": ""
    },
    {
      "key": "303.0",
      "line_index": 303,
      "inline_index": 0,
      "line_hash": "9af644e0",
      "speaker": "{G_PlayerName}",
      "ja": "いくらでもイってくれ……！　このままカルーアの中に出すからなっ！",
      "zh": ""
    },
    {
      "key": "307.0",
      "line_index": 307,
      "inline_index": 0,
      "line_hash": "149d4f5d",
      "speaker": "カルーア",
      "ja": "中は……らめぇっ！♥　ううう、ダメダメ、ダメでしゅぅっ！♥　ふぅっ、んっ、んは、はっ！♥　あああぁっ！！♥",
      "zh": ""
    },
    {
      "key": "309.0",
      "line_index": 309,
      "inline_index": 0,
      "line_hash": "b6987495",
      "speaker": "",
      "ja": "中出しを宣言すると、精液を求めるようにきゅっと子宮口が亀頭の先端に吸い付く。",
      "zh": ""
    },
    {
      "key": "310.0",
      "line_index": 310,
      "inline_index": 0,
      "line_hash": "9a4a95d",
      "speaker": "",
      "ja": "精液を搾り取ろうと締め付けがさらに強くなり、睾丸が射精を求め強烈に疼き始める。",
      "zh": ""
    },
    {
      "key": "313.0",
      "line_index": 313,
      "inline_index": 0,
      "line_hash": "dd4265d9",
      "speaker": "カルーア",
      "ja": "あっ！♥　んあ！♥　イっちゃ……んんんっ！♥　イグっ！♥　イグイグっ！♥　ふあ、ふあああぁっ！♥　あ、あ、あああああーーーっ！！♥♥",
      "zh": ""
    },
    {
      "key": "322.0",
      "line_index": 322,
      "inline_index": 0,
      "line_hash": "79f15ef3",
      "speaker": "カルーア",
      "ja": "んんんんっ！♥　んあ、あ、熱ちゅいぃ……！♥　ううう、んぐぅ、ふぅ、ふうううううっ！！♥♥",
      "zh": ""
    },
    {
      "key": "324.0",
      "line_index": 324,
      "inline_index": 0,
      "line_hash": "f9c174a5",
      "speaker": "",
      "ja": "絶頂に達したカルーアの膣が今までにないほど締まり、柔らかな膣肉が肉棒を包み込む。",
      "zh": ""
    },
    {
      "key": "326.0",
      "line_index": 326,
      "inline_index": 0,
      "line_hash": "7ad83a46",
      "speaker": "",
      "ja": "その締まりに予兆もなしに射精し、カルーアの子宮に精液を注ぎ込んでいく。",
      "zh": ""
    },
    {
      "key": "329.0",
      "line_index": 329,
      "inline_index": 0,
      "line_hash": "ffbe23ff",
      "speaker": "カルーア",
      "ja": "んんぅぅぅ、出てるぅ……♥　熱いの、ドクドク出てるよぉ♥　おまんこ、蕩けるぅ……♥　うあ、あ、あああ……♥",
      "zh": ""
    },
    {
      "key": "331.0",
      "line_index": 331,
      "inline_index": 0,
      "line_hash": "25359fd0",
      "speaker": "",
      "ja": "俺は腰を小刻みに揺すり、さらに射精を繰り返す。",
      "zh": ""
    },
    {
      "key": "333.0",
      "line_index": 333,
      "inline_index": 0,
      "line_hash": "7f30f5d7",
      "speaker": "",
      "ja": "中に出されるたびにカルーアの小さく細い腰がビクンと跳ね、大量の精液が子宮に注がれたことでお腹が僅かに膨らんでいた。",
      "zh": ""
    },
    {
      "key": "336.0",
      "line_index": 336,
      "inline_index": 0,
      "line_hash": "1bc1061a",
      "speaker": "カルーア",
      "ja": "うう……中に、出されちゃったぁ……♥　中出しレイプされちゃったよぉ……♥　あはぁ～……♥",
      "zh": ""
    },
    {
      "key": "339.0",
      "line_index": 339,
      "inline_index": 0,
      "line_hash": "12037c4f",
      "speaker": "{G_PlayerName}",
      "ja": "……いくらお金を払うとはいえやり過ぎたか……だいじょうぶか、カルーア？",
      "zh": ""
    },
    {
      "key": "343.0",
      "line_index": 343,
      "inline_index": 0,
      "line_hash": "ad5b8bac",
      "speaker": "カルーア",
      "ja": "もうらめですぅ……クビになっちゃいますぅ……♥　明日からニートですぅ……♥",
      "zh": ""
    },
    {
      "key": "346.0",
      "line_index": 346,
      "inline_index": 0,
      "line_hash": "8d3734a5",
      "speaker": "{G_PlayerName}",
      "ja": "黙ってればバレないだろ？　まぁ仮にクビになるんだったら……最後にもう一回やるか",
      "zh": ""
    },
    {
      "key": "350.0",
      "line_index": 350,
      "inline_index": 0,
      "line_hash": "815e35c5",
      "speaker": "カルーア",
      "ja": "へ……？♥　あっ、あっ！♥　機械士くんっ！？♥　ま、まだ続けるんですかぁっ！？♥",
      "zh": ""
    },
    {
      "key": "353.0",
      "line_index": 353,
      "inline_index": 0,
      "line_hash": "955032da",
      "speaker": "カルーア",
      "ja": "んぉ、おおっ！！♥　どっ、どこまで絶倫なんですかぁっ！♥　うあ、だめ、だめっ！♥　ああ、おまんこ感じちゃうぅ～～っ！♥",
      "zh": ""
    },
    {
      "key": "356.0",
      "line_index": 356,
      "inline_index": 0,
      "line_hash": "9c6a11ce",
      "speaker": "{G_PlayerName}",
      "ja": "これで最後だから！　チップ弾むからもっとやらせてくれっ！",
      "zh": ""
    },
    {
      "key": "360.0",
      "line_index": 360,
      "inline_index": 0,
      "line_hash": "ba84b26b",
      "speaker": "カルーア",
      "ja": "チップはずるいぃぃ～～っ！♥　そんなこと言われたら断れなくなっちゃいますぅぅぅぅ～～～っ！！♥",
      "zh": ""
    },
    {
      "key": "362.0",
      "line_index": 362,
      "inline_index": 0,
      "line_hash": "13853d56",
      "speaker": "",
      "ja": "お金でカルーアを懐柔する……我ながら卑怯な手段だとは思ってしまう。",
      "zh": ""
    },
    {
      "key": "363.0",
      "line_index": 363,
      "inline_index": 0,
      "line_hash": "1664bc64",
      "speaker": "",
      "ja": "それでもカルーアとセックスしたい欲望には勝てず、刹那的な快楽を求め腰を突き動かすのであった。",
      "zh": ""
    }
  ]
}
