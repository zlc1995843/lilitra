{
  "lines": [
    {
      "key": "20.0",
      "line_index": 20,
      "inline_index": 0,
      "line_hash": "d5ca9b23",
      "speaker": "{G_PlayerName}",
      "ja": "なぁ、ラヴィリス……",
      "zh": ""
    },
    {
      "key": "23.0",
      "line_index": 23,
      "inline_index": 0,
      "line_hash": "a01f21ac",
      "speaker": "",
      "ja": "俺はラヴィリスの名を呼びながら小さな身体をそっと抱きかかえる。",
      "zh": ""
    },
    {
      "key": "26.0",
      "line_index": 26,
      "inline_index": 0,
      "line_hash": "dc471bce",
      "speaker": "{G_PlayerName}",
      "ja": "続き、しないか……？　お互いに満足できてないみたいだしさ",
      "zh": ""
    },
    {
      "key": "29.0",
      "line_index": 29,
      "inline_index": 0,
      "line_hash": "b027bd70",
      "speaker": "",
      "ja": "優しくベッドの上に寝かせると、ラヴィリスは小さく声を上げながら俺を迎えるように両腕を伸ばす。",
      "zh": ""
    },
    {
      "key": "31.0",
      "line_index": 31,
      "inline_index": 0,
      "line_hash": "3faba11f",
      "speaker": "",
      "ja": "俺はそれを合意と判断し、ラヴィリスの身体の上に覆いかぶさる。",
      "zh": ""
    },
    {
      "key": "33.0",
      "line_index": 33,
      "inline_index": 0,
      "line_hash": "bdb8b855",
      "speaker": "",
      "ja": "自発的な動きはほとんど見せていなかったラヴィリスが自らの意思で俺を迎え入れる。",
      "zh": ""
    },
    {
      "key": "35.0",
      "line_index": 35,
      "inline_index": 0,
      "line_hash": "2fd6931d",
      "speaker": "",
      "ja": "それがより俺の心がイヤらしくたぎり、絶対に気持ち良くさせよう、そう強く決意しながら俺はいきり立つ肉棒をいきなり膣にねじ込んだ。",
      "zh": ""
    },
    {
      "key": "40.1",
      "line_index": 40,
      "inline_index": 1,
      "line_hash": "7f0faa0",
      "speaker": "ラヴィリス",
      "ja": "んんっ……！♥　んはぁっ♥　いきなり挿れるんだねぇ～……♥　あああ、おまんこメチャクチャ拡がってるぅ……♥",
      "zh": ""
    },
    {
      "key": "43.1",
      "line_index": 43,
      "inline_index": 1,
      "line_hash": "3d7f6658",
      "speaker": "ラヴィリス",
      "ja": "でも……これだけじゃ物足りないから～……♥",
      "zh": ""
    },
    {
      "key": "45.0",
      "line_index": 45,
      "inline_index": 0,
      "line_hash": "c02c727a",
      "speaker": "",
      "ja": "ラヴィリスは俺の腕に手を伸ばすと、そっと俺の手を自分の首元に持ってくる。",
      "zh": ""
    },
    {
      "key": "47.0",
      "line_index": 47,
      "inline_index": 0,
      "line_hash": "8aff4f4b",
      "speaker": "",
      "ja": "ラヴィリスが何をさせたいのかわからず困惑しているとラヴィリスは小さく笑う。",
      "zh": ""
    },
    {
      "key": "50.1",
      "line_index": 50,
      "inline_index": 1,
      "line_hash": "33c1279b",
      "speaker": "ラヴィリス",
      "ja": "ね……首、ぎゅってして……♥",
      "zh": ""
    },
    {
      "key": "53.0",
      "line_index": 53,
      "inline_index": 0,
      "line_hash": "eab2e2d8",
      "speaker": "{G_PlayerName}",
      "ja": "は……？　お、お前、何言って──",
      "zh": ""
    },
    {
      "key": "57.1",
      "line_index": 57,
      "inline_index": 1,
      "line_hash": "5c230e21",
      "speaker": "ラヴィリス",
      "ja": "おちんちん喉の奥に突っ込まれてさ～……なんかスイッチ入っちゃったんだよね～♥",
      "zh": ""
    },
    {
      "key": "60.1",
      "line_index": 60,
      "inline_index": 1,
      "line_hash": "e2d7e24f",
      "speaker": "ラヴィリス",
      "ja": "というか隠し機能に気が付いちゃった感じかな～？♥　だからさ……ほら、ぎゅって首締めて♥　思いっきり♥",
      "zh": ""
    },
    {
      "key": "63.0",
      "line_index": 63,
      "inline_index": 0,
      "line_hash": "b635f491",
      "speaker": "{G_PlayerName}",
      "ja": "そ、そんなことできるわけないだろ……！",
      "zh": ""
    },
    {
      "key": "67.1",
      "line_index": 67,
      "inline_index": 1,
      "line_hash": "79b8da61",
      "speaker": "ラヴィリス",
      "ja": "いいじゃん、あたし機械なんだしさ～♥　お前機械フェチでしょ？♥　分解とかしちゃうんでしょ？♥",
      "zh": ""
    },
    {
      "key": "70.1",
      "line_index": 70,
      "inline_index": 1,
      "line_hash": "66a6471",
      "speaker": "ラヴィリス",
      "ja": "そういう気持ちで頭と身体を……ね、お願い～……♥　このままじゃ何度エッチしたって満足できないしさぁ～……♥",
      "zh": ""
    },
    {
      "key": "73.0",
      "line_index": 73,
      "inline_index": 0,
      "line_hash": "4cd9de82",
      "speaker": "{G_PlayerName}",
      "ja": "だからって……うう……！？",
      "zh": ""
    },
    {
      "key": "76.0",
      "line_index": 76,
      "inline_index": 0,
      "line_hash": "76d3357b",
      "speaker": "",
      "ja": "ラヴィリスの膣が、首絞めの期待からかぎゅっと肉棒を締め付ける。",
      "zh": ""
    },
    {
      "key": "78.0",
      "line_index": 78,
      "inline_index": 0,
      "line_hash": "976bdcb3",
      "speaker": "",
      "ja": "いくら機械でも乱暴には……そう思う一方で膣のもたらす気持ち良さに欲情してしまう。",
      "zh": ""
    },
    {
      "key": "79.0",
      "line_index": 79,
      "inline_index": 0,
      "line_hash": "9c097626",
      "speaker": "",
      "ja": "少しだけ……少しだけ、そう思いながらラヴィリスの細い首を掴む指に少しずつ力が入っていく。",
      "zh": ""
    },
    {
      "key": "84.1",
      "line_index": 84,
      "inline_index": 1,
      "line_hash": "414beff0",
      "speaker": "ラヴィリス",
      "ja": "んぅぅ……もっと、もっと強くぅ……♥　お前のおちんちんでめちゃくちゃにして♥　あたしを肉便器にしてぇ～っ♥",
      "zh": ""
    },
    {
      "key": "100.0",
      "line_index": 100,
      "inline_index": 0,
      "line_hash": "27ffa192",
      "speaker": "ラヴィリス",
      "ja": "ぐ……！♥　う゛っ！♥　んっ、ぐぅ、ぐ、……お゛っ♥　お゛っ！！♥　ぉお゛っ！！♥",
      "zh": ""
    },
    {
      "key": "102.0",
      "line_index": 102,
      "inline_index": 0,
      "line_hash": "af18bb27",
      "speaker": "",
      "ja": "俺はぐっと腕に力を入れると同時に腰を前後に動かし始める。",
      "zh": ""
    },
    {
      "key": "104.0",
      "line_index": 104,
      "inline_index": 0,
      "line_hash": "42c385f5",
      "speaker": "",
      "ja": "蕩けた柔膣が肉棒を包み込むように締まり、ゾクゾクした快感に思わず背筋が震える。",
      "zh": ""
    },
    {
      "key": "106.0",
      "line_index": 106,
      "inline_index": 0,
      "line_hash": "c5cfcbf8",
      "speaker": "",
      "ja": "女の子の首を絞めるなんて……そう思いながらも、異様に締まる膣に快感に抗えない。",
      "zh": ""
    },
    {
      "key": "107.0",
      "line_index": 107,
      "inline_index": 0,
      "line_hash": "c27c9585",
      "speaker": "",
      "ja": "感触を試すように首をぎゅっぎゅと締め続け、無数のヒダが亀頭を舐めるように絡みついてきた。",
      "zh": ""
    },
    {
      "key": "110.0",
      "line_index": 110,
      "inline_index": 0,
      "line_hash": "e34fbfa1",
      "speaker": "ラヴィリス",
      "ja": "（ホントに首絞めてるっ……！♥　首絞められながらとかっ、絶対におかしいのっ！♥　でも身体が自然と求めちゃってる！♥）",
      "zh": ""
    },
    {
      "key": "113.0",
      "line_index": 113,
      "inline_index": 0,
      "line_hash": "fae24f2b",
      "speaker": "ラヴィリス",
      "ja": "（首絞めピストン、絶対に気持ち良いって最初からわかってた……！♥　これが人間の言うところの第六感……？♥）",
      "zh": ""
    },
    {
      "key": "116.0",
      "line_index": 116,
      "inline_index": 0,
      "line_hash": "9270f9d2",
      "speaker": "ラヴィリス",
      "ja": "ぐっ、んぐっ！♥　んふぅぅ……！♥　んふーっ、ふーーっ！！♥　ぐううっ！♥　うう……！！♥",
      "zh": ""
    },
    {
      "key": "119.0",
      "line_index": 119,
      "inline_index": 0,
      "line_hash": "efa62fc7",
      "speaker": "{G_PlayerName}",
      "ja": "お、おい？　だいじょうぶか？　なんかマジで苦しそうで……さすがにこれ以上は無理だって……！",
      "zh": ""
    },
    {
      "key": "123.0",
      "line_index": 123,
      "inline_index": 0,
      "line_hash": "2f8cc23b",
      "speaker": "ラヴィリス",
      "ja": "んぅぅっ！♥　手の力弱くなってるぅっ！♥　機械相手なんだから手加減なんてしないでよ……♥",
      "zh": ""
    },
    {
      "key": "126.0",
      "line_index": 126,
      "inline_index": 0,
      "line_hash": "c7fb4fb0",
      "speaker": "ラヴィリス",
      "ja": "ほらぁ……もっと思いっきり首絞めてよぉ！♥　おちんちんと首絞めであたしを狂わせてよぉっ♥　んふふふふふっ♥",
      "zh": ""
    },
    {
      "key": "128.0",
      "line_index": 128,
      "inline_index": 0,
      "line_hash": "17299c27",
      "speaker": "",
      "ja": "ラヴィリスはいたずらっぽい笑みを浮かべる。",
      "zh": ""
    },
    {
      "key": "129.0",
      "line_index": 129,
      "inline_index": 0,
      "line_hash": "2fb6a23",
      "speaker": "",
      "ja": "本気で首を絞められることを望んでいるとわかり、俺は再び両手に力を込めた。",
      "zh": ""
    },
    {
      "key": "132.0",
      "line_index": 132,
      "inline_index": 0,
      "line_hash": "8f41012c",
      "speaker": "ラヴィリス",
      "ja": "お゛っ！♥　いぎっ、できなっ……！♥　おお、んぅぅ！！♥　んふーっ！！♥　んぐうう、ぐ、ぐっ！！♥",
      "zh": ""
    },
    {
      "key": "140.0",
      "line_index": 140,
      "inline_index": 0,
      "line_hash": "f4136df8",
      "speaker": "ラヴィリス",
      "ja": "あ゛～～っ！♥　死ぬっ！♥　快感死するっ！♥　絶対死んじゃうっ！！♥",
      "zh": ""
    },
    {
      "key": "143.0",
      "line_index": 143,
      "inline_index": 0,
      "line_hash": "65e917b5",
      "speaker": "{G_PlayerName}",
      "ja": "気軽に死ぬとか言うな……！！　本当にそうなったらどうするつもりなんだっ",
      "zh": ""
    },
    {
      "key": "147.0",
      "line_index": 147,
      "inline_index": 0,
      "line_hash": "39095dc5",
      "speaker": "ラヴィリス",
      "ja": "んぅぅぅっ！♥　やさしっ♥　機械だから問題無いのにっ♥　お前の方がよわよわのザコなのに、心配とかっ♥",
      "zh": ""
    },
    {
      "key": "150.0",
      "line_index": 150,
      "inline_index": 0,
      "line_hash": "12d4547",
      "speaker": "ラヴィリス",
      "ja": "は゛ーっ！♥　んは゛ーっ！！♥　もう情緒ぐちゃぐちゃぁっ！♥　もっと首絞めてぇ～～っ！！♥　お゛っ、おお゛っ！！♥",
      "zh": ""
    },
    {
      "key": "152.0",
      "line_index": 152,
      "inline_index": 0,
      "line_hash": "d809f972",
      "speaker": "",
      "ja": "これ以上ラヴィリスの首を絞め続けていたら後戻りが出来なくなりそうな気がする。",
      "zh": ""
    },
    {
      "key": "154.0",
      "line_index": 154,
      "inline_index": 0,
      "line_hash": "b1b7e7d1",
      "speaker": "",
      "ja": "それでも俺の腕は快感欲しさに力が入り、息をするように収縮を繰り返す膣の感触に肉棒が肥大化する。",
      "zh": ""
    },
    {
      "key": "156.0",
      "line_index": 156,
      "inline_index": 0,
      "line_hash": "793c99ad",
      "speaker": "",
      "ja": "日常や普通のセックスでは経験できない行為に異様なまでに高ぶりを覚える。",
      "zh": ""
    },
    {
      "key": "157.0",
      "line_index": 157,
      "inline_index": 0,
      "line_hash": "cc2d495c",
      "speaker": "",
      "ja": "俺はこみ上げる昂ぶりをラヴィリスにぶつけるように、さらにピストンを早めていった。",
      "zh": ""
    },
    {
      "key": "160.0",
      "line_index": 160,
      "inline_index": 0,
      "line_hash": "20d1e265",
      "speaker": "ラヴィリス",
      "ja": "ん、んぐっ、ぐっ！♥　ふうう、ふうううっ！♥　快感、しゅごいぃ……んぅぅっ！！♥　おまんこおかしくなりそぉ……あお゛っ！！♥",
      "zh": ""
    },
    {
      "key": "163.0",
      "line_index": 163,
      "inline_index": 0,
      "line_hash": "370f410c",
      "speaker": "ラヴィリス",
      "ja": "おちんぽ、しゅごいのぉ……んんっ！！♥　もっと奥ぅ……ぐりぐりしてぇっ♥　ん゛っ！♥　んふうう、ふうううっ！！♥",
      "zh": ""
    },
    {
      "key": "166.0",
      "line_index": 166,
      "inline_index": 0,
      "line_hash": "1dbc10b",
      "speaker": "ラヴィリス",
      "ja": "（ヤバイ、ヤバイ……首絞めセックス、絶対にクセになっちゃう……ていうかもうなってる……♥　もう普通のじゃ絶対に満足できないよっ♥）",
      "zh": ""
    },
    {
      "key": "169.0",
      "line_index": 169,
      "inline_index": 0,
      "line_hash": "a4d878fe",
      "speaker": "ラヴィリス",
      "ja": "（なんでこんなヤバイセックスで気持ち良くなるようになってんの……あたしを造ったヤツってマジのヘンタイだよ……間違いないっ♥）",
      "zh": ""
    },
    {
      "key": "172.0",
      "line_index": 172,
      "inline_index": 0,
      "line_hash": "8e572135",
      "speaker": "ラヴィリス",
      "ja": "んぐっ、ぐぅ、ずんずん、気持ち良いっ♥　ぶっといおちんちんでおまんこ壊されちゃいそっ♥",
      "zh": ""
    },
    {
      "key": "175.0",
      "line_index": 175,
      "inline_index": 0,
      "line_hash": "a6e9aecb",
      "speaker": "ラヴィリス",
      "ja": "機械の扱い上手すぎだってぇ……ん゛っ！♥　機械弄りで欲情する男は一味違うね～っ♥",
      "zh": ""
    },
    {
      "key": "178.0",
      "line_index": 178,
      "inline_index": 0,
      "line_hash": "cdd69e01",
      "speaker": "{G_PlayerName}",
      "ja": "べ、別に興奮するから機械弄っていたわけじゃ……それにラヴィリスを機械だなんて全然思えないぞ……",
      "zh": ""
    },
    {
      "key": "182.0",
      "line_index": 182,
      "inline_index": 0,
      "line_hash": "d2334740",
      "speaker": "{G_PlayerName}",
      "ja": "表情も声も……身体の柔らかさも、おまんこの気持ち良さも人間そのものだ。だからこんな夢中になってしまってんだよ",
      "zh": ""
    },
    {
      "key": "186.0",
      "line_index": 186,
      "inline_index": 0,
      "line_hash": "7ff51114",
      "speaker": "ラヴィリス",
      "ja": "うそばっかりぃ～♥　機械弄りしながらおちんぽシコシコしてんでしょ～っ♥　わかるんだからぁ……んんっ！！♥",
      "zh": ""
    },
    {
      "key": "189.0",
      "line_index": 189,
      "inline_index": 0,
      "line_hash": "f374504a",
      "speaker": "ラヴィリス",
      "ja": "この……ヘンタイ……♥　お前はあたしを造った奴と同じくらいせーへき歪んじゃってるよ～っ♥　んふふふっ♥",
      "zh": ""
    },
    {
      "key": "192.0",
      "line_index": 192,
      "inline_index": 0,
      "line_hash": "bc78da2f",
      "speaker": "ラヴィリス",
      "ja": "んお゛っ！♥　しゅごっ……！！♥　おお、もっとぉ……絞めてぇ……お゛っ！♥　ほぉ、お゛っ！！♥　ん、んぐ、ぐううっ！！♥",
      "zh": ""
    },
    {
      "key": "195.0",
      "line_index": 195,
      "inline_index": 0,
      "line_hash": "f7b10a6c",
      "speaker": "ラヴィリス",
      "ja": "げほっ、ごほっ！♥　喉、押されるの、ヤバイぃ……！♥　今、意識飛んだぁっ！♥　もっとぉ……おお゛っ！♥　ぐ、ぐっ！！♥",
      "zh": ""
    },
    {
      "key": "198.0",
      "line_index": 198,
      "inline_index": 0,
      "line_hash": "f673fedf",
      "speaker": "ラヴィリス",
      "ja": "あ゛っ！♥　クるっ！♥　クる゛っ！！♥　波っ、キてる゛っ！！♥",
      "zh": ""
    },
    {
      "key": "201.0",
      "line_index": 201,
      "inline_index": 0,
      "line_hash": "316b58d3",
      "speaker": "ラヴィリス",
      "ja": "お゛っ！♥　んお゛！♥　一緒にぃ……一緒に、イキたいっ……♥　ね、一緒に……イこ……♥　ぐっ、ぐお゛っ！！♥",
      "zh": ""
    },
    {
      "key": "203.0",
      "line_index": 203,
      "inline_index": 0,
      "line_hash": "1431014f",
      "speaker": "",
      "ja": "弱々しさを感じさせるラヴィリスの声にゾクゾクと身体が震える。",
      "zh": ""
    },
    {
      "key": "204.0",
      "line_index": 204,
      "inline_index": 0,
      "line_hash": "c916e89",
      "speaker": "",
      "ja": "それと同時に射精感が一気にこみ上げ、俺は前のめりになると腕と腰に力をぐっと込めた。",
      "zh": ""
    },
    {
      "key": "207.0",
      "line_index": 207,
      "inline_index": 0,
      "line_hash": "5d984108",
      "speaker": "ラヴィリス",
      "ja": "ほぉ、お゛！！♥　お、お゛っ！！♥　おまんこ、イぐぅっ！！♥　イグ、イグっ……！！♥",
      "zh": ""
    },
    {
      "key": "210.0",
      "line_index": 210,
      "inline_index": 0,
      "line_hash": "c802ccda",
      "speaker": "ラヴィリス",
      "ja": "おぁ゛っ！！♥　イっ……！！♥　んっ、んぅぅぅ、ん、ぐ、んあ、あああぁぁぁぁ～～っ！！♥♥",
      "zh": ""
    },
    {
      "key": "219.0",
      "line_index": 219,
      "inline_index": 0,
      "line_hash": "34bd3575",
      "speaker": "ラヴィリス",
      "ja": "ん゛ぅ～～～～～っ！！♥　んぐ、う゛っ！♥　んっ゛♥　んんん～～～～～っ！！♥♥",
      "zh": ""
    },
    {
      "key": "221.0",
      "line_index": 221,
      "inline_index": 0,
      "line_hash": "576971f1",
      "speaker": "",
      "ja": "ラヴィリスの膣奥が亀頭をぎゅっと締め付け、その反動で俺は射精してしまう。",
      "zh": ""
    },
    {
      "key": "222.0",
      "line_index": 222,
      "inline_index": 0,
      "line_hash": "40daec32",
      "speaker": "",
      "ja": "あまりの快感に思わず手に力が入ってしまい、ラヴィリスの細い首を更に絞め上げてしまう。",
      "zh": ""
    },
    {
      "key": "225.0",
      "line_index": 225,
      "inline_index": 0,
      "line_hash": "3ad04799",
      "speaker": "ラヴィリス",
      "ja": "（これっ、しゅごぉ……！！♥　想像以上、かもぉ……！！♥　目チカチカしてるぅ……！♥　思考回路爆発しちゃいそ～っ！！♥♥）",
      "zh": ""
    },
    {
      "key": "228.0",
      "line_index": 228,
      "inline_index": 0,
      "line_hash": "59ad8f",
      "speaker": "ラヴィリス",
      "ja": "んぐぅ……ぐうっ！！♥　はぁ、おまんこ、ぎもぢぃっ！♥　もっと……もっと指に力入れて……♥　首絞めてぇ……お゛っ！！♥",
      "zh": ""
    },
    {
      "key": "231.0",
      "line_index": 231,
      "inline_index": 0,
      "line_hash": "836fcb58",
      "speaker": "ラヴィリス",
      "ja": "あぁ゛っ！♥　目の前チカチカして……あおっ！♥　顔見えないぃ……♥　んはっ！♥　お願い、好きって言ってぇ……目の前にいるって教えてぇ～っ♥",
      "zh": ""
    },
    {
      "key": "234.0",
      "line_index": 234,
      "inline_index": 0,
      "line_hash": "fdf973ba",
      "speaker": "{G_PlayerName}",
      "ja": "っ、そんなお願いされなくても……いくらでも言ってやるぞ！　ラヴィリス、好きだ！　好きっ、好きっ！！",
      "zh": ""
    },
    {
      "key": "238.0",
      "line_index": 238,
      "inline_index": 0,
      "line_hash": "90acce46",
      "speaker": "ラヴィリス",
      "ja": "あうううっ！！♥　あたしも好きぃっ！♥　おおおお゛……！！♥　言葉でおまんこイってるぅっ！！♥　う、ううう……！！♥",
      "zh": ""
    },
    {
      "key": "240.0",
      "line_index": 240,
      "inline_index": 0,
      "line_hash": "97514075",
      "speaker": "",
      "ja": "今まで手のかかる妹のような関係だと思っていた。",
      "zh": ""
    },
    {
      "key": "241.0",
      "line_index": 241,
      "inline_index": 0,
      "line_hash": "350aa13c",
      "speaker": "",
      "ja": "好意はあっても恥ずかしさから自分の想いを告げられずにいた。",
      "zh": ""
    },
    {
      "key": "243.0",
      "line_index": 243,
      "inline_index": 0,
      "line_hash": "30b48bf1",
      "speaker": "",
      "ja": "俺は勢いのままに何度もラヴィリスに告白を繰り返し、ラヴィリスも想いに応えてくれるように絶頂を繰り返した。",
      "zh": ""
    },
    {
      "key": "246.0",
      "line_index": 246,
      "inline_index": 0,
      "line_hash": "9ce40f4d",
      "speaker": "ラヴィリス",
      "ja": "ねぇ、もっとしよぉ……♥　もっとおまんこぐちゅぐちゅにしてぇ……♥",
      "zh": ""
    },
    {
      "key": "253.0",
      "line_index": 253,
      "inline_index": 0,
      "line_hash": "cac10e55",
      "speaker": "ラヴィリス",
      "ja": "ほぉお゛っ！♥　んぐ、んっ、ふうう、ふう゛う゛！！♥　おちんぽっ、おまんこ壊しにきてるぅっ！！♥",
      "zh": ""
    },
    {
      "key": "256.0",
      "line_index": 256,
      "inline_index": 0,
      "line_hash": "d92d07a0",
      "speaker": "ラヴィリス",
      "ja": "ねぇ、キスしてぇっ♥　息止めるみたいに、大きな口で……あたしの口塞いで～っ♥",
      "zh": ""
    },
    {
      "key": "259.0",
      "line_index": 259,
      "inline_index": 0,
      "line_hash": "f80f10c6",
      "speaker": "ラヴィリス",
      "ja": "んふっ、ん、んっ！♥　んふぅ、んぢゅる♥　あむぅ………れる、れろぉ……ぢゅる、ちゅうううっ！！♥",
      "zh": ""
    },
    {
      "key": "262.0",
      "line_index": 262,
      "inline_index": 0,
      "line_hash": "395f237",
      "speaker": "ラヴィリス",
      "ja": "（あぁ、舌まで絡めてきてるぅ……♥　息できないぃ……うう、気持ち良いっ♥　ちゅーでおまんこ喜んでるぅ……♥）",
      "zh": ""
    },
    {
      "key": "264.0",
      "line_index": 264,
      "inline_index": 0,
      "line_hash": "7085bc4c",
      "speaker": "",
      "ja": "俺はラヴィリスの求めるままに唇を重ねると、夢中になって舌を絡ませる。",
      "zh": ""
    },
    {
      "key": "265.0",
      "line_index": 265,
      "inline_index": 0,
      "line_hash": "d4e9f20b",
      "speaker": "",
      "ja": "唾液を流し込むような濃厚なキスに俺は興奮し、肉棒が狭すぎる膣の中で何度も跳ねる。",
      "zh": ""
    },
    {
      "key": "267.0",
      "line_index": 267,
      "inline_index": 0,
      "line_hash": "91830341",
      "speaker": "",
      "ja": "鼻まで塞ぐ勢いで俺はキスを続け、その間もラヴィリスの首をぎゅうぎゅうと絞め続けた。",
      "zh": ""
    },
    {
      "key": "270.0",
      "line_index": 270,
      "inline_index": 0,
      "line_hash": "1b4791fc",
      "speaker": "ラヴィリス",
      "ja": "んぎぃ……ぐう、んっ！♥　んはぁ、苦しくて気持ち良くてぇ……もう頭バカになってるぅっ！！♥",
      "zh": ""
    },
    {
      "key": "273.0",
      "line_index": 273,
      "inline_index": 0,
      "line_hash": "b79a3e5e",
      "speaker": "ラヴィリス",
      "ja": "壊されるの、いいのぉっ……♥　もっと壊してぇ……首へし折ってもいいからぁ……お、ごっ……！♥　んっ！♥　んふ、うううっ！！♥",
      "zh": ""
    },
    {
      "key": "275.0",
      "line_index": 275,
      "inline_index": 0,
      "line_hash": "546c4563",
      "speaker": "",
      "ja": "俺は自分の体重をラヴィリスの小さな身体に乗せるように唇を奪い続ける。",
      "zh": ""
    },
    {
      "key": "276.0",
      "line_index": 276,
      "inline_index": 0,
      "line_hash": "b410db39",
      "speaker": "",
      "ja": "首を絞めるたびに膣が締まり、キスをするたびに柔膣が肉棒を撫で上げる。",
      "zh": ""
    },
    {
      "key": "278.0",
      "line_index": 278,
      "inline_index": 0,
      "line_hash": "ab092fe8",
      "speaker": "",
      "ja": "ゾクゾクした快感が止まらずに俺を襲い、快感欲しさにラヴィリスの身体に負荷をかけ続けてしまう。",
      "zh": ""
    },
    {
      "key": "281.0",
      "line_index": 281,
      "inline_index": 0,
      "line_hash": "c767e567",
      "speaker": "ラヴィリス",
      "ja": "お、お゛っ！♥　らめ……おまんこ、イキっぱなし……おふぅっ！♥　う゛っ、うう゛っ！！♥　ぐっ、んぐっ！！♥",
      "zh": ""
    },
    {
      "key": "284.0",
      "line_index": 284,
      "inline_index": 0,
      "line_hash": "f0121a88",
      "speaker": "ラヴィリス",
      "ja": "もっと、もっとぉ……♥　おまんこもっとイかせてぇ……ぐっ！！♥　お、お゛っ！♥　力が……ご、んごぉぉ゛！！♥　お゛お゛お゛♥",
      "zh": ""
    },
    {
      "key": "286.0",
      "line_index": 286,
      "inline_index": 0,
      "line_hash": "d75ab181",
      "speaker": "",
      "ja": "苦しみに悶え喘ぐラビリスに興奮を抑えられない。",
      "zh": ""
    },
    {
      "key": "287.0",
      "line_index": 287,
      "inline_index": 0,
      "line_hash": "e5319baa",
      "speaker": "",
      "ja": "普通の人なら死んでいるかもしれない……それくらいの強さで小さな首を何度も絞める。",
      "zh": ""
    },
    {
      "key": "289.0",
      "line_index": 289,
      "inline_index": 0,
      "line_hash": "65779be7",
      "speaker": "",
      "ja": "気道を止めるように親指で喉の中心を押すと、ラヴィリスはさらに快感に表情を蕩けさせる。",
      "zh": ""
    },
    {
      "key": "291.0",
      "line_index": 291,
      "inline_index": 0,
      "line_hash": "6effa714",
      "speaker": "",
      "ja": "それが膣の動きをより活発にさせ、肉棒全体を扱かれるような感覚が最高の気持ち良さをもたらした。",
      "zh": ""
    },
    {
      "key": "294.0",
      "line_index": 294,
      "inline_index": 0,
      "line_hash": "8d5a2baf",
      "speaker": "ラヴィリス",
      "ja": "んひひぃ、んひぃっ！♥　死ぬ、死ぬぅ……うう゛っ！♥　意識、何度も飛んでるぅ……！！♥",
      "zh": ""
    },
    {
      "key": "297.0",
      "line_index": 297,
      "inline_index": 0,
      "line_hash": "fce5ffe0",
      "speaker": "ラヴィリス",
      "ja": "あたし、ホントに死んじゃう……♥　イキ殺されちゃう……♥　うう！♥　ぐ、ぐっ！！♥　ううううっ！！♥",
      "zh": ""
    },
    {
      "key": "299.0",
      "line_index": 299,
      "inline_index": 0,
      "line_hash": "ae7470e0",
      "speaker": "",
      "ja": "ラヴィリスの悶え喘ぐほどに、膣の中が愛液でグチョグチョになっていく。",
      "zh": ""
    },
    {
      "key": "301.0",
      "line_index": 301,
      "inline_index": 0,
      "line_hash": "d926ae8d",
      "speaker": "",
      "ja": "亀頭と陰茎の根元を同時に締め付けられ、限界が近づいてくるのを感じる。",
      "zh": ""
    },
    {
      "key": "304.0",
      "line_index": 304,
      "inline_index": 0,
      "line_hash": "4e7f7106",
      "speaker": "ラヴィリス",
      "ja": "ぐ、ぐっ、う゛う゛！♥　しゅ、しゅご、いのっ……♥　うぐっ！♥　グりゅぅ！！♥　あ゛っ！♥　あぁっ！♥",
      "zh": ""
    },
    {
      "key": "307.0",
      "line_index": 307,
      "inline_index": 0,
      "line_hash": "1c61c595",
      "speaker": "ラヴィリス",
      "ja": "殺してぇっ！♥　あたしを絞め殺しでぇ！♥　ぐ、ぐっ！！♥　ぐう、ぐううううっ！！♥♥",
      "zh": ""
    },
    {
      "key": "310.0",
      "line_index": 310,
      "inline_index": 0,
      "line_hash": "48f2ee1d",
      "speaker": "{G_PlayerName}",
      "ja": "ラヴィリス……！！　うう、出るっ……！！",
      "zh": ""
    },
    {
      "key": "321.0",
      "line_index": 321,
      "inline_index": 0,
      "line_hash": "2ecd6a68",
      "speaker": "ラヴィリス",
      "ja": "ぉお゛っ！♥　お゛！♥　んぅ、ぐ、んぐ、ぐぐぐ……！！♥　う゛う゛っ！♥　ぐう゛っ！！♥　うううう……！！♥♥",
      "zh": ""
    },
    {
      "key": "323.0",
      "line_index": 323,
      "inline_index": 0,
      "line_hash": "13490901",
      "speaker": "",
      "ja": "俺はラヴィリスの首をもぐような勢いできつく締める。",
      "zh": ""
    },
    {
      "key": "324.0",
      "line_index": 324,
      "inline_index": 0,
      "line_hash": "4ef6814f",
      "speaker": "",
      "ja": "そして歪な興奮のままに膣奥にこみ上げてきたモノを一気に吐き出した。",
      "zh": ""
    },
    {
      "key": "327.0",
      "line_index": 327,
      "inline_index": 0,
      "line_hash": "b894c816",
      "speaker": "ラヴィリス",
      "ja": "（おまんこっ、熱いの出てるぅっ！！♥　あああぁ、こんなにいっぱいぃっ！♥）",
      "zh": ""
    },
    {
      "key": "330.0",
      "line_index": 330,
      "inline_index": 0,
      "line_hash": "fca998c3",
      "speaker": "ラヴィリス",
      "ja": "（イクの止まらないぃ……！！♥　こんなに出されたら、機械なのに妊娠しちゃうよぉ～～っ！！♥♥）",
      "zh": ""
    },
    {
      "key": "332.0",
      "line_index": 332,
      "inline_index": 0,
      "line_hash": "8c72ffcf",
      "speaker": "",
      "ja": "俺は腰を小刻みに揺すり何度もオスの欲望をラヴィリスの子宮に吐き出す。",
      "zh": ""
    },
    {
      "key": "333.0",
      "line_index": 333,
      "inline_index": 0,
      "line_hash": "e8d0f357",
      "speaker": "",
      "ja": "首を絞めるたびに子宮口が吸い付き、搾り取られるような快感に何度も射精を繰り返した。",
      "zh": ""
    },
    {
      "key": "336.0",
      "line_index": 336,
      "inline_index": 0,
      "line_hash": "984a5ba5",
      "speaker": "ラヴィリス",
      "ja": "んぐ、ぐっ……！♥　おまんこ、ぎもぢいぃ……♥　はぁ、はぁぁ……♥　あああぁ、せーえき、いいのぉ……♥",
      "zh": ""
    },
    {
      "key": "339.0",
      "line_index": 339,
      "inline_index": 0,
      "line_hash": "26b2b145",
      "speaker": "ラヴィリス",
      "ja": "こんなに出してくれて嬉しい……♥　ねぇ、き、かいし……はぁ、はぁ……あたしの、おまんこ……どうだった……？♥",
      "zh": ""
    },
    {
      "key": "342.0",
      "line_index": 342,
      "inline_index": 0,
      "line_hash": "e8a81232",
      "speaker": "ラヴィリス",
      "ja": "あたしの体温……どうだった？♥　　鼓動、感じてくれた……？♥",
      "zh": ""
    },
    {
      "key": "345.0",
      "line_index": 345,
      "inline_index": 0,
      "line_hash": "2b13177",
      "speaker": "{G_PlayerName}",
      "ja": "あ、ああ……最高だった……機械とかそういうの全然感じないくらい気持ち良かった……",
      "zh": ""
    },
    {
      "key": "349.0",
      "line_index": 349,
      "inline_index": 0,
      "line_hash": "35f47401",
      "speaker": "ラヴィリス",
      "ja": "んへへ……♥　機械士が気持ち良くなってくれたなら良かったよ……♥",
      "zh": ""
    },
    {
      "key": "351.0",
      "line_index": 351,
      "inline_index": 0,
      "line_hash": "da5b1059",
      "speaker": "",
      "ja": "ラヴィリスに『機械士』と呼ばれ、思わず胸がドキっとしてしまう。",
      "zh": ""
    },
    {
      "key": "354.0",
      "line_index": 354,
      "inline_index": 0,
      "line_hash": "3a778256",
      "speaker": "ラヴィリス",
      "ja": "なんか顔赤いよ……？♥　また興奮しちゃった……？♥",
      "zh": ""
    },
    {
      "key": "357.0",
      "line_index": 357,
      "inline_index": 0,
      "line_hash": "ce039787",
      "speaker": "{G_PlayerName}",
      "ja": "興奮しないわけないだろ……ラヴィリスのことが好きだって再確認できたんだから……",
      "zh": ""
    },
    {
      "key": "360.0",
      "line_index": 360,
      "inline_index": 0,
      "line_hash": "fecfb17c",
      "speaker": "",
      "ja": "俺はそう呟くと、ラヴィリスの細い首についた絞めた跡をそっと撫でる。",
      "zh": ""
    },
    {
      "key": "363.0",
      "line_index": 363,
      "inline_index": 0,
      "line_hash": "f9e0fc36",
      "speaker": "{G_PlayerName}",
      "ja": "でもこういう形でエッチするのはちょっと……なんか後戻りできなくなりそうだ……",
      "zh": ""
    },
    {
      "key": "367.0",
      "line_index": 367,
      "inline_index": 0,
      "line_hash": "682de063",
      "speaker": "ラヴィリス",
      "ja": "別に戻らなくてもいいよ～……♥　気持ち良ければなんだっていいんだから～……♥",
      "zh": ""
    },
    {
      "key": "370.0",
      "line_index": 370,
      "inline_index": 0,
      "line_hash": "638f5aff",
      "speaker": "ラヴィリス",
      "ja": "機械士がサドであたしはマゾ……いいじゃん、それで～……♥",
      "zh": ""
    },
    {
      "key": "372.0",
      "line_index": 372,
      "inline_index": 0,
      "line_hash": "4d29d30e",
      "speaker": "",
      "ja": "ラヴィリスはそう言うと、首を絞めてと言いたげに俺の手にそっと自分の手を重ねる。",
      "zh": ""
    },
    {
      "key": "375.0",
      "line_index": 375,
      "inline_index": 0,
      "line_hash": "6069a842",
      "speaker": "ラヴィリス",
      "ja": "ね、もっとしよ……♥　あたしが壊れちゃうくらい愛して……♥",
      "zh": ""
    },
    {
      "key": "377.0",
      "line_index": 377,
      "inline_index": 0,
      "line_hash": "e3e325e0",
      "speaker": "",
      "ja": "その言葉を合図に、俺達は再びアブノーマルな快感に溺れていく。",
      "zh": ""
    },
    {
      "key": "379.0",
      "line_index": 379,
      "inline_index": 0,
      "line_hash": "dd751541",
      "speaker": "",
      "ja": "ラヴィリスと一緒に気持ち良くなれるなら後戻りできなくてもいい……。",
      "zh": ""
    },
    {
      "key": "380.0",
      "line_index": 380,
      "inline_index": 0,
      "line_hash": "67253be4",
      "speaker": "",
      "ja": "そんなことを思いながら再びラヴィリスの細い首をぎゅっと絞めるのであった。",
      "zh": ""
    }
  ]
}
