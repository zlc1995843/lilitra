{
  "lines": [
    {
      "key": "19.1",
      "line_index": 19,
      "inline_index": 1,
      "line_hash": "8e9497d6",
      "speaker": "アルフ",
      "ja": "ちゅ……♥　ぢゅるっ……れろっ♥　ちゅちゅ……ちゅぅぅ……♥　ちゅぱっ、ちゅちゅ……ぢゅるるるっ♥",
      "zh": ""
    },
    {
      "key": "21.0",
      "line_index": 21,
      "inline_index": 0,
      "line_hash": "3eb4ad99",
      "speaker": "",
      "ja": "俺たちはお互いを求めるように唇を押し付け舌を絡ませ合う。",
      "zh": ""
    },
    {
      "key": "22.0",
      "line_index": 22,
      "inline_index": 0,
      "line_hash": "1f6a4a4f",
      "speaker": "",
      "ja": "どれだけ唇を重ねても満足できない、飢えにも似たような感覚。",
      "zh": ""
    },
    {
      "key": "24.0",
      "line_index": 24,
      "inline_index": 0,
      "line_hash": "ea6ce9ce",
      "speaker": "",
      "ja": "キスをすればするほど愛おしくなり、それが俺たちをいつまでもキスさせ続けてしまっていた。",
      "zh": ""
    },
    {
      "key": "27.1",
      "line_index": 27,
      "inline_index": 1,
      "line_hash": "b83d50",
      "speaker": "アルフ",
      "ja": "んはぁ～……♥　んへへ……♥　おちんちん、完全に元に……ううん、それ以上におっきくなっちゃったね♥",
      "zh": ""
    },
    {
      "key": "30.1",
      "line_index": 30,
      "inline_index": 1,
      "line_hash": "9273c35c",
      "speaker": "アルフ",
      "ja": "こんなの押し込まれたらおまんこ壊れちゃうかも……♥",
      "zh": ""
    },
    {
      "key": "33.0",
      "line_index": 33,
      "inline_index": 0,
      "line_hash": "773fc64b",
      "speaker": "{G_PlayerName}",
      "ja": "それでも俺はアルフとセックスするよ……したくてたまらないんだ",
      "zh": ""
    },
    {
      "key": "48.0",
      "line_index": 48,
      "inline_index": 0,
      "line_hash": "9c8320aa",
      "speaker": "アルフ",
      "ja": "やだぁ♥　さらし解けちゃった♥　君がおっぱい揉みまくったせいだからね♥",
      "zh": ""
    },
    {
      "key": "50.0",
      "line_index": 50,
      "inline_index": 0,
      "line_hash": "1fe3a082",
      "speaker": "",
      "ja": "俺はアルフを優しく押し倒すと、さらしの下に隠れていたアルフの胸が露わになる。",
      "zh": ""
    },
    {
      "key": "51.0",
      "line_index": 51,
      "inline_index": 0,
      "line_hash": "97ad9a2f",
      "speaker": "",
      "ja": "思わず手が伸びてしまい、乳房を揉みながらピンク色の突起物を指の腹で捏ねる。",
      "zh": ""
    },
    {
      "key": "54.0",
      "line_index": 54,
      "inline_index": 0,
      "line_hash": "db5b1860",
      "speaker": "アルフ",
      "ja": "んぅぅぅ……♥　君ってさ、おっぱいとお尻どっちが好き……？♥",
      "zh": ""
    },
    {
      "key": "57.0",
      "line_index": 57,
      "inline_index": 0,
      "line_hash": "43cf9e1e",
      "speaker": "{G_PlayerName}",
      "ja": "その質問は意味ないぞ？　俺はアルフのすべてが好きなんだから。アルフのおっぱいもお尻もおまんこも……顔も身体も性格も何もかも好きなんだ",
      "zh": ""
    },
    {
      "key": "61.0",
      "line_index": 61,
      "inline_index": 0,
      "line_hash": "1643ac16",
      "speaker": "アルフ",
      "ja": "ふあ……あっ♥　おまんこ、すっご……ちょっと触れただけでビリってぇ……♥",
      "zh": ""
    },
    {
      "key": "64.0",
      "line_index": 64,
      "inline_index": 0,
      "line_hash": "cdbe2585",
      "speaker": "アルフ",
      "ja": "はぁ、はぁ……♥　思っていた以上に過敏になっちゃってるかもぉ……♥　ふぅ、ふぅぅぅ……♥",
      "zh": ""
    },
    {
      "key": "67.0",
      "line_index": 67,
      "inline_index": 0,
      "line_hash": "49df57ee",
      "speaker": "アルフ",
      "ja": "そっかぁ……てっきりお尻だけかと思ったんだけど……♥　それなら毎日褌にならなくても良さそうだね♥",
      "zh": ""
    },
    {
      "key": "70.0",
      "line_index": 70,
      "inline_index": 0,
      "line_hash": "e6f81fa1",
      "speaker": "{G_PlayerName}",
      "ja": "それはそれで勿体ない気もするな",
      "zh": ""
    },
    {
      "key": "74.0",
      "line_index": 74,
      "inline_index": 0,
      "line_hash": "11cce90e",
      "speaker": "アルフ",
      "ja": "んっ……♥　まぁたまには褌でも、ね♥　それよりさぁ……もうホント限界♥　君もそうでしょ？♥",
      "zh": ""
    },
    {
      "key": "77.0",
      "line_index": 77,
      "inline_index": 0,
      "line_hash": "23dbbe2a",
      "speaker": "アルフ",
      "ja": "はやく君のぶっといの突っ込んで……♥　奥の奥までぐっしょりなんだからさぁ～♥",
      "zh": ""
    },
    {
      "key": "79.0",
      "line_index": 79,
      "inline_index": 0,
      "line_hash": "85c5351d",
      "speaker": "",
      "ja": "アルフはおまんこをくぱっと拡げ、膣中を俺に見せつける。",
      "zh": ""
    },
    {
      "key": "80.0",
      "line_index": 80,
      "inline_index": 0,
      "line_hash": "fbb54b7",
      "speaker": "",
      "ja": "中はこれでもかと愛液で満たされ、膣肉が何かを求めるようにぐにぐにと怪しく蠢く。",
      "zh": ""
    },
    {
      "key": "82.0",
      "line_index": 82,
      "inline_index": 0,
      "line_hash": "2b0cb52c",
      "speaker": "",
      "ja": "膣穴から愛液がどろどろと垂れ落ち、お漏らしをしたようにアナルの方までぐっしょりと濡れていた。",
      "zh": ""
    },
    {
      "key": "85.0",
      "line_index": 85,
      "inline_index": 0,
      "line_hash": "fab5af14",
      "speaker": "{G_PlayerName}",
      "ja": "すっげぇエロいな……愛液が糸引いてるよ",
      "zh": ""
    },
    {
      "key": "89.0",
      "line_index": 89,
      "inline_index": 0,
      "line_hash": "bff848d8",
      "speaker": "アルフ",
      "ja": "君が待たせ過ぎるからエロエロになっちゃったんだよ……♥　ほらぁ、来て……♥　君のおっきいので、ウチをいっぱい愛して……♥",
      "zh": ""
    },
    {
      "key": "96.0",
      "line_index": 96,
      "inline_index": 0,
      "line_hash": "69d980f3",
      "speaker": "アルフ",
      "ja": "んあぁっ！♥　んぅ、ふぅ、あぁっ！♥　あうううっ！！♥",
      "zh": ""
    },
    {
      "key": "98.0",
      "line_index": 98,
      "inline_index": 0,
      "line_hash": "7062cb15",
      "speaker": "",
      "ja": "アルフの甘い声に導かれるように俺は膣の中に肉棒を押し込む。",
      "zh": ""
    },
    {
      "key": "99.0",
      "line_index": 99,
      "inline_index": 0,
      "line_hash": "e48b0681",
      "speaker": "",
      "ja": "柔らかな膣が肉棒を包み込み、トロトロの愛液の刺激にゾクゾクと背筋が震える。",
      "zh": ""
    },
    {
      "key": "102.0",
      "line_index": 102,
      "inline_index": 0,
      "line_hash": "b7103fe4",
      "speaker": "",
      "ja": "快感に我慢できず腰を前後に動かすと、アルフは甘い声を上げながら潤んだ瞳で俺をじっと見つめてくる。",
      "zh": ""
    },
    {
      "key": "105.0",
      "line_index": 105,
      "inline_index": 0,
      "line_hash": "c8087d61",
      "speaker": "アルフ",
      "ja": "すっご……んっ！♥　入れられちゃっただけで少しイっちゃった……♥　君のおちんちん、気持ち良すぎるよぉ……♥",
      "zh": ""
    },
    {
      "key": "108.0",
      "line_index": 108,
      "inline_index": 0,
      "line_hash": "75ead43e",
      "speaker": "アルフ",
      "ja": "んぅ、んは、あっ！♥　君のおちんちんも……んぐっ！♥　喜んでるね……ふぅ、ふぅ♥　ビクビクすっごい震えてる……♥",
      "zh": ""
    },
    {
      "key": "111.0",
      "line_index": 111,
      "inline_index": 0,
      "line_hash": "ccb2d756",
      "speaker": "アルフ",
      "ja": "はうううっ！♥　乳首摘まんじゃダメぇ……！♥　んぅぅぅっ！♥　ウチのおっぱい小っちゃいから触ってもつまんないでしょ？♥",
      "zh": ""
    },
    {
      "key": "114.0",
      "line_index": 114,
      "inline_index": 0,
      "line_hash": "d10d202f",
      "speaker": "{G_PlayerName}",
      "ja": "大きいとか小さいとかどうでもいいんだって。アルフのおっぱいであるのが重要なんだからさっ",
      "zh": ""
    },
    {
      "key": "118.0",
      "line_index": 118,
      "inline_index": 0,
      "line_hash": "fbd38736",
      "speaker": "アルフ",
      "ja": "んんっ！♥　おっぱいとおまんこ、同時にされるのっ、イイっ！♥　気持ち良くってぇ、おかしくなりそうっ！！♥",
      "zh": ""
    },
    {
      "key": "120.0",
      "line_index": 120,
      "inline_index": 0,
      "line_hash": "903ffaca",
      "speaker": "",
      "ja": "乳首を捏ねると膣が肉棒を甘く締め付ける。",
      "zh": ""
    },
    {
      "key": "121.0",
      "line_index": 121,
      "inline_index": 0,
      "line_hash": "2f5fc23d",
      "speaker": "",
      "ja": "狭い膣を肉棒で押し広げながら掻き回し、その刺激で自然とピストンが早くなっていく。",
      "zh": ""
    },
    {
      "key": "124.0",
      "line_index": 124,
      "inline_index": 0,
      "line_hash": "fef6891",
      "speaker": "アルフ",
      "ja": "はぁ、んはぁっ！♥　ああぁっ！♥　今日の君のおちんちん、なんか本当にすごくってぇ……！！♥",
      "zh": ""
    },
    {
      "key": "127.0",
      "line_index": 127,
      "inline_index": 0,
      "line_hash": "6e5756da",
      "speaker": "アルフ",
      "ja": "君とのエッチはいっつも気持ち良いけどぉ……あんっ！♥　今日はそれ以上に感じちゃってるよぉっ！！♥",
      "zh": ""
    },
    {
      "key": "130.0",
      "line_index": 130,
      "inline_index": 0,
      "line_hash": "fb152a02",
      "speaker": "{G_PlayerName}",
      "ja": "アルフのおまんこもな……ぐっ！　吸い付きがすごい……！　いつもよりも全然エロエロだっ",
      "zh": ""
    },
    {
      "key": "134.0",
      "line_index": 134,
      "inline_index": 0,
      "line_hash": "3b659bdb",
      "speaker": "アルフ",
      "ja": "んんんっ！♥　ウチら、とんでもないくらいドスケベになっちゃってんだね……♥　はぁ、んんっ！♥　はぁ、ああぁっ！！♥",
      "zh": ""
    },
    {
      "key": "137.0",
      "line_index": 137,
      "inline_index": 0,
      "line_hash": "b04c5419",
      "speaker": "アルフ",
      "ja": "今日は忘れられない……ん！　夜に、なりそ……はぁ、んあ、あぁん！♥　一生の思い出になるかもぉ……！！♥",
      "zh": ""
    },
    {
      "key": "140.0",
      "line_index": 140,
      "inline_index": 0,
      "line_hash": "fc08a1a",
      "speaker": "{G_PlayerName}",
      "ja": "絶対にそうなるさ……俺がそうなるようにするから……！",
      "zh": ""
    },
    {
      "key": "144.0",
      "line_index": 144,
      "inline_index": 0,
      "line_hash": "e1ca453f",
      "speaker": "アルフ",
      "ja": "んふぅっ！♥　ふあ、激しっ……！♥　こ、これダメっ！♥　おちんちんずんずん奥にぃっ！！♥　んんっ！！♥",
      "zh": ""
    },
    {
      "key": "147.0",
      "line_index": 147,
      "inline_index": 0,
      "line_hash": "5fa5b4e4",
      "speaker": "アルフ",
      "ja": "はぁ、あぁぁんっ！！♥　奥、感じるぅっ！♥　も、もっとぐちゅぐちゅしてぇっ！♥　おまんこ掻き回してぇっ！♥",
      "zh": ""
    },
    {
      "key": "149.0",
      "line_index": 149,
      "inline_index": 0,
      "line_hash": "6f15b6de",
      "speaker": "",
      "ja": "俺は体重を前かがみにすると、腰を打ち付けるようにピストンを繰り返す。",
      "zh": ""
    },
    {
      "key": "150.0",
      "line_index": 150,
      "inline_index": 0,
      "line_hash": "b22c97c0",
      "speaker": "",
      "ja": "まだ少し余裕があったアルフの表情からそれが消え、表情が快感に蕩けていく。",
      "zh": ""
    },
    {
      "key": "152.0",
      "line_index": 152,
      "inline_index": 0,
      "line_hash": "36556f0c",
      "speaker": "",
      "ja": "俺は腰を打ち付けるたびに甘い悲鳴が大きくなり、肉棒を咥える膣からぐちゅぐちゅと水音が鳴る。",
      "zh": ""
    },
    {
      "key": "155.0",
      "line_index": 155,
      "inline_index": 0,
      "line_hash": "be3cd180",
      "speaker": "アルフ",
      "ja": "はぁ、はぁっ！♥　ウチ、もうダメっ！♥　おまんこイっちゃいそうっ！♥　んぅ、は、はぁぁんっ！！♥",
      "zh": ""
    },
    {
      "key": "158.0",
      "line_index": 158,
      "inline_index": 0,
      "line_hash": "11f0a8ab",
      "speaker": "{G_PlayerName}",
      "ja": "二人で一緒にだからな、アルフ……！！",
      "zh": ""
    },
    {
      "key": "162.0",
      "line_index": 162,
      "inline_index": 0,
      "line_hash": "4addfbb5",
      "speaker": "アルフ",
      "ja": "うんっ♥　うんっ！♥　ふぅっ！♥　一緒にぃっ！！♥　あっ！♥　んあぁんっ！！♥",
      "zh": ""
    },
    {
      "key": "164.0",
      "line_index": 164,
      "inline_index": 0,
      "line_hash": "acf53f5",
      "speaker": "",
      "ja": "アルフは脚を俺の腰に回し、俺たちはさらに密着する。",
      "zh": ""
    },
    {
      "key": "165.0",
      "line_index": 165,
      "inline_index": 0,
      "line_hash": "d7ac3a79",
      "speaker": "",
      "ja": "俺は腰を小刻みに激しく揺すり、アルフの膣奥へ射精しようと突き進む。",
      "zh": ""
    },
    {
      "key": "168.0",
      "line_index": 168,
      "inline_index": 0,
      "line_hash": "fa46a8bb",
      "speaker": "アルフ",
      "ja": "あっ！♥　んあっ！♥　イクっ♥　イクっ！♥　出してっ！♥　ウチのおまんこっ、ザーメンでいっぱいにしてぇぇ～～っ！！♥♥",
      "zh": ""
    },
    {
      "key": "177.0",
      "line_index": 177,
      "inline_index": 0,
      "line_hash": "ccc01d81",
      "speaker": "アルフ",
      "ja": "んんんんん～～～っ！！♥　あ、熱いぃ……！♥　うあ、ふぅ、んふぅっ！♥　ふあ、ふあぁぁぁ～～っ！！♥♥",
      "zh": ""
    },
    {
      "key": "179.0",
      "line_index": 179,
      "inline_index": 0,
      "line_hash": "9e11fbb1",
      "speaker": "",
      "ja": "俺が射精するとほぼ同時に絶頂に達するアルフ。",
      "zh": ""
    },
    {
      "key": "180.0",
      "line_index": 180,
      "inline_index": 0,
      "line_hash": "efd005",
      "speaker": "",
      "ja": "ビクンと大きく身体を跳ねらせ、甘いイキ声が部屋中に響き渡る。",
      "zh": ""
    },
    {
      "key": "182.0",
      "line_index": 182,
      "inline_index": 0,
      "line_hash": "d8f1497b",
      "speaker": "",
      "ja": "柔膣が肉棒を強く締め付け、肉棒を吸い上げる。",
      "zh": ""
    },
    {
      "key": "183.0",
      "line_index": 183,
      "inline_index": 0,
      "line_hash": "2d4efdf8",
      "speaker": "",
      "ja": "狭い膣の中で小刻みに肉棒を擦りながら、アルフの膣奥に精液を何度も注ぎ込む。",
      "zh": ""
    },
    {
      "key": "186.0",
      "line_index": 186,
      "inline_index": 0,
      "line_hash": "c3d83722",
      "speaker": "アルフ",
      "ja": "はぁ、あっ、あはぁっ！♥　ザーメン、いっぱいぃ～っ♥　お腹の奥、タプタプになってるぅ……あふぅっ！♥",
      "zh": ""
    },
    {
      "key": "188.0",
      "line_index": 188,
      "inline_index": 0,
      "line_hash": "145ea7d1",
      "speaker": "",
      "ja": "アルフは無意識にお腹を愛しそうに撫でる。",
      "zh": ""
    },
    {
      "key": "189.0",
      "line_index": 189,
      "inline_index": 0,
      "line_hash": "79382aad",
      "speaker": "",
      "ja": "今までに無かった母性を感じさせるアルフの優しくもイヤらしい笑み。",
      "zh": ""
    },
    {
      "key": "191.0",
      "line_index": 191,
      "inline_index": 0,
      "line_hash": "2c5ed10a",
      "speaker": "",
      "ja": "その様子に俺の肉棒が再び硬くなり、アルフ欲しさに射精が終わっても小さく腰を揺り動かしていた。",
      "zh": ""
    },
    {
      "key": "194.0",
      "line_index": 194,
      "inline_index": 0,
      "line_hash": "d5465511",
      "speaker": "アルフ",
      "ja": "はぁ、はぁぁ……♥　２回もどっぴゅんしてたのに、まだこんなに出るんだね～……♥",
      "zh": ""
    },
    {
      "key": "197.0",
      "line_index": 197,
      "inline_index": 0,
      "line_hash": "ac5fa227",
      "speaker": "アルフ",
      "ja": "そんなにこの恰好エロエロだった……？♥",
      "zh": ""
    },
    {
      "key": "200.0",
      "line_index": 200,
      "inline_index": 0,
      "line_hash": "f76f31e4",
      "speaker": "{G_PlayerName}",
      "ja": "はぁ、はぁ……はぁ……それもあるけどさ、やっぱりアルフが……",
      "zh": ""
    },
    {
      "key": "203.0",
      "line_index": 203,
      "inline_index": 0,
      "line_hash": "c49daccf",
      "speaker": "",
      "ja": "俺はそういうとアルフの頬をそっと撫でる。",
      "zh": ""
    },
    {
      "key": "204.0",
      "line_index": 204,
      "inline_index": 0,
      "line_hash": "bf69827d",
      "speaker": "",
      "ja": "アルフは息を切らせながらも、頬を撫でる俺の手に自分の手を重ね微笑みかける。",
      "zh": ""
    },
    {
      "key": "207.0",
      "line_index": 207,
      "inline_index": 0,
      "line_hash": "488eb761",
      "speaker": "アルフ",
      "ja": "……ウチが好きってこと？♥　くすくす……♥",
      "zh": ""
    },
    {
      "key": "210.0",
      "line_index": 210,
      "inline_index": 0,
      "line_hash": "998ec60d",
      "speaker": "{G_PlayerName}",
      "ja": "ああ……もうエロ可愛くて……収まりがつかないっ",
      "zh": ""
    },
    {
      "key": "218.0",
      "line_index": 218,
      "inline_index": 0,
      "line_hash": "ca65faaa",
      "speaker": "アルフ",
      "ja": "んぉおっ！？♥　ま、待ってぇっ！♥　あうっ！♥　イったばっかなのにぃ……！♥　お゛っ！！♥",
      "zh": ""
    },
    {
      "key": "220.0",
      "line_index": 220,
      "inline_index": 0,
      "line_hash": "25d35931",
      "speaker": "",
      "ja": "俺は照れ隠しをするようにピストンを再開する。",
      "zh": ""
    },
    {
      "key": "221.0",
      "line_index": 221,
      "inline_index": 0,
      "line_hash": "1871eee",
      "speaker": "",
      "ja": "突然の俺の行動にアルフは戸惑い、快感から逃げるように腰を捩らせる。",
      "zh": ""
    },
    {
      "key": "223.0",
      "line_index": 223,
      "inline_index": 0,
      "line_hash": "7832e441",
      "speaker": "",
      "ja": "俺はアルフの身体を抑えるように身体を前に傾け、上から叩きつけるように腰を打ち付けた。",
      "zh": ""
    },
    {
      "key": "226.0",
      "line_index": 226,
      "inline_index": 0,
      "line_hash": "9d62edff",
      "speaker": "アルフ",
      "ja": "こ、これぇっ！♥　あぎゅぅっ！♥　しゅ、しゅごぉ……お゛っ！♥　お゛っ！♥　お゛ぉ゛～～～っ！！♥♥",
      "zh": ""
    },
    {
      "key": "228.0",
      "line_index": 228,
      "inline_index": 0,
      "line_hash": "d430be7c",
      "speaker": "",
      "ja": "執拗に子宮口を肉棒の先端で叩き続け、またもアルフは絶頂してしまう。",
      "zh": ""
    },
    {
      "key": "229.0",
      "line_index": 229,
      "inline_index": 0,
      "line_hash": "911422a8",
      "speaker": "",
      "ja": "潮を噴いているのが見なくてもわかるほど、ビシャビシャと俺の下腹部を濡らす。",
      "zh": ""
    },
    {
      "key": "232.0",
      "line_index": 232,
      "inline_index": 0,
      "line_hash": "7c095032",
      "speaker": "アルフ",
      "ja": "イってるぅっ！♥　今イっでるからぁっ！♥　少し、待っ……んぎっ！♥　うう！♥　あう、あうううっ！！♥",
      "zh": ""
    },
    {
      "key": "235.0",
      "line_index": 235,
      "inline_index": 0,
      "line_hash": "b122a9a2",
      "speaker": "{G_PlayerName}",
      "ja": "逃げるな……！　もっとイかせてやるから……！！",
      "zh": ""
    },
    {
      "key": "239.0",
      "line_index": 239,
      "inline_index": 0,
      "line_hash": "364b89f3",
      "speaker": "アルフ",
      "ja": "ダメダメっ！♥　これ以上イったらぁ……ぉお゛っ♥　おがじぐ、なりゅぅ……！！♥　んんっ！♥　ふお゛っ！♥　おおお……！！♥♥",
      "zh": ""
    },
    {
      "key": "241.0",
      "line_index": 241,
      "inline_index": 0,
      "line_hash": "ed02bf1e",
      "speaker": "",
      "ja": "俺の身体の下でもがき、何度も果てるアルフ。",
      "zh": ""
    },
    {
      "key": "242.0",
      "line_index": 242,
      "inline_index": 0,
      "line_hash": "5890110c",
      "speaker": "",
      "ja": "絶頂するほどにエロく、そして可愛くなっていく姿に俺はのめり込んでしまう。",
      "zh": ""
    },
    {
      "key": "244.0",
      "line_index": 244,
      "inline_index": 0,
      "line_hash": "2dab9a6c",
      "speaker": "",
      "ja": "アルフの噴き出す潮と愛液、そして俺の精液がぐちゃぐちゃに絡み合い、俺たちの下半身はでろでろになるほど体液で塗れていた。",
      "zh": ""
    },
    {
      "key": "247.0",
      "line_index": 247,
      "inline_index": 0,
      "line_hash": "caef7e6",
      "speaker": "アルフ",
      "ja": "ふあぁっ！？♥　乳首ぃっ！？♥　んぐっ、ダメだってぇっ！♥　あ、あっ！♥　な、なんでそんなにいっぱい感じさせたいんだよぉ……！！♥",
      "zh": ""
    },
    {
      "key": "250.0",
      "line_index": 250,
      "inline_index": 0,
      "line_hash": "96e8c23f",
      "speaker": "{G_PlayerName}",
      "ja": "アルフが好きだからに決まってるだろ……！　好きな子にはどこまでも気持ち良くなって欲しいんだよっ",
      "zh": ""
    },
    {
      "key": "254.0",
      "line_index": 254,
      "inline_index": 0,
      "line_hash": "de50198c",
      "speaker": "アルフ",
      "ja": "お゛っお゛っお゛っ！♥　げ、限度が、あるってぇっ……！♥　おおおおお～～っ！！♥♥",
      "zh": ""
    },
    {
      "key": "256.0",
      "line_index": 256,
      "inline_index": 0,
      "line_hash": "90743a8a",
      "speaker": "",
      "ja": "アルフはもう何度絶頂したのかわからない。",
      "zh": ""
    },
    {
      "key": "257.0",
      "line_index": 257,
      "inline_index": 0,
      "line_hash": "440869f8",
      "speaker": "",
      "ja": "イクたびに肉棒を甘く強烈に締め付け、蠢くヒダが精液を搾り取ろうと絡む。",
      "zh": ""
    },
    {
      "key": "259.0",
      "line_index": 259,
      "inline_index": 0,
      "line_hash": "c8de3ca4",
      "speaker": "",
      "ja": "脳裏に射精感がチラつくが、俺はそれを無視するようにひたすらにピストンを繰り返す。",
      "zh": ""
    },
    {
      "key": "262.0",
      "line_index": 262,
      "inline_index": 0,
      "line_hash": "bc02f0f9",
      "speaker": "アルフ",
      "ja": "イギしゅぎてぇっ！♥　もう何も考えりゃれないぃぃ！♥　バカになってりゅぅ！♥　おまんこも頭もヘンになってりゅぅぅっ！！♥♥",
      "zh": ""
    },
    {
      "key": "265.0",
      "line_index": 265,
      "inline_index": 0,
      "line_hash": "8d5e72b1",
      "speaker": "{G_PlayerName}",
      "ja": "でも最高にエロ可愛くて……！　腰が止まらねえっ……！！　アルフっ！　もっと俺で喜んでくれっ！！",
      "zh": ""
    },
    {
      "key": "269.0",
      "line_index": 269,
      "inline_index": 0,
      "line_hash": "5cd498b0",
      "speaker": "アルフ",
      "ja": "はううっ！♥　うあ、んぅぅぅ！♥　んお゛っ！♥　おっ！♥　んぉお゛っ！！♥　ふぎぃ、ダメ、ま、また……しゅごいのっ、来りゅぅっ！！♥",
      "zh": ""
    },
    {
      "key": "271.0",
      "line_index": 271,
      "inline_index": 0,
      "line_hash": "77048765",
      "speaker": "",
      "ja": "アルフの膣奥からさらに大量の愛液が溢れ、結合部の隙間から噴き出す。",
      "zh": ""
    },
    {
      "key": "273.0",
      "line_index": 273,
      "inline_index": 0,
      "line_hash": "bc050ad8",
      "speaker": "",
      "ja": "限界まで蕩けた柔膣とグチョグチョの愛液に肉棒全体を包み、無視していた射精感が一気に溢れてくる。",
      "zh": ""
    },
    {
      "key": "276.0",
      "line_index": 276,
      "inline_index": 0,
      "line_hash": "f2e9c6",
      "speaker": "アルフ",
      "ja": "イグイグイグイグっ！！♥　おまんこイグぅぅぅぅ～～～～～っ！！♥",
      "zh": ""
    },
    {
      "key": "279.0",
      "line_index": 279,
      "inline_index": 0,
      "line_hash": "e84c6def",
      "speaker": "{G_PlayerName}",
      "ja": "く、くっ！　出、出るっ……！！",
      "zh": ""
    },
    {
      "key": "283.0",
      "line_index": 283,
      "inline_index": 0,
      "line_hash": "d2586c5b",
      "speaker": "アルフ",
      "ja": "イっぐぅ～～～～～～～～～～っ！！♥♥",
      "zh": ""
    },
    {
      "key": "293.0",
      "line_index": 293,
      "inline_index": 0,
      "line_hash": "ecb475d0",
      "speaker": "アルフ",
      "ja": "お゛っ！♥　お゛っ、お゛～～～～っ！！♥　んぉおお！♥　ふうううううっ！！♥♥",
      "zh": ""
    },
    {
      "key": "295.0",
      "line_index": 295,
      "inline_index": 0,
      "line_hash": "ea4df016",
      "speaker": "",
      "ja": "絶頂に達したアルフの膣が肉棒をぎゅっと締め付ける。",
      "zh": ""
    },
    {
      "key": "296.0",
      "line_index": 296,
      "inline_index": 0,
      "line_hash": "e7dbdfa9",
      "speaker": "",
      "ja": "蠢く膣に肉棒を扱かれ、俺はこみ上げてきたモノを一気にアルフの膣奥へ吐き出す。",
      "zh": ""
    },
    {
      "key": "299.0",
      "line_index": 299,
      "inline_index": 0,
      "line_hash": "2fc95791",
      "speaker": "アルフ",
      "ja": "ふぅっ！♥　んふぅっ！♥　おまんこぉ……ぎもぢっ、イイぃ～……！♥　はーっ、んはーっ！♥　らめぇ、まらぁ……あおおっ！！♥♥",
      "zh": ""
    },
    {
      "key": "301.0",
      "line_index": 301,
      "inline_index": 0,
      "line_hash": "65fb517e",
      "speaker": "",
      "ja": "アルフの膣の気持ち良さに射精が全然止まらない。",
      "zh": ""
    },
    {
      "key": "302.0",
      "line_index": 302,
      "inline_index": 0,
      "line_hash": "a33705fc",
      "speaker": "",
      "ja": "射精の気持ち良さが何度も背筋を駆け抜け、脳まで痺れる快感に襲われる。",
      "zh": ""
    },
    {
      "key": "304.0",
      "line_index": 304,
      "inline_index": 0,
      "line_hash": "d9535cdb",
      "speaker": "",
      "ja": "意識が一瞬途切れそうになりながらも俺は無意識に腰を揺すり、オスの本懐を果たし続けていた。",
      "zh": ""
    },
    {
      "key": "307.0",
      "line_index": 307,
      "inline_index": 0,
      "line_hash": "e24d8a82",
      "speaker": "アルフ",
      "ja": "ひぃ、ひぃぃ……♥　君の、しゅごすぎるぅ……♥　もうお腹の中パンパンだよぉ……♥　はぁ、んはーっ……！♥",
      "zh": ""
    },
    {
      "key": "310.0",
      "line_index": 310,
      "inline_index": 0,
      "line_hash": "4dc909a1",
      "speaker": "{G_PlayerName}",
      "ja": "はーっ！　はーっ！　んはーっ！　アルフの、おまんこが……気持ち良すぎるんだよ……ん……",
      "zh": ""
    },
    {
      "key": "314.0",
      "line_index": 314,
      "inline_index": 0,
      "line_hash": "df3b8f95",
      "speaker": "アルフ",
      "ja": "んふぅ……♥　ぢゅるっ、ちゅ……♥　ちゅぅ……ぢゅるる♥　ちゅっ、ちゅぅぅ……♥♥",
      "zh": ""
    },
    {
      "key": "317.0",
      "line_index": 317,
      "inline_index": 0,
      "line_hash": "42ee2ea4",
      "speaker": "アルフ",
      "ja": "ぷはぁっ♥　キス気持ち良いぃ……おまんこまたイっちゃったよぉ……あひぃぃ……♥",
      "zh": ""
    },
    {
      "key": "319.0",
      "line_index": 319,
      "inline_index": 0,
      "line_hash": "79b87150",
      "speaker": "",
      "ja": "やがて射精も収まり始め、アルフも次第に落ち着きを取り戻していく。",
      "zh": ""
    },
    {
      "key": "320.0",
      "line_index": 320,
      "inline_index": 0,
      "line_hash": "5a066f1b",
      "speaker": "",
      "ja": "俺は何度もアルフの唇を奪い、嬉しそうにキスを受け止める。",
      "zh": ""
    },
    {
      "key": "322.0",
      "line_index": 322,
      "inline_index": 0,
      "line_hash": "b7cde88d",
      "speaker": "",
      "ja": "俺を受け入れてくれるアルフが愛おしい、そんな想いを込め何度もキスを繰り返してしまう。",
      "zh": ""
    },
    {
      "key": "325.0",
      "line_index": 325,
      "inline_index": 0,
      "line_hash": "a3d9633c",
      "speaker": "アルフ",
      "ja": "はー……♥　はぁ……♥　えへへ……今日の君、色々すごすぎ……♥　ザーメンいっぱい出てたし……♥",
      "zh": ""
    },
    {
      "key": "328.0",
      "line_index": 328,
      "inline_index": 0,
      "line_hash": "faff2017",
      "speaker": "アルフ",
      "ja": "もう途中からわけわかんなくなったけど、でも……いっぱい愛されて嬉しかったよ……♥",
      "zh": ""
    },
    {
      "key": "331.0",
      "line_index": 331,
      "inline_index": 0,
      "line_hash": "bb34e6fb",
      "speaker": "{G_PlayerName}",
      "ja": "それだけアルフが魅力的で可愛いんだよ……",
      "zh": ""
    },
    {
      "key": "335.0",
      "line_index": 335,
      "inline_index": 0,
      "line_hash": "231ba512",
      "speaker": "アルフ",
      "ja": "んへへ……それだけ夢中になってくれて嬉しい……♥　ね、もっとちゅーして……♥",
      "zh": ""
    },
    {
      "key": "338.0",
      "line_index": 338,
      "inline_index": 0,
      "line_hash": "5d846d21",
      "speaker": "アルフ",
      "ja": "もっとイチャイチャしよ……？♥　ちゅ、ちゅっ♥　ぢゅる……ちゅぅぅ……♥",
      "zh": ""
    },
    {
      "key": "340.0",
      "line_index": 340,
      "inline_index": 0,
      "line_hash": "f5cfcaaa",
      "speaker": "",
      "ja": "どちらからともなく抱きつき、俺たちは何度も唇を重ね合う。",
      "zh": ""
    },
    {
      "key": "342.0",
      "line_index": 342,
      "inline_index": 0,
      "line_hash": "4a4097d4",
      "speaker": "",
      "ja": "激しさの一切ない唇が触れるだけのキス……でもそれが最高に心地よく、俺は何度もアルフの唇を求めキスをする。",
      "zh": ""
    },
    {
      "key": "345.0",
      "line_index": 345,
      "inline_index": 0,
      "line_hash": "89370a4",
      "speaker": "アルフ",
      "ja": "ふふ……男らしい君も好きだけど、今の優しい君も好き……♥　ちゅ、ちゅっ♥　ちゅぅ……♥",
      "zh": ""
    },
    {
      "key": "348.0",
      "line_index": 348,
      "inline_index": 0,
      "line_hash": "21b5871",
      "speaker": "アルフ",
      "ja": "今日君とお祭りに参加して本当に良かった……♥　最高の夏の思い出できちゃったからね……♥",
      "zh": ""
    },
    {
      "key": "350.0",
      "line_index": 350,
      "inline_index": 0,
      "line_hash": "3566c218",
      "speaker": "",
      "ja": "さっきまでの激しいセックスが嘘のように緩やかな空気が俺たちを包み込む。",
      "zh": ""
    },
    {
      "key": "351.0",
      "line_index": 351,
      "inline_index": 0,
      "line_hash": "4e542d8a",
      "speaker": "",
      "ja": "緩やかな雰囲気の中、俺たちは絶頂の余韻に浸るようにいつまでもキスをしているのであった。",
      "zh": ""
    }
  ]
}
