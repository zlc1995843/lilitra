{
  "lines": [
    {
      "key": "17.0",
      "line_index": 17,
      "inline_index": 0,
      "line_hash": "6a47dfc1",
      "speaker": "雛菊",
      "ja": "はむはむっ、むしゃむしゃ、",
      "zh": ""
    },
    {
      "key": "17.2",
      "line_index": 17,
      "inline_index": 2,
      "line_hash": "6a47dfc1",
      "speaker": "雛菊",
      "ja": "う～ん美味しいでありんす♥",
      "zh": ""
    },
    {
      "key": "19.0",
      "line_index": 19,
      "inline_index": 0,
      "line_hash": "f40081d8",
      "speaker": "",
      "ja": "今日も今日とて雛菊は、食道楽とばかりに食事を楽しんでいた。",
      "zh": ""
    },
    {
      "key": "24.0",
      "line_index": 24,
      "inline_index": 0,
      "line_hash": "bfd93c6a",
      "speaker": "雛菊",
      "ja": "お肉もお魚も美味しい物ばかりで、たまらないでありんす～♥",
      "zh": ""
    },
    {
      "key": "26.0",
      "line_index": 26,
      "inline_index": 0,
      "line_hash": "68d5ed29",
      "speaker": "",
      "ja": "しかし食事を終えた雛菊は、ふと思い出して叫んだ。",
      "zh": ""
    },
    {
      "key": "31.0",
      "line_index": 31,
      "inline_index": 0,
      "line_hash": "229d6f8b",
      "speaker": "雛菊",
      "ja": "このままではだめでありんす！　",
      "zh": ""
    },
    {
      "key": "31.2",
      "line_index": 31,
      "inline_index": 2,
      "line_hash": "229d6f8b",
      "speaker": "雛菊",
      "ja": "わちきは何をしているんでありんすか～！",
      "zh": ""
    },
    {
      "key": "31.5",
      "line_index": 31,
      "inline_index": 5,
      "line_hash": "229d6f8b",
      "speaker": "雛菊",
      "ja": "ほぼほぼ食べてばかりでありんす～！",
      "zh": ""
    },
    {
      "key": "33.0",
      "line_index": 33,
      "inline_index": 0,
      "line_hash": "3c1402fe",
      "speaker": "",
      "ja": "雛菊は思いっきり拳を握りしめて高らかに宣言する。",
      "zh": ""
    },
    {
      "key": "38.0",
      "line_index": 38,
      "inline_index": 0,
      "line_hash": "710c9bdc",
      "speaker": "雛菊",
      "ja": "一念発起でありんす！　",
      "zh": ""
    },
    {
      "key": "38.2",
      "line_index": 38,
      "inline_index": 2,
      "line_hash": "710c9bdc",
      "speaker": "雛菊",
      "ja": "花魁修行をしなければならないでありんす！",
      "zh": ""
    },
    {
      "key": "38.5",
      "line_index": 38,
      "inline_index": 5,
      "line_hash": "710c9bdc",
      "speaker": "雛菊",
      "ja": "思い立ったが吉日でありんす～！",
      "zh": ""
    },
    {
      "key": "40.0",
      "line_index": 40,
      "inline_index": 0,
      "line_hash": "8705e8ce",
      "speaker": "",
      "ja": "そう言い放った雛菊は慌てた感じで目的の人物を探しに行くのだった。",
      "zh": ""
    },
    {
      "key": "53.0",
      "line_index": 53,
      "inline_index": 0,
      "line_hash": "4601fc3d",
      "speaker": "雛菊",
      "ja": "やっと見つけたでありんす！",
      "zh": ""
    },
    {
      "key": "56.0",
      "line_index": 56,
      "inline_index": 0,
      "line_hash": "16e78f3a",
      "speaker": "{G_PlayerName}",
      "ja": "えっ？　雛菊じゃないか……そんなに慌ててどうしたんだい？",
      "zh": ""
    },
    {
      "key": "62.0",
      "line_index": 62,
      "inline_index": 0,
      "line_hash": "4930658a",
      "speaker": "雛菊",
      "ja": "実は折り入ってぬしさんにお願いがありんす",
      "zh": ""
    },
    {
      "key": "65.0",
      "line_index": 65,
      "inline_index": 0,
      "line_hash": "690f61e",
      "speaker": "{G_PlayerName}",
      "ja": "お願い？　俺が出来ることなら何でもしてあげるけど",
      "zh": ""
    },
    {
      "key": "68.0",
      "line_index": 68,
      "inline_index": 0,
      "line_hash": "1ce3de9c",
      "speaker": "",
      "ja": "何の疑いもなくそう言ったのが間違いだったのか……。",
      "zh": ""
    },
    {
      "key": "82.0",
      "line_index": 82,
      "inline_index": 0,
      "line_hash": "cbbf8c31",
      "speaker": "雛菊",
      "ja": "ほら、リラックスしていいでありんすよ？",
      "zh": ""
    },
    {
      "key": "85.0",
      "line_index": 85,
      "inline_index": 0,
      "line_hash": "9c9b8e5f",
      "speaker": "{G_PlayerName}",
      "ja": "いきなりこんなことって！　リラックスなんてできないよ！",
      "zh": ""
    },
    {
      "key": "88.0",
      "line_index": 88,
      "inline_index": 0,
      "line_hash": "424af8a2",
      "speaker": "",
      "ja": "雛菊に言われるままにしていると、",
      "zh": ""
    },
    {
      "key": "88.2",
      "line_index": 88,
      "inline_index": 2,
      "line_hash": "424af8a2",
      "speaker": "",
      "ja": "いつの間にか裸にされてローションまで塗られてしまい",
      "zh": ""
    },
    {
      "key": "88.4",
      "line_index": 88,
      "inline_index": 4,
      "line_hash": "424af8a2",
      "speaker": "",
      "ja": "こんな状況になってしまった。",
      "zh": ""
    },
    {
      "key": "90.0",
      "line_index": 90,
      "inline_index": 0,
      "line_hash": "303c0163",
      "speaker": "",
      "ja": "そんな俺の上にこれまた全裸になった雛菊が跨がってきて、",
      "zh": ""
    },
    {
      "key": "90.2",
      "line_index": 90,
      "inline_index": 2,
      "line_hash": "303c0163",
      "speaker": "",
      "ja": "柔らかなおまんこを俺のちんぽに押しつけてきている。",
      "zh": ""
    },
    {
      "key": "93.0",
      "line_index": 93,
      "inline_index": 0,
      "line_hash": "c1b3b7d",
      "speaker": "{G_PlayerName}",
      "ja": "しゅ、修行ってこれのことなのか？！",
      "zh": ""
    },
    {
      "key": "96.0",
      "line_index": 96,
      "inline_index": 0,
      "line_hash": "440976d8",
      "speaker": "",
      "ja": "ただ修行を手伝って欲しいと言われただけなのに、",
      "zh": ""
    },
    {
      "key": "96.2",
      "line_index": 96,
      "inline_index": 2,
      "line_hash": "440976d8",
      "speaker": "",
      "ja": "まさかこんな展開になってしまうなんて予想できなかった。",
      "zh": ""
    },
    {
      "key": "98.0",
      "line_index": 98,
      "inline_index": 0,
      "line_hash": "42a17500",
      "speaker": "",
      "ja": "困惑している俺の上で雛菊は余裕のある笑みを浮かべて",
      "zh": ""
    },
    {
      "key": "98.2",
      "line_index": 98,
      "inline_index": 2,
      "line_hash": "42a17500",
      "speaker": "",
      "ja": "囁きかけてくる。",
      "zh": ""
    },
    {
      "key": "101.0",
      "line_index": 101,
      "inline_index": 0,
      "line_hash": "badeb577",
      "speaker": "雛菊",
      "ja": "ぬしさんは大人しくネててくれればいいんでありんす。",
      "zh": ""
    },
    {
      "key": "101.2",
      "line_index": 101,
      "inline_index": 2,
      "line_hash": "badeb577",
      "speaker": "雛菊",
      "ja": "わちきが殿方をどれくらい気持ちよく出来るか",
      "zh": ""
    },
    {
      "key": "101.4",
      "line_index": 101,
      "inline_index": 4,
      "line_hash": "badeb577",
      "speaker": "雛菊",
      "ja": "テストでありんす……♥",
      "zh": ""
    },
    {
      "key": "104.0",
      "line_index": 104,
      "inline_index": 0,
      "line_hash": "59a48e65",
      "speaker": "{G_PlayerName}",
      "ja": "き、気持ちよくって……",
      "zh": ""
    },
    {
      "key": "108.0",
      "line_index": 108,
      "inline_index": 0,
      "line_hash": "32f65934",
      "speaker": "雛菊",
      "ja": "それでは始めるでありんすよ♥",
      "zh": ""
    },
    {
      "key": "110.0",
      "line_index": 110,
      "inline_index": 0,
      "line_hash": "1e95910b",
      "speaker": "",
      "ja": "そう言うと雛菊はゆっくりと腰を振り始め、",
      "zh": ""
    },
    {
      "key": "110.2",
      "line_index": 110,
      "inline_index": 2,
      "line_hash": "1e95910b",
      "speaker": "",
      "ja": "俺のペニスを柔らかなおまんこで擦り始めた。",
      "zh": ""
    },
    {
      "key": "118.0",
      "line_index": 118,
      "inline_index": 0,
      "line_hash": "ec6f835f",
      "speaker": "雛菊",
      "ja": "どうでありんすか？　",
      "zh": ""
    },
    {
      "key": "118.2",
      "line_index": 118,
      "inline_index": 2,
      "line_hash": "ec6f835f",
      "speaker": "雛菊",
      "ja": "わちきのおまんこ……ぷにぷにで気持ちいいでありんしょう？",
      "zh": ""
    },
    {
      "key": "120.0",
      "line_index": 120,
      "inline_index": 0,
      "line_hash": "a2d8d778",
      "speaker": "",
      "ja": "彼女の言う通りちんぽを擦るおまんこはすごく柔らかくて気持ちがいい。",
      "zh": ""
    },
    {
      "key": "122.0",
      "line_index": 122,
      "inline_index": 0,
      "line_hash": "6fa14167",
      "speaker": "",
      "ja": "でもそれをさすがに口には出来ず、俺はただ身悶えるだけだった。",
      "zh": ""
    },
    {
      "key": "124.0",
      "line_index": 124,
      "inline_index": 0,
      "line_hash": "67c3ec48",
      "speaker": "",
      "ja": "そんな俺を責め立てるように、雛菊の腰が淫らに揺れる。",
      "zh": ""
    },
    {
      "key": "127.0",
      "line_index": 127,
      "inline_index": 0,
      "line_hash": "2b01f82d",
      "speaker": "雛菊",
      "ja": "このローション……ネトネト～って絡みついて……",
      "zh": ""
    },
    {
      "key": "127.2",
      "line_index": 127,
      "inline_index": 2,
      "line_hash": "2b01f82d",
      "speaker": "雛菊",
      "ja": "とんでもない快楽を生み出すのでありんすよ♥",
      "zh": ""
    },
    {
      "key": "129.0",
      "line_index": 129,
      "inline_index": 0,
      "line_hash": "d03ac352",
      "speaker": "",
      "ja": "雛菊は何度も柔らかなおまんこで",
      "zh": ""
    },
    {
      "key": "129.2",
      "line_index": 129,
      "inline_index": 2,
      "line_hash": "d03ac352",
      "speaker": "",
      "ja": "反り返った肉棒を擦りながら楽しげにそう呟いた。",
      "zh": ""
    },
    {
      "key": "132.0",
      "line_index": 132,
      "inline_index": 0,
      "line_hash": "153c9572",
      "speaker": "{G_PlayerName}",
      "ja": "ううっ……こ、これは……すごいっ……くっ……んんっ……",
      "zh": ""
    },
    {
      "key": "135.0",
      "line_index": 135,
      "inline_index": 0,
      "line_hash": "97042708",
      "speaker": "",
      "ja": "彼女が言った通りローションが絡みついた柔らかな肉襞がすごくいい。",
      "zh": ""
    },
    {
      "key": "137.0",
      "line_index": 137,
      "inline_index": 0,
      "line_hash": "963c2a56",
      "speaker": "",
      "ja": "あまりの気持ちよさに俺のペニスはビクンビクンと跳ね、",
      "zh": ""
    },
    {
      "key": "137.2",
      "line_index": 137,
      "inline_index": 2,
      "line_hash": "963c2a56",
      "speaker": "",
      "ja": "先からはカウパーが溢れ出てきてしまっていた。",
      "zh": ""
    },
    {
      "key": "140.0",
      "line_index": 140,
      "inline_index": 0,
      "line_hash": "cf99f341",
      "speaker": "雛菊",
      "ja": "ふふふっ♪　気持ちよさそうな顔でありんすね♥",
      "zh": ""
    },
    {
      "key": "140.2",
      "line_index": 140,
      "inline_index": 2,
      "line_hash": "cf99f341",
      "speaker": "雛菊",
      "ja": "大きくなったマラからいっぱい汁が溢れてるでありんすよ♥",
      "zh": ""
    },
    {
      "key": "142.0",
      "line_index": 142,
      "inline_index": 0,
      "line_hash": "a3abba09",
      "speaker": "",
      "ja": "雛菊はどこか楽しそうな感じでそう言いながら、",
      "zh": ""
    },
    {
      "key": "142.2",
      "line_index": 142,
      "inline_index": 2,
      "line_hash": "a3abba09",
      "speaker": "",
      "ja": "徐々に腰の動きを速めてくる。",
      "zh": ""
    },
    {
      "key": "144.0",
      "line_index": 144,
      "inline_index": 0,
      "line_hash": "4a317c77",
      "speaker": "",
      "ja": "ローションで滑りがよくなっているので",
      "zh": ""
    },
    {
      "key": "144.2",
      "line_index": 144,
      "inline_index": 2,
      "line_hash": "4a317c77",
      "speaker": "",
      "ja": "彼女の腰の動きはスムーズで、割れ目が裏スジを撫でる度に",
      "zh": ""
    },
    {
      "key": "144.4",
      "line_index": 144,
      "inline_index": 4,
      "line_hash": "4a317c77",
      "speaker": "",
      "ja": "ゾクッとする快感が駆け抜けた。",
      "zh": ""
    },
    {
      "key": "147.0",
      "line_index": 147,
      "inline_index": 0,
      "line_hash": "76b17418",
      "speaker": "雛菊",
      "ja": "ぬしさんのマラ、こんなの大きく反り返ってしまって♥",
      "zh": ""
    },
    {
      "key": "147.2",
      "line_index": 147,
      "inline_index": 2,
      "line_hash": "76b17418",
      "speaker": "雛菊",
      "ja": "本当に立派なモノをお持ちでありんすな♥",
      "zh": ""
    },
    {
      "key": "149.0",
      "line_index": 149,
      "inline_index": 0,
      "line_hash": "1f19def",
      "speaker": "",
      "ja": "少し興奮気味にそう呟きつつ、雛菊は緩急を付けながら腰を振り続ける。",
      "zh": ""
    },
    {
      "key": "151.0",
      "line_index": 151,
      "inline_index": 0,
      "line_hash": "37adb0cc",
      "speaker": "",
      "ja": "そのテクニックは想像を絶する快感を俺に与えてきて、",
      "zh": ""
    },
    {
      "key": "151.2",
      "line_index": 151,
      "inline_index": 2,
      "line_hash": "37adb0cc",
      "speaker": "",
      "ja": "すぐさま射精衝動に襲われてしまった。",
      "zh": ""
    },
    {
      "key": "154.0",
      "line_index": 154,
      "inline_index": 0,
      "line_hash": "689f07f1",
      "speaker": "雛菊",
      "ja": "どうでありんすか？　わちきのおまんこでしごかれて♥　",
      "zh": ""
    },
    {
      "key": "154.2",
      "line_index": 154,
      "inline_index": 2,
      "line_hash": "689f07f1",
      "speaker": "雛菊",
      "ja": "気持ちいいでありんすか♥",
      "zh": ""
    },
    {
      "key": "156.0",
      "line_index": 156,
      "inline_index": 0,
      "line_hash": "adef5013",
      "speaker": "",
      "ja": "雛菊のおまんこが俺のちんぽをしごき上げてくる度に",
      "zh": ""
    },
    {
      "key": "156.2",
      "line_index": 156,
      "inline_index": 2,
      "line_hash": "adef5013",
      "speaker": "",
      "ja": "射精したいという衝動が強くなって堪えきれなくなってくる。",
      "zh": ""
    },
    {
      "key": "159.0",
      "line_index": 159,
      "inline_index": 0,
      "line_hash": "fb83f573",
      "speaker": "{G_PlayerName}",
      "ja": "あぁぁ……そんなに激しくされたら……で、出ちゃう……",
      "zh": ""
    },
    {
      "key": "163.0",
      "line_index": 163,
      "inline_index": 0,
      "line_hash": "9647e88d",
      "speaker": "雛菊",
      "ja": "まだまだ、これからがいいところでありんすよ♥",
      "zh": ""
    },
    {
      "key": "165.0",
      "line_index": 165,
      "inline_index": 0,
      "line_hash": "8c7b85c3",
      "speaker": "",
      "ja": "そう言われても込み上げてくる感覚が止められなくなってしまい",
      "zh": ""
    },
    {
      "key": "165.2",
      "line_index": 165,
      "inline_index": 2,
      "line_hash": "8c7b85c3",
      "speaker": "",
      "ja": "あまりの快感に俺は、たまらず精液を発射してしまった。",
      "zh": ""
    },
    {
      "key": "176.0",
      "line_index": 176,
      "inline_index": 0,
      "line_hash": "db2efad9",
      "speaker": "雛菊",
      "ja": "んっ……♥",
      "zh": ""
    },
    {
      "key": "178.0",
      "line_index": 178,
      "inline_index": 0,
      "line_hash": "b09baa21",
      "speaker": "",
      "ja": "脈打ちながら射精するちんぽが雛菊の割れ目を刺激したようで",
      "zh": ""
    },
    {
      "key": "178.2",
      "line_index": 178,
      "inline_index": 2,
      "line_hash": "b09baa21",
      "speaker": "",
      "ja": "甘い声が漏れる。",
      "zh": ""
    },
    {
      "key": "180.0",
      "line_index": 180,
      "inline_index": 0,
      "line_hash": "e6a7a055",
      "speaker": "",
      "ja": "それがまた俺の興奮を煽って、何度も射精を繰り返してしまった。",
      "zh": ""
    },
    {
      "key": "183.0",
      "line_index": 183,
      "inline_index": 0,
      "line_hash": "d3f8233c",
      "speaker": "雛菊",
      "ja": "ぎょうさんデタでありんすが……",
      "zh": ""
    },
    {
      "key": "183.2",
      "line_index": 183,
      "inline_index": 2,
      "line_hash": "d3f8233c",
      "speaker": "雛菊",
      "ja": "まだまだこれから楽しいところでありんしたが……",
      "zh": ""
    },
    {
      "key": "185.0",
      "line_index": 185,
      "inline_index": 0,
      "line_hash": "dbf01402",
      "speaker": "",
      "ja": "少し残念そうにそう呟いた雛菊を見て、",
      "zh": ""
    },
    {
      "key": "185.2",
      "line_index": 185,
      "inline_index": 2,
      "line_hash": "dbf01402",
      "speaker": "",
      "ja": "俺は自分の不甲斐なさと申し訳ないという気持ちになってしまう。",
      "zh": ""
    },
    {
      "key": "187.0",
      "line_index": 187,
      "inline_index": 0,
      "line_hash": "719948b3",
      "speaker": "",
      "ja": "彼女をガッカリさせる訳にはいかないと、",
      "zh": ""
    },
    {
      "key": "187.2",
      "line_index": 187,
      "inline_index": 2,
      "line_hash": "719948b3",
      "speaker": "",
      "ja": "俺は更に興奮を高めて陰茎を剛直させた。",
      "zh": ""
    },
    {
      "key": "189.0",
      "line_index": 189,
      "inline_index": 0,
      "line_hash": "6db4cb6c",
      "speaker": "",
      "ja": "それを目の当たりにした雛菊は、少し驚いた感じで呟く。",
      "zh": ""
    },
    {
      "key": "192.0",
      "line_index": 192,
      "inline_index": 0,
      "line_hash": "4cf1b506",
      "speaker": "雛菊",
      "ja": "すごいでありんすな♥　まだまだ、カチカチのままでありんす♥",
      "zh": ""
    },
    {
      "key": "194.0",
      "line_index": 194,
      "inline_index": 0,
      "line_hash": "d8ef75c3",
      "speaker": "",
      "ja": "まるで萎える気配が無い勃起した肉棒に雛菊は",
      "zh": ""
    },
    {
      "key": "194.2",
      "line_index": 194,
      "inline_index": 2,
      "line_hash": "d8ef75c3",
      "speaker": "",
      "ja": "またヌルヌルのおまんこを擦り付けてきた。",
      "zh": ""
    },
    {
      "key": "203.0",
      "line_index": 203,
      "inline_index": 0,
      "line_hash": "64630af7",
      "speaker": "雛菊",
      "ja": "んっ♥　ううっ♥",
      "zh": ""
    },
    {
      "key": "205.0",
      "line_index": 205,
      "inline_index": 0,
      "line_hash": "f47433d",
      "speaker": "",
      "ja": "勃起したちんぽに柔らかなおまんこを擦りつける",
      "zh": ""
    },
    {
      "key": "205.2",
      "line_index": 205,
      "inline_index": 2,
      "line_hash": "f47433d",
      "speaker": "",
      "ja": "雛菊の薄く開いた口からは甘い吐息が漏れ出てきている。",
      "zh": ""
    },
    {
      "key": "207.0",
      "line_index": 207,
      "inline_index": 0,
      "line_hash": "2d243023",
      "speaker": "",
      "ja": "それにおまんこからもローションとは",
      "zh": ""
    },
    {
      "key": "207.2",
      "line_index": 207,
      "inline_index": 2,
      "line_hash": "2d243023",
      "speaker": "",
      "ja": "違うネットリとした汁が溢れ出てきていた。",
      "zh": ""
    },
    {
      "key": "210.0",
      "line_index": 210,
      "inline_index": 0,
      "line_hash": "d26add13",
      "speaker": "雛菊",
      "ja": "あぁぁ♥　わちきがっ♥　気持ちよくなっちゃっ♥　",
      "zh": ""
    },
    {
      "key": "210.2",
      "line_index": 210,
      "inline_index": 2,
      "line_hash": "d26add13",
      "speaker": "雛菊",
      "ja": "だ、だめでありんす……なのに、止められないでありんすっ……♥",
      "zh": ""
    },
    {
      "key": "212.0",
      "line_index": 212,
      "inline_index": 0,
      "line_hash": "dd3afe88",
      "speaker": "",
      "ja": "すっかり興奮した感じでそう呟くと、雛菊は腰の動きを激しくさせてくる。",
      "zh": ""
    },
    {
      "key": "215.0",
      "line_index": 215,
      "inline_index": 0,
      "line_hash": "cb3d6825",
      "speaker": "雛菊",
      "ja": "んっ♥　んんっ♥　ぬしさんのマラ、すごく熱くなってて♥　",
      "zh": ""
    },
    {
      "key": "215.2",
      "line_index": 215,
      "inline_index": 2,
      "line_hash": "cb3d6825",
      "speaker": "雛菊",
      "ja": "あふっ♥　はぁんっ♥おまんこに擦れるとぞくぞくしてしまって♥　",
      "zh": ""
    },
    {
      "key": "215.4",
      "line_index": 215,
      "inline_index": 4,
      "line_hash": "cb3d6825",
      "speaker": "雛菊",
      "ja": "ああっ、気持ちいいでありんすぅ♥",
      "zh": ""
    },
    {
      "key": "217.0",
      "line_index": 217,
      "inline_index": 0,
      "line_hash": "c5b0600c",
      "speaker": "",
      "ja": "俺も濡れた柔襞が擦れる度に激しい快感に襲われて",
      "zh": ""
    },
    {
      "key": "217.2",
      "line_index": 217,
      "inline_index": 2,
      "line_hash": "c5b0600c",
      "speaker": "",
      "ja": "射精したばかりのチンポがビクンビクンと強く跳ねた。",
      "zh": ""
    },
    {
      "key": "220.0",
      "line_index": 220,
      "inline_index": 0,
      "line_hash": "8fc237e2",
      "speaker": "雛菊",
      "ja": "んふぅ♥　なんて元気なおちんちんでありんすか♥",
      "zh": ""
    },
    {
      "key": "220.2",
      "line_index": 220,
      "inline_index": 2,
      "line_hash": "8fc237e2",
      "speaker": "雛菊",
      "ja": "わちきのおまんこを叩いてくるでありんす♥　あっ♥　はぁぁんっ♥",
      "zh": ""
    },
    {
      "key": "222.0",
      "line_index": 222,
      "inline_index": 0,
      "line_hash": "6984b4ed",
      "speaker": "",
      "ja": "可愛らしく喘ぎながら雛菊は夢中で腰を振り",
      "zh": ""
    },
    {
      "key": "222.2",
      "line_index": 222,
      "inline_index": 2,
      "line_hash": "6984b4ed",
      "speaker": "",
      "ja": "おまんこを強くペニスに擦りつける。",
      "zh": ""
    },
    {
      "key": "224.0",
      "line_index": 224,
      "inline_index": 0,
      "line_hash": "986ebea2",
      "speaker": "",
      "ja": "その度にクチュクチュといういやらしい水音が鳴って",
      "zh": ""
    },
    {
      "key": "224.2",
      "line_index": 224,
      "inline_index": 2,
      "line_hash": "986ebea2",
      "speaker": "",
      "ja": "耳からも俺の興奮を煽った。",
      "zh": ""
    },
    {
      "key": "227.0",
      "line_index": 227,
      "inline_index": 0,
      "line_hash": "44adcc81",
      "speaker": "雛菊",
      "ja": "あんっ♥　あっ♥　はぁんっ♥　",
      "zh": ""
    },
    {
      "key": "227.2",
      "line_index": 227,
      "inline_index": 2,
      "line_hash": "44adcc81",
      "speaker": "雛菊",
      "ja": "も、もうわちき……どうにかなってしまいそうでありんすぅ♥",
      "zh": ""
    },
    {
      "key": "229.0",
      "line_index": 229,
      "inline_index": 0,
      "line_hash": "ce6bc2ce",
      "speaker": "",
      "ja": "すっかり気持ちが高まってきたのか、",
      "zh": ""
    },
    {
      "key": "229.2",
      "line_index": 229,
      "inline_index": 2,
      "line_hash": "ce6bc2ce",
      "speaker": "",
      "ja": "雛菊は可愛らしく喘ぎながら何度も腰を前後させて",
      "zh": ""
    },
    {
      "key": "229.4",
      "line_index": 229,
      "inline_index": 4,
      "line_hash": "ce6bc2ce",
      "speaker": "",
      "ja": "おまんこを強く擦りつけてくる。",
      "zh": ""
    },
    {
      "key": "232.0",
      "line_index": 232,
      "inline_index": 0,
      "line_hash": "a8ca113a",
      "speaker": "雛菊",
      "ja": "だめでありんすっ♥　んはぁぁ♥　",
      "zh": ""
    },
    {
      "key": "232.2",
      "line_index": 232,
      "inline_index": 2,
      "line_hash": "a8ca113a",
      "speaker": "雛菊",
      "ja": "気持ちよくてもう止められないでありんすぅ♥",
      "zh": ""
    },
    {
      "key": "234.0",
      "line_index": 234,
      "inline_index": 0,
      "line_hash": "ba88d349",
      "speaker": "",
      "ja": "俺も雛菊同様気持ちよすぎてまた出してしまいそうになってきた。",
      "zh": ""
    },
    {
      "key": "236.0",
      "line_index": 236,
      "inline_index": 0,
      "line_hash": "1070e30",
      "speaker": "",
      "ja": "あれだけ出した後なのに、また込み上げてくる感覚が湧き上がってくる。",
      "zh": ""
    },
    {
      "key": "238.0",
      "line_index": 238,
      "inline_index": 0,
      "line_hash": "3154bdaa",
      "speaker": "",
      "ja": "俺を絶頂へと誘おうとしているのか、それとも自らの快感を求めているのか",
      "zh": ""
    },
    {
      "key": "238.2",
      "line_index": 238,
      "inline_index": 2,
      "line_hash": "3154bdaa",
      "speaker": "",
      "ja": "雛菊の腰が何度も何度も前後した。",
      "zh": ""
    },
    {
      "key": "241.0",
      "line_index": 241,
      "inline_index": 0,
      "line_hash": "8a1c9829",
      "speaker": "雛菊",
      "ja": "はぁ♥　はぁ♥　やばいでありんす♥　",
      "zh": ""
    },
    {
      "key": "241.2",
      "line_index": 241,
      "inline_index": 2,
      "line_hash": "8a1c9829",
      "speaker": "雛菊",
      "ja": "わちきも、そろそろイキそうでありんすぅ♥",
      "zh": ""
    },
    {
      "key": "243.0",
      "line_index": 243,
      "inline_index": 0,
      "line_hash": "d02eb3f",
      "speaker": "",
      "ja": "あまりにも激しい腰使いに、俺のちんぽがビクンビクンと跳ねてしまう。",
      "zh": ""
    },
    {
      "key": "245.0",
      "line_index": 245,
      "inline_index": 0,
      "line_hash": "575449ea",
      "speaker": "",
      "ja": "さっき出した精液とローション、それに加えて",
      "zh": ""
    },
    {
      "key": "245.2",
      "line_index": 245,
      "inline_index": 2,
      "line_hash": "575449ea",
      "speaker": "",
      "ja": "雛菊のおまんこから溢れ出た愛液が混ざり",
      "zh": ""
    },
    {
      "key": "245.4",
      "line_index": 245,
      "inline_index": 4,
      "line_hash": "575449ea",
      "speaker": "",
      "ja": "グチョグチョになっていてスムーズに動けるのだろうか。",
      "zh": ""
    },
    {
      "key": "247.0",
      "line_index": 247,
      "inline_index": 0,
      "line_hash": "b2ee1a1b",
      "speaker": "",
      "ja": "とにかくおまんこを強く押しつけられしごかれると、",
      "zh": ""
    },
    {
      "key": "247.2",
      "line_index": 247,
      "inline_index": 2,
      "line_hash": "b2ee1a1b",
      "speaker": "",
      "ja": "また出てしまいそうだ。",
      "zh": ""
    },
    {
      "key": "250.0",
      "line_index": 250,
      "inline_index": 0,
      "line_hash": "8b2e9529",
      "speaker": "雛菊",
      "ja": "あぁぁぁ♥　気持ちいいでありんすぅ♥　んっ♥　はぁぁんっ♥",
      "zh": ""
    },
    {
      "key": "250.2",
      "line_index": 250,
      "inline_index": 2,
      "line_hash": "8b2e9529",
      "speaker": "雛菊",
      "ja": "わちきのおまんこがヒクヒクして♥　あふっ♥　うふぅぅん♥",
      "zh": ""
    },
    {
      "key": "252.0",
      "line_index": 252,
      "inline_index": 0,
      "line_hash": "887be620",
      "speaker": "",
      "ja": "すっかり恍惚の表情を浮かべながら、",
      "zh": ""
    },
    {
      "key": "252.2",
      "line_index": 252,
      "inline_index": 2,
      "line_hash": "887be620",
      "speaker": "",
      "ja": "雛菊の体が俺の上で踊るように動く度に",
      "zh": ""
    },
    {
      "key": "252.4",
      "line_index": 252,
      "inline_index": 4,
      "line_hash": "887be620",
      "speaker": "",
      "ja": "俺は強烈な快感を覚えて限界へと向かっていく。",
      "zh": ""
    },
    {
      "key": "255.0",
      "line_index": 255,
      "inline_index": 0,
      "line_hash": "ddb049ad",
      "speaker": "{G_PlayerName}",
      "ja": "ううっ……また……で、出そうだ……あっ……くぅぅ……",
      "zh": ""
    },
    {
      "key": "258.0",
      "line_index": 258,
      "inline_index": 0,
      "line_hash": "67ed702a",
      "speaker": "",
      "ja": "俺はまた込み上げてくる感覚を抑えきれずに",
      "zh": ""
    },
    {
      "key": "258.2",
      "line_index": 258,
      "inline_index": 2,
      "line_hash": "67ed702a",
      "speaker": "",
      "ja": "再度激しく射精をしてしまった。",
      "zh": ""
    },
    {
      "key": "269.0",
      "line_index": 269,
      "inline_index": 0,
      "line_hash": "17385cfb",
      "speaker": "雛菊",
      "ja": "ふぁ……♥　だめでありんすぅ……♥",
      "zh": ""
    },
    {
      "key": "271.0",
      "line_index": 271,
      "inline_index": 0,
      "line_hash": "d77b6d4",
      "speaker": "",
      "ja": "俺が射精すると同時に雛菊も絶頂に達したらしく、",
      "zh": ""
    },
    {
      "key": "271.2",
      "line_index": 271,
      "inline_index": 2,
      "line_hash": "d77b6d4",
      "speaker": "",
      "ja": "ワナワナと唇を震わせながら全身を小さく痙攣させている。",
      "zh": ""
    },
    {
      "key": "273.0",
      "line_index": 273,
      "inline_index": 0,
      "line_hash": "1f68a7f7",
      "speaker": "",
      "ja": "俺と雛菊の股間が、精液と愛液でもうドロドロだ。",
      "zh": ""
    },
    {
      "key": "276.0",
      "line_index": 276,
      "inline_index": 0,
      "line_hash": "aa6e1531",
      "speaker": "雛菊",
      "ja": "はぁぁ♥　わちきまでイッてしまうなんて♥",
      "zh": ""
    },
    {
      "key": "276.2",
      "line_index": 276,
      "inline_index": 2,
      "line_hash": "aa6e1531",
      "speaker": "雛菊",
      "ja": "でもすごく気持ちよかったでありんすぅ♥",
      "zh": ""
    },
    {
      "key": "278.0",
      "line_index": 278,
      "inline_index": 0,
      "line_hash": "60667159",
      "speaker": "",
      "ja": "甘い声でそう呟く雛菊の姿があまりにも可愛らしくて、",
      "zh": ""
    },
    {
      "key": "278.2",
      "line_index": 278,
      "inline_index": 2,
      "line_hash": "60667159",
      "speaker": "",
      "ja": "２回射精したのに俺のペニスは萎えるどころか",
      "zh": ""
    },
    {
      "key": "278.4",
      "line_index": 278,
      "inline_index": 4,
      "line_hash": "60667159",
      "speaker": "",
      "ja": "更に滾ってきてしまう。",
      "zh": ""
    },
    {
      "key": "281.0",
      "line_index": 281,
      "inline_index": 0,
      "line_hash": "dff8affc",
      "speaker": "雛菊",
      "ja": "……あふっ♥　２回もデタのにまだ大きいまんまでありんすぅ♥　",
      "zh": ""
    },
    {
      "key": "281.2",
      "line_index": 281,
      "inline_index": 2,
      "line_hash": "dff8affc",
      "speaker": "雛菊",
      "ja": "なんと逞しい♥わちきもまだまだでありんすな♥　",
      "zh": ""
    },
    {
      "key": "281.4",
      "line_index": 281,
      "inline_index": 4,
      "line_hash": "dff8affc",
      "speaker": "雛菊",
      "ja": "これはもっと修行する必要がありんすぅ♥",
      "zh": ""
    },
    {
      "key": "283.0",
      "line_index": 283,
      "inline_index": 0,
      "line_hash": "e639131",
      "speaker": "",
      "ja": "そう呟いた雛菊はまた腰を妖しく動かし始めるのだった。",
      "zh": ""
    },
    {
      "key": "286.0",
      "line_index": 286,
      "inline_index": 0,
      "line_hash": "f5621829",
      "speaker": "雛菊",
      "ja": "もっともっと♥　いっぱい修行をするでありんすよぉ♥",
      "zh": ""
    },
    {
      "key": "288.0",
      "line_index": 288,
      "inline_index": 0,
      "line_hash": "e3d894f4",
      "speaker": "",
      "ja": "どうやらしばらく雛菊の修行は終わりそうになさそうだ。",
      "zh": ""
    }
  ]
}
