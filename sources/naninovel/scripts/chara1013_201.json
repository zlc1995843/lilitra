      "key": "227.0",
      "line_index": 227,
      "inline_index": 0,
      "line_hash": "df3c22e2",
      "speaker": "イビリア",
      "ja": "う、ううう……！♥　だ、ダメって……言ったのにぃ……！♥　",
      "zh": ""
