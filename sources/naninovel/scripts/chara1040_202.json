      "zh": ""
    },
    {
      "key": "401.0",
      "line_index": 401,
      "inline_index": 0,
      "line_hash": "42d5a137",
      "speaker": "{G_PlayerName}",
      "ja": "ああ……！　すべてベリルの中に出すから……！！",
      "zh": ""
    },
    {
      "key": "401.2",
      "line_index": 401,
      "inline_index": 2,
      "line_hash": "42d5a137",
      "speaker": "{G_PlayerName}",
      "ja": "だからベリルも最高に気持ち良くなってくれっ！！",
