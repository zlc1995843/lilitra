    },
    {
      "key": "317.0",
      "line_index": 317,
      "inline_index": 0,
      "line_hash": "2162549b",
      "speaker": "シュエ",
      "ja": "あうう、ご主人様の、出て……熱いぃ……♥　ううう、ま、また……イっ……あううう！！♥♥",
