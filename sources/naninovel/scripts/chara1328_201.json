    {
      "key": "347.0",
      "line_index": 347,
      "inline_index": 0,
      "line_hash": "bafa7653",
      "speaker": "シュエ",
      "ja": "ダメ……すぐに、したい……♥　ご主人様、セックス、しよ……♥",
