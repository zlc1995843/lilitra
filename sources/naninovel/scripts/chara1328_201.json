    },
    {
      "key": "258.0",
      "line_index": 258,
      "inline_index": 0,
      "line_hash": "3bcc0e00",
      "speaker": "シュエ",
      "ja": "ご主人、様……んはぁ♥　おちんちん、もっと、近くで……見せて……♥",
