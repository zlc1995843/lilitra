      "zh": ""
    },
    {
      "key": "197.0",
      "line_index": 197,
      "inline_index": 0,
      "line_hash": "68f31735",
      "speaker": "{G_PlayerName}",
      "ja": "あ──",
      "zh": ""
    },
    {
      "key": "199.0",
      "line_index": 199,
      "inline_index": 0,
      "line_hash": "8d9317cd",
      "speaker": "{G_PlayerName}",
      "ja": "（今、雫が笑顔に……なんてカワイイんだ……。あれ、俺今すげードキドキしちゃってる……）",
      "zh": ""
    },
    {
      "key": "201.1",
      "line_index": 201,
      "inline_index": 1,
      "line_hash": "a577181f",
      "speaker": "雫",
      "ja": "何をぼーっとしているのですか？　宇宙船に帰りますよ？",
      "zh": ""
    },
