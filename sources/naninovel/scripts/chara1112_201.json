      "key": "375.0",
      "line_index": 375,
      "inline_index": 0,
      "line_hash": "fcde0bf0",
      "speaker": "フニ",
      "ja": "わたしなら平気だから……♥　だからもっとしてあげるね……♥",
      "zh": ""
    },
