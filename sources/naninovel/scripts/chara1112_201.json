      "key": "417.0",
      "line_index": 417,
      "inline_index": 0,
      "line_hash": "5d8a9c73",
      "speaker": "{G_PlayerName}",
      "ja": "ううう゛っ！　う、うくぅっ！　ふぅーっ！　ぐ、うううう゛！！",
      "zh": ""
    },
