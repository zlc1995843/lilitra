{
  "lines": [
    {
      "key": "16.0",
      "line_index": 16,
      "inline_index": 0,
      "line_hash": "d8d423bb",
      "speaker": "コルト",
      "ja": "ふぅ……今日も一日頑張りました……",
      "zh": ""
    },
    {
      "key": "18.0",
      "line_index": 18,
      "inline_index": 0,
      "line_hash": "41e99aad",
      "speaker": "",
      "ja": "すでに日も暮れ営業時間も終了したので",
      "zh": ""
    },
    {
      "key": "18.2",
      "line_index": 18,
      "inline_index": 2,
      "line_hash": "41e99aad",
      "speaker": "",
      "ja": "コルトはお店の入り口にある札をひっくり返し",
      "zh": ""
    },
    {
      "key": "18.4",
      "line_index": 18,
      "inline_index": 4,
      "line_hash": "41e99aad",
      "speaker": "",
      "ja": "ＯＰＥＮからＣＬＯＳＥに変える。",
      "zh": ""
    },
    {
      "key": "20.0",
      "line_index": 20,
      "inline_index": 0,
      "line_hash": "594a7055",
      "speaker": "",
      "ja": "その後はお店のお掃除をし終えて、そこでようやく彼女は一息つけた。",
      "zh": ""
    },
    {
      "key": "24.0",
      "line_index": 24,
      "inline_index": 0,
      "line_hash": "50d057c0",
      "speaker": "コルト",
      "ja": "……",
      "zh": ""
    },
    {
      "key": "26.0",
      "line_index": 26,
      "inline_index": 0,
      "line_hash": "d052c041",
      "speaker": "",
      "ja": "椅子に座ってキレイになったお店の中を見渡していた",
      "zh": ""
    },
    {
      "key": "26.2",
      "line_index": 26,
      "inline_index": 2,
      "line_hash": "d052c041",
      "speaker": "",
      "ja": "コルトの目に止まったのは売れ残ってしまったバゲット。",
      "zh": ""
    },
    {
      "key": "30.0",
      "line_index": 30,
      "inline_index": 0,
      "line_hash": "6c71122f",
      "speaker": "コルト",
      "ja": "（長くて……太くて……すごく美味しそうなバゲット……）",
      "zh": ""
    },
    {
      "key": "32.0",
      "line_index": 32,
      "inline_index": 0,
      "line_hash": "d5bc95ad",
      "speaker": "",
      "ja": "売れ残りのバゲットを見つめる彼女の目は、売れ残りを悲しむものではなく",
      "zh": ""
    },
    {
      "key": "32.2",
      "line_index": 32,
      "inline_index": 2,
      "line_hash": "d5bc95ad",
      "speaker": "",
      "ja": "うっとりとした感じの潤んだ瞳だった。",
      "zh": ""
    },
    {
      "key": "34.0",
      "line_index": 34,
      "inline_index": 0,
      "line_hash": "e22d4c14",
      "speaker": "",
      "ja": "コルトは周囲を見回すとゆっくりと立ち上がって、",
      "zh": ""
    },
    {
      "key": "34.2",
      "line_index": 34,
      "inline_index": 2,
      "line_hash": "e22d4c14",
      "speaker": "",
      "ja": "売れ残っているそのバゲットの中から一本手に取る。",
      "zh": ""
    },
    {
      "key": "38.0",
      "line_index": 38,
      "inline_index": 0,
      "line_hash": "78840980",
      "speaker": "コルト",
      "ja": "さ、最近忙しかったですしね～……しょうがないですよね……",
      "zh": ""
    },
    {
      "key": "40.0",
      "line_index": 40,
      "inline_index": 0,
      "line_hash": "10253fda",
      "speaker": "",
      "ja": "少しいい訳っぽくそう呟き、バゲットを持ったままコルトは床に座り込んだ。",
      "zh": ""
    },
    {
      "key": "42.0",
      "line_index": 42,
      "inline_index": 0,
      "line_hash": "60ab218b",
      "speaker": "",
      "ja": "そしておもむろにパンツを脱ぐと下半身を露わにさせる。",
      "zh": ""
    },
    {
      "key": "47.0",
      "line_index": 47,
      "inline_index": 0,
      "line_hash": "16a35d5b",
      "speaker": "コルト",
      "ja": "ここのところ忙しかったですし、",
      "zh": ""
    },
    {
      "key": "47.2",
      "line_index": 47,
      "inline_index": 2,
      "line_hash": "16a35d5b",
      "speaker": "コルト",
      "ja": "繁盛するのは有り難いですけど……すごく欲求が溜まってしまいました……",
      "zh": ""
    },
    {
      "key": "49.0",
      "line_index": 49,
      "inline_index": 0,
      "line_hash": "2a985e0f",
      "speaker": "",
      "ja": "そう呟いたコルトの女性器は物欲しげにヒクヒクと蠢きながら",
      "zh": ""
    },
    {
      "key": "49.2",
      "line_index": 49,
      "inline_index": 2,
      "line_hash": "2a985e0f",
      "speaker": "",
      "ja": "ヨダレを垂らすようにネットリとした愛液を溢れさせ",
      "zh": ""
    },
    {
      "key": "49.4",
      "line_index": 49,
      "inline_index": 4,
      "line_hash": "2a985e0f",
      "speaker": "",
      "ja": "ヌラリと濡れてしまっていた。",
      "zh": ""
    },
    {
      "key": "53.0",
      "line_index": 53,
      "inline_index": 0,
      "line_hash": "71e98569",
      "speaker": "コルト",
      "ja": "こんなに美味しそうに焼けたバゲットなのに、",
      "zh": ""
    },
    {
      "key": "53.2",
      "line_index": 53,
      "inline_index": 2,
      "line_hash": "71e98569",
      "speaker": "コルト",
      "ja": "売れ残っちゃうなんて……本当にもったいないですよね……♥",
      "zh": ""
    },
    {
      "key": "55.0",
      "line_index": 55,
      "inline_index": 0,
      "line_hash": "92415400",
      "speaker": "",
      "ja": "少し息を荒げながらそう呟いた彼女は、",
      "zh": ""
    },
    {
      "key": "55.2",
      "line_index": 55,
      "inline_index": 2,
      "line_hash": "92415400",
      "speaker": "",
      "ja": "手にしたバゲットをウットリとした目で見つめる。",
      "zh": ""
    },
    {
      "key": "57.0",
      "line_index": 57,
      "inline_index": 0,
      "line_hash": "3a7957c2",
      "speaker": "",
      "ja": "そしてコルトはそのバゲットを股間へと押し当て",
      "zh": ""
    },
    {
      "key": "57.2",
      "line_index": 57,
      "inline_index": 2,
      "line_hash": "3a7957c2",
      "speaker": "",
      "ja": "そのまま膣内へとズブズブと挿入していった。",
      "zh": ""
    },
    {
      "key": "71.0",
      "line_index": 71,
      "inline_index": 0,
      "line_hash": "2e043657",
      "speaker": "コルト",
      "ja": "あは～、深いっ♥　やっぱり閉店後のオナニーは利く～♥",
      "zh": ""
    },
    {
      "key": "73.0",
      "line_index": 73,
      "inline_index": 0,
      "line_hash": "f82eff6d",
      "speaker": "",
      "ja": "コルトはおまんこでバゲットを咥え込むと歓喜の声を上げる。",
      "zh": ""
    },
    {
      "key": "73.2",
      "line_index": 73,
      "inline_index": 2,
      "line_hash": "f82eff6d",
      "speaker": "",
      "ja": "太いバケットはあっという間に彼女の膣の奥まで入り込んでいた。",
      "zh": ""
    },
    {
      "key": "76.0",
      "line_index": 76,
      "inline_index": 0,
      "line_hash": "3a36ea7",
      "speaker": "コルト",
      "ja": "このずりゅずりゅっておまんこが広がっていく感じ……癖になってる♥",
      "zh": ""
    },
    {
      "key": "78.0",
      "line_index": 78,
      "inline_index": 0,
      "line_hash": "fae93db4",
      "speaker": "",
      "ja": "甘い声でそう呟いたコルトはすっかり興奮した様子で",
      "zh": ""
    },
    {
      "key": "78.2",
      "line_index": 78,
      "inline_index": 2,
      "line_hash": "fae93db4",
      "speaker": "",
      "ja": "顔を赤らめながらワナワナと唇を震わせている。",
      "zh": ""
    },
    {
      "key": "80.0",
      "line_index": 80,
      "inline_index": 0,
      "line_hash": "2db7a5c9",
      "speaker": "",
      "ja": "バゲットを呑み込んだおまんこからは膣内に溜まっていたネットリとした汁が",
      "zh": ""
    },
    {
      "key": "80.2",
      "line_index": 80,
      "inline_index": 2,
      "line_hash": "2db7a5c9",
      "speaker": "",
      "ja": "ブチュブチュと音を立てながら溢れ出ていた。",
      "zh": ""
    },
    {
      "key": "83.0",
      "line_index": 83,
      "inline_index": 0,
      "line_hash": "f37524a6",
      "speaker": "コルト",
      "ja": "あぁぁ♥　この太さ、この固さ♥　んふぅぅん♥　やっぱり気持ちいいっ♥",
      "zh": ""
    },
    {
      "key": "85.0",
      "line_index": 85,
      "inline_index": 0,
      "line_hash": "261fb80a",
      "speaker": "",
      "ja": "この行為が初めてではないような台詞を口にしつつ、",
      "zh": ""
    },
    {
      "key": "85.2",
      "line_index": 85,
      "inline_index": 2,
      "line_hash": "261fb80a",
      "speaker": "",
      "ja": "コルトは挿入したバゲットをゆっくり出し入れさせ始めていく。",
      "zh": ""
    },
    {
      "key": "93.0",
      "line_index": 93,
      "inline_index": 0,
      "line_hash": "c393cb37",
      "speaker": "コルト",
      "ja": "こんなこと、本当は駄目なのにっ～♥　手が止まらないっ♥",
      "zh": ""
    },
    {
      "key": "95.0",
      "line_index": 95,
      "inline_index": 0,
      "line_hash": "31e3517c",
      "speaker": "",
      "ja": "気持ちよさそうに喘ぎながらコルトは股間のバゲットを夢中で動かした。",
      "zh": ""
    },
    {
      "key": "97.0",
      "line_index": 97,
      "inline_index": 0,
      "line_hash": "32b39746",
      "speaker": "",
      "ja": "太いバゲットが小さなコルトのおまんこに",
      "zh": ""
    },
    {
      "key": "97.2",
      "line_index": 97,
      "inline_index": 2,
      "line_hash": "32b39746",
      "speaker": "",
      "ja": "深々と突き刺さる様は少し異様に見える。",
      "zh": ""
    },
    {
      "key": "99.0",
      "line_index": 99,
      "inline_index": 0,
      "line_hash": "d197749b",
      "speaker": "",
      "ja": "しかし彼女は構うことなく、",
      "zh": ""
    },
    {
      "key": "99.2",
      "line_index": 99,
      "inline_index": 2,
      "line_hash": "d197749b",
      "speaker": "",
      "ja": "性欲を満たすために何度も抽送を繰り返し続けた。",
      "zh": ""
    },
    {
      "key": "102.0",
      "line_index": 102,
      "inline_index": 0,
      "line_hash": "2c32595f",
      "speaker": "コルト",
      "ja": "おっ♥　バゲットでゴリゴリって！　おまんこ擦れるっ♥",
      "zh": ""
    },
    {
      "key": "104.0",
      "line_index": 104,
      "inline_index": 0,
      "line_hash": "3b0340b5",
      "speaker": "",
      "ja": "凸凹したバゲットが膣内を引っ掻くように出入りを繰り返すと",
      "zh": ""
    },
    {
      "key": "104.2",
      "line_index": 104,
      "inline_index": 2,
      "line_hash": "3b0340b5",
      "speaker": "",
      "ja": "コルトは普段とはまるで違う声を上げながら喘ぎ声を上げる。",
      "zh": ""
    },
    {
      "key": "107.0",
      "line_index": 107,
      "inline_index": 0,
      "line_hash": "dd9dd7df",
      "speaker": "コルト",
      "ja": "んんんっ♥　あっ、はぁんっ♥　やっぱりこれっ♥　これが気持ちいい♥",
      "zh": ""
    },
    {
      "key": "109.0",
      "line_index": 109,
      "inline_index": 0,
      "line_hash": "bebb1100",
      "speaker": "",
      "ja": "そう言いながらコルトはいつも通りという感じで",
      "zh": ""
    },
    {
      "key": "109.2",
      "line_index": 109,
      "inline_index": 2,
      "line_hash": "bebb1100",
      "speaker": "",
      "ja": "バゲットを何度もズボズボさせた。",
      "zh": ""
    },
    {
      "key": "111.0",
      "line_index": 111,
      "inline_index": 0,
      "line_hash": "50980193",
      "speaker": "",
      "ja": "抽送を繰り返していくうちにオマンコから溢れ出た愛液で",
      "zh": ""
    },
    {
      "key": "111.2",
      "line_index": 111,
      "inline_index": 2,
      "line_hash": "50980193",
      "speaker": "",
      "ja": "バゲットが湿って柔らかくなっていく。",
      "zh": ""
    },
    {
      "key": "114.0",
      "line_index": 114,
      "inline_index": 0,
      "line_hash": "2f862013",
      "speaker": "コルト",
      "ja": "あぁぁぁ♥　もうこんなにグチュグチュになっちゃって♥　あぁんっ♥",
      "zh": ""
    },
    {
      "key": "114.2",
      "line_index": 114,
      "inline_index": 2,
      "line_hash": "2f862013",
      "speaker": "コルト",
      "ja": "おまんこヌルヌルぅ♥　あっ、はぁぁんっ♥",
      "zh": ""
    },
    {
      "key": "116.0",
      "line_index": 116,
      "inline_index": 0,
      "line_hash": "34bad954",
      "speaker": "",
      "ja": "太いバゲットが出入りする度におまんこからは",
      "zh": ""
    },
    {
      "key": "116.2",
      "line_index": 116,
      "inline_index": 2,
      "line_hash": "34bad954",
      "speaker": "",
      "ja": "ネットリとした汁が溢れて垂れた。",
      "zh": ""
    },
    {
      "key": "118.0",
      "line_index": 118,
      "inline_index": 0,
      "line_hash": "607dd2bd",
      "speaker": "",
      "ja": "そしてジュポジュポという淫らな水音が店内に響き渡っていく。",
      "zh": ""
    },
    {
      "key": "121.0",
      "line_index": 121,
      "inline_index": 0,
      "line_hash": "82976a9",
      "speaker": "コルト",
      "ja": "んふぅぅん♥　わたしのおまんこ、もうビチョビチョになっちゃってるぅ♥",
      "zh": ""
    },
    {
      "key": "121.2",
      "line_index": 121,
      "inline_index": 2,
      "line_hash": "82976a9",
      "speaker": "コルト",
      "ja": "もっとバゲットでジュポジュポぉ♥　んはぁぁ♥　気持ちいい～♥",
      "zh": ""
    },
    {
      "key": "123.0",
      "line_index": 123,
      "inline_index": 0,
      "line_hash": "189cd754",
      "speaker": "",
      "ja": "普段は口にしないような淫らな言葉を口にしながら",
      "zh": ""
    },
    {
      "key": "123.2",
      "line_index": 123,
      "inline_index": 2,
      "line_hash": "189cd754",
      "speaker": "",
      "ja": "コルトはどんどん乱れていった。",
      "zh": ""
    },
    {
      "key": "125.0",
      "line_index": 125,
      "inline_index": 0,
      "line_hash": "d10285d",
      "speaker": "",
      "ja": "バゲットを深く咥え込んだおまんこは",
      "zh": ""
    },
    {
      "key": "125.2",
      "line_index": 125,
      "inline_index": 2,
      "line_hash": "d10285d",
      "speaker": "",
      "ja": "ビュクビュクと息づくように蠢いているが",
      "zh": ""
    },
    {
      "key": "125.4",
      "line_index": 125,
      "inline_index": 4,
      "line_hash": "d10285d",
      "speaker": "",
      "ja": "それでも彼女は抽送を激しくさせていく。",
      "zh": ""
    },
    {
      "key": "128.0",
      "line_index": 128,
      "inline_index": 0,
      "line_hash": "9be7514a",
      "speaker": "コルト",
      "ja": "んはぁ♥　これっ♥　奥にズンズンくるのいいっ♥",
      "zh": ""
    },
    {
      "key": "128.2",
      "line_index": 128,
      "inline_index": 2,
      "line_hash": "9be7514a",
      "speaker": "コルト",
      "ja": "はうぅっ♥　もうイクッ♥",
      "zh": ""
    },
    {
      "key": "128.4",
      "line_index": 128,
      "inline_index": 4,
      "line_hash": "9be7514a",
      "speaker": "コルト",
      "ja": "バゲットオナニーでイクゥ♥　あっ♥　んはぁぁぁ♥",
      "zh": ""
    },
    {
      "key": "130.0",
      "line_index": 130,
      "inline_index": 0,
      "line_hash": "a2fb67db",
      "speaker": "",
      "ja": "ラストスパートをかけるかのように",
      "zh": ""
    },
    {
      "key": "130.2",
      "line_index": 130,
      "inline_index": 2,
      "line_hash": "a2fb67db",
      "speaker": "",
      "ja": "コルトはバゲットを激しく何度もピストンさせて体を大きくのけ反らせた。",
      "zh": ""
    },
    {
      "key": "161.0",
      "line_index": 161,
      "inline_index": 0,
      "line_hash": "d893b26f",
      "speaker": "コルト",
      "ja": "イクッ♥　イグッ♥　イグッ～～～～～～♥",
      "zh": ""
    },
    {
      "key": "163.0",
      "line_index": 163,
      "inline_index": 0,
      "line_hash": "f1940aa8",
      "speaker": "",
      "ja": "コルトはビクンビクンと腰を震わせながら絶頂に達した。",
      "zh": ""
    },
    {
      "key": "165.0",
      "line_index": 165,
      "inline_index": 0,
      "line_hash": "28e4fb5f",
      "speaker": "",
      "ja": "その表情はすっかり緩み恍惚の表情を浮かべている。",
      "zh": ""
    },
    {
      "key": "168.0",
      "line_index": 168,
      "inline_index": 0,
      "line_hash": "4c3955ad",
      "speaker": "コルト",
      "ja": "おっ♥　おっ♥　おおっ♥",
      "zh": ""
    },
    {
      "key": "170.0",
      "line_index": 170,
      "inline_index": 0,
      "line_hash": "ab87abc6",
      "speaker": "",
      "ja": "押し寄せてくる快感に身悶え、",
      "zh": ""
    },
    {
      "key": "170.2",
      "line_index": 170,
      "inline_index": 2,
      "line_hash": "ab87abc6",
      "speaker": "",
      "ja": "コルトは下品な声を漏らしながら小さく腰を震わせ続けた。",
      "zh": ""
    },
    {
      "key": "172.0",
      "line_index": 172,
      "inline_index": 0,
      "line_hash": "b5f86c93",
      "speaker": "",
      "ja": "そのまましばし絶頂の余韻に浸っていたコルトだが、",
      "zh": ""
    },
    {
      "key": "172.2",
      "line_index": 172,
      "inline_index": 2,
      "line_hash": "b5f86c93",
      "speaker": "",
      "ja": "冷めるにつれてまた強い欲求が湧き上がってくるのを感じてしまう。",
      "zh": ""
    },
    {
      "key": "175.0",
      "line_index": 175,
      "inline_index": 0,
      "line_hash": "9d449ca6",
      "speaker": "コルト",
      "ja": "はぁ……はぁ……まだ足りない♥",
      "zh": ""
    },
    {
      "key": "177.0",
      "line_index": 177,
      "inline_index": 0,
      "line_hash": "fda2824e",
      "speaker": "",
      "ja": "更なる快楽を求めて彼女はバゲットを掴む手に力を込める。",
      "zh": ""
    },
    {
      "key": "180.0",
      "line_index": 180,
      "inline_index": 0,
      "line_hash": "9c65bbd7",
      "speaker": "コルト",
      "ja": "もっと……深く♥　んっ♥　んんんんっ♥",
      "zh": ""
    },
    {
      "key": "182.0",
      "line_index": 182,
      "inline_index": 0,
      "line_hash": "d5f8acea",
      "speaker": "",
      "ja": "そのままコルトは握ったバケットで再度抽送を始めた。",
      "zh": ""
    },
    {
      "key": "190.0",
      "line_index": 190,
      "inline_index": 0,
      "line_hash": "7a5b75af",
      "speaker": "コルト",
      "ja": "おっ♥　ほぉんっ♥　バゲットオナニーさいこぉおおっ♥",
      "zh": ""
    },
    {
      "key": "192.0",
      "line_index": 192,
      "inline_index": 0,
      "line_hash": "c80762a4",
      "speaker": "",
      "ja": "絶頂の直後にも関わらずコルトは激しくバゲットを出し入れさせていく。",
      "zh": ""
    },
    {
      "key": "194.0",
      "line_index": 194,
      "inline_index": 0,
      "line_hash": "391574d0",
      "speaker": "",
      "ja": "すっかりグチュグチュになっている膣はその度にイヤらしい水音を鳴らした。",
      "zh": ""
    },
    {
      "key": "197.0",
      "line_index": 197,
      "inline_index": 0,
      "line_hash": "22a0e4c",
      "speaker": "コルト",
      "ja": "んっ♥　はぁぁ♥　奥にズンズン届いて♥　あふぅ♥　気持ちいいっ♥",
      "zh": ""
    },
    {
      "key": "199.0",
      "line_index": 199,
      "inline_index": 0,
      "line_hash": "1e5424f3",
      "speaker": "",
      "ja": "すっかり夢中になったコルトは、",
      "zh": ""
    },
    {
      "key": "199.2",
      "line_index": 199,
      "inline_index": 2,
      "line_hash": "1e5424f3",
      "speaker": "",
      "ja": "何度も何度もバゲットを深くおまんこに押し込んで淫らに悶え喘いでいく。",
      "zh": ""
    },
    {
      "key": "202.0",
      "line_index": 202,
      "inline_index": 0,
      "line_hash": "9c741347",
      "speaker": "コルト",
      "ja": "はぁはぁ♥　んっ……あぁぁ♥　もっと♥　もっとぉ♥　ひっ、んんんっ♥",
      "zh": ""
    },
    {
      "key": "204.0",
      "line_index": 204,
      "inline_index": 0,
      "line_hash": "6d1c8647",
      "speaker": "",
      "ja": "バゲットが深く入り込む度に軽い絶頂が彼女を襲い、",
      "zh": ""
    },
    {
      "key": "204.2",
      "line_index": 204,
      "inline_index": 2,
      "line_hash": "6d1c8647",
      "speaker": "",
      "ja": "大きく開いた股間からは派手に潮が噴き上がった。",
      "zh": ""
    },
    {
      "key": "206.0",
      "line_index": 206,
      "inline_index": 0,
      "line_hash": "ded2c99e",
      "speaker": "",
      "ja": "それでもコルトは手を止めることなく、バゲットの抽送を繰り返す。",
      "zh": ""
    },
    {
      "key": "209.0",
      "line_index": 209,
      "inline_index": 0,
      "line_hash": "bd4c81d0",
      "speaker": "コルト",
      "ja": "んあぁ♥　イク♥　いっぱいイク♥　あっ♥　あああぁぁぁっ♥",
      "zh": ""
    },
    {
      "key": "211.0",
      "line_index": 211,
      "inline_index": 0,
      "line_hash": "2b349c86",
      "speaker": "",
      "ja": "潮吹きが止まらなくなる程感じてしまっているコルトは、",
      "zh": ""
    },
    {
      "key": "211.2",
      "line_index": 211,
      "inline_index": 2,
      "line_hash": "2b349c86",
      "speaker": "",
      "ja": "腰を大きく跳ねさせイヤらしい声を上げながら身悶え続けた。",
      "zh": ""
    },
    {
      "key": "213.0",
      "line_index": 213,
      "inline_index": 0,
      "line_hash": "c1a2137f",
      "speaker": "",
      "ja": "すでに床は彼女が溢れさせた愛液と吹いた潮とでベチャベチャになっている。",
      "zh": ""
    },
    {
      "key": "216.0",
      "line_index": 216,
      "inline_index": 0,
      "line_hash": "2cc03b8f",
      "speaker": "コルト",
      "ja": "はぁはぁ♥　イクの止まらないの♥　あっ♥　あっ♥　あああっ♥",
      "zh": ""
    },
    {
      "key": "218.0",
      "line_index": 218,
      "inline_index": 0,
      "line_hash": "67b75be1",
      "speaker": "",
      "ja": "軽い絶頂を繰り返していくうちに、",
      "zh": ""
    },
    {
      "key": "218.2",
      "line_index": 218,
      "inline_index": 2,
      "line_hash": "67b75be1",
      "speaker": "",
      "ja": "コルトは大きな絶頂が近づいてきているのを感じていた。",
      "zh": ""
    },
    {
      "key": "221.0",
      "line_index": 221,
      "inline_index": 0,
      "line_hash": "6988b8d0",
      "speaker": "コルト",
      "ja": "んひぃぃ♥　す、すごいのきちゃうっ♥　すごい気持ちいいのが♥　ああっ♥",
      "zh": ""
    },
    {
      "key": "252.0",
      "line_index": 252,
      "inline_index": 0,
      "line_hash": "3ff7b58",
      "speaker": "コルト",
      "ja": "ヒギィ♥　イグ、イグ、イグッ♥　ンッ♥　ンハァァァァァァァ♥",
      "zh": ""
    },
    {
      "key": "254.0",
      "line_index": 254,
      "inline_index": 0,
      "line_hash": "ede64fe0",
      "speaker": "",
      "ja": "悲鳴のような声を上げながらコルトは大きな絶頂に身を震わせる。",
      "zh": ""
    },
    {
      "key": "256.0",
      "line_index": 256,
      "inline_index": 0,
      "line_hash": "b1b40267",
      "speaker": "",
      "ja": "バゲットを咥え込んだおまんこからは飛沫が派手に迸った。",
      "zh": ""
    },
    {
      "key": "259.0",
      "line_index": 259,
      "inline_index": 0,
      "line_hash": "a71380fb",
      "speaker": "コルト",
      "ja": "フヒィィィィ♥　ハァハァ♥　イグゥゥゥッ♥　ア゛ア゛ア゛ア゛ッ♥",
      "zh": ""
    },
    {
      "key": "261.0",
      "line_index": 261,
      "inline_index": 0,
      "line_hash": "33b5d035",
      "speaker": "",
      "ja": "あまりにも強烈な絶頂に",
      "zh": ""
    },
    {
      "key": "261.2",
      "line_index": 261,
      "inline_index": 2,
      "line_hash": "33b5d035",
      "speaker": "",
      "ja": "コルトは全身を激しく痙攣させながら獣のような声を上げる。",
      "zh": ""
    },
    {
      "key": "263.0",
      "line_index": 263,
      "inline_index": 0,
      "line_hash": "da52f985",
      "speaker": "",
      "ja": "おまんこを貫いているバゲットは",
      "zh": ""
    },
    {
      "key": "263.2",
      "line_index": 263,
      "inline_index": 2,
      "line_hash": "da52f985",
      "speaker": "",
      "ja": "彼女が噴き出した潮と愛液でグチュグチュになってしまっていた。",
      "zh": ""
    },
    {
      "key": "266.0",
      "line_index": 266,
      "inline_index": 0,
      "line_hash": "af1af053",
      "speaker": "コルト",
      "ja": "あっ♥　あっ♥　あああっ♥　も、もう……だめ……ぇぇぇ♥",
      "zh": ""
    },
    {
      "key": "268.0",
      "line_index": 268,
      "inline_index": 0,
      "line_hash": "b69d3a4",
      "speaker": "",
      "ja": "コルトは激しい絶頂の末、気を失ってその場に倒れ込んでしまう。",
      "zh": ""
    },
    {
      "key": "270.0",
      "line_index": 270,
      "inline_index": 0,
      "line_hash": "44a206e9",
      "speaker": "",
      "ja": "横たわった彼女の体はピクピクと痙攣し続け、",
      "zh": ""
    },
    {
      "key": "270.2",
      "line_index": 270,
      "inline_index": 2,
      "line_hash": "44a206e9",
      "speaker": "",
      "ja": "バゲットを突き立てたおまんこもイヤらしく蠢きながら",
      "zh": ""
    },
    {
      "key": "270.4",
      "line_index": 270,
      "inline_index": 4,
      "line_hash": "44a206e9",
      "speaker": "",
      "ja": "ネットリとした汁を垂れ流し続けていた。",
      "zh": ""
    }
  ]
}
