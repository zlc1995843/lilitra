{
  "lines": [
    {
      "key": "14.1",
      "line_index": 14,
      "inline_index": 1,
      "line_hash": "51095ceb",
      "speaker": "コハル",
      "ja": "ただいま～！",
      "zh": ""
    },
    {
      "key": "16.1",
      "line_index": 16,
      "inline_index": 1,
      "line_hash": "669b359e",
      "speaker": "アポロ",
      "ja": "お帰りなさいませ、お疲れ様です",
      "zh": ""
    },
    {
      "key": "18.1",
      "line_index": 18,
      "inline_index": 1,
      "line_hash": "423ef52b",
      "speaker": "ルミナ",
      "ja": "色々……買ってきた、よ……",
      "zh": ""
    },
    {
      "key": "20.1",
      "line_index": 20,
      "inline_index": 1,
      "line_hash": "98825a63",
      "speaker": "アポロ",
      "ja": "ありがとうございます、スキャンさせていただきます",
      "zh": ""
    },
    {
      "key": "22.1",
      "line_index": 22,
      "inline_index": 1,
      "line_hash": "64852c41",
      "speaker": "アポロ",
      "ja": "……はい、宇宙船の修理に必要な物資はこちらで揃いました。修理作業を開始いたします",
      "zh": ""
    },
    {
      "key": "24.1",
      "line_index": 24,
      "inline_index": 1,
      "line_hash": "5ddf0b2e",
      "speaker": "コハル",
      "ja": "ひとまずは安心って感じかしら？　次はどうする？",
      "zh": ""
    },
    {
      "key": "26.1",
      "line_index": 26,
      "inline_index": 1,
      "line_hash": "db371a0f",
      "speaker": "ルミナ",
      "ja": "食べ物……かな？",
      "zh": ""
    },
    {
      "key": "28.1",
      "line_index": 28,
      "inline_index": 1,
      "line_hash": "a401ec19",
      "speaker": "アポロ",
      "ja": "その件なのですが、先程雫様から提案がございまして……",
      "zh": ""
    },
    {
      "key": "30.1",
      "line_index": 30,
      "inline_index": 1,
      "line_hash": "8ff46a81",
      "speaker": "コハル",
      "ja": "雫から？　何て言ってたの？",
      "zh": ""
    },
    {
      "key": "43.1",
      "line_index": 43,
      "inline_index": 1,
      "line_hash": "14289d7d",
      "speaker": "雫",
      "ja": "今回の星では他の星と違い、原住民と交流しても母星から咎められない、という特徴があります",
      "zh": ""
    },
    {
      "key": "45.1",
      "line_index": 45,
      "inline_index": 1,
      "line_hash": "9745b38e",
      "speaker": "雫",
      "ja": "つまり派手に動いても問題ないということ。この星での最新の技術を持ち帰ればルミナ様の功績の１つとなるでしょう",
      "zh": ""
    },
    {
      "key": "61.1",
      "line_index": 61,
      "inline_index": 1,
      "line_hash": "55d20591",
      "speaker": "コハル",
      "ja": "えっとー、つまり……？",
      "zh": ""
    },
    {
      "key": "63.1",
      "line_index": 63,
      "inline_index": 1,
      "line_hash": "ca6eaec8",
      "speaker": "アポロ",
      "ja": "今まで確認されていない、実用的な爆弾を持ち帰ることが出来れば、母星に帰った際に言い訳の１つに出来ます",
      "zh": ""
    },
    {
      "key": "65.1",
      "line_index": 65,
      "inline_index": 1,
      "line_hash": "405e682d",
      "speaker": "コハル",
      "ja": "……凄い爆弾を探して買ってこい、ってことね！",
      "zh": ""
    },
    {
      "key": "67.1",
      "line_index": 67,
      "inline_index": 1,
      "line_hash": "1800564",
      "speaker": "ルミナ",
      "ja": "そう簡単に、見つからなさそうだけれど……",
      "zh": ""
    },
    {
      "key": "69.1",
      "line_index": 69,
      "inline_index": 1,
      "line_hash": "17944b07",
      "speaker": "アポロ",
      "ja": "必要という訳ではございませんので、もしも機会があればとお考えください",
      "zh": ""
    },
    {
      "key": "71.1",
      "line_index": 71,
      "inline_index": 1,
      "line_hash": "55870d48",
      "speaker": "コハル",
      "ja": "わかったわ。……じゃあ、街に戻る？　他の物を買いながら、少し観光しましょっか！",
      "zh": ""
    },
    {
      "key": "73.1",
      "line_index": 73,
      "inline_index": 1,
      "line_hash": "8e580802",
      "speaker": "ルミナ",
      "ja": "うん、行こう……！",
      "zh": ""
    },
    {
      "key": "80.1",
      "line_index": 80,
      "inline_index": 1,
      "line_hash": "7306c9de",
      "speaker": "アポロ",
      "ja": "…………",
      "zh": ""
    },
    {
      "key": "82.1",
      "line_index": 82,
      "inline_index": 1,
      "line_hash": "f0ebc1fa",
      "speaker": "アポロ",
      "ja": "（ワタシや雫様以外にもご友人が出来て、本当に良かったですねマスター……）",
      "zh": ""
    },
    {
      "key": "100.1",
      "line_index": 100,
      "inline_index": 1,
      "line_hash": "28ba2673",
      "speaker": "コハル",
      "ja": "うーん……こっちの果物は、ちょっと……鼻にツンとくる酸っぱさがあるわね。好き嫌い分かれそう",
      "zh": ""
    },
    {
      "key": "102.1",
      "line_index": 102,
      "inline_index": 1,
      "line_hash": "958ce025",
      "speaker": "ルミナ",
      "ja": "こっちのは……少し、ザラッとしてて……舌に残るけど、甘くて美味しい、よ……",
      "zh": ""
    },
    {
      "key": "104.0",
      "line_index": 104,
      "inline_index": 0,
      "line_hash": "e0271262",
      "speaker": "店主",
      "ja": "ははは、ウチの果物はオリジナル配合の農用爆弾で育ててるからね！　他の店には負けないよ！",
      "zh": ""
    },
    {
      "key": "106.1",
      "line_index": 106,
      "inline_index": 1,
      "line_hash": "53ebafa4",
      "speaker": "コハル",
      "ja": "そ、そうなんですねー……あっ",
      "zh": ""
    },
    {
      "key": "108.1",
      "line_index": 108,
      "inline_index": 1,
      "line_hash": "40cdc184",
      "speaker": "コハル",
      "ja": "変わった爆弾とか、新しい爆弾が買える店とか、作ってる人……を探してるんですけど、ご存じないですか？",
      "zh": ""
    },
    {
      "key": "110.0",
      "line_index": 110,
      "inline_index": 0,
      "line_hash": "f54e32a6",
      "speaker": "店主",
      "ja": "変わった爆弾？　だったらやっぱり、ベルさんとこじゃないかな",
      "zh": ""
    },
    {
      "key": "112.1",
      "line_index": 112,
      "inline_index": 1,
      "line_hash": "d406673a",
      "speaker": "ルミナ",
      "ja": "ベル、さん……？",
      "zh": ""
    },
    {
      "key": "114.0",
      "line_index": 114,
      "inline_index": 0,
      "line_hash": "1cf6a6d5",
      "speaker": "店主",
      "ja": "変わり者の天才で有名だからねー、波はあるけど、やっぱり爆弾研究者じゃ一番有名だと思うよ",
      "zh": ""
    },
    {
      "key": "116.0",
      "line_index": 116,
      "inline_index": 0,
      "line_hash": "42c2ca20",
      "speaker": "店主",
      "ja": "ちょうどこの時間、あのデカい工場の前で実演販売してるから、気になるなら行ってみたら？",
      "zh": ""
    },
    {
      "key": "118.1",
      "line_index": 118,
      "inline_index": 1,
      "line_hash": "28bfc7a2",
      "speaker": "コハル",
      "ja": "わかりました、ありがとうございます！",
      "zh": ""
    },
    {
      "key": "134.1",
      "line_index": 134,
      "inline_index": 1,
      "line_hash": "2eb3f65d",
      "speaker": "コハル",
      "ja": "えーと……このあたりよね",
      "zh": ""
    },
    {
      "key": "136.0",
      "line_index": 136,
      "inline_index": 0,
      "line_hash": "b81a5041",
      "speaker": "？？？",
      "ja": "さあさあ皆さんお立会い！　ここに取り出したるは、わがはいがついさっき完成させた新作の爆弾だ！",
      "zh": ""
    },
    {
      "key": "138.1",
      "line_index": 138,
      "inline_index": 1,
      "line_hash": "85ee3829",
      "speaker": "コハル",
      "ja": "あ、あれかしら？",
      "zh": ""
    },
    {
      "key": "140.0",
      "line_index": 140,
      "inline_index": 0,
      "line_hash": "8ee8490a",
      "speaker": "",
      "ja": "声に反応した客が、みるみるうちに集まってくる。新作の爆弾という響きに弱いのか、遠くからもドンドン駆けつけていく。",
      "zh": ""
    },
    {
      "key": "142.1",
      "line_index": 142,
      "inline_index": 1,
      "line_hash": "f9a5e31b",
      "speaker": "コハル",
      "ja": "い、急がないと見られないわね……！",
      "zh": ""
    },
    {
      "key": "144.1",
      "line_index": 144,
      "inline_index": 1,
      "line_hash": "a73ab3a0",
      "speaker": "ルミナ",
      "ja": "前のほうに、行こう……！",
      "zh": ""
    },
    {
      "key": "156.1",
      "line_index": 156,
      "inline_index": 1,
      "line_hash": "5b21ed5e",
      "speaker": "ベル",
      "ja": "皆さん、準備はよろしいかな？　では実演を始めよう！",
      "zh": ""
    },
    {
      "key": "158.0",
      "line_index": 158,
      "inline_index": 0,
      "line_hash": "f8edb49d",
      "speaker": "",
      "ja": "多くの見物客に囲まれながら、小さなリリアンが懐から１つの爆弾を取り出し、大げさに掲げて見せた。",
      "zh": ""
    },
    {
      "key": "160.1",
      "line_index": 160,
      "inline_index": 1,
      "line_hash": "6022f4c",
      "speaker": "ベル",
      "ja": "そこの可愛らしいお姉さん、こちらへ！",
      "zh": ""
    },
    {
      "key": "162.0",
      "line_index": 162,
      "inline_index": 0,
      "line_hash": "f157ff2",
      "speaker": "女性",
      "ja": "え？　……私？",
      "zh": ""
    },
    {
      "key": "164.1",
      "line_index": 164,
      "inline_index": 1,
      "line_hash": "112d7fb2",
      "speaker": "ベル",
      "ja": "こちらへ、こちらへ！",
      "zh": ""
    },
    {
      "key": "166.0",
      "line_index": 166,
      "inline_index": 0,
      "line_hash": "ef26d218",
      "speaker": "",
      "ja": "女性が狼狽えながらも、おずおずと前へ出る。不安半分、期待半分といった様子だ。",
      "zh": ""
    },
    {
      "key": "168.1",
      "line_index": 168,
      "inline_index": 1,
      "line_hash": "6d6bb538",
      "speaker": "ベル",
      "ja": "……見目麗しいお姉さんだが、この爆弾を使うと～……！",
      "zh": ""
    },
    {
      "key": "173.0",
      "line_index": 173,
      "inline_index": 0,
      "line_hash": "573b2f0b",
      "speaker": "女性",
      "ja": "きゃっ！？",
      "zh": ""
    },
    {
      "key": "175.0",
      "line_index": 175,
      "inline_index": 0,
      "line_hash": "aaa83394",
      "speaker": "",
      "ja": "女性を包み込むような、緑色の爆煙がたちこめる。……爆煙が晴れると、見物客達がどよめいた。",
      "zh": ""
    },
    {
      "key": "177.1",
      "line_index": 177,
      "inline_index": 1,
      "line_hash": "ec0c0ae2",
      "speaker": "ベル",
      "ja": "どうだー！　筋肉ムキムキの男性に早変わり！　これが新作の、モーフィングボムである！",
      "zh": ""
    },
    {
      "key": "179.1",
      "line_index": 179,
      "inline_index": 1,
      "line_hash": "1d106fef",
      "speaker": "ベル",
      "ja": "まだ他の姿になれるボムを作ってないので、実質ムキムキボムであるが……",
      "zh": ""
    },
    {
      "key": "181.0",
      "line_index": 181,
      "inline_index": 0,
      "line_hash": "f550efe1",
      "speaker": "",
      "ja": "おお、と観客がどよめく。……が、半数ほどは怪訝な表情を見せ苦笑しているようだ。",
      "zh": ""
    },
    {
      "key": "194.1",
      "line_index": 194,
      "inline_index": 1,
      "line_hash": "9fbf5b18",
      "speaker": "コハル",
      "ja": "す、すごーい……けど……何に使うのかしら……",
      "zh": ""
    },
    {
      "key": "196.1",
      "line_index": 196,
      "inline_index": 1,
      "line_hash": "b60a162",
      "speaker": "ルミナ",
      "ja": "パーティーグッズ……とか、かな……？　……持って帰る技術にしては、ちょっと変わりすぎてるかも……",
      "zh": ""
    },
    {
      "key": "210.0",
      "line_index": 210,
      "inline_index": 0,
      "line_hash": "49aa1d5b",
      "speaker": "元女性",
      "ja": "ちょ、ちょっと！　戻しなさいよ！　この後、人と会うのよ私っ！",
      "zh": ""
    },
    {
      "key": "212.1",
      "line_index": 212,
      "inline_index": 1,
      "line_hash": "ddafe322",
      "speaker": "ベル",
      "ja": "あ、ああ……もちろん戻すとも！　ちょっと待っ……",
      "zh": ""
    },
    {
      "key": "214.0",
      "line_index": 214,
      "inline_index": 0,
      "line_hash": "22e141b4",
      "speaker": "客",
      "ja": "面白い！　３つ……いや、５つくれ！",
      "zh": ""
    },
    {
      "key": "216.0",
      "line_index": 216,
      "inline_index": 0,
      "line_hash": "17661f19",
      "speaker": "客",
      "ja": "こっちは１０個だ！",
      "zh": ""
    },
    {
      "key": "219.1",
      "line_index": 219,
      "inline_index": 1,
      "line_hash": "105da649",
      "speaker": "ベル",
      "ja": "お、押すでない！　首が締まっ……ちょ、ちょっと、おごごっ！",
      "zh": ""
    },
    {
      "key": "233.1",
      "line_index": 233,
      "inline_index": 1,
      "line_hash": "216f226c",
      "speaker": "コハル",
      "ja": "これはちょっと近づけないわね……",
      "zh": ""
    },
    {
      "key": "235.1",
      "line_index": 235,
      "inline_index": 1,
      "line_hash": "3fd91ad7",
      "speaker": "ルミナ",
      "ja": "お店、覚えたから……また明日来よう、か……",
      "zh": ""
    },
    {
      "key": "247.0",
      "line_index": 247,
      "inline_index": 0,
      "line_hash": "781cc75f",
      "speaker": "",
      "ja": "時は少し遡り……",
      "zh": ""
    },
    {
      "key": "254.1",
      "line_index": 254,
      "inline_index": 1,
      "line_hash": "e870da41",
      "speaker": "アコ",
      "ja": "協力していただいてありがとうございます……でも、本当にいいんですか……？",
      "zh": ""
    },
    {
      "key": "256.0",
      "line_index": 256,
      "inline_index": 0,
      "line_hash": "b81db06c",
      "speaker": "{G_PlayerName}",
      "ja": "俺にとっては願ったり叶ったりだからな……そっちこそ、俺はそんなに爆弾について詳しくないんだけど、いいのか？",
      "zh": ""
    },
    {
      "key": "258.1",
      "line_index": 258,
      "inline_index": 1,
      "line_hash": "f03b1a6b",
      "speaker": "アコ",
      "ja": "大丈夫です！　私なんかより絶対、良いアイデアをお持ちだと思うので！",
      "zh": ""
    },
    {
      "key": "260.0",
      "line_index": 260,
      "inline_index": 0,
      "line_hash": "c088030d",
      "speaker": "{G_PlayerName}",
      "ja": "ひ、卑屈すぎるだろ……",
      "zh": ""
    },
    {
      "key": "262.0",
      "line_index": 262,
      "inline_index": 0,
      "line_hash": "9fa9a075",
      "speaker": "{G_PlayerName}",
      "ja": "……でも、こんな所で爆弾作ってるのか？",
      "zh": ""
    },
    {
      "key": "264.1",
      "line_index": 264,
      "inline_index": 1,
      "line_hash": "1e5cca1",
      "speaker": "アコ",
      "ja": "はい……！　色々、使える材料が転がってるので、それを使ってるんです！",
      "zh": ""
    },
    {
      "key": "266.0",
      "line_index": 266,
      "inline_index": 0,
      "line_hash": "812402f3",
      "speaker": "{G_PlayerName}",
      "ja": "お金が無いとか……？",
      "zh": ""
    },
    {
      "key": "268.1",
      "line_index": 268,
      "inline_index": 1,
      "line_hash": "92e2cc44",
      "speaker": "アコ",
      "ja": "というより……お店で材料買うのと、そんなに変わらなく感じると言いますか……むしろここのほうが品揃え豊富……",
      "zh": ""
    },
    {
      "key": "270.0",
      "line_index": 270,
      "inline_index": 0,
      "line_hash": "5c2da99c",
      "speaker": "{G_PlayerName}",
      "ja": "（流石にそんなワケないだろ……！）",
      "zh": ""
    },
    {
      "key": "272.1",
      "line_index": 272,
      "inline_index": 1,
      "line_hash": "ed4ce136",
      "speaker": "アコ",
      "ja": "この街の皆さんをアッと言わせるような、凄い爆弾を作りたいと思ってます！　改めて、ご協力よろしくお願いしますね……！",
      "zh": ""
    },
    {
      "key": "274.0",
      "line_index": 274,
      "inline_index": 0,
      "line_hash": "59403516",
      "speaker": "{G_PlayerName}",
      "ja": "お、おー……出来るかな……",
      "zh": ""
    },
    {
      "key": "288.0",
      "line_index": 288,
      "inline_index": 0,
      "line_hash": "dda06432",
      "speaker": "{G_PlayerName}",
      "ja": "ただいまー……",
      "zh": ""
    },
    {
      "key": "294.1",
      "line_index": 294,
      "inline_index": 1,
      "line_hash": "7208c1d5",
      "speaker": "コハル",
      "ja": "{G_PlayerName}！　遅かったわね",
      "zh": ""
    },
    {
      "key": "296.0",
      "line_index": 296,
      "inline_index": 0,
      "line_hash": "bb4f4679",
      "speaker": "{G_PlayerName}",
      "ja": "色々あってな……運良く爆弾作りが近くで見れたのは良かったんだが",
      "zh": ""
    },
    {
      "key": "311.1",
      "line_index": 311,
      "inline_index": 1,
      "line_hash": "c2350170",
      "speaker": "アコ",
      "ja": "えっと……こうして……こうやって……",
      "zh": ""
    },
    {
      "key": "313.0",
      "line_index": 313,
      "inline_index": 0,
      "line_hash": "68c93830",
      "speaker": "",
      "ja": "テキパキと、どこからか端材を持ってきては凄いスピードで爆弾を組み立てるアコ。素人目で見ても、ただならぬ技量なのはわかるのだが……",
      "zh": ""
    },
    {
      "key": "315.0",
      "line_index": 315,
      "inline_index": 0,
      "line_hash": "3e573f13",
      "speaker": "{G_PlayerName}",
      "ja": "（……何をやってるのか、早すぎてさっぱりわからない……！　この星の人たちって、皆こんな速度で爆弾作るのか！？）",
      "zh": ""
    },
    {
      "key": "317.1",
      "line_index": 317,
      "inline_index": 1,
      "line_hash": "fa774461",
      "speaker": "アコ",
      "ja": "出来ました！　早速爆発、させてみますね！",
      "zh": ""
    },
    {
      "key": "323.1",
      "line_index": 323,
      "inline_index": 1,
      "line_hash": "9b3b8b81",
      "speaker": "アコ",
      "ja": "……どうでしょう！？",
      "zh": ""
    },
    {
      "key": "325.0",
      "line_index": 325,
      "inline_index": 0,
      "line_hash": "2eab294e",
      "speaker": "{G_PlayerName}",
      "ja": "え、えーと……なんというか、シンプルだなと……",
      "zh": ""
    },
    {
      "key": "327.1",
      "line_index": 327,
      "inline_index": 1,
      "line_hash": "78ff80a2",
      "speaker": "アコ",
      "ja": "綺麗だなとは、なりませんか……？",
      "zh": ""
    },
    {
      "key": "329.0",
      "line_index": 329,
      "inline_index": 0,
      "line_hash": "27f4315b",
      "speaker": "{G_PlayerName}",
      "ja": "そう……だなあ。煙も黒いし、特には……",
      "zh": ""
    },
    {
      "key": "331.1",
      "line_index": 331,
      "inline_index": 1,
      "line_hash": "b51df4ef",
      "speaker": "アコ",
      "ja": "ありがとうございます！　次を作ります……！",
      "zh": ""
    },
    {
      "key": "344.0",
      "line_index": 344,
      "inline_index": 0,
      "line_hash": "213689a3",
      "speaker": "{G_PlayerName}",
      "ja": "（勉強になるんだかならないんだか……ずっと同じような爆弾だったし……）",
      "zh": ""
    },
    {
      "key": "346.1",
      "line_index": 346,
      "inline_index": 1,
      "line_hash": "223b59a8",
      "speaker": "コハル",
      "ja": "お、お疲れ様……？",
      "zh": ""
    },
    {
      "key": "352.1",
      "line_index": 352,
      "inline_index": 1,
      "line_hash": "59c78315",
      "speaker": "ルミナ",
      "ja": "{G_PlayerName}くん……疲れた顔、してるね……",
      "zh": ""
    },
    {
      "key": "354.0",
      "line_index": 354,
      "inline_index": 0,
      "line_hash": "3bab37df",
      "speaker": "{G_PlayerName}",
      "ja": "そうか？　……作業を集中して見てたから、目が疲れたんだろうな",
      "zh": ""
    },
    {
      "key": "360.1",
      "line_index": 360,
      "inline_index": 1,
      "line_hash": "941f873f",
      "speaker": "雫",
      "ja": "全く、くだらない事で疲弊するとは。本当に時間の無駄がお好きですね",
      "zh": ""
    },
    {
      "key": "362.0",
      "line_index": 362,
      "inline_index": 0,
      "line_hash": "c66eb0ed",
      "speaker": "{G_PlayerName}",
      "ja": "時間の無駄だとぉ……？　今に見てろよ、すげー爆弾作ってギャフンと言わせてやる！",
      "zh": ""
    },
    {
      "key": "364.1",
      "line_index": 364,
      "inline_index": 1,
      "line_hash": "1a107204",
      "speaker": "コハル",
      "ja": "セリフだけ聞くとただの犯罪者ね……",
      "zh": ""
    },
    {
      "key": "366.1",
      "line_index": 366,
      "inline_index": 1,
      "line_hash": "cc17378b",
      "speaker": "雫",
      "ja": "どちらかというと、なかなか思ったようにいかない貴方のほうがギャフンと言いそうですけどね……",
      "zh": ""
    },
    {
      "key": "368.0",
      "line_index": 368,
      "inline_index": 0,
      "line_hash": "56b0749f",
      "speaker": "{G_PlayerName}",
      "ja": "そんなわけあるか！　初日で協力者が見つかって、トントン拍子に行くに決まってるだろ！",
      "zh": ""
    },
    {
      "key": "382.0",
      "line_index": 382,
      "inline_index": 0,
      "line_hash": "a7e40d48",
      "speaker": "{G_PlayerName}",
      "ja": "……ギャフン！",
      "zh": ""
    },
    {
      "key": "387.1",
      "line_index": 387,
      "inline_index": 1,
      "line_hash": "4dd63be1",
      "speaker": "アコ",
      "ja": "ど、どうしたんですか{G_PlayerName}さん……！？",
      "zh": ""
    },
    {
      "key": "389.0",
      "line_index": 389,
      "inline_index": 0,
      "line_hash": "bfd48f",
      "speaker": "{G_PlayerName}",
      "ja": "いや……認めるべき敗北は認めておこうかと……",
      "zh": ""
    },
    {
      "key": "394.0",
      "line_index": 394,
      "inline_index": 0,
      "line_hash": "98d3abba",
      "speaker": "",
      "ja": "５日後。あれから毎日アコの爆弾作りに協力していたが、アコの爆弾の出来には進展は見られていなかった。",
      "zh": ""
    },
    {
      "key": "396.0",
      "line_index": 396,
      "inline_index": 0,
      "line_hash": "ec5966b6",
      "speaker": "{G_PlayerName}",
      "ja": "（流石にそろそろ、爆弾の大まかな構造くらいは予想ついてきたけど……）",
      "zh": ""
    },
    {
      "key": "403.1",
      "line_index": 403,
      "inline_index": 1,
      "line_hash": "9eacedde",
      "speaker": "アコ",
      "ja": "えいっ！　……どうですか、{G_PlayerName}さん！？",
      "zh": ""
    },
    {
      "key": "405.0",
      "line_index": 405,
      "inline_index": 0,
      "line_hash": "d9b075ca",
      "speaker": "{G_PlayerName}",
      "ja": "……シンプルだな！",
      "zh": ""
    },
    {
      "key": "407.1",
      "line_index": 407,
      "inline_index": 1,
      "line_hash": "bf32451",
      "speaker": "アコ",
      "ja": "し、シンプルな中に見える美とかは……？",
      "zh": ""
    },
    {
      "key": "409.0",
      "line_index": 409,
      "inline_index": 0,
      "line_hash": "a3e072f4",
      "speaker": "{G_PlayerName}",
      "ja": "わ……わからん。どうだろう……",
      "zh": ""
    },
    {
      "key": "411.1",
      "line_index": 411,
      "inline_index": 1,
      "line_hash": "8270fc62",
      "speaker": "アコ",
      "ja": "うぅ……そうですか……前とは大きく構造を変えてみたのですが……",
      "zh": ""
    },
    {
      "key": "413.0",
      "line_index": 413,
      "inline_index": 0,
      "line_hash": "d24ccf14",
      "speaker": "{G_PlayerName}",
      "ja": "（全く違いがわからんかった……）",
      "zh": ""
    },
    {
      "key": "415.0",
      "line_index": 415,
      "inline_index": 0,
      "line_hash": "810a55f6",
      "speaker": "{G_PlayerName}",
      "ja": "また、中身を見せてもらっていいか？",
      "zh": ""
    },
    {
      "key": "417.1",
      "line_index": 417,
      "inline_index": 1,
      "line_hash": "787383e8",
      "speaker": "アコ",
      "ja": "はい！　どうぞ！",
      "zh": ""
    },
    {
      "key": "419.0",
      "line_index": 419,
      "inline_index": 0,
      "line_hash": "301906de",
      "speaker": "",
      "ja": "どうやら技術を隠そうとするつもりはアコには無く、言えば気軽に爆弾の構造を見せてくれる。本当にありがたい話ではあるのだが……",
      "zh": ""
    },
    {
      "key": "421.0",
      "line_index": 421,
      "inline_index": 0,
      "line_hash": "a6be268a",
      "speaker": "{G_PlayerName}",
      "ja": "ここ、どうなってるんだ……？",
      "zh": ""
    },
    {
      "key": "423.1",
      "line_index": 423,
      "inline_index": 1,
      "line_hash": "b6025392",
      "speaker": "アコ",
      "ja": "はい！　ここは特にこだわった部分ですね！　■■からの接続を■■で補強して、■■からの衝撃を伝達して……",
      "zh": ""
    },
    {
      "key": "425.0",
      "line_index": 425,
      "inline_index": 0,
      "line_hash": "714ff9a1",
      "speaker": "{G_PlayerName}",
      "ja": "（うおお、いつも通り爆弾職人用語連発でサッパリだ……！）",
      "zh": ""
    },
    {
      "key": "427.1",
      "line_index": 427,
      "inline_index": 1,
      "line_hash": "6e0c8d76",
      "speaker": "アコ",
      "ja": "ガーッといって、バーンというわけなんです！",
      "zh": ""
    },
    {
      "key": "429.0",
      "line_index": 429,
      "inline_index": 0,
      "line_hash": "20776908",
      "speaker": "{G_PlayerName}",
      "ja": "（そしてオーロラによく似た抽象的な説明も挟まってくるから、言葉で説明してもらうのは諦めるしか無いんだよな……）",
      "zh": ""
    },
    {
      "key": "431.0",
      "line_index": 431,
      "inline_index": 0,
      "line_hash": "1c1b443c",
      "speaker": "{G_PlayerName}",
      "ja": "……なるほどな！",
      "zh": ""
    },
    {
      "key": "433.1",
      "line_index": 433,
      "inline_index": 1,
      "line_hash": "6df5939e",
      "speaker": "アコ",
      "ja": "えへへ……こだわって作った爆弾を理解してもらうのって、嬉しいですね……！",
      "zh": ""
    },
    {
      "key": "435.0",
      "line_index": 435,
      "inline_index": 0,
      "line_hash": "4e13409a",
      "speaker": "{G_PlayerName}",
      "ja": "（すまん……全然理解はしてないんだけど……）",
      "zh": ""
    },
    {
      "key": "440.0",
      "line_index": 440,
      "inline_index": 0,
      "line_hash": "42aa4ee3",
      "speaker": "？？？",
      "ja": "お～い、アコちゃ～ん？　このあたりにいるの～？　いたら返事して～？",
      "zh": ""
    },
    {
      "key": "442.1",
      "line_index": 442,
      "inline_index": 1,
      "line_hash": "835d15ef",
      "speaker": "アコ",
      "ja": "（ぴっ！？　……ど、どなたでしょうか……？）",
      "zh": ""
    },
    {
      "key": "444.0",
      "line_index": 444,
      "inline_index": 0,
      "line_hash": "4e7b8823",
      "speaker": "{G_PlayerName}",
      "ja": "知り合いか？",
      "zh": ""
    },
    {
      "key": "446.1",
      "line_index": 446,
      "inline_index": 1,
      "line_hash": "f1b90992",
      "speaker": "アコ",
      "ja": "（こ、ここに呼んだことがある人は、{G_PlayerName}さんしかいませんよ……！）",
      "zh": ""
    },
    {
      "key": "454.1",
      "line_index": 454,
      "inline_index": 1,
      "line_hash": "ceb2644e",
      "speaker": "アルフ",
      "ja": "なんだ、いるなら返事してよ。……おん？　キミも関係者かな？",
      "zh": ""
    },
    {
      "key": "456.1",
      "line_index": 456,
      "inline_index": 1,
      "line_hash": "a03a1591",
      "speaker": "アコ",
      "ja": "えっ？　……ええーっ！？",
      "zh": ""
    },
    {
      "key": "458.0",
      "line_index": 458,
      "inline_index": 0,
      "line_hash": "d32b5775",
      "speaker": "{G_PlayerName}",
      "ja": "この人は、確か……？",
      "zh": ""
    }
  ]
}
