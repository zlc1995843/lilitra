{
  "lines": [
    {
      "key": "14.0",
      "line_index": 14,
      "inline_index": 0,
      "line_hash": "317b3cbe",
      "speaker": "",
      "ja": "リリアンに囲まれた生活は楽しく充実している反面、",
      "zh": ""
    },
    {
      "key": "14.2",
      "line_index": 14,
      "inline_index": 2,
      "line_hash": "317b3cbe",
      "speaker": "",
      "ja": "俺は問題を抱えていた。",
      "zh": ""
    },
    {
      "key": "16.0",
      "line_index": 16,
      "inline_index": 0,
      "line_hash": "c98e12ea",
      "speaker": "",
      "ja": "それはたまりにたまっていく性欲だ。",
      "zh": ""
    },
    {
      "key": "16.2",
      "line_index": 16,
      "inline_index": 2,
      "line_hash": "c98e12ea",
      "speaker": "",
      "ja": "自分で処理をしてもまるで追いつかない。",
      "zh": ""
    },
    {
      "key": "18.0",
      "line_index": 18,
      "inline_index": 0,
      "line_hash": "f7649181",
      "speaker": "",
      "ja": "そんな目で彼女たちを見ているということに後ろめたさを",
      "zh": ""
    },
    {
      "key": "18.2",
      "line_index": 18,
      "inline_index": 2,
      "line_hash": "f7649181",
      "speaker": "",
      "ja": "感じた俺は気がつくと教会の懺悔室へと足を運んでいた。",
      "zh": ""
    },
    {
      "key": "20.0",
      "line_index": 20,
      "inline_index": 0,
      "line_hash": "d52f69ad",
      "speaker": "",
      "ja": "懺悔室に入った俺はその場に跪いて両手を合わせ懺悔の言葉を口にする。",
      "zh": ""
    },
    {
      "key": "23.0",
      "line_index": 23,
      "inline_index": 0,
      "line_hash": "526459e0",
      "speaker": "{G_PlayerName}",
      "ja": "周りの子達が可愛すぎて……その……欲情してしまうことがあって……",
      "zh": ""
    },
    {
      "key": "26.0",
      "line_index": 26,
      "inline_index": 0,
      "line_hash": "f71abbe3",
      "speaker": "",
      "ja": "そんな言葉を口にした時、不意に懺悔室の外から笑い声が聞こえてきた。",
      "zh": ""
    },
    {
      "key": "29.0",
      "line_index": 29,
      "inline_index": 0,
      "line_hash": "4423b3dc",
      "speaker": "クイン",
      "ja": "ぷっ……くすくす♥",
      "zh": ""
    },
    {
      "key": "32.0",
      "line_index": 32,
      "inline_index": 0,
      "line_hash": "92dc9738",
      "speaker": "{G_PlayerName}",
      "ja": "……えっ？",
      "zh": ""
    },
    {
      "key": "39.0",
      "line_index": 39,
      "inline_index": 0,
      "line_hash": "dc98f1f8",
      "speaker": "",
      "ja": "慌てて振り返ると懺悔室に笑みを浮かべたクインが入ってくる。",
      "zh": ""
    },
    {
      "key": "43.0",
      "line_index": 43,
      "inline_index": 0,
      "line_hash": "27e71a81",
      "speaker": "クイン",
      "ja": "おじさ～ん♥　周りの小っちゃい子達を～……",
      "zh": ""
    },
    {
      "key": "43.2",
      "line_index": 43,
      "inline_index": 2,
      "line_hash": "27e71a81",
      "speaker": "クイン",
      "ja": "エッチな目で見ちゃってるんだ～♥",
      "zh": ""
    },
    {
      "key": "46.0",
      "line_index": 46,
      "inline_index": 0,
      "line_hash": "d2c21ce5",
      "speaker": "{G_PlayerName}",
      "ja": "あっ……いや……そ、それは……",
      "zh": ""
    },
    {
      "key": "49.0",
      "line_index": 49,
      "inline_index": 0,
      "line_hash": "28a334ea",
      "speaker": "",
      "ja": "しどろもどろになってしまう俺に歩み寄ってきたクインは",
      "zh": ""
    },
    {
      "key": "49.2",
      "line_index": 49,
      "inline_index": 2,
      "line_hash": "28a334ea",
      "speaker": "",
      "ja": "意味ありげな笑いを浮かべ耳元で囁きかけてきた。",
      "zh": ""
    },
    {
      "key": "53.0",
      "line_index": 53,
      "inline_index": 0,
      "line_hash": "b70ed96a",
      "speaker": "クイン",
      "ja": "そっか～、おじさんって性欲たまりまくっちゃってるって訳なんだ～♥",
      "zh": ""
    },
    {
      "key": "55.0",
      "line_index": 55,
      "inline_index": 0,
      "line_hash": "456a4af8",
      "speaker": "",
      "ja": "クインの言葉に俺は何も答えられず、顔が熱くなっていくのを感じる。",
      "zh": ""
    },
    {
      "key": "57.0",
      "line_index": 57,
      "inline_index": 0,
      "line_hash": "cbac8fe",
      "speaker": "",
      "ja": "それと同時に股間ではちんぽが大きくなってきていた。",
      "zh": ""
    },
    {
      "key": "59.0",
      "line_index": 59,
      "inline_index": 0,
      "line_hash": "4da0cfa1",
      "speaker": "",
      "ja": "クインはそんな俺の変化を目ざとく見つけるとまた囁きかけてくる。",
      "zh": ""
    },
    {
      "key": "64.0",
      "line_index": 64,
      "inline_index": 0,
      "line_hash": "77e1b83a",
      "speaker": "クイン",
      "ja": "あれ～？　おじさんのズボン、膨らんじゃってるよ～♥",
      "zh": ""
    },
    {
      "key": "64.2",
      "line_index": 64,
      "inline_index": 2,
      "line_hash": "77e1b83a",
      "speaker": "クイン",
      "ja": "もしかして私に欲情しちゃったのかな～♥　気持ち悪～い♥",
      "zh": ""
    },
    {
      "key": "66.0",
      "line_index": 66,
      "inline_index": 0,
      "line_hash": "23822b6d",
      "speaker": "",
      "ja": "蔑む言葉を投げかけられているのに、俺は妙にドキドキしてしまっていた。",
      "zh": ""
    },
    {
      "key": "68.0",
      "line_index": 68,
      "inline_index": 0,
      "line_hash": "bc8d5ac9",
      "speaker": "",
      "ja": "おかげで肉棒はさらに大きくなっていってしまう。",
      "zh": ""
    },
    {
      "key": "70.0",
      "line_index": 70,
      "inline_index": 0,
      "line_hash": "47984c32",
      "speaker": "",
      "ja": "そんな俺にすり寄ってきたクインはズボンの上から",
      "zh": ""
    },
    {
      "key": "70.2",
      "line_index": 70,
      "inline_index": 2,
      "line_hash": "47984c32",
      "speaker": "",
      "ja": "俺の膨らんだ股間を捏ね回すように撫でてきた。",
      "zh": ""
    },
    {
      "key": "73.0",
      "line_index": 73,
      "inline_index": 0,
      "line_hash": "c3c7fae0",
      "speaker": "{G_PlayerName}",
      "ja": "うっ……あっ……ちょっと……うぅぅっ……",
      "zh": ""
    },
    {
      "key": "76.0",
      "line_index": 76,
      "inline_index": 0,
      "line_hash": "a32a4a98",
      "speaker": "",
      "ja": "ペニスを刺激された俺は情けなく呻き声を漏らす。",
      "zh": ""
    },
    {
      "key": "78.0",
      "line_index": 78,
      "inline_index": 0,
      "line_hash": "375ef5af",
      "speaker": "",
      "ja": "クインは俺の反応を面白がるように手を動かしながら",
      "zh": ""
    },
    {
      "key": "78.2",
      "line_index": 78,
      "inline_index": 2,
      "line_hash": "375ef5af",
      "speaker": "",
      "ja": "耳に息を吹きかけながら囁きかけてきた。",
      "zh": ""
    },
    {
      "key": "83.0",
      "line_index": 83,
      "inline_index": 0,
      "line_hash": "fce11020",
      "speaker": "クイン",
      "ja": "もうおちんちんガッチガチじゃない♥　",
      "zh": ""
    },
    {
      "key": "83.2",
      "line_index": 83,
      "inline_index": 2,
      "line_hash": "fce11020",
      "speaker": "クイン",
      "ja": "おじさんって本当に変態なんだから♥",
      "zh": ""
    },
    {
      "key": "85.0",
      "line_index": 85,
      "inline_index": 0,
      "line_hash": "8c3ccfcc",
      "speaker": "",
      "ja": "その言葉に俺は返す言葉も見つからずただされるがままになっていた。",
      "zh": ""
    },
    {
      "key": "87.0",
      "line_index": 87,
      "inline_index": 0,
      "line_hash": "44c234",
      "speaker": "",
      "ja": "するとクインが俺のズボンとパンツに手をかけて",
      "zh": ""
    },
    {
      "key": "87.2",
      "line_index": 87,
      "inline_index": 2,
      "line_hash": "44c234",
      "speaker": "",
      "ja": "上目遣いで俺を見つめてくる。",
      "zh": ""
    },
    {
      "key": "92.0",
      "line_index": 92,
      "inline_index": 0,
      "line_hash": "aeb52c43",
      "speaker": "クイン",
      "ja": "これでもシスターだから～♥　きっも～いおじさんのおちんちん……",
      "zh": ""
    },
    {
      "key": "92.2",
      "line_index": 92,
      "inline_index": 2,
      "line_hash": "aeb52c43",
      "speaker": "クイン",
      "ja": "私が慰めてあげちゃおうか～？♥",
      "zh": ""
    },
    {
      "key": "94.0",
      "line_index": 94,
      "inline_index": 0,
      "line_hash": "153cf5bb",
      "speaker": "",
      "ja": "そう言うと何の躊躇もなく俺のズボンとパンツを一気にズリ下ろしてきた。",
      "zh": ""
    },
    {
      "key": "108.0",
      "line_index": 108,
      "inline_index": 0,
      "line_hash": "8b3bf569",
      "speaker": "クイン",
      "ja": "すんすんっ",
      "zh": ""
    },
    {
      "key": "110.0",
      "line_index": 110,
      "inline_index": 0,
      "line_hash": "1ff6f6c2",
      "speaker": "",
      "ja": "クインは露わになった俺のちんぽに顔を寄せると",
      "zh": ""
    },
    {
      "key": "110.2",
      "line_index": 110,
      "inline_index": 2,
      "line_hash": "1ff6f6c2",
      "speaker": "",
      "ja": "鼻を鳴らして匂いを嗅いでくる。",
      "zh": ""
    },
    {
      "key": "112.0",
      "line_index": 112,
      "inline_index": 0,
      "line_hash": "3b9792f5",
      "speaker": "",
      "ja": "そしてニヤニヤと笑いながら俺に告げてきた。",
      "zh": ""
    },
    {
      "key": "115.0",
      "line_index": 115,
      "inline_index": 0,
      "line_hash": "b7f2a4fa",
      "speaker": "クイン",
      "ja": "こ～んなにおちんちんにカス溜めちゃって♥　",
      "zh": ""
    },
    {
      "key": "115.2",
      "line_index": 115,
      "inline_index": 2,
      "line_hash": "b7f2a4fa",
      "speaker": "クイン",
      "ja": "すんすんっ……♥ くっさ～い♥　最悪な童貞チンポ♥",
      "zh": ""
    },
    {
      "key": "117.0",
      "line_index": 117,
      "inline_index": 0,
      "line_hash": "197dd74",
      "speaker": "",
      "ja": "俺のちんぽをマジマジと見ながらそう言ったクインは",
      "zh": ""
    },
    {
      "key": "117.2",
      "line_index": 117,
      "inline_index": 2,
      "line_hash": "197dd74",
      "speaker": "",
      "ja": "舌を突き出してちろちろと舐め始めてくる。",
      "zh": ""
    },
    {
      "key": "119.0",
      "line_index": 119,
      "inline_index": 0,
      "line_hash": "78441a77",
      "speaker": "",
      "ja": "生暖かい感触が亀頭に触れると、",
      "zh": ""
    },
    {
      "key": "119.2",
      "line_index": 119,
      "inline_index": 2,
      "line_hash": "78441a77",
      "speaker": "",
      "ja": "ゾクッとする快感が俺の股間から全身へと駆け抜けた。",
      "zh": ""
    },
    {
      "key": "122.0",
      "line_index": 122,
      "inline_index": 0,
      "line_hash": "9eb4a4ed",
      "speaker": "クイン",
      "ja": "チンカスがいっぱい♥　お手入れも出来ないなんて♥",
      "zh": ""
    },
    {
      "key": "124.0",
      "line_index": 124,
      "inline_index": 0,
      "line_hash": "6e1ca533",
      "speaker": "",
      "ja": "舐めながら小馬鹿にするような言葉を口にするクインに対して",
      "zh": ""
    },
    {
      "key": "124.2",
      "line_index": 124,
      "inline_index": 2,
      "line_hash": "6e1ca533",
      "speaker": "",
      "ja": "俺はどんな感情を抱けば良いのか。",
      "zh": ""
    },
    {
      "key": "126.0",
      "line_index": 126,
      "inline_index": 0,
      "line_hash": "171b8076",
      "speaker": "",
      "ja": "だけど舐められている事実は変わりないのでその刺激に",
      "zh": ""
    },
    {
      "key": "126.2",
      "line_index": 126,
      "inline_index": 2,
      "line_hash": "171b8076",
      "speaker": "",
      "ja": "俺のチンポは大きく反り返っていってしまった。",
      "zh": ""
    },
    {
      "key": "129.0",
      "line_index": 129,
      "inline_index": 0,
      "line_hash": "891ae779",
      "speaker": "クイン",
      "ja": "んふっ♥　ちょっと舐めただけでこんなにカウパーだだ漏れになって♥　",
      "zh": ""
    },
    {
      "key": "129.2",
      "line_index": 129,
      "inline_index": 2,
      "line_hash": "891ae779",
      "speaker": "クイン",
      "ja": "どんだけ溜めていたって感じだし♥",
      "zh": ""
    },
    {
      "key": "131.0",
      "line_index": 131,
      "inline_index": 0,
      "line_hash": "baf53149",
      "speaker": "",
      "ja": "彼女の言う通り勃起したペニスの先からは、",
      "zh": ""
    },
    {
      "key": "131.2",
      "line_index": 131,
      "inline_index": 2,
      "line_hash": "baf53149",
      "speaker": "",
      "ja": "ネットリとした我慢汁が後から後から溢れ出てきてしまっている。",
      "zh": ""
    },
    {
      "key": "133.0",
      "line_index": 133,
      "inline_index": 0,
      "line_hash": "f92d6c68",
      "speaker": "",
      "ja": "肉竿もビクンビクンと上下して今にも暴発してしまいそうだ。",
      "zh": ""
    },
    {
      "key": "136.0",
      "line_index": 136,
      "inline_index": 0,
      "line_hash": "ec66a43a",
      "speaker": "クイン",
      "ja": "もう出しちゃう？　びゅるるって出しちゃう？",
      "zh": ""
    },
    {
      "key": "138.0",
      "line_index": 138,
      "inline_index": 0,
      "line_hash": "ff3032f9",
      "speaker": "",
      "ja": "挑発するようなその言葉に、",
      "zh": ""
    },
    {
      "key": "138.2",
      "line_index": 138,
      "inline_index": 2,
      "line_hash": "ff3032f9",
      "speaker": "",
      "ja": "俺はすぐにでも射精しそうな感覚をグッと堪える。",
      "zh": ""
    },
    {
      "key": "140.0",
      "line_index": 140,
      "inline_index": 0,
      "line_hash": "41680b42",
      "speaker": "",
      "ja": "すると彼女は意味ありげな笑みを浮かべて呟いた。",
      "zh": ""
    },
    {
      "key": "143.0",
      "line_index": 143,
      "inline_index": 0,
      "line_hash": "edd203c9",
      "speaker": "クイン",
      "ja": "さてと……そろそろこのくっさい童貞チンポ、食べちゃおうかなぁ♥",
      "zh": ""
    },
    {
      "key": "145.0",
      "line_index": 145,
      "inline_index": 0,
      "line_hash": "41645905",
      "speaker": "",
      "ja": "クインはそう言うとおもむろに口を大きく開いて",
      "zh": ""
    },
    {
      "key": "145.2",
      "line_index": 145,
      "inline_index": 2,
      "line_hash": "41645905",
      "speaker": "",
      "ja": "剛直している俺のちんぽをぱっくりと咥え込んでくる。",
      "zh": ""
    },
    {
      "key": "153.0",
      "line_index": 153,
      "inline_index": 0,
      "line_hash": "90817c31",
      "speaker": "クイン",
      "ja": "あむぅぅ♥　んっ、んんんっ♥　んぐんぐっ♥　じゅるるっ♥",
      "zh": ""
    },
    {
      "key": "156.0",
      "line_index": 156,
      "inline_index": 0,
      "line_hash": "b5d4885c",
      "speaker": "{G_PlayerName}",
      "ja": "うっ……あぁぁぁ……そんな……くっ……ううっ……",
      "zh": ""
    },
    {
      "key": "159.0",
      "line_index": 159,
      "inline_index": 0,
      "line_hash": "67daf8ee",
      "speaker": "",
      "ja": "生暖かい感触に包まれた肉棒にねっとりとクインの舌が絡みついてくると",
      "zh": ""
    },
    {
      "key": "159.2",
      "line_index": 159,
      "inline_index": 2,
      "line_hash": "67daf8ee",
      "speaker": "",
      "ja": "まるで電気が走ったかのように俺の体がビクンと跳ねてしまった。",
      "zh": ""
    },
    {
      "key": "161.0",
      "line_index": 161,
      "inline_index": 0,
      "line_hash": "22c6e99",
      "speaker": "",
      "ja": "それ程までに彼女の舌使いはあまりにも気持ちよくて",
      "zh": ""
    },
    {
      "key": "161.2",
      "line_index": 161,
      "inline_index": 2,
      "line_hash": "22c6e99",
      "speaker": "",
      "ja": "足がガクガクと震え出す。",
      "zh": ""
    },
    {
      "key": "164.0",
      "line_index": 164,
      "inline_index": 0,
      "line_hash": "3c006adf",
      "speaker": "クイン",
      "ja": "ジュポッ♥　ジュポッ♥　グポッ♥　ブチュルル♥　ジュポジュプ♥",
      "zh": ""
    },
    {
      "key": "166.0",
      "line_index": 166,
      "inline_index": 0,
      "line_hash": "9610dce7",
      "speaker": "",
      "ja": "下品な音を立てながらクインが俺のちんぽを激しくしゃぶった。",
      "zh": ""
    },
    {
      "key": "168.0",
      "line_index": 168,
      "inline_index": 0,
      "line_hash": "3c49c2a",
      "speaker": "",
      "ja": "その音と淫らなフェラ顔に俺の心臓は一気に鼓動を速めて",
      "zh": ""
    },
    {
      "key": "168.2",
      "line_index": 168,
      "inline_index": 2,
      "line_hash": "3c49c2a",
      "speaker": "",
      "ja": "ちんぽもビクビクと小さく上下してしまう。",
      "zh": ""
    },
    {
      "key": "171.0",
      "line_index": 171,
      "inline_index": 0,
      "line_hash": "449ed494",
      "speaker": "クイン",
      "ja": "んっ、んんんっ♥　",
      "zh": ""
    },
    {
      "key": "171.2",
      "line_index": 171,
      "inline_index": 2,
      "line_hash": "449ed494",
      "speaker": "クイン",
      "ja": "タマタマも、こ～んなに重くなってる～♥　んじゅるっ♥",
      "zh": ""
    },
    {
      "key": "173.0",
      "line_index": 173,
      "inline_index": 0,
      "line_hash": "7cff6d51",
      "speaker": "",
      "ja": "彼女の小さい手が俺の陰嚢を弄びペニスの先を転がすように舐め回した。",
      "zh": ""
    },
    {
      "key": "175.0",
      "line_index": 175,
      "inline_index": 0,
      "line_hash": "c3fd6a08",
      "speaker": "",
      "ja": "その刺激に俺は腰を小さく震わせてしまい、",
      "zh": ""
    },
    {
      "key": "175.2",
      "line_index": 175,
      "inline_index": 2,
      "line_hash": "c3fd6a08",
      "speaker": "",
      "ja": "ちんぽからは大量のカウパーが溢れ出してしまう。",
      "zh": ""
    },
    {
      "key": "178.0",
      "line_index": 178,
      "inline_index": 0,
      "line_hash": "a76bd389",
      "speaker": "クイン",
      "ja": "ねえ、出したい？　こんなに我慢汁漏らしちゃって♥　",
      "zh": ""
    },
    {
      "key": "178.2",
      "line_index": 178,
      "inline_index": 2,
      "line_hash": "a76bd389",
      "speaker": "クイン",
      "ja": "んちゅるるっ♥　んっ、んじゅるっ♥　",
      "zh": ""
    },
    {
      "key": "178.4",
      "line_index": 178,
      "inline_index": 4,
      "line_hash": "a76bd389",
      "speaker": "クイン",
      "ja": "びゅ～ってエッチなお汁出したいの～♥",
      "zh": ""
    },
    {
      "key": "180.0",
      "line_index": 180,
      "inline_index": 0,
      "line_hash": "c1207950",
      "speaker": "",
      "ja": "クインは俺を嘲笑しながら更に激しく俺のチンポを吸ってきた。",
      "zh": ""
    },
    {
      "key": "182.0",
      "line_index": 182,
      "inline_index": 0,
      "line_hash": "fb06f0b",
      "speaker": "",
      "ja": "そして溢れ出ているカウパーを舐め取りながら睾丸を転がすようにいじる。",
      "zh": ""
    },
    {
      "key": "185.0",
      "line_index": 185,
      "inline_index": 0,
      "line_hash": "3062a684",
      "speaker": "{G_PlayerName}",
      "ja": "ああ……も、もう……で、出る……",
      "zh": ""
    },
    {
      "key": "188.0",
      "line_index": 188,
      "inline_index": 0,
      "line_hash": "a4bb1358",
      "speaker": "",
      "ja": "まるで搾り取ろうとするようなその刺激に、",
      "zh": ""
    },
    {
      "key": "188.2",
      "line_index": 188,
      "inline_index": 2,
      "line_hash": "a4bb1358",
      "speaker": "",
      "ja": "たまらず俺は絶頂に達してしまった。",
      "zh": ""
    },
    {
      "key": "199.0",
      "line_index": 199,
      "inline_index": 0,
      "line_hash": "9a937697",
      "speaker": "クイン",
      "ja": "ぶびゅッ♥",
      "zh": ""
    },
    {
      "key": "201.0",
      "line_index": 201,
      "inline_index": 0,
      "line_hash": "b9ecd8dc",
      "speaker": "",
      "ja": "俺がクインの口の中に大量の精液を吐き出すと、",
      "zh": ""
    },
    {
      "key": "201.2",
      "line_index": 201,
      "inline_index": 2,
      "line_hash": "b9ecd8dc",
      "speaker": "",
      "ja": "何とも言えない声が上がる。",
      "zh": ""
    },
    {
      "key": "203.0",
      "line_index": 203,
      "inline_index": 0,
      "line_hash": "1ac4829e",
      "speaker": "",
      "ja": "それでも彼女はちんぽを咥えたまま、",
      "zh": ""
    },
    {
      "key": "203.2",
      "line_index": 203,
      "inline_index": 2,
      "line_hash": "1ac4829e",
      "speaker": "",
      "ja": "断続的に出てしまう精液を喉を鳴らして飲み下した。",
      "zh": ""
    },
    {
      "key": "206.0",
      "line_index": 206,
      "inline_index": 0,
      "line_hash": "63fb2504",
      "speaker": "クイン",
      "ja": "んゅぎゅ♥　ごくん……♥　ごくん……♥",
      "zh": ""
    },
    {
      "key": "208.0",
      "line_index": 208,
      "inline_index": 0,
      "line_hash": "5bed7df1",
      "speaker": "",
      "ja": "イヤらしく精液を飲むクインの姿に興奮した俺は、何度も射精を繰り返す。",
      "zh": ""
    },
    {
      "key": "211.0",
      "line_index": 211,
      "inline_index": 0,
      "line_hash": "5d35ad11",
      "speaker": "クイン",
      "ja": "ごほっ♥　ごほぉっ♥　おじさん、出し過ぎ♥　んぐんぐっじゅるるっ♥",
      "zh": ""
    },
    {
      "key": "213.0",
      "line_index": 213,
      "inline_index": 0,
      "line_hash": "5fa4290b",
      "speaker": "",
      "ja": "あまりの量にクインは少しむせながらも",
      "zh": ""
    },
    {
      "key": "213.2",
      "line_index": 213,
      "inline_index": 2,
      "line_hash": "5fa4290b",
      "speaker": "",
      "ja": "俺が出した精液を一滴残らす飲み干した。",
      "zh": ""
    },
    {
      "key": "215.0",
      "line_index": 215,
      "inline_index": 0,
      "line_hash": "ef4db3b5",
      "speaker": "",
      "ja": "でも彼女は俺のちんぽから口を離すことなく",
      "zh": ""
    },
    {
      "key": "215.2",
      "line_index": 215,
      "inline_index": 2,
      "line_hash": "ef4db3b5",
      "speaker": "",
      "ja": "再び口全体で激しくしゃぶり始める。",
      "zh": ""
    },
    {
      "key": "223.0",
      "line_index": 223,
      "inline_index": 0,
      "line_hash": "602c1bbf",
      "speaker": "クイン",
      "ja": "ジュポッ♥　グポッ♥　じゅるるッ♥",
      "zh": ""
    },
    {
      "key": "225.0",
      "line_index": 225,
      "inline_index": 0,
      "line_hash": "435fd2f3",
      "speaker": "",
      "ja": "わざとこんなにもイヤらしくて",
      "zh": ""
    },
    {
      "key": "225.2",
      "line_index": 225,
      "inline_index": 2,
      "line_hash": "435fd2f3",
      "speaker": "",
      "ja": "下品な音を立てているんじゃないかと思えるくらい",
      "zh": ""
    },
    {
      "key": "225.4",
      "line_index": 225,
      "inline_index": 4,
      "line_hash": "435fd2f3",
      "speaker": "",
      "ja": "クインのフェラチオは激しくて淫らな感じだった。",
      "zh": ""
    },
    {
      "key": "227.0",
      "line_index": 227,
      "inline_index": 0,
      "line_hash": "b6e0618b",
      "speaker": "",
      "ja": "それを目の当たりにした俺は出したばかりなのに",
      "zh": ""
    },
    {
      "key": "227.2",
      "line_index": 227,
      "inline_index": 2,
      "line_hash": "b6e0618b",
      "speaker": "",
      "ja": "またペニスが剛直していく。",
      "zh": ""
    },
    {
      "key": "230.0",
      "line_index": 230,
      "inline_index": 0,
      "line_hash": "3ea7594d",
      "speaker": "クイン",
      "ja": "ど～ぉ？　射精したばっかりのビンカンなおちんちん♥　",
      "zh": ""
    },
    {
      "key": "230.2",
      "line_index": 230,
      "inline_index": 2,
      "line_hash": "3ea7594d",
      "speaker": "クイン",
      "ja": "ジュポジュポってフェラチオされちゃうの～♥",
      "zh": ""
    },
    {
      "key": "232.0",
      "line_index": 232,
      "inline_index": 0,
      "line_hash": "1e907b97",
      "speaker": "",
      "ja": "確かに射精したばかりの俺のペニスはかなり敏感になっているようで",
      "zh": ""
    },
    {
      "key": "232.2",
      "line_index": 232,
      "inline_index": 2,
      "line_hash": "1e907b97",
      "speaker": "",
      "ja": "彼女の舌使いがさっきよりも生々しい。",
      "zh": ""
    },
    {
      "key": "235.0",
      "line_index": 235,
      "inline_index": 0,
      "line_hash": "1a4dca6a",
      "speaker": "クイン",
      "ja": "んっぐんっぐ♥　じゅるるっ♥　んふぅぅ♥　",
      "zh": ""
    },
    {
      "key": "235.2",
      "line_index": 235,
      "inline_index": 2,
      "line_hash": "1a4dca6a",
      "speaker": "クイン",
      "ja": "弱々の童貞ペニス♥　ちゅるる♥　んっ、んんっ♥　",
      "zh": ""
    },
    {
      "key": "235.4",
      "line_index": 235,
      "inline_index": 4,
      "line_hash": "1a4dca6a",
      "speaker": "クイン",
      "ja": "またすぐに射精しちゃうかなぁ♥",
      "zh": ""
    },
    {
      "key": "237.0",
      "line_index": 237,
      "inline_index": 0,
      "line_hash": "de7c8ece",
      "speaker": "",
      "ja": "からかうようなクインの言葉に、",
      "zh": ""
    },
    {
      "key": "237.2",
      "line_index": 237,
      "inline_index": 2,
      "line_hash": "de7c8ece",
      "speaker": "",
      "ja": "俺は何も返せずにただ悶えるしかなかった。",
      "zh": ""
    },
    {
      "key": "239.0",
      "line_index": 239,
      "inline_index": 0,
      "line_hash": "ef967373",
      "speaker": "",
      "ja": "そんな俺を弄ぶようにクインの舌が",
      "zh": ""
    },
    {
      "key": "239.2",
      "line_index": 239,
      "inline_index": 2,
      "line_hash": "ef967373",
      "speaker": "",
      "ja": "淫らに蠢き裏筋から亀頭までを丹念にしゃぶる。",
      "zh": ""
    },
    {
      "key": "242.0",
      "line_index": 242,
      "inline_index": 0,
      "line_hash": "671d03e1",
      "speaker": "クイン",
      "ja": "ちゅるる♥　んちゅぅ♥　うっ、むふぅぅ♥　じゅるっ、んぐふぅぅ♥",
      "zh": ""
    },
    {
      "key": "244.0",
      "line_index": 244,
      "inline_index": 0,
      "line_hash": "4f0777dc",
      "speaker": "",
      "ja": "さっき出したばかりなのに俺はまた込み上げてくる感覚に襲われた。",
      "zh": ""
    },
    {
      "key": "247.0",
      "line_index": 247,
      "inline_index": 0,
      "line_hash": "f5ea3484",
      "speaker": "クイン",
      "ja": "もうおちんちんビックンビックンしちゃってる♥　んちゅぅぅ♥　",
      "zh": ""
    },
    {
      "key": "247.2",
      "line_index": 247,
      "inline_index": 2,
      "line_hash": "f5ea3484",
      "speaker": "クイン",
      "ja": "じゅるるっ♥　本当に弱々おちんちんなんだから♥　ちゅるるっ♥",
      "zh": ""
    },
    {
      "key": "249.0",
      "line_index": 249,
      "inline_index": 0,
      "line_hash": "8accc1b0",
      "speaker": "",
      "ja": "どんどん激しくなるクインのフェラチオに",
      "zh": ""
    },
    {
      "key": "249.2",
      "line_index": 249,
      "inline_index": 2,
      "line_hash": "8accc1b0",
      "speaker": "",
      "ja": "俺はもう我慢できなくなってしまう。",
      "zh": ""
    },
    {
      "key": "251.0",
      "line_index": 251,
      "inline_index": 0,
      "line_hash": "ddce37a",
      "speaker": "",
      "ja": "俺は堪えきれずにまたクインの口の中に精液をぶちまけてしまう。",
      "zh": ""
    },
    {
      "key": "262.0",
      "line_index": 262,
      "inline_index": 0,
      "line_hash": "5aa75e6d",
      "speaker": "クイン",
      "ja": "ん゛ん゛ん゛ッ♥",
      "zh": ""
    },
    {
      "key": "264.0",
      "line_index": 264,
      "inline_index": 0,
      "line_hash": "366017f5",
      "speaker": "",
      "ja": "俺のペニスから発射されるザーメンを",
      "zh": ""
    },
    {
      "key": "264.2",
      "line_index": 264,
      "inline_index": 2,
      "line_hash": "366017f5",
      "speaker": "",
      "ja": "クインはまたなんの躊躇もなく飲んでいった。",
      "zh": ""
    },
    {
      "key": "267.0",
      "line_index": 267,
      "inline_index": 0,
      "line_hash": "63fb2504",
      "speaker": "クイン",
      "ja": "んゅぎゅ♥　ごくん……♥　ごくん……♥",
      "zh": ""
    },
    {
      "key": "269.0",
      "line_index": 269,
      "inline_index": 0,
      "line_hash": "626e31a4",
      "speaker": "",
      "ja": "音を立てながら精液を飲むその姿に興奮が高まり、",
      "zh": ""
    },
    {
      "key": "269.2",
      "line_index": 269,
      "inline_index": 2,
      "line_hash": "626e31a4",
      "speaker": "",
      "ja": "俺は何度も射精を続ける。",
      "zh": ""
    },
    {
      "key": "272.0",
      "line_index": 272,
      "inline_index": 0,
      "line_hash": "77af91dd",
      "speaker": "クイン",
      "ja": "んっぷっ♥　まだ出て……んっ、んんんっ♥　んじゅるっ♥　ごきゅぅ♥",
      "zh": ""
    },
    {
      "key": "274.0",
      "line_index": 274,
      "inline_index": 0,
      "line_hash": "2dfe32f4",
      "speaker": "",
      "ja": "２回目の射精なのにどれだけ出るんだと自分でも思うぐらい",
      "zh": ""
    },
    {
      "key": "274.2",
      "line_index": 274,
      "inline_index": 2,
      "line_hash": "2dfe32f4",
      "speaker": "",
      "ja": "俺はクインの口の中に大量のザーメンを出しきって果てた。",
      "zh": ""
    },
    {
      "key": "280.0",
      "line_index": 280,
      "inline_index": 0,
      "line_hash": "8569ae6f",
      "speaker": "クイン",
      "ja": "んはぁ……♥　はぁ……♥　ぷはぁ……♥　全然飲みきれなかった～♥　",
      "zh": ""
    },
    {
      "key": "280.2",
      "line_index": 280,
      "inline_index": 2,
      "line_hash": "8569ae6f",
      "speaker": "クイン",
      "ja": "んれぇ～♥　こんなに大量のザーメンぶちまけちゃうとか……　",
      "zh": ""
    },
    {
      "key": "280.4",
      "line_index": 280,
      "inline_index": 4,
      "line_hash": "8569ae6f",
      "speaker": "クイン",
      "ja": "ロリコンおじさん、出し過ぎ～♥",
      "zh": ""
    },
    {
      "key": "282.0",
      "line_index": 282,
      "inline_index": 0,
      "line_hash": "6b9842d5",
      "speaker": "",
      "ja": "まるで俺に見せつけるようにクインは舌を出した。",
      "zh": ""
    },
    {
      "key": "284.0",
      "line_index": 284,
      "inline_index": 0,
      "line_hash": "1746ce5",
      "speaker": "",
      "ja": "その舌の上には俺が出したばかりの精液がのっていて、",
      "zh": ""
    },
    {
      "key": "284.2",
      "line_index": 284,
      "inline_index": 2,
      "line_hash": "1746ce5",
      "speaker": "",
      "ja": "とろりと滴り落ちていく。",
      "zh": ""
    },
    {
      "key": "286.0",
      "line_index": 286,
      "inline_index": 0,
      "line_hash": "fd97c5f0",
      "speaker": "",
      "ja": "そんなのを見せつけられた俺のちんぽは",
      "zh": ""
    },
    {
      "key": "286.2",
      "line_index": 286,
      "inline_index": 2,
      "line_hash": "fd97c5f0",
      "speaker": "",
      "ja": "ビクンと小さく跳ねてしまうがもう１滴たりとも溢れ出てこない。",
      "zh": ""
    },
    {
      "key": "289.0",
      "line_index": 289,
      "inline_index": 0,
      "line_hash": "31aef75f",
      "speaker": "クイン",
      "ja": "あ～あ♥　タマタマ、きゅ～って窄んじゃったね♥　",
      "zh": ""
    },
    {
      "key": "289.2",
      "line_index": 289,
      "inline_index": 2,
      "line_hash": "31aef75f",
      "speaker": "クイン",
      "ja": "さすがに出し過ぎちゃった～？♥",
      "zh": ""
    },
    {
      "key": "291.0",
      "line_index": 291,
      "inline_index": 0,
      "line_hash": "62fff7db",
      "speaker": "",
      "ja": "からかうようなクインの言葉に、俺は何も言えずに荒い息を漏らし続ける。",
      "zh": ""
    },
    {
      "key": "293.0",
      "line_index": 293,
      "inline_index": 0,
      "line_hash": "cc3c5129",
      "speaker": "",
      "ja": "クインはそんな俺をニヤニヤしながら見つめながら耳元に囁きかけてきた。",
      "zh": ""
    },
    {
      "key": "296.0",
      "line_index": 296,
      "inline_index": 0,
      "line_hash": "327f31be",
      "speaker": "クイン",
      "ja": "それじゃあ、今日の懺悔はここまで……♥　",
      "zh": ""
    },
    {
      "key": "296.2",
      "line_index": 296,
      "inline_index": 2,
      "line_hash": "327f31be",
      "speaker": "クイン",
      "ja": "気が向いたらまたロリコンおじさんのザーメン搾り取ってあげる♥",
      "zh": ""
    },
    {
      "key": "298.0",
      "line_index": 298,
      "inline_index": 0,
      "line_hash": "660ed641",
      "speaker": "",
      "ja": "そんな言葉を残してクインは懺悔室から去って行く。",
      "zh": ""
    },
    {
      "key": "300.0",
      "line_index": 300,
      "inline_index": 0,
      "line_hash": "922f5b89",
      "speaker": "",
      "ja": "取り残された俺はしばし懺悔室の中で呆然としてしまっていた。",
      "zh": ""
    }
  ]
}
