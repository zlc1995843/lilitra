{
  "lines": [
    {
      "key": "15.1",
      "line_index": 15,
      "inline_index": 1,
      "line_hash": "d8da56a6",
      "speaker": "ラチャナ",
      "ja": "ぷはぁっ♥　はぁ～っ♥　はぁ～っ♥　はーっ♥　や、やっとおぬしの射精したの全部飲み込めたぞ……♥",
      "zh": ""
    },
    {
      "key": "18.1",
      "line_index": 18,
      "inline_index": 1,
      "line_hash": "a2368f5c",
      "speaker": "ラチャナ",
      "ja": "まったく……治療には必要なこととは言え射精しすぎじゃ、バカ者が……♥",
      "zh": ""
    },
    {
      "key": "21.0",
      "line_index": 21,
      "inline_index": 0,
      "line_hash": "b1464d2d",
      "speaker": "{G_PlayerName}",
      "ja": "ラチャナっ！",
      "zh": ""
    },
    {
      "key": "27.1",
      "line_index": 27,
      "inline_index": 1,
      "line_hash": "2deadc98",
      "speaker": "ラチャナ",
      "ja": "うわぁっ！？　どっ、どうしたのじゃっ、いきなり押し倒して……！",
      "zh": ""
    },
    {
      "key": "29.0",
      "line_index": 29,
      "inline_index": 0,
      "line_hash": "f3c6710d",
      "speaker": "",
      "ja": "{G_PlayerName}の精液をすべて飲み干したラチャナは、完全にスイッチの入った{G_PlayerName}に押し倒されてしまう。",
      "zh": ""
    },
    {
      "key": "30.0",
      "line_index": 30,
      "inline_index": 0,
      "line_hash": "d26034df",
      "speaker": "",
      "ja": "ラチャナの小さな身体が砂浜の上に横たわる。",
      "zh": ""
    },
    {
      "key": "33.0",
      "line_index": 33,
      "inline_index": 0,
      "line_hash": "24de0084",
      "speaker": "{G_PlayerName}",
      "ja": "次は二人で一緒に気持ち良くなろう……！",
      "zh": ""
    },
    {
      "key": "39.1",
      "line_index": 39,
      "inline_index": 1,
      "line_hash": "ca17b565",
      "speaker": "ラチャナ",
      "ja": "ふあっ！？♥　な、なんだかそなたのおちんちん、さっきより大きくなっておらぬか！？♥",
      "zh": ""
    },
    {
      "key": "42.0",
      "line_index": 42,
      "inline_index": 0,
      "line_hash": "51be4b35",
      "speaker": "{G_PlayerName}",
      "ja": "ラチャナがエッチすぎて収まるわけないだろ！",
      "zh": ""
    },
    {
      "key": "46.1",
      "line_index": 46,
      "inline_index": 1,
      "line_hash": "a814c2c3",
      "speaker": "ラチャナ",
      "ja": "ワシのせいだと言うのかっ！？♥",
      "zh": ""
    },
    {
      "key": "49.0",
      "line_index": 49,
      "inline_index": 0,
      "line_hash": "b9ebf839",
      "speaker": "{G_PlayerName}",
      "ja": "いや、そうじゃないけどっ！　でも交尾、してもいいだろ！？　ラチャナもこんなに濡れてるぞ！",
      "zh": ""
    },
    {
      "key": "52.0",
      "line_index": 52,
      "inline_index": 0,
      "line_hash": "ae770d25",
      "speaker": "",
      "ja": "俺がラチャナの股間を触ると、ぐちゃりと水着の中から濡れた音がする。",
      "zh": ""
    },
    {
      "key": "57.1",
      "line_index": 57,
      "inline_index": 1,
      "line_hash": "2ddd916c",
      "speaker": "ラチャナ",
      "ja": "んひぃっ！♥　こ、こりゃ、勝手に触るなぁっ♥",
      "zh": ""
    },
    {
      "key": "60.0",
      "line_index": 60,
      "inline_index": 0,
      "line_hash": "7903309b",
      "speaker": "{G_PlayerName}",
      "ja": "俺はラチャナと一つになりたい……！　ラチャナ、だめか……？",
      "zh": ""
    },
    {
      "key": "64.1",
      "line_index": 64,
      "inline_index": 1,
      "line_hash": "ae6e2659",
      "speaker": "ラチャナ",
      "ja": "（うう……またこやつと交尾を……？　いかん、お股の奥が疼いてしまう……！♥　ワシはこやつのおちんちんを求めておるのか……？♥）",
      "zh": ""
    },
    {
      "key": "66.0",
      "line_index": 66,
      "inline_index": 0,
      "line_hash": "6b387515",
      "speaker": "",
      "ja": "{G_PlayerName}はラチャナの制止も聞かずに割れ目にそっと肉棒を押し当てる。",
      "zh": ""
    },
    {
      "key": "69.1",
      "line_index": 69,
      "inline_index": 1,
      "line_hash": "4b510dd8",
      "speaker": "ラチャナ",
      "ja": "う、あ……！♥　あ、熱……！♥　そなたのものすごく熱くなっておる……！♥　こんなモノを挿れられたらワシのお股が火傷してしまうぞ……！♥",
      "zh": ""
    },
    {
      "key": "72.0",
      "line_index": 72,
      "inline_index": 0,
      "line_hash": "4dc935d6",
      "speaker": "{G_PlayerName}",
      "ja": "大丈夫、ラチャナの中も同じくらい熱いから……！",
      "zh": ""
    },
    {
      "key": "75.0",
      "line_index": 75,
      "inline_index": 0,
      "line_hash": "c6e4fa53",
      "speaker": "",
      "ja": "そして肉棒を小さな膣穴に押し込もうとした瞬間──",
      "zh": ""
    },
    {
      "key": "78.0",
      "line_index": 78,
      "inline_index": 0,
      "line_hash": "986b704",
      "speaker": "リリアンＡ",
      "ja": "──今日もあっついね～♪　でもこんなに日差しが強いとこんがりと日焼けできるかな？",
      "zh": ""
    },
    {
      "key": "81.0",
      "line_index": 81,
      "inline_index": 0,
      "line_hash": "b9544578",
      "speaker": "リリアンＢ",
      "ja": "んー……あたしはあんま焼きたくないな～。ヒリヒリしちゃうし、あとが残っちゃうかもしれないしさぁ",
      "zh": ""
    },
    {
      "key": "83.0",
      "line_index": 83,
      "inline_index": 0,
      "line_hash": "81720b2b",
      "speaker": "",
      "ja": "遠くの方からリリアンの声が聞こえてきた。",
      "zh": ""
    },
    {
      "key": "97.0",
      "line_index": 97,
      "inline_index": 0,
      "line_hash": "3acd6e30",
      "speaker": "",
      "ja": "しかし{G_PlayerName}はそんな声を意に返さず肉棒を押し込もうと腰に力を入れる。",
      "zh": ""
    },
    {
      "key": "100.0",
      "line_index": 100,
      "inline_index": 0,
      "line_hash": "e93c190",
      "speaker": "ラチャナ",
      "ja": "まっ、待つのじゃ……！　近くに人がおる……！　こんなところで一つになったら声が聞こえてしまう……！",
      "zh": ""
    },
    {
      "key": "103.0",
      "line_index": 103,
      "inline_index": 0,
      "line_hash": "6bdc0c88",
      "speaker": "ラチャナ",
      "ja": "後でなら構わぬ！　今はやめるのじゃ……！",
      "zh": ""
    },
    {
      "key": "106.0",
      "line_index": 106,
      "inline_index": 0,
      "line_hash": "b471bf60",
      "speaker": "{G_PlayerName}",
      "ja": "大丈夫……この距離なら大きな声を出さなければ気づかれないって",
      "zh": ""
    },
    {
      "key": "110.0",
      "line_index": 110,
      "inline_index": 0,
      "line_hash": "84613083",
      "speaker": "ラチャナ",
      "ja": "そ、そんなのムリじゃ……！　そなたとの子作りをすると勝手に声が出てしまうのじゃ……♥",
      "zh": ""
    },
    {
      "key": "113.0",
      "line_index": 113,
      "inline_index": 0,
      "line_hash": "580feca6",
      "speaker": "ラチャナ",
      "ja": "（うう……身体が動かぬ……♥　本来であれば、リリアンの力でこやつを跳ねのけることができるのに……♥）",
      "zh": ""
    },
    {
      "key": "116.0",
      "line_index": 116,
      "inline_index": 0,
      "line_hash": "bf0a73f4",
      "speaker": "ラチャナ",
      "ja": "（こやつの熱いまなざしがワシから抵抗する意思を奪うのじゃ……♥　ワシはこやつに強引に求められることを望んでおったのか……？♥）",
      "zh": ""
    },
    {
      "key": "119.0",
      "line_index": 119,
      "inline_index": 0,
      "line_hash": "6854ff0c",
      "speaker": "ラチャナ",
      "ja": "（腹の奥が……また疼いて……♥　きゅんきゅんが止まらぬ……♥　ダメなのに……こやつを一つになりたいって思い始めてしまっておるぅ……♥）",
      "zh": ""
    },
    {
      "key": "121.0",
      "line_index": 121,
      "inline_index": 0,
      "line_hash": "269ff0",
      "speaker": "",
      "ja": "ラチャナは最初こそ強い抵抗を示していたが、今はウソのように大人しくなってしまう。",
      "zh": ""
    },
    {
      "key": "122.0",
      "line_index": 122,
      "inline_index": 0,
      "line_hash": "7ef39426",
      "speaker": "",
      "ja": "{G_PlayerName}はチャンスとばかりに腰をゆっくりと沈めていく。",
      "zh": ""
    },
    {
      "key": "125.0",
      "line_index": 125,
      "inline_index": 0,
      "line_hash": "8a75e3a8",
      "speaker": "ラチャナ",
      "ja": "あ、ああ……っ！♥　んぅ……っ♥",
      "zh": ""
    },
    {
      "key": "128.0",
      "line_index": 128,
      "inline_index": 0,
      "line_hash": "1387ff61",
      "speaker": "ラチャナ",
      "ja": "わ、分かった、交尾を許す……！♥　だが、静かに、じゃぞ……！？♥　ゆっくり、ゆっくり動くのじゃ……♥",
      "zh": ""
    },
    {
      "key": "136.0",
      "line_index": 136,
      "inline_index": 0,
      "line_hash": "bebbebc7",
      "speaker": "ラチャナ",
      "ja": "あ……！♥　んは、はぁ……う、んぅぅぅ……！♥　ふぅ、ふぅ……！♥",
      "zh": ""
    },
    {
      "key": "138.0",
      "line_index": 138,
      "inline_index": 0,
      "line_hash": "cfa4a623",
      "speaker": "",
      "ja": "亀頭を膣の中に押し込めると、肉棒を招き入れいるようにずるりとラチャナのあそこに挿ってしまう。",
      "zh": ""
    },
    {
      "key": "139.0",
      "line_index": 139,
      "inline_index": 0,
      "line_hash": "dc31c308",
      "speaker": "",
      "ja": "ただでさえ狭い膣が肉棒をぎゅっと締め付け、そして夏の日差しにも負けないほど熱くなっている膣中。",
      "zh": ""
    },
    {
      "key": "141.0",
      "line_index": 141,
      "inline_index": 0,
      "line_hash": "afe64972",
      "speaker": "",
      "ja": "とろとろの愛液が肉棒に絡み、ゆっくりと腰を揺らすだけで気持ち良さに全身が震え上がる。",
      "zh": ""
    },
    {
      "key": "144.0",
      "line_index": 144,
      "inline_index": 0,
      "line_hash": "d8d95b99",
      "speaker": "ラチャナ",
      "ja": "そなたの……中でもっと大きく……♥　ああぁぁ……ワシのお股、広げられてるぅ……♥　はぁぁ……♥",
      "zh": ""
    },
    {
      "key": "146.0",
      "line_index": 146,
      "inline_index": 0,
      "line_hash": "83e0f5a",
      "speaker": "",
      "ja": "肉棒を収めた下腹部がぽっこりと膨らみ、それを見るだけでラチャナと一つになっていることを強く実感できる。",
      "zh": ""
    },
    {
      "key": "149.0",
      "line_index": 149,
      "inline_index": 0,
      "line_hash": "7c69cacb",
      "speaker": "ラチャナ",
      "ja": "ふー……っ♥　ふー……っ♥　うっ、あぁ……っ♥　ん、くぅ……っ♥",
      "zh": ""
    },
    {
      "key": "151.0",
      "line_index": 151,
      "inline_index": 0,
      "line_hash": "43949f75",
      "speaker": "",
      "ja": "ラチャナは必死に声を押し殺し、{G_PlayerName}を受け入れている。",
      "zh": ""
    },
    {
      "key": "154.0",
      "line_index": 154,
      "inline_index": 0,
      "line_hash": "a41da576",
      "speaker": "{G_PlayerName}",
      "ja": "はぁあ……！　ラチャナ、気持ちいい……っ、気持ち良くてちんこ、溶けそうだ……！",
      "zh": ""
    },
    {
      "key": "158.0",
      "line_index": 158,
      "inline_index": 0,
      "line_hash": "b7c34680",
      "speaker": "ラチャナ",
      "ja": "こ、これ……！　静かにせぬか……！　黙って腰を振るのじゃ……お゛うぅ！？♥",
      "zh": ""
    },
    {
      "key": "161.0",
      "line_index": 161,
      "inline_index": 0,
      "line_hash": "fb4d395a",
      "speaker": "ラチャナ",
      "ja": "んん、ま、待て奥をそんなに突くでないぃ……！♥　声が出てしまうっ！♥　あっ、あっ！♥",
      "zh": ""
    },
    {
      "key": "164.0",
      "line_index": 164,
      "inline_index": 0,
      "line_hash": "265700db",
      "speaker": "ラチャナ",
      "ja": "やはり近くに人がいる状況で……んぐっ！♥　子作りはムリじゃ……！♥",
      "zh": ""
    },
    {
      "key": "167.0",
      "line_index": 167,
      "inline_index": 0,
      "line_hash": "af619400",
      "speaker": "ラチャナ",
      "ja": "あとでいくらでもしていいから、今はここまでにするのじゃ……ぐっ！♥",
      "zh": ""
    },
    {
      "key": "170.0",
      "line_index": 170,
      "inline_index": 0,
      "line_hash": "26ee792c",
      "speaker": "{G_PlayerName}",
      "ja": "ごめん、無理……！　止まれない……！！　ラチャナでもっと気持ち良くなりたい……！　ラチャナをもっと気持ち良くさせたい……！！",
      "zh": ""
    },
    {
      "key": "174.0",
      "line_index": 174,
      "inline_index": 0,
      "line_hash": "3b379bd8",
      "speaker": "ラチャナ",
      "ja": "あぐっ！♥　んっ、んおっ！♥　ほぉぉっ！！♥　や、やめ……奥ばかりぃ……はおおっ！！♥",
      "zh": ""
    },
    {
      "key": "176.0",
      "line_index": 176,
      "inline_index": 0,
      "line_hash": "4d11f5c1",
      "speaker": "",
      "ja": "ラチャナの声、ラチャナの感じる仕草、ラチャナの締まる膣、そのどれもが目の前の男を高ぶらせる。",
      "zh": ""
    },
    {
      "key": "178.0",
      "line_index": 178,
      "inline_index": 0,
      "line_hash": "740efab9",
      "speaker": "",
      "ja": "もはや自分でも抑えられないくらい腰が早くなり、狭い膣を掻き回す卑猥な音がどんどん強くなっていく。",
      "zh": ""
    },
    {
      "key": "180.0",
      "line_index": 180,
      "inline_index": 0,
      "line_hash": "35a77758",
      "speaker": "",
      "ja": "必死に声を抑えるラチャナがより火を付け、執拗に膣奥を肉棒で叩きつけてしまう。",
      "zh": ""
    },
    {
      "key": "183.0",
      "line_index": 183,
      "inline_index": 0,
      "line_hash": "f31f83f7",
      "speaker": "ラチャナ",
      "ja": "このバカ者が……！♥　そなたというヤツは……んんんっ！♥　ワシとの子作り、見られてもよいのかっ！？♥",
      "zh": ""
    },
    {
      "key": "186.0",
      "line_index": 186,
      "inline_index": 0,
      "line_hash": "a4b4184d",
      "speaker": "{G_PlayerName}",
      "ja": "ッラチャナ、イくっ、イくぞっ！",
      "zh": ""
    },
    {
      "key": "190.0",
      "line_index": 190,
      "inline_index": 0,
      "line_hash": "7cb4e851",
      "speaker": "ラチャナ",
      "ja": "イヤっ、イヤじゃイヤじゃぁ……！♥　こんな恥ずかしいところ、誰にも見られとうないぃっ！♥",
      "zh": ""
    },
    {
      "key": "193.0",
      "line_index": 193,
      "inline_index": 0,
      "line_hash": "6346ca9a",
      "speaker": "{G_PlayerName}",
      "ja": "ラチャナも一緒に……！　ラチャナの本気イキマンコの中に射精させてくれっ！♥",
      "zh": ""
    },
    {
      "key": "197.0",
      "line_index": 197,
      "inline_index": 0,
      "line_hash": "90537271",
      "speaker": "ラチャナ",
      "ja": "ひぃいっ！♥　ああ゛っ！♥　おぐぅ！♥　おぐっ、ら゛めぇっ！♥",
      "zh": ""
    },
    {
      "key": "199.0",
      "line_index": 199,
      "inline_index": 0,
      "line_hash": "1fa17acd",
      "speaker": "",
      "ja": "子宮口をどちゅっと勢いよく突くたびに膣がぎゅっと締まり、大量の愛液が子宮口から流れ込んでくる。",
      "zh": ""
    },
    {
      "key": "201.0",
      "line_index": 201,
      "inline_index": 0,
      "line_hash": "1c8cab0e",
      "speaker": "",
      "ja": "粘り気のある真っ白愛液が掻き出されるように結合部から溢れ、肉棒とあそこにいやらしくまとわりつく。",
      "zh": ""
    },
    {
      "key": "204.0",
      "line_index": 204,
      "inline_index": 0,
      "line_hash": "f0d4046f",
      "speaker": "ラチャナ",
      "ja": "ダメっ♥　ダメじゃ……！♥　イってしまうっ！♥　大きいのくるっ！♥",
      "zh": ""
    },
    {
      "key": "204.2",
      "line_index": 204,
      "inline_index": 2,
      "line_hash": "f0d4046f",
      "speaker": "ラチャナ",
      "ja": "だめだめだめ……！！♥♥",
      "zh": ""
    },
    {
      "key": "207.0",
      "line_index": 207,
      "inline_index": 0,
      "line_hash": "59ef3faa",
      "speaker": "{G_PlayerName}",
      "ja": "ラチャナ、イって……！！",
      "zh": ""
    },
    {
      "key": "211.0",
      "line_index": 211,
      "inline_index": 0,
      "line_hash": "1bc2e431",
      "speaker": "ラチャナ",
      "ja": "イクっ！♥　イクイクイクっ！♥　う、ううううっ！♥　んあああぁ～～っ！！♥♥",
      "zh": ""
    },
    {
      "key": "222.0",
      "line_index": 222,
      "inline_index": 0,
      "line_hash": "ad40c416",
      "speaker": "ラチャナ",
      "ja": "あああぁぁぁ～～～っ！！♥♥",
      "zh": ""
    },
    {
      "key": "224.0",
      "line_index": 224,
      "inline_index": 0,
      "line_hash": "3df01eb5",
      "speaker": "リリアンＡ",
      "ja": "ん？　今ヘンな声しなかったー？",
      "zh": ""
    },
    {
      "key": "226.0",
      "line_index": 226,
      "inline_index": 0,
      "line_hash": "e5169f8b",
      "speaker": "リリアンＢ",
      "ja": "えーっ？　やだぁ、こんなところでパコパコしてるのかな？♥　くすくすっ♥",
      "zh": ""
    },
    {
      "key": "229.0",
      "line_index": 229,
      "inline_index": 0,
      "line_hash": "53b471f9",
      "speaker": "{G_PlayerName}",
      "ja": "く、うう……！！　ラ、ラチャナ、声抑えて……！　流石に聞こえちゃうってっ！",
      "zh": ""
    },
    {
      "key": "233.0",
      "line_index": 233,
      "inline_index": 0,
      "line_hash": "d1f410ad",
      "speaker": "ラチャナ",
      "ja": "そっ、そんなこと、言われてもぉ……！♥　んっ、んんぅぅっ！！♥♥　ふーっ！♥　んふーっ！♥",
      "zh": ""
    },
    {
      "key": "235.0",
      "line_index": 235,
      "inline_index": 0,
      "line_hash": "acb299ef",
      "speaker": "",
      "ja": "ラチャナは口を閉じ、必死に声を抑える。",
      "zh": ""
    },
    {
      "key": "236.0",
      "line_index": 236,
      "inline_index": 0,
      "line_hash": "2f9ca5dd",
      "speaker": "",
      "ja": "しかし快感が強烈すぎるのか、完全に声を抑えることができず、近くにいる人たちに聞こえてしまう。",
      "zh": ""
    },
    {
      "key": "238.0",
      "line_index": 238,
      "inline_index": 0,
      "line_hash": "b91fa071",
      "speaker": "",
      "ja": "幸いなことにわざわざ声の主を探そうと思っていないのか、俺たちに近づく気配は無かった。",
      "zh": ""
    },
    {
      "key": "241.0",
      "line_index": 241,
      "inline_index": 0,
      "line_hash": "a0dbc66f",
      "speaker": "ラチャナ",
      "ja": "あぅ♥　イくぅ♥　お股、気持ち良いのじゃ……♥　ふぅ、ふぅっ！♥",
      "zh": ""
    },
    {
      "key": "244.0",
      "line_index": 244,
      "inline_index": 0,
      "line_hash": "18c5c20d",
      "speaker": "ラチャナ",
      "ja": "あっ♥　あっ♥　んあぁぁっ♥　まだおぬしの射精て……はうう……！♥",
      "zh": ""
    },
    {
      "key": "246.0",
      "line_index": 246,
      "inline_index": 0,
      "line_hash": "c9f62a6",
      "speaker": "",
      "ja": "ラチャナは俺との密着度を高めようと、足を俺の腰に回す。",
      "zh": ""
    },
    {
      "key": "247.0",
      "line_index": 247,
      "inline_index": 0,
      "line_hash": "9059d5c4",
      "speaker": "",
      "ja": "肉棒がさらにぐっと奥に押し込められ、子宮口をこじ開け中に直接精液を注ぎ込む。",
      "zh": ""
    },
    {
      "key": "250.0",
      "line_index": 250,
      "inline_index": 0,
      "line_hash": "1dbd1f92",
      "speaker": "ラチャナ",
      "ja": "身体、ふわふわするのじゃ……♥　はぁ♥　はぁっ♥　そなたはどうなのじゃ……？♥　気持ち良くなっておるかぁ……？♥",
      "zh": ""
    },
    {
      "key": "252.0",
      "line_index": 252,
      "inline_index": 0,
      "line_hash": "5d4a6992",
      "speaker": "",
      "ja": "イきながらふわふわ笑うラチャナの健気さに、{G_PlayerName}は身体を傾け、ラチャナの小さな身体の上に覆いかぶさる。",
      "zh": ""
    },
    {
      "key": "253.0",
      "line_index": 253,
      "inline_index": 0,
      "line_hash": "5c4f2a0d",
      "speaker": "",
      "ja": "そして荒い息をしている口にそっと自分の唇を近づけ──",
      "zh": ""
    },
    {
      "key": "256.0",
      "line_index": 256,
      "inline_index": 0,
      "line_hash": "9a6b861e",
      "speaker": "ラチャナ",
      "ja": "んふぅ……♥　ちゅ……ちゅぅ……♥　ぢゅる……ちゅう……♥♥",
      "zh": ""
    },
    {
      "key": "259.0",
      "line_index": 259,
      "inline_index": 0,
      "line_hash": "15c3c32d",
      "speaker": "{G_PlayerName}",
      "ja": "（うあ……！　やばっ……！　キスするとオマンコの中グニグニ動いて……くう、これすごい……どんどんラチャナのオマンコの動きが激しくなっていってる気がする……）",
      "zh": ""
    },
    {
      "key": "263.0",
      "line_index": 263,
      "inline_index": 0,
      "line_hash": "407b85a4",
      "speaker": "{G_PlayerName}",
      "ja": "（よ、ようやく収まったのに、これじゃまた……っ）",
      "zh": ""
    },
    {
      "key": "267.0",
      "line_index": 267,
      "inline_index": 0,
      "line_hash": "1d34d2",
      "speaker": "ラチャナ",
      "ja": "ぷはぁ～♥　ああぁ……キス、蕩けそうじゃ……♥",
      "zh": ""
    },
    {
      "key": "270.0",
      "line_index": 270,
      "inline_index": 0,
      "line_hash": "396883cc",
      "speaker": "ラチャナ",
      "ja": "のう……そなたのまだ硬いままじゃ……♥　治療の続きをせねば……♥",
      "zh": ""
    },
    {
      "key": "273.0",
      "line_index": 273,
      "inline_index": 0,
      "line_hash": "a8615954",
      "speaker": "{G_PlayerName}",
      "ja": "ううっ、ラチャナすまん……っ！",
      "zh": ""
    },
    {
      "key": "276.0",
      "line_index": 276,
      "inline_index": 0,
      "line_hash": "d35c3a74",
      "speaker": "",
      "ja": "ラチャナとまだセックスをしたい、その欲が再び腰を動かす。",
      "zh": ""
    },
    {
      "key": "279.0",
      "line_index": 279,
      "inline_index": 0,
      "line_hash": "6b7e121b",
      "speaker": "ラチャナ",
      "ja": "ワシのおまんこがそなたのを欲しておる……♥　また大きなおちんちんでぐちゅぐちゅ掻き回しておくれっ……♥",
      "zh": ""
    },
    {
      "key": "287.0",
      "line_index": 287,
      "inline_index": 0,
      "line_hash": "fa2851f1",
      "speaker": "ラチャナ",
      "ja": "あううっ！♥　ふぅぅぅ……！♥　んっ、んぅぅぅ……んあ、はぁぁぁ……！！♥",
      "zh": ""
    },
    {
      "key": "290.0",
      "line_index": 290,
      "inline_index": 0,
      "line_hash": "63f1dd3d",
      "speaker": "ラチャナ",
      "ja": "あ、あ……♥　お゛っ♥　んお゛っ♥　おまんこ、すごいのじゃぁっ♥",
      "zh": ""
    },
    {
      "key": "293.0",
      "line_index": 293,
      "inline_index": 0,
      "line_hash": "97a608ac",
      "speaker": "{G_PlayerName}",
      "ja": "しー！　ラチャナ、もうちょい静かに……！",
      "zh": ""
    },
    {
      "key": "297.0",
      "line_index": 297,
      "inline_index": 0,
      "line_hash": "2327625a",
      "speaker": "ラチャナ",
      "ja": "お゛ぅっ♥　おほっ♥　ほっ♥　お゛～～～～っ！！♥",
      "zh": ""
    },
    {
      "key": "299.0",
      "line_index": 299,
      "inline_index": 0,
      "line_hash": "3bfc5388",
      "speaker": "",
      "ja": "ラチャナの獣じみた喘ぎ声が辺りに響き渡る。",
      "zh": ""
    },
    {
      "key": "300.0",
      "line_index": 300,
      "inline_index": 0,
      "line_hash": "6eef7ef4",
      "speaker": "",
      "ja": "可愛らしい水着姿の少女が、{G_PlayerName}の陰茎に悶え狂うその声はやはり他のリリアンに届いてしまう。",
      "zh": ""
    },
    {
      "key": "303.0",
      "line_index": 303,
      "inline_index": 0,
      "line_hash": "c506dc3c",
      "speaker": "リリアンＡ",
      "ja": "ちょっとぉ、やばぁ♪　あははっ、誰ぇ？　すっごい大きな声でエッチなことしてるんだけど！",
      "zh": ""
    },
    {
      "key": "306.0",
      "line_index": 306,
      "inline_index": 0,
      "line_hash": "879516f6",
      "speaker": "リリアンＢ",
      "ja": "野外でこんな声良く出せるよね？　バカップルっていうか、セックス依存症？　どんなセックスしてるんだろ？",
      "zh": ""
    },
    {
      "key": "309.0",
      "line_index": 309,
      "inline_index": 0,
      "line_hash": "69dc42a5",
      "speaker": "ラチャナ",
      "ja": "んお゛っ！♥　お、おくぅっ！♥　奥もっと突いてほしいのじゃぁっ！♥",
      "zh": ""
    },
    {
      "key": "309.2",
      "line_index": 309,
      "inline_index": 2,
      "line_hash": "69dc42a5",
      "speaker": "ラチャナ",
      "ja": "んお、ほぉぉ！♥　おお゛っ！♥　イっぐぅっ！♥",
      "zh": ""
    },
    {
      "key": "312.0",
      "line_index": 312,
      "inline_index": 0,
      "line_hash": "68344b2",
      "speaker": "{G_PlayerName}",
      "ja": "ごめん、ラチャナ……！　見つかってるけどあとちょっとで終わるからっ……！",
      "zh": ""
    },
    {
      "key": "316.0",
      "line_index": 316,
      "inline_index": 0,
      "line_hash": "d7c5816b",
      "speaker": "ラチャナ",
      "ja": "んぎぃっ！♥　ふおお、おおっ！♥　くっ……！♥　んお、おほぉっ！♥",
      "zh": ""
    },
    {
      "key": "319.0",
      "line_index": 319,
      "inline_index": 0,
      "line_hash": "56b7bd40",
      "speaker": "ラチャナ",
      "ja": "そんな小刻みにぃ……！♥　ぐうう、ふ、ふっ！♥　お゛っ！♥　お゛っ！♥　おおぉお゛～～っ！！♥",
      "zh": ""
    },
    {
      "key": "321.0",
      "line_index": 321,
      "inline_index": 0,
      "line_hash": "3324bb33",
      "speaker": "",
      "ja": "どちゅどちゅと子宮口を執拗に押し上げ、獣のように喘ぐラチャナ。",
      "zh": ""
    },
    {
      "key": "322.0",
      "line_index": 322,
      "inline_index": 0,
      "line_hash": "64253086",
      "speaker": "",
      "ja": "そして僅かに開いた子宮口が亀頭をぱくりと咥えこみ、熱すぎる気持ち良さが肉棒から全身に一気に走った。",
      "zh": ""
    },
    {
      "key": "325.0",
      "line_index": 325,
      "inline_index": 0,
      "line_hash": "35d31e8d",
      "speaker": "ラチャナ",
      "ja": "奥、すごいのじゃ～～！！♥　気持ち良すぎるぅっ！♥　ま、またおまんこイってしまう！♥　おまんこイきくるぅうっ！♥",
      "zh": ""
    },
    {
      "key": "328.0",
      "line_index": 328,
      "inline_index": 0,
      "line_hash": "a6a4c2dc",
      "speaker": "{G_PlayerName}",
      "ja": "あーもうっ聞かれてもいい……！　気持ち良すぎて、無理だってこんなのっ！",
      "zh": ""
    },
    {
      "key": "332.0",
      "line_index": 332,
      "inline_index": 0,
      "line_hash": "b2111232",
      "speaker": "ラチャナ",
      "ja": "イク、イってしまう！♥　おまんこイってしまうぅぅっ！！♥",
      "zh": ""
    },
    {
      "key": "335.0",
      "line_index": 335,
      "inline_index": 0,
      "line_hash": "299d9ef3",
      "speaker": "{G_PlayerName}",
      "ja": "イって……！　俺もイクから、次も二人で一緒に……！！",
      "zh": ""
    },
    {
      "key": "339.0",
      "line_index": 339,
      "inline_index": 0,
      "line_hash": "9067cb9e",
      "speaker": "ラチャナ",
      "ja": "んんんっ！♥　イク、イクっ！♥　ああああぁっ！♥　イグぅううっ！！♥♥",
      "zh": ""
    },
    {
      "key": "350.0",
      "line_index": 350,
      "inline_index": 0,
      "line_hash": "953232b3",
      "speaker": "{G_PlayerName}",
      "ja": "ラチャナ！　好きだっ……！！",
      "zh": ""
    },
    {
      "key": "354.0",
      "line_index": 354,
      "inline_index": 0,
      "line_hash": "c7945ae3",
      "speaker": "ラチャナ",
      "ja": "あうううっ！♥　あ、あっ！♥　ふうう、んんんんんぅぅぅっ！！♥♥",
      "zh": ""
    },
    {
      "key": "356.0",
      "line_index": 356,
      "inline_index": 0,
      "line_hash": "b0cdaf72",
      "speaker": "",
      "ja": "ラチャナの全身がビクンと跳ねると同時に、膣がぎゅっと肉棒を締め付ける。",
      "zh": ""
    },
    {
      "key": "357.0",
      "line_index": 357,
      "inline_index": 0,
      "line_hash": "3e5cf528",
      "speaker": "",
      "ja": "{G_PlayerName}は腰をぐいっと押し付けると、子宮に直接精液を流し込んでいく。",
      "zh": ""
    },
    {
      "key": "360.0",
      "line_index": 360,
      "inline_index": 0,
      "line_hash": "45a202f2",
      "speaker": "ラチャナ",
      "ja": "くう、ううう……！♥　熱いの、またいっぱい射精ておるぅ……！♥　気持ち良い、気持ち良いのじゃ～……！♥",
      "zh": ""
    },
    {
      "key": "363.0",
      "line_index": 363,
      "inline_index": 0,
      "line_hash": "c625062c",
      "speaker": "{G_PlayerName}",
      "ja": "まだ射精るから……！　全部受け止めてくれっ！！",
      "zh": ""
    },
    {
      "key": "367.0",
      "line_index": 367,
      "inline_index": 0,
      "line_hash": "6b9f28e9",
      "speaker": "ラチャナ",
      "ja": "んんんっ！♥　ああぁぁ、おまんこ溶けてしまうぅっ！♥　ふう、んんぅぅぅっ！！♥♥",
      "zh": ""
    },
    {
      "key": "369.0",
      "line_index": 369,
      "inline_index": 0,
      "line_hash": "b98f0402",
      "speaker": "",
      "ja": "腰を小刻みに揺らし、うねる膣の中で肉棒を扱く。",
      "zh": ""
    },
    {
      "key": "370.0",
      "line_index": 370,
      "inline_index": 0,
      "line_hash": "f775c05b",
      "speaker": "",
      "ja": "びゅるびゅると熱いモノが何度も肉竿を駆け上がり、子宮に精液が注がれるたびにラチャナは絶頂する。",
      "zh": ""
    },
    {
      "key": "372.0",
      "line_index": 372,
      "inline_index": 0,
      "line_hash": "493a6289",
      "speaker": "",
      "ja": "ラチャナをもっと絶頂させたい、その想いが何度も機械士を射精をさせていた。",
      "zh": ""
    },
    {
      "key": "375.0",
      "line_index": 375,
      "inline_index": 0,
      "line_hash": "78d44591",
      "speaker": "ラチャナ",
      "ja": "はぁ♥　はぁぁ♥　子作り気持ち良すぎるのじゃ……♥　クセになってしまいそうじゃ……♥",
      "zh": ""
    },
    {
      "key": "378.0",
      "line_index": 378,
      "inline_index": 0,
      "line_hash": "748cd40d",
      "speaker": "{G_PlayerName}",
      "ja": "クセになっていいよ、俺がいくらでもラチャナと子作りするから……ん……",
      "zh": ""
    },
    {
      "key": "382.0",
      "line_index": 382,
      "inline_index": 0,
      "line_hash": "8f8d7f5f",
      "speaker": "ラチャナ",
      "ja": "んふぅ……♥　ぢゅる……♥　ちゅ、ちゅ……♥　れるぅ……ぢゅるる♥",
      "zh": ""
    },
    {
      "key": "384.0",
      "line_index": 384,
      "inline_index": 0,
      "line_hash": "e73da99c",
      "speaker": "",
      "ja": "{G_PlayerName}が唇を重ねると、ラチャナは嬉しそうに舌を絡めてくる。暑すぎる日差しの中、互いの唾液で喉を潤すようにキスを繰り返す。",
      "zh": ""
    },
    {
      "key": "386.0",
      "line_index": 386,
      "inline_index": 0,
      "line_hash": "6185f8b7",
      "speaker": "",
      "ja": "2人は繋がったまま心地よい余韻に浸りながら、いつまでも口づけをしていたのであった。",
      "zh": ""
    }
  ]
}
