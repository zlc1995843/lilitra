{
  "lines": [
    {
      "key": "15.1",
      "line_index": 15,
      "inline_index": 1,
      "line_hash": "7085658a",
      "speaker": "ケット(夢鏡)",
      "ja": "おにぃさ～ん♥　ケット遊びに来ちゃった♥",
      "zh": ""
    },
    {
      "key": "26.1",
      "line_index": 26,
      "inline_index": 1,
      "line_hash": "cba1d55c",
      "speaker": "ケット",
      "ja": "えっ……？",
      "zh": ""
    },
    {
      "key": "28.1",
      "line_index": 28,
      "inline_index": 1,
      "line_hash": "71b942ce",
      "speaker": "ケット(夢鏡)",
      "ja": "あっ……！",
      "zh": ""
    },
    {
      "key": "34.1",
      "line_index": 34,
      "inline_index": 1,
      "line_hash": "e2b01c6e",
      "speaker": "ケット",
      "ja": "あれ？　あれれ？　ケットが……もう一人……？",
      "zh": ""
    },
    {
      "key": "36.1",
      "line_index": 36,
      "inline_index": 1,
      "line_hash": "fd7486f8",
      "speaker": "ケット",
      "ja": "おにぃちゃん、ケット夢でも見てるのかな……？",
      "zh": ""
    },
    {
      "key": "38.0",
      "line_index": 38,
      "inline_index": 0,
      "line_hash": "7401e849",
      "speaker": "{G_PlayerName}",
      "ja": "あー！　別世界のケットと会うのは初めてか……！　すまん、話そうと思ってたんだけどすっかり忘れてた",
      "zh": ""
    },
    {
      "key": "40.1",
      "line_index": 40,
      "inline_index": 1,
      "line_hash": "8178f5dd",
      "speaker": "ケット",
      "ja": "別、世界……？　どういうこと、おにぃちゃん……？",
      "zh": ""
    },
    {
      "key": "42.1",
      "line_index": 42,
      "inline_index": 1,
      "line_hash": "5d0e16a8",
      "speaker": "ケット(夢鏡)",
      "ja": "そのまんまの意味だよ？　ケットはケットだけど、あなたと違うケット",
      "zh": ""
    },
    {
      "key": "44.1",
      "line_index": 44,
      "inline_index": 1,
      "line_hash": "389cc1",
      "speaker": "ケット(夢鏡)",
      "ja": "……ホント、そのまんまケットだね。なんだか不思議な感じ",
      "zh": ""
    },
    {
      "key": "46.1",
      "line_index": 46,
      "inline_index": 1,
      "line_hash": "2a195936",
      "speaker": "ケット",
      "ja": "う、うん、そのまんま……えっと、あなたはケットにそっくりな人……？",
      "zh": ""
    },
    {
      "key": "51.1",
      "line_index": 51,
      "inline_index": 1,
      "line_hash": "61dc5d50",
      "speaker": "ケット(夢鏡)",
      "ja": "だーかーらー、同じケットなんだよ。あたしはケット、あなたもケット。ただそれだけなのっ",
      "zh": ""
    },
    {
      "key": "56.1",
      "line_index": 56,
      "inline_index": 1,
      "line_hash": "53076ce0",
      "speaker": "ケット",
      "ja": "ええっ？　ええええ～っ！？　おにぃちゃん、ケットよくわからないんだけど……？　ど、どういうことなの？",
      "zh": ""
    },
    {
      "key": "58.0",
      "line_index": 58,
      "inline_index": 0,
      "line_hash": "d5514aab",
      "speaker": "",
      "ja": "自分と同じ存在を見て困惑してしまうこっちのケット。",
      "zh": ""
    },
    {
      "key": "60.0",
      "line_index": 60,
      "inline_index": 0,
      "line_hash": "c43f45cb",
      "speaker": "",
      "ja": "別世界のケットはなんで理解できないの、そんな表情でこっちのケットを見ていた。",
      "zh": ""
    },
    {
      "key": "62.0",
      "line_index": 62,
      "inline_index": 0,
      "line_hash": "3dabc3d0",
      "speaker": "{G_PlayerName}",
      "ja": "ま、まぁ、その……こっちのケットと同じ存在っていうか……てか二人のことどう呼べば……！？",
      "zh": ""
    },
    {
      "key": "64.1",
      "line_index": 64,
      "inline_index": 1,
      "line_hash": "2526290f",
      "speaker": "ケット(夢鏡)",
      "ja": "ケットのことはケットって呼べばいいんじゃない？",
      "zh": ""
    },
    {
      "key": "66.0",
      "line_index": 66,
      "inline_index": 0,
      "line_hash": "b21edbc0",
      "speaker": "{G_PlayerName}",
      "ja": "それじゃお互い困るだろ……！",
      "zh": ""
    },
    {
      "key": "68.1",
      "line_index": 68,
      "inline_index": 1,
      "line_hash": "92f720a1",
      "speaker": "ケット(夢鏡)",
      "ja": "むぅ……呼び方なんてどうでもいいよっ。おにぃさんはケットのこと大好きだもんね？",
      "zh": ""
    },
    {
      "key": "75.1",
      "line_index": 75,
      "inline_index": 1,
      "line_hash": "4bab4a25",
      "speaker": "ケット",
      "ja": "あーっ！　独り占めしようとしてるーっ！",
      "zh": ""
    },
    {
      "key": "84.1",
      "line_index": 84,
      "inline_index": 1,
      "line_hash": "a94599b5",
      "speaker": "ケット",
      "ja": "おにぃちゃんはケットのこと好きだもんっ！　ずっと一緒にいるもんね、おにぃちゃん！",
      "zh": ""
    },
    {
      "key": "93.1",
      "line_index": 93,
      "inline_index": 1,
      "line_hash": "4f877a60",
      "speaker": "ケット(夢鏡)",
      "ja": "そんなわけないよっ！　おにぃさんはケットの方が好きなのっ！",
      "zh": ""
    },
    {
      "key": "95.1",
      "line_index": 95,
      "inline_index": 1,
      "line_hash": "488f5b9b",
      "speaker": "ケット",
      "ja": "違うもん！　違うったら違うもんっ！",
      "zh": ""
    },
    {
      "key": "97.0",
      "line_index": 97,
      "inline_index": 0,
      "line_hash": "7754e20b",
      "speaker": "{G_PlayerName}",
      "ja": "おんなじ声でケンカはやめろって……！",
      "zh": ""
    },
    {
      "key": "99.1",
      "line_index": 99,
      "inline_index": 1,
      "line_hash": "d02c442c",
      "speaker": "ケット(夢鏡)",
      "ja": "何言ってるの、おにぃさん？　ケット、こんな声してないよ？",
      "zh": ""
    },
    {
      "key": "101.1",
      "line_index": 101,
      "inline_index": 1,
      "line_hash": "f788a9ff",
      "speaker": "ケット",
      "ja": "そうだよっ……！　全然声違うよ……！　ケットはもっと違う声してるよっ",
      "zh": ""
    },
    {
      "key": "103.0",
      "line_index": 103,
      "inline_index": 0,
      "line_hash": "8d0827a",
      "speaker": "{G_PlayerName}",
      "ja": "俺には同じ声にしか聞こえないから……！　とりあえず二人とも落ち着け！",
      "zh": ""
    },
    {
      "key": "105.1",
      "line_index": 105,
      "inline_index": 1,
      "line_hash": "f2a79844",
      "speaker": "ケット",
      "ja": "わかった、おにぃちゃんがそういうなら……",
      "zh": ""
    },
    {
      "key": "107.1",
      "line_index": 107,
      "inline_index": 1,
      "line_hash": "c153eeb5",
      "speaker": "ケット(夢鏡)",
      "ja": "おにぃさんも大変だね～。この際ハッキリ言った方がいいんじゃない？",
      "zh": ""
    },
    {
      "key": "112.1",
      "line_index": 112,
      "inline_index": 1,
      "line_hash": "c1217042",
      "speaker": "ケット(夢鏡)",
      "ja": "ケットの方が好きだってさ♥　この子理解力低いからハッキリ言わないとわからないからね♥",
      "zh": ""
    },
    {
      "key": "114.0",
      "line_index": 114,
      "inline_index": 0,
      "line_hash": "2bf78c93",
      "speaker": "",
      "ja": "ケットは俺が自分のモノだと主張するように腕を組ませてくる。",
      "zh": ""
    },
    {
      "key": "115.0",
      "line_index": 115,
      "inline_index": 0,
      "line_hash": "63a6217e",
      "speaker": "",
      "ja": "そんな別世界のケットを見て、珍しく怒っているこっちのケット。",
      "zh": ""
    },
    {
      "key": "120.1",
      "line_index": 120,
      "inline_index": 1,
      "line_hash": "3c196a51",
      "speaker": "ケット",
      "ja": "違うよーっ！　おにぃちゃんはケットのこと好きなのっ！",
      "zh": ""
    },
    {
      "key": "122.0",
      "line_index": 122,
      "inline_index": 0,
      "line_hash": "31d12bf4",
      "speaker": "",
      "ja": "こっちのケットも負けじと俺に腕を絡ませ、二人は俺を取り合うように俺の腕を引っ張る。",
      "zh": ""
    },
    {
      "key": "124.0",
      "line_index": 124,
      "inline_index": 0,
      "line_hash": "158ae84e",
      "speaker": "{G_PlayerName}",
      "ja": "お、おい、やめろって……！",
      "zh": ""
    },
    {
      "key": "129.1",
      "line_index": 129,
      "inline_index": 1,
      "line_hash": "60701ad1",
      "speaker": "ケット(夢鏡)",
      "ja": "そっちのケットに言って……！　ケット本当のことしか言ってないから……！",
      "zh": ""
    },
    {
      "key": "134.1",
      "line_index": 134,
      "inline_index": 1,
      "line_hash": "5eccde7c",
      "speaker": "ケット",
      "ja": "ケットだって本当のことしか言ってないーっ！　おにぃちゃんはケットのなんだからぁ～っ",
      "zh": ""
    },
    {
      "key": "136.0",
      "line_index": 136,
      "inline_index": 0,
      "line_hash": "34ff3bf",
      "speaker": "",
      "ja": "ケット達は俺を挟み、バチバチと視線の火花を散らせる。",
      "zh": ""
    },
    {
      "key": "137.0",
      "line_index": 137,
      "inline_index": 0,
      "line_hash": "a83dfd13",
      "speaker": "",
      "ja": "ケンカはよくないが、これはこれで微笑ましく思えてきてなんだかほっこりしてきてしまう。",
      "zh": ""
    },
    {
      "key": "139.0",
      "line_index": 139,
      "inline_index": 0,
      "line_hash": "64c803be",
      "speaker": "二人",
      "ja": "おにぃさん、おにぃちゃんはどっちが好きなのっ！？",
      "zh": ""
    },
    {
      "key": "141.0",
      "line_index": 141,
      "inline_index": 0,
      "line_hash": "c3c5ba9",
      "speaker": "{G_PlayerName}",
      "ja": "えぇっ！？　そ、そんなこと言われてもさ……どっちのケットも好きだし……選べないって",
      "zh": ""
    },
    {
      "key": "143.0",
      "line_index": 143,
      "inline_index": 0,
      "line_hash": "51acdbde",
      "speaker": "{G_PlayerName}",
      "ja": "どっちも大事なケットじゃダメなのか……？",
      "zh": ""
    },
    {
      "key": "145.1",
      "line_index": 145,
      "inline_index": 1,
      "line_hash": "57473373",
      "speaker": "ケット(夢鏡)",
      "ja": "ダメ♥　ちゃんとどっちか選ばなくっちゃ、ね？",
      "zh": ""
    },
    {
      "key": "147.0",
      "line_index": 147,
      "inline_index": 0,
      "line_hash": "8f33b2ef",
      "speaker": "",
      "ja": "どっちも大事、という言葉が別世界のケットは気に入らない様子。",
      "zh": ""
    },
    {
      "key": "148.0",
      "line_index": 148,
      "inline_index": 0,
      "line_hash": "e4298e5a",
      "speaker": "",
      "ja": "笑顔を見せながらも圧を感じさせる、そんな視線を俺に向けてきた。",
      "zh": ""
    },
    {
      "key": "150.1",
      "line_index": 150,
      "inline_index": 1,
      "line_hash": "1f96c435",
      "speaker": "ケット",
      "ja": "あ……！　脅すなんてダメだよ……！　そんなのおにぃちゃん困っちゃうよ……！",
      "zh": ""
    },
    {
      "key": "152.0",
      "line_index": 152,
      "inline_index": 0,
      "line_hash": "44330e04",
      "speaker": "{G_PlayerName}",
      "ja": "（しかし声は同じでも性格はそれなりに違ってるもんなんだな……）",
      "zh": ""
    },
    {
      "key": "154.0",
      "line_index": 154,
      "inline_index": 0,
      "line_hash": "b17ebd64",
      "speaker": "",
      "ja": "夢鏡の世界のケットは強気で少し大人びている。",
      "zh": ""
    },
    {
      "key": "155.0",
      "line_index": 155,
      "inline_index": 0,
      "line_hash": "f7fce231",
      "speaker": "",
      "ja": "こっちの世界のケットは少し弱気な様子。",
      "zh": ""
    },
    {
      "key": "157.0",
      "line_index": 157,
      "inline_index": 0,
      "line_hash": "5c5251e3",
      "speaker": "",
      "ja": "グイグイと圧をかける別世界のケットと違い、控えめで圧らしい圧を感じさせない。",
      "zh": ""
    },
    {
      "key": "159.0",
      "line_index": 159,
      "inline_index": 0,
      "line_hash": "7459d8c4",
      "speaker": "",
      "ja": "ただ、それでも主張するところは主張する……それもケットらしいと思えてくる。",
      "zh": ""
    },
    {
      "key": "161.1",
      "line_index": 161,
      "inline_index": 1,
      "line_hash": "b68100dc",
      "speaker": "ケット(夢鏡)",
      "ja": "ねぇねぇ、おにぃさん、こんな子ほっといてケットと遊ぼ？♥",
      "zh": ""
    },
    {
      "key": "163.1",
      "line_index": 163,
      "inline_index": 1,
      "line_hash": "24fb5203",
      "speaker": "ケット(夢鏡)",
      "ja": "あの子じゃできないこと、ケット色々してあげるよ？♥　くすくすっ♥",
      "zh": ""
    },
    {
      "key": "165.1",
      "line_index": 165,
      "inline_index": 1,
      "line_hash": "796ecb1",
      "speaker": "ケット",
      "ja": "あっ……！？",
      "zh": ""
    },
    {
      "key": "167.0",
      "line_index": 167,
      "inline_index": 0,
      "line_hash": "1bbeece5",
      "speaker": "{G_PlayerName}",
      "ja": "あっ……！　ど、どこ触って……！！",
      "zh": ""
    },
    {
      "key": "169.0",
      "line_index": 169,
      "inline_index": 0,
      "line_hash": "bc972841",
      "speaker": "",
      "ja": "別世界のケットが俺の股間を擦り、思わず身体が勝手に震えてしまう。",
      "zh": ""
    },
    {
      "key": "171.1",
      "line_index": 171,
      "inline_index": 1,
      "line_hash": "7e2d28f",
      "speaker": "ケット",
      "ja": "ケットだってできるよ……！　おにぃちゃん、いっぱい気持ち良くしてあげるから……！",
      "zh": ""
    },
    {
      "key": "173.0",
      "line_index": 173,
      "inline_index": 0,
      "line_hash": "642d8a7a",
      "speaker": "",
      "ja": "こっちの世界のケットも負けじと股間に手を伸ばす。",
      "zh": ""
    },
    {
      "key": "174.0",
      "line_index": 174,
      "inline_index": 0,
      "line_hash": "ddacbbe9",
      "speaker": "",
      "ja": "二人の小さな手が陰茎を取り合うように動き、俺は快感に声が漏れ出してしまう。",
      "zh": ""
    },
    {
      "key": "179.1",
      "line_index": 179,
      "inline_index": 1,
      "line_hash": "92d356d5",
      "speaker": "ケット(夢鏡)",
      "ja": "くすっ♥　少しずつおっきくなってきた……♥　やっぱりケットと”そういうこと”したいんだね……♥",
      "zh": ""
    },
    {
      "key": "181.1",
      "line_index": 181,
      "inline_index": 1,
      "line_hash": "88de6643",
      "speaker": "ケット",
      "ja": "違うよ、おにぃちゃんはケットで喜んでるんだよ？♥",
      "zh": ""
    },
    {
      "key": "183.1",
      "line_index": 183,
      "inline_index": 1,
      "line_hash": "200bfd3c",
      "speaker": "ケット(夢鏡)",
      "ja": "そんなわけないでしょ……！　ケットの手でエッチな気分になってるんだから",
      "zh": ""
    },
    {
      "key": "185.1",
      "line_index": 185,
      "inline_index": 1,
      "line_hash": "fe5fee97",
      "speaker": "ケット",
      "ja": "おにぃちゃんはケットと気持ち良いことしたいって思ってるからおっきくなってるんだよっ",
      "zh": ""
    },
    {
      "key": "187.1",
      "line_index": 187,
      "inline_index": 1,
      "line_hash": "4d2507f4",
      "speaker": "ケット(夢鏡)",
      "ja": "でもあなた、触ってるだけでしょ？♥　ケットはこんなことだってできるんだから",
      "zh": ""
    },
    {
      "key": "189.0",
      "line_index": 189,
      "inline_index": 0,
      "line_hash": "62955fb4",
      "speaker": "{G_PlayerName}",
      "ja": "おいっ……！　二人ともやめろって……！　ううう！！",
      "zh": ""
    },
    {
      "key": "191.0",
      "line_index": 191,
      "inline_index": 0,
      "line_hash": "d64dee0",
      "speaker": "",
      "ja": "別世界のケットがズボン越しに亀頭を擦り快感の度合いが強くなっていく。",
      "zh": ""
    },
    {
      "key": "193.1",
      "line_index": 193,
      "inline_index": 1,
      "line_hash": "3ccf8151",
      "speaker": "ケット",
      "ja": "ケットだって～～っ！",
      "zh": ""
    },
    {
      "key": "195.0",
      "line_index": 195,
      "inline_index": 0,
      "line_hash": "868494d9",
      "speaker": "",
      "ja": "こっちの世界のケットも負けないと言わんばかりに陰茎を擦り、気持ち良さが二倍に。",
      "zh": ""
    },
    {
      "key": "197.0",
      "line_index": 197,
      "inline_index": 0,
      "line_hash": "97e4adfc",
      "speaker": "",
      "ja": "止めさせないと、そう思ってはいるが二人のケットのもたらす快感に、足が張り付いたかのように動かなくなってしまった。",
      "zh": ""
    },
    {
      "key": "199.1",
      "line_index": 199,
      "inline_index": 1,
      "line_hash": "8092fb0c",
      "speaker": "ケット",
      "ja": "ほら、おにぃちゃん、気持ち良いでしょ？♥　ケット、おにぃちゃんが喜ぶんだったらなんだってしてあげるから……♥",
      "zh": ""
    },
    {
      "key": "201.1",
      "line_index": 201,
      "inline_index": 1,
      "line_hash": "f075948d",
      "speaker": "ケット(夢鏡)",
      "ja": "ケットと気持ち良いことしたいって素直になりなよ……♥　いくらでもおちんちん喜ばせてあげるからさ～♥",
      "zh": ""
    },
    {
      "key": "203.0",
      "line_index": 203,
      "inline_index": 0,
      "line_hash": "96772e1d",
      "speaker": "",
      "ja": "二人の行為がどんどんえっちな方向にエスカレートしていく。",
      "zh": ""
    },
    {
      "key": "204.0",
      "line_index": 204,
      "inline_index": 0,
      "line_hash": "3d7a13b",
      "speaker": "",
      "ja": "結局二人のケンカを止めることができず、俺はひたすらに快感に悶えるのであった。",
      "zh": ""
    }
  ]
}
