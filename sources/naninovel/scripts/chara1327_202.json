{
  "lines": [
    {
      "key": "19.1",
      "line_index": 19,
      "inline_index": 1,
      "line_hash": "370fb786",
      "speaker": "フォニー",
      "ja": "ほ、ほら……するんでしょ？♥",
      "zh": ""
    },
    {
      "key": "21.0",
      "line_index": 21,
      "inline_index": 0,
      "line_hash": "71af035e",
      "speaker": "",
      "ja": "フォニーは立ち上がると、そっと俺の手を取る。",
      "zh": ""
    },
    {
      "key": "22.0",
      "line_index": 22,
      "inline_index": 0,
      "line_hash": "5d61160c",
      "speaker": "",
      "ja": "緊張なのか興奮なのかフォニーの手はしっとりと汗ばんでいた。",
      "zh": ""
    },
    {
      "key": "25.0",
      "line_index": 25,
      "inline_index": 0,
      "line_hash": "2971a35e",
      "speaker": "{G_PlayerName}",
      "ja": "……それじゃあちゃんと濡らさないと",
      "zh": ""
    },
    {
      "key": "29.1",
      "line_index": 29,
      "inline_index": 1,
      "line_hash": "ce1851cb",
      "speaker": "フォニー",
      "ja": "ええ……触って……♥",
      "zh": ""
    },
    {
      "key": "31.0",
      "line_index": 31,
      "inline_index": 0,
      "line_hash": "f3a52f77",
      "speaker": "",
      "ja": "俺はそっとフォニーのあそこに指を伸ばす。",
      "zh": ""
    },
    {
      "key": "32.0",
      "line_index": 32,
      "inline_index": 0,
      "line_hash": "5d5d0ff7",
      "speaker": "",
      "ja": "しかしすでにあそこは愛液まみれで、指先で軽く触れただけでそれをはっきりとわかってしまう。",
      "zh": ""
    },
    {
      "key": "35.0",
      "line_index": 35,
      "inline_index": 0,
      "line_hash": "daa43def",
      "speaker": "{G_PlayerName}",
      "ja": "その必要は無さそうだな",
      "zh": ""
    },
    {
      "key": "39.1",
      "line_index": 39,
      "inline_index": 1,
      "line_hash": "709d982a",
      "speaker": "フォニー",
      "ja": "うう……♥　しょうがないでしょ……！♥　あんなにエッチな射精を見せつけられたら、誰だって興奮しちゃうわよ……♥",
      "zh": ""
    },
    {
      "key": "42.0",
      "line_index": 42,
      "inline_index": 0,
      "line_hash": "c0a50559",
      "speaker": "{G_PlayerName}",
      "ja": "フォニーが俺でそこまでエロエロになってくれて嬉しいよ",
      "zh": ""
    },
    {
      "key": "45.0",
      "line_index": 45,
      "inline_index": 0,
      "line_hash": "23d2290d",
      "speaker": "",
      "ja": "フォニーの柔らかな髪をそっと撫でると気恥ずかしそうに俯く。",
      "zh": ""
    },
    {
      "key": "48.1",
      "line_index": 48,
      "inline_index": 1,
      "line_hash": "2ecfa2cf",
      "speaker": "フォニー",
      "ja": "……ねぇ、して♥　私、もう我慢の限界……♥　あなたの硬くて逞しいおちんちんでおまんこ慰めて……♥",
      "zh": ""
    },
    {
      "key": "65.0",
      "line_index": 65,
      "inline_index": 0,
      "line_hash": "1fbf6c3d",
      "speaker": "フォニー",
      "ja": "はうううっ！？♥　いっ、いきなりぃっ♥　んんぅ、奥に当たってるぅ……♥　あうううっ！！♥",
      "zh": ""
    },
    {
      "key": "67.0",
      "line_index": 67,
      "inline_index": 0,
      "line_hash": "94e1e581",
      "speaker": "",
      "ja": "フォニーの甘い囁きに性欲が爆発し、俺は挿入と同時にピストンを開始する。",
      "zh": ""
    },
    {
      "key": "68.0",
      "line_index": 68,
      "inline_index": 0,
      "line_hash": "f5d3c774",
      "speaker": "",
      "ja": "狭い膣を限界以上に肥大化していた肉棒で乱雑に掻き回す。",
      "zh": ""
    },
    {
      "key": "70.0",
      "line_index": 70,
      "inline_index": 0,
      "line_hash": "ac4cc3c",
      "speaker": "",
      "ja": "ぐちゅぐちゅと卑猥な音が部屋の中に響き、いきなりの激しい行為にフォニーは戸惑いの声を上げていた。",
      "zh": ""
    },
    {
      "key": "73.0",
      "line_index": 73,
      "inline_index": 0,
      "line_hash": "87324d04",
      "speaker": "フォニー",
      "ja": "んはぁ、はぁっ！♥　いつもよりっ、んんっ！♥　硬い、かもぉ……！♥",
      "zh": ""
    },
    {
      "key": "76.0",
      "line_index": 76,
      "inline_index": 0,
      "line_hash": "5a685a29",
      "speaker": "フォニー",
      "ja": "そんなに私と一つに……あんっ！♥　なりたかったの？♥",
      "zh": ""
    },
    {
      "key": "79.0",
      "line_index": 79,
      "inline_index": 0,
      "line_hash": "7fbaf4e8",
      "speaker": "{G_PlayerName}",
      "ja": "それもあるけど……魔法のせいだろう？　それに、そんなエロくてかわいい格好されたら男として興奮しないはずがないって",
      "zh": ""
    },
    {
      "key": "83.0",
      "line_index": 83,
      "inline_index": 0,
      "line_hash": "1507c2a7",
      "speaker": "フォニー",
      "ja": "ふ、ふ～ん……んっ！♥　ワキだけじゃなくて、んんん……服装も……んはぁ、はぁっ、んはぁっ！♥",
      "zh": ""
    },
    {
      "key": "86.0",
      "line_index": 86,
      "inline_index": 0,
      "line_hash": "ea4cbc8e",
      "speaker": "フォニー",
      "ja": "それじゃあもっともっと動かなきゃ満足できないでしょ？♥　なら動いて……ちゃんと魔法かけちゃった責任取ってあげるから♥",
      "zh": ""
    },
    {
      "key": "89.0",
      "line_index": 89,
      "inline_index": 0,
      "line_hash": "17ffa279",
      "speaker": "{G_PlayerName}",
      "ja": "そんなこと言って……単純に激しく犯して欲しいって思っているだけだろ？",
      "zh": ""
    },
    {
      "key": "92.0",
      "line_index": 92,
      "inline_index": 0,
      "line_hash": "e069030a",
      "speaker": "",
      "ja": "俺はフォニーの耳元でそう囁くと、フォニーの小さな身体がブルブルと小さく震える。",
      "zh": ""
    },
    {
      "key": "93.0",
      "line_index": 93,
      "inline_index": 0,
      "line_hash": "92d65ed2",
      "speaker": "",
      "ja": "膣がきゅんと肉棒を締め上げ、動くたびに無数のツブツブが肉棒の気持ち良いところを刺激する。",
      "zh": ""
    },
    {
      "key": "96.0",
      "line_index": 96,
      "inline_index": 0,
      "line_hash": "b59361a9",
      "speaker": "フォニー",
      "ja": "そ、そうよ……して欲しいって思っちゃってる……♥　優しいエッチも好きだけど、でも……たまには激しくぅ……♥",
      "zh": ""
    },
    {
      "key": "99.0",
      "line_index": 99,
      "inline_index": 0,
      "line_hash": "ccfbd315",
      "speaker": "フォニー",
      "ja": "はうっ！？♥　あっ♥　あっ！♥　んぅ、んは、あっ！！♥　ふあ、ああぁぁんっ！！♥",
      "zh": ""
    },
    {
      "key": "101.0",
      "line_index": 101,
      "inline_index": 0,
      "line_hash": "63c337d7",
      "speaker": "",
      "ja": "俺はフォニーの言葉に腰を小さなお尻に叩きつけるように打ち付ける。",
      "zh": ""
    },
    {
      "key": "102.0",
      "line_index": 102,
      "inline_index": 0,
      "line_hash": "77f3fd20",
      "speaker": "",
      "ja": "パンパンと肌のぶつかり合う音が大きくなり、同時にフォニーの口から甘い悲鳴が漏れる。",
      "zh": ""
    },
    {
      "key": "104.0",
      "line_index": 104,
      "inline_index": 0,
      "line_hash": "83f8cea",
      "speaker": "",
      "ja": "真っ白な愛液が膣奥からドロドロと溢れ、その滑りがさらなる快感を呼び込む。",
      "zh": ""
    },
    {
      "key": "105.0",
      "line_index": 105,
      "inline_index": 0,
      "line_hash": "ec156c67",
      "speaker": "",
      "ja": "俺は興奮と快感に身を任せながら激しくピストンを繰り返し、エッチでカワイイフォニーにさらにのめり込んでいく。",
      "zh": ""
    },
    {
      "key": "108.0",
      "line_index": 108,
      "inline_index": 0,
      "line_hash": "4bcfc9d7",
      "speaker": "フォニー",
      "ja": "んぅぅぅっ！♥　奥ばっかりぃっ！♥　んぅ、気持ち良い、気持ち良いよぉっ！♥　はぁ、あはぁっ！！♥",
      "zh": ""
    },
    {
      "key": "111.0",
      "line_index": 111,
      "inline_index": 0,
      "line_hash": "d5e65d95",
      "speaker": "フォニー",
      "ja": "もっと、もっとしてぇ……あうっ！♥　ふあああ、ああぁっ、あはぁっ！！♥",
      "zh": ""
    },
    {
      "key": "114.0",
      "line_index": 114,
      "inline_index": 0,
      "line_hash": "6989b295",
      "speaker": "{G_PlayerName}",
      "ja": "くう、すげえ締まり……！！",
      "zh": ""
    },
    {
      "key": "117.0",
      "line_index": 117,
      "inline_index": 0,
      "line_hash": "f8174de1",
      "speaker": "",
      "ja": "フォニーが感じるほど膣が締め上げ、快感のあまり思わず肉棒を引き抜きそうになってしまう。",
      "zh": ""
    },
    {
      "key": "119.0",
      "line_index": 119,
      "inline_index": 0,
      "line_hash": "2c7ad62f",
      "speaker": "",
      "ja": "それでもフォニーを求める性欲が肉棒を再び膣奥に押し込み、射精を求めひたすらに腰を突き動かす。",
      "zh": ""
    },
    {
      "key": "122.0",
      "line_index": 122,
      "inline_index": 0,
      "line_hash": "afa2f17c",
      "speaker": "フォニー",
      "ja": "んはぁっ、はぁっ！♥　ああ、も、もうダメっ♥　イっちゃう、イっちゃう！♥",
      "zh": ""
    },
    {
      "key": "124.0",
      "line_index": 124,
      "inline_index": 0,
      "line_hash": "70cde917",
      "speaker": "",
      "ja": "ぎゅっと肉棒を包み込む蕩けた膣から、卑猥な水音がさらに大きくなる。",
      "zh": ""
    },
    {
      "key": "125.0",
      "line_index": 125,
      "inline_index": 0,
      "line_hash": "1d0ab36d",
      "speaker": "",
      "ja": "ただでさえ狭い膣が肉棒を強く吸い上げ、精液を搾り取ろうと絡みつく。",
      "zh": ""
    },
    {
      "key": "128.0",
      "line_index": 128,
      "inline_index": 0,
      "line_hash": "102fa458",
      "speaker": "{G_PlayerName}",
      "ja": "フォニー……！　このまま出すぞ……！！",
      "zh": ""
    },
    {
      "key": "132.0",
      "line_index": 132,
      "inline_index": 0,
      "line_hash": "e673df59",
      "speaker": "フォニー",
      "ja": "ああ、ああぁっ！♥　イクイクっ！♥　イっ……！♥　んっ、んんんんんんっ！！♥♥",
      "zh": ""
    },
    {
      "key": "140.0",
      "line_index": 140,
      "inline_index": 0,
      "line_hash": "23779dc2",
      "speaker": "フォニー",
      "ja": "んはぁっ！♥　んっ！♥　んふぅぅ、ふあ、あ、はぁぁぁぁんっ！！♥♥",
      "zh": ""
    },
    {
      "key": "142.0",
      "line_index": 142,
      "inline_index": 0,
      "line_hash": "def5c360",
      "speaker": "",
      "ja": "甲高い悲鳴と共に果てるフォニー。",
      "zh": ""
    },
    {
      "key": "143.0",
      "line_index": 143,
      "inline_index": 0,
      "line_hash": "890a412",
      "speaker": "",
      "ja": "膣がぎゅっと肉棒を締め上げ、その快感に耐え切れず俺も射精してしまう。",
      "zh": ""
    },
    {
      "key": "146.0",
      "line_index": 146,
      "inline_index": 0,
      "line_hash": "6d6880d8",
      "speaker": "フォニー",
      "ja": "う、ううっ♥　出て、るぅ……！♥　おまんこの奥にいっぱいぃ……♥　あう、イクの、止まらないぃ……あうう、んぅぅっ！！♥♥",
      "zh": ""
    },
    {
      "key": "148.0",
      "line_index": 148,
      "inline_index": 0,
      "line_hash": "8b17d01e",
      "speaker": "",
      "ja": "少しでもフォニーの中で果てようと俺は腰を小刻みに揺する。",
      "zh": ""
    },
    {
      "key": "149.0",
      "line_index": 149,
      "inline_index": 0,
      "line_hash": "4da0fc31",
      "speaker": "",
      "ja": "射精のたびにフォニーは絶頂し、ビクンビクンと何度も大きく身体を跳ねらせる。",
      "zh": ""
    },
    {
      "key": "151.0",
      "line_index": 151,
      "inline_index": 0,
      "line_hash": "33805c63",
      "speaker": "",
      "ja": "いやらしく絶頂する姿に俺は射精しているにも関わらず興奮し、何度も膣奥に精液を注ぎ込み続けた。",
      "zh": ""
    },
    {
      "key": "154.0",
      "line_index": 154,
      "inline_index": 0,
      "line_hash": "f3494fd9",
      "speaker": "フォニー",
      "ja": "はぁ、はぁっ！♥　んはぁっ♥　うう、出しすぎぃ……子宮の中、すごいことになっているんですけどぉ……あはぁ……♥",
      "zh": ""
    },
    {
      "key": "157.0",
      "line_index": 157,
      "inline_index": 0,
      "line_hash": "4086af90",
      "speaker": "{G_PlayerName}",
      "ja": "そう、みたいだな……はぁ、はぁ……",
      "zh": ""
    },
    {
      "key": "161.0",
      "line_index": 161,
      "inline_index": 0,
      "line_hash": "3d6d75d9",
      "speaker": "フォニー",
      "ja": "あうっ！？♥　だめっ、お腹摩らないでぇ……♥　んんんんっ！！♥",
      "zh": ""
    },
    {
      "key": "163.0",
      "line_index": 163,
      "inline_index": 0,
      "line_hash": "9d806b45",
      "speaker": "",
      "ja": "フォニーのお腹を擦ると僅かに膨らみを感じる。",
      "zh": ""
    },
    {
      "key": "164.0",
      "line_index": 164,
      "inline_index": 0,
      "line_hash": "52efa172",
      "speaker": "",
      "ja": "それだけフォニーの子宮に射精したのかと思うだけで、ゾクゾクと身体が震え上がる。",
      "zh": ""
    },
    {
      "key": "166.0",
      "line_index": 166,
      "inline_index": 0,
      "line_hash": "a92b1f32",
      "speaker": "",
      "ja": "もっとフォニーとセックスしたい……その気持ちを指し示すようにそっと背後からフォニーの小さな身体を抱きしめてしまう。",
      "zh": ""
    },
    {
      "key": "169.0",
      "line_index": 169,
      "inline_index": 0,
      "line_hash": "b2b4251c",
      "speaker": "フォニー",
      "ja": "もう３回も出しているのに、まだおちんちん硬いままなんだけど……まだ満足していない……？♥",
      "zh": ""
    },
    {
      "key": "172.0",
      "line_index": 172,
      "inline_index": 0,
      "line_hash": "2acad00",
      "speaker": "{G_PlayerName}",
      "ja": "ああ……フォニーが欲しすぎて満足できるわけないだろ……ヘンな魔法をかけたのが悪いんだからな？",
      "zh": ""
    },
    {
      "key": "180.0",
      "line_index": 180,
      "inline_index": 0,
      "line_hash": "23c96dac",
      "speaker": "フォニー",
      "ja": "やぁぁっ！♥　あ、脚持ち上げないでぇ……！！♥　精液垂れてきちゃうわ！♥",
      "zh": ""
    },
    {
      "key": "183.0",
      "line_index": 183,
      "inline_index": 0,
      "line_hash": "70d197fe",
      "speaker": "フォニー",
      "ja": "こ、こんな犬のおしっこみたいな格好……恥ずかしいっ♥",
      "zh": ""
    },
    {
      "key": "185.0",
      "line_index": 185,
      "inline_index": 0,
      "line_hash": "c28900d6",
      "speaker": "",
      "ja": "脚を持ち上げたことで僅かに肉棒と膣に隙間が出来、精液と愛液が糸を引きながら床に垂れ落ちる。",
      "zh": ""
    },
    {
      "key": "187.0",
      "line_index": 187,
      "inline_index": 0,
      "line_hash": "d73b551c",
      "speaker": "",
      "ja": "フォニーは恥ずかしさのあまり首まで真っ赤になり、どれだけ恥ずかしがっているのか背後からでもわかってしまう。",
      "zh": ""
    },
    {
      "key": "190.0",
      "line_index": 190,
      "inline_index": 0,
      "line_hash": "f6bc4c05",
      "speaker": "{G_PlayerName}",
      "ja": "動いてもいないのに奥から愛液溢れてきてるぞ？　フォニーも満足していないんだろ？",
      "zh": ""
    },
    {
      "key": "194.0",
      "line_index": 194,
      "inline_index": 0,
      "line_hash": "64a40863",
      "speaker": "フォニー",
      "ja": "そ、それは……あ、ダメ、腰揺すらないでぇ……！♥　イったばっかりなんだからぁっ！♥",
      "zh": ""
    },
    {
      "key": "196.0",
      "line_index": 196,
      "inline_index": 0,
      "line_hash": "464d8d7f",
      "speaker": "",
      "ja": "フォニーの耳元で囁きながら割れ目を肉棒で擦り上げる。",
      "zh": ""
    },
    {
      "key": "198.0",
      "line_index": 198,
      "inline_index": 0,
      "line_hash": "8e914cea",
      "speaker": "",
      "ja": "身体をブルブルと小さく震わせながら、さらに大量の愛液が精液を押し出すように垂れ落ちる。",
      "zh": ""
    },
    {
      "key": "201.0",
      "line_index": 201,
      "inline_index": 0,
      "line_hash": "b68d33a2",
      "speaker": "{G_PlayerName}",
      "ja": "犯して欲しいんだろ？　もっと中出しして欲しいんだろ？　おまんこのハッキリ動きでわかるぞ",
      "zh": ""
    },
    {
      "key": "205.0",
      "line_index": 205,
      "inline_index": 0,
      "line_hash": "66c78c2b",
      "speaker": "フォニー",
      "ja": "ううう……そ、そうよぉ……♥　んぅ、あんなに突きまくったあなたがいけないんだからぁっ♥",
      "zh": ""
    },
    {
      "key": "212.0",
      "line_index": 212,
      "inline_index": 0,
      "line_hash": "8fcc73b8",
      "speaker": "フォニー",
      "ja": "んぉっ！？♥　あお、おおっ！♥　んぅぅぅ、んひぃっ！♥　ふっ、ふぅ、ふあ、あおっ♥　おお゛っ！！♥",
      "zh": ""
    },
    {
      "key": "214.0",
      "line_index": 214,
      "inline_index": 0,
      "line_hash": "59728eb",
      "speaker": "",
      "ja": "俺は再び肉棒を押し込むと、子宮口を押し潰すように腰を押し付ける。",
      "zh": ""
    },
    {
      "key": "216.0",
      "line_index": 216,
      "inline_index": 0,
      "line_hash": "617cbba6",
      "speaker": "",
      "ja": "いきなりの挿入とピストンに軽く絶頂してしまうフォニー。",
      "zh": ""
    },
    {
      "key": "217.0",
      "line_index": 217,
      "inline_index": 0,
      "line_hash": "225ac7d5",
      "speaker": "",
      "ja": "プシャっと潮を噴かせながら、快感から逃げるように腰を捩らせる。",
      "zh": ""
    },
    {
      "key": "220.0",
      "line_index": 220,
      "inline_index": 0,
      "line_hash": "664c192e",
      "speaker": "フォニー",
      "ja": "らめぇっ！♥　刺激がっ……あうっ！！♥　待ってぇっ！♥　うううう、こんな激しいのっ、ムリぃっ！♥　んひぃぃぃっ！！♥",
      "zh": ""
    },
    {
      "key": "222.0",
      "line_index": 222,
      "inline_index": 0,
      "line_hash": "3d6ff166",
      "speaker": "",
      "ja": "蕩け切った膣が肉棒を撫で上げるたびにゾクっと快感が全身を駆け巡る。",
      "zh": ""
    },
    {
      "key": "224.0",
      "line_index": 224,
      "inline_index": 0,
      "line_hash": "b690f2cc",
      "speaker": "",
      "ja": "その気持ち良さに夢中になるように俺はピストンを繰り返し、肉棒を押し込むたびにフォニーは身体を震わせ悶える。",
      "zh": ""
    },
    {
      "key": "226.0",
      "line_index": 226,
      "inline_index": 0,
      "line_hash": "8a607a7b",
      "speaker": "",
      "ja": "三度射精した肉棒は膣の気持ち良さとフォニーのエロ可愛さにさらに硬くなり、狭い膣を蹂躙するようにビクンと何度も跳ね上がっていた。",
      "zh": ""
    },
    {
      "key": "229.0",
      "line_index": 229,
      "inline_index": 0,
      "line_hash": "b7d07191",
      "speaker": "フォニー",
      "ja": "こんなのムリぃっ♥　おまんこおかしくなっちゃう！♥　あああっ！♥　おまんこイキっぱなしぃっ！♥　あひぃっ！！♥",
      "zh": ""
    },
    {
      "key": "232.0",
      "line_index": 232,
      "inline_index": 0,
      "line_hash": "93a4a4f9",
      "speaker": "フォニー",
      "ja": "ひゃいっ！？♥　あああぁっ！！♥　クリダメぇええっ！！♥　あ、あっ！！♥　同時になんて無理だってぇえっ！♥　らめらめらめぇええっ！！♥",
      "zh": ""
    },
    {
      "key": "234.0",
      "line_index": 234,
      "inline_index": 0,
      "line_hash": "83244133",
      "speaker": "",
      "ja": "俺はさらにフォニーを感じさせようとクリトリスに指を伸ばす。",
      "zh": ""
    },
    {
      "key": "236.0",
      "line_index": 236,
      "inline_index": 0,
      "line_hash": "cf70bf64",
      "speaker": "",
      "ja": "愛液と精液に塗れ限界まで肥大化していた突起物を指先で摘まむ。",
      "zh": ""
    },
    {
      "key": "237.0",
      "line_index": 237,
      "inline_index": 0,
      "line_hash": "f8fa60cc",
      "speaker": "",
      "ja": "コリコリと指の腹で擦るとさらに膣がギュっと締まり、さらにフォニーの顔がいやらしく歪んでいく。",
      "zh": ""
    },
    {
      "key": "240.0",
      "line_index": 240,
      "inline_index": 0,
      "line_hash": "e8b3c3df",
      "speaker": "フォニー",
      "ja": "ひお、おっ！♥　ふぅ、ふぐっ！♥　んふぅ、そんなにっ、されたらぁっ……んふぅうぅっ！！♥",
      "zh": ""
    },
    {
      "key": "243.0",
      "line_index": 243,
      "inline_index": 0,
      "line_hash": "256e735d",
      "speaker": "フォニー",
      "ja": "ますますあなたに恋しちゃうぅっ！♥　あなたから離れられなくなってしまう～っ！！♥",
      "zh": ""
    },
    {
      "key": "246.0",
      "line_index": 246,
      "inline_index": 0,
      "line_hash": "a1b5e5fd",
      "speaker": "{G_PlayerName}",
      "ja": "離れる必要なんてないだろ、もうフォニーは一生俺の傍にいるんだ、決定事項だからなっ！",
      "zh": ""
    },
    {
      "key": "250.0",
      "line_index": 250,
      "inline_index": 0,
      "line_hash": "480336ae",
      "speaker": "フォニー",
      "ja": "ひぐぅぅっ！♥　そんな一方的にぃぃっ！♥　はうう、んぅぅ、んお゛っ！♥　お゛っ！♥　おお゛っ！！♥",
      "zh": ""
    },
    {
      "key": "252.0",
      "line_index": 252,
      "inline_index": 0,
      "line_hash": "4bf9ccac",
      "speaker": "",
      "ja": "腰を回転させグリグリと子宮口を押し潰す。",
      "zh": ""
    },
    {
      "key": "253.0",
      "line_index": 253,
      "inline_index": 0,
      "line_hash": "c573ce04",
      "speaker": "",
      "ja": "俺の攻めにフォニーはたまらず喉の奥から搾り出したような声を上げ、その声が俺を余計に高ぶらせる。",
      "zh": ""
    },
    {
      "key": "255.0",
      "line_index": 255,
      "inline_index": 0,
      "line_hash": "6be0c3ce",
      "speaker": "",
      "ja": "俺はその興奮をフォニーにぶつけるようにさらにクリトリスを激しく擦り、フォニーは腰をビクンと張らせる。",
      "zh": ""
    },
    {
      "key": "258.0",
      "line_index": 258,
      "inline_index": 0,
      "line_hash": "3ada8d32",
      "speaker": "フォニー",
      "ja": "んっ、んあっ！♥　ダメっ！♥　またイっちゃう！♥　おまんこもクリも気持ち良いっ！！♥",
      "zh": ""
    },
    {
      "key": "261.0",
      "line_index": 261,
      "inline_index": 0,
      "line_hash": "d4d34ec6",
      "speaker": "{G_PlayerName}",
      "ja": "俺もだ……また中で出すからな？　フォニーの子宮に精液押し込むから",
      "zh": ""
    },
    {
      "key": "265.0",
      "line_index": 265,
      "inline_index": 0,
      "line_hash": "e09b2a5f",
      "speaker": "フォニー",
      "ja": "ううううっ！♥　これ以上は無理よぉっ！♥　子宮おかしくなっちゃう～っ！！♥",
      "zh": ""
    },
    {
      "key": "268.0",
      "line_index": 268,
      "inline_index": 0,
      "line_hash": "2aca4106",
      "speaker": "フォニー",
      "ja": "あおっ！？♥　お゛っ！♥　んお゛っ！！♥　らっ、めぇっ！♥　入っちゃうぅ！♥　子宮におちんちん入っちゃうぅっ！！♥",
      "zh": ""
    },
    {
      "key": "271.0",
      "line_index": 271,
      "inline_index": 0,
      "line_hash": "2d874fec",
      "speaker": "{G_PlayerName}",
      "ja": "フォニーのすべてが俺のだってマーキングするから……！！",
      "zh": ""
    },
    {
      "key": "275.0",
      "line_index": 275,
      "inline_index": 0,
      "line_hash": "b0d80140",
      "speaker": "フォニー",
      "ja": "ふぎいいいっ！♥　おおおお゛！♥　ふおっ、お゛！♥　んぅ、んふぅっ！♥　ふあ、ふあああっ！！♥",
      "zh": ""
    },
    {
      "key": "278.0",
      "line_index": 278,
      "inline_index": 0,
      "line_hash": "b1bea9fc",
      "speaker": "フォニー",
      "ja": "イっぢゃうっ！♥　おまんごイグっ！！♥　イグイグぅっ！♥　あ、あぁっ！！♥",
      "zh": ""
    },
    {
      "key": "281.0",
      "line_index": 281,
      "inline_index": 0,
      "line_hash": "1f52cdb6",
      "speaker": "{G_PlayerName}",
      "ja": "ううっ！！　出すぞ……！　また子宮で受け止めてくれぇっ！！",
      "zh": ""
    },
    {
      "key": "291.0",
      "line_index": 291,
      "inline_index": 0,
      "line_hash": "35eb1526",
      "speaker": "フォニー",
      "ja": "イグぅぅぅっ！♥　んはっ、あああああぁぁぁぁ～～～っ！！♥♥",
      "zh": ""
    },
    {
      "key": "293.0",
      "line_index": 293,
      "inline_index": 0,
      "line_hash": "1a539010",
      "speaker": "",
      "ja": "亀頭の先端を無理やり子宮口に押し込んだ瞬間、フォニーは甲高い悲鳴を上げながら絶頂する。",
      "zh": ""
    },
    {
      "key": "295.0",
      "line_index": 295,
      "inline_index": 0,
      "line_hash": "ae1ee67f",
      "speaker": "",
      "ja": "柔らかな膣が精液を搾り取るように蠢き、俺はそれに逆らわずに子宮に直接精液を流し込む。",
      "zh": ""
    },
    {
      "key": "298.0",
      "line_index": 298,
      "inline_index": 0,
      "line_hash": "914ee42a",
      "speaker": "フォニー",
      "ja": "また、いっぱいぃ……あうっ！♥　びゅるびゅるしゅごいぃっ！♥　子宮蕩けちゃう……はぁ、んはぁぁぁっ！！♥♥",
      "zh": ""
    },
    {
      "key": "301.0",
      "line_index": 301,
      "inline_index": 0,
      "line_hash": "48bf1fe5",
      "speaker": "フォニー",
      "ja": "もっとぉ……もっとらしてぇ～……♥　子宮いっぱいにしてぇ～……♥　あひぃ、ひぃっ！♥♥",
      "zh": ""
    },
    {
      "key": "303.0",
      "line_index": 303,
      "inline_index": 0,
      "line_hash": "5a6be950",
      "speaker": "",
      "ja": "俺はフォニーに応えるように子宮口で亀頭を扱き何度も射精を繰り返す。",
      "zh": ""
    },
    {
      "key": "305.0",
      "line_index": 305,
      "inline_index": 0,
      "line_hash": "23809b87",
      "speaker": "",
      "ja": "フォニーはすっかり快楽に溺れ、蕩けた声を上げながら子宮で精液を受け止める。",
      "zh": ""
    },
    {
      "key": "306.0",
      "line_index": 306,
      "inline_index": 0,
      "line_hash": "fdeed079",
      "speaker": "",
      "ja": "恍惚とした笑みを見せながら何度も絶頂を繰り返し、普段のキリっとしたフォニーとは別人のようにさえ思えてしまった。",
      "zh": ""
    },
    {
      "key": "309.0",
      "line_index": 309,
      "inline_index": 0,
      "line_hash": "8c1db973",
      "speaker": "フォニー",
      "ja": "あひぃ、あひぃぃ……♥　セックスしゅごいのぉ……♥　しゅきな人セックス……幸せだよぉ……♥",
      "zh": ""
    },
    {
      "key": "312.0",
      "line_index": 312,
      "inline_index": 0,
      "line_hash": "6f00dc44",
      "speaker": "フォニー",
      "ja": "もっとぉ……もっとセックスしてぇ……♥　おまんこしゅきしゅきしてぇ……♥　精液ドクドクしてぇ～……♥",
      "zh": ""
    },
    {
      "key": "315.0",
      "line_index": 315,
      "inline_index": 0,
      "line_hash": "93e7f2f3",
      "speaker": "{G_PlayerName}",
      "ja": "（さすがにやり過ぎたかな……とっくに魔法は解けてるっぽいけど、こんなにしちゃったんだったらちゃんと責任取らないとな……）",
      "zh": ""
    },
    {
      "key": "318.0",
      "line_index": 318,
      "inline_index": 0,
      "line_hash": "4cebd2b6",
      "speaker": "",
      "ja": "俺はそう思いながらそっとフォニーの小さな身体を抱きしめる。",
      "zh": ""
    },
    {
      "key": "321.0",
      "line_index": 321,
      "inline_index": 0,
      "line_hash": "3765e8e6",
      "speaker": "フォニー",
      "ja": "セックスしてぇ……♥　だいしゅきなあなたにもっと愛されたいのぉ……♥",
      "zh": ""
    },
    {
      "key": "324.0",
      "line_index": 324,
      "inline_index": 0,
      "line_hash": "fa8db1bb",
      "speaker": "{G_PlayerName}",
      "ja": "わかった……フォニーが満足するまでエッチするから。今度なゆっくり愛するから",
      "zh": ""
    },
    {
      "key": "328.0",
      "line_index": 328,
      "inline_index": 0,
      "line_hash": "2b7d5afe",
      "speaker": "フォニー",
      "ja": "ゆっくりでもはげしくてもどっちでもいいのぉ……♥　あなたに愛されるならぁ……♥",
      "zh": ""
    },
    {
      "key": "330.0",
      "line_index": 330,
      "inline_index": 0,
      "line_hash": "7dea00a9",
      "speaker": "",
      "ja": "フォニーの淫らな欲望と、射精しても衰える気配の無い俺の性欲がいつまでもお互いを求める。",
      "zh": ""
    },
    {
      "key": "331.0",
      "line_index": 331,
      "inline_index": 0,
      "line_hash": "a3e2a05e",
      "speaker": "",
      "ja": "お互いを貪り合うように俺たちはいつまでもセックスを繰り返すのであった。",
      "zh": ""
    }
  ]
}
