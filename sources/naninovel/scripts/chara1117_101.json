{
  "lines": [
    {
      "key": "10.1",
      "line_index": 10,
      "inline_index": 1,
      "line_hash": "31ecf416",
      "speaker": "真宵",
      "ja": "おにぃ、いたぁ～！",
      "zh": ""
    },
    {
      "key": "12.0",
      "line_index": 12,
      "inline_index": 0,
      "line_hash": "6d04414",
      "speaker": "",
      "ja": "真宵はソファに座る{G_PlayerName}を見つけると、嬉しそうにその腕に飛びついた。",
      "zh": ""
    },
    {
      "key": "14.0",
      "line_index": 14,
      "inline_index": 0,
      "line_hash": "e93a8081",
      "speaker": "{G_PlayerName}",
      "ja": "うわっ！　真宵っ！　いきなり抱きついてくるなよ！　もう真宵は毎日元気だな、はははっ",
      "zh": ""
    },
    {
      "key": "16.1",
      "line_index": 16,
      "inline_index": 1,
      "line_hash": "c418ae4f",
      "speaker": "真宵",
      "ja": "むむっ！",
      "zh": ""
    },
    {
      "key": "18.1",
      "line_index": 18,
      "inline_index": 1,
      "line_hash": "5077d07d",
      "speaker": "真宵",
      "ja": "（あたしみたいな女の子が抱きついているのに、おにぃは照れもしなければ動揺もしないって、どういうこと？）",
      "zh": ""
    },
    {
      "key": "20.1",
      "line_index": 20,
      "inline_index": 1,
      "line_hash": "1e433bcd",
      "speaker": "真宵",
      "ja": "（それにこの対応って……あたしを異性として見ていないんじゃ？　完全に妹みたいな扱いなんだけど！）",
      "zh": ""
    },
    {
      "key": "22.0",
      "line_index": 22,
      "inline_index": 0,
      "line_hash": "aebf2619",
      "speaker": "{G_PlayerName}",
      "ja": "んっ、真宵？　どうかしたのか？",
      "zh": ""
    },
    {
      "key": "24.1",
      "line_index": 24,
      "inline_index": 1,
      "line_hash": "2bbe8f2",
      "speaker": "真宵",
      "ja": "べ、別に～……なんでもないよ～",
      "zh": ""
    },
    {
      "key": "26.1",
      "line_index": 26,
      "inline_index": 1,
      "line_hash": "90787f19",
      "speaker": "真宵",
      "ja": "（くそー！　何としてもおにぃに女として意識して貰わなきゃ！）",
      "zh": ""
    },
    {
      "key": "28.1",
      "line_index": 28,
      "inline_index": 1,
      "line_hash": "38a9222b",
      "speaker": "真宵",
      "ja": "（やっぱり女として意識させるには、ボディータッチだよねっ♥）",
      "zh": ""
    },
    {
      "key": "30.1",
      "line_index": 30,
      "inline_index": 1,
      "line_hash": "74a6a1f6",
      "speaker": "真宵",
      "ja": "ねえねえ、おにぃ♥　何作ってたのー？",
      "zh": ""
    },
    {
      "key": "32.1",
      "line_index": 32,
      "inline_index": 1,
      "line_hash": "9c252ca3",
      "speaker": "真宵",
      "ja": "（どうだ！　こうやって腕にギュッと抱きついておっぱいを押しつけてやる！）",
      "zh": ""
    },
    {
      "key": "34.0",
      "line_index": 34,
      "inline_index": 0,
      "line_hash": "cd8ae8f5",
      "speaker": "",
      "ja": "真宵は作戦通り、小さな胸を腕で必死に寄せながら{G_PlayerName}へと擦り付けた。",
      "zh": ""
    },
    {
      "key": "36.1",
      "line_index": 36,
      "inline_index": 1,
      "line_hash": "3c2695bc",
      "speaker": "真宵",
      "ja": "（これぞ必殺おっぱい攻撃！　ちっさいけどあたしにだっておっぱいは一応あるし！）",
      "zh": ""
    },
    {
      "key": "38.0",
      "line_index": 38,
      "inline_index": 0,
      "line_hash": "e2cf3599",
      "speaker": "{G_PlayerName}",
      "ja": "ん～……",
      "zh": ""
    },
    {
      "key": "40.1",
      "line_index": 40,
      "inline_index": 1,
      "line_hash": "ac920658",
      "speaker": "真宵",
      "ja": "（こうやって腕におっぱいを押しつけてるんだし、おにぃだって男なんだから絶対に興奮……って無反応ぉ～？！）",
      "zh": ""
    },
    {
      "key": "42.1",
      "line_index": 42,
      "inline_index": 1,
      "line_hash": "67c0b50b",
      "speaker": "真宵",
      "ja": "（あたしが強くおっぱい押しつけてるのに手元の機械に集中して！　どういうことー！）",
      "zh": ""
    },
    {
      "key": "44.0",
      "line_index": 44,
      "inline_index": 0,
      "line_hash": "88669477",
      "speaker": "{G_PlayerName}",
      "ja": "別に作っていたわけじゃなくてさ、これが何なのかさえよくわからないから、取りあえず分解しようと思ってね",
      "zh": ""
    },
    {
      "key": "49.1",
      "line_index": 49,
      "inline_index": 1,
      "line_hash": "60fd12c9",
      "speaker": "ルルハ",
      "ja": "あー♪　きみたち～♪　何をして遊んでるのかな～？",
      "zh": ""
    },
    {
      "key": "51.0",
      "line_index": 51,
      "inline_index": 0,
      "line_hash": "d28efa19",
      "speaker": "",
      "ja": "そこに唐突に現れたルルハが、{G_PlayerName}の手元を覗き込むように背後に近寄る。",
      "zh": ""
    },
    {
      "key": "52.0",
      "line_index": 52,
      "inline_index": 0,
      "line_hash": "b329361c",
      "speaker": "",
      "ja": "{G_PlayerName}の頭に胸を乗せ、ほぼ後ろから抱きしめているような形になっていた。",
      "zh": ""
    },
    {
      "key": "54.0",
      "line_index": 54,
      "inline_index": 0,
      "line_hash": "ea6c1b83",
      "speaker": "{G_PlayerName}",
      "ja": "うわぁ！　ルルハ！　ちょ、頭に乗ってるって！",
      "zh": ""
    },
    {
      "key": "56.1",
      "line_index": 56,
      "inline_index": 1,
      "line_hash": "849c0285",
      "speaker": "ルルハ",
      "ja": "別にいいじゃな～い♪　あたしときみの仲なんですから～",
      "zh": ""
    },
    {
      "key": "60.1",
      "line_index": 60,
      "inline_index": 1,
      "line_hash": "50278f18",
      "speaker": "真宵",
      "ja": "（あたしときみの仲～？！　どんな仲～？！　しかもおにぃは動揺してる？！　あたしも負けていられないっ！）",
      "zh": ""
    },
    {
      "key": "62.1",
      "line_index": 62,
      "inline_index": 1,
      "line_hash": "bb84b6d",
      "speaker": "真宵",
      "ja": "おにぃ～♪　ねえねえ、あたしとおにぃの仲ってどんな仲ぁ～？",
      "zh": ""
    },
    {
      "key": "64.0",
      "line_index": 64,
      "inline_index": 0,
      "line_hash": "3cc98603",
      "speaker": "{G_PlayerName}",
      "ja": "えっ！　い、いや……そんなに特別な仲というわけじゃ……",
      "zh": ""
    },
    {
      "key": "68.1",
      "line_index": 68,
      "inline_index": 1,
      "line_hash": "3b7f0308",
      "speaker": "ルルハ",
      "ja": "ひど～い、真宵ちゃんとは遊びだったの～？",
      "zh": ""
    },
    {
      "key": "70.0",
      "line_index": 70,
      "inline_index": 0,
      "line_hash": "d900fb09",
      "speaker": "{G_PlayerName}",
      "ja": "ちょっと……ルルハ……そういう言い方は変な誤解が……",
      "zh": ""
    },
    {
      "key": "77.1",
      "line_index": 77,
      "inline_index": 1,
      "line_hash": "36babc72",
      "speaker": "フィリス",
      "ja": "あらあら～♪　仲良く何をしてるんですか～♪　わたしも混ぜてもらえますでしょうか～♪",
      "zh": ""
    },
    {
      "key": "79.0",
      "line_index": 79,
      "inline_index": 0,
      "line_hash": "ef959db1",
      "speaker": "{G_PlayerName}",
      "ja": "わぁっ！？　びっくりした、フィリスか……！",
      "zh": ""
    },
    {
      "key": "81.0",
      "line_index": 81,
      "inline_index": 0,
      "line_hash": "3b5eba2",
      "speaker": "",
      "ja": "さらに何やら盛り上がっている{G_PlayerName}たちを見つけたフィリスは上機嫌にソファに腰かけた。",
      "zh": ""
    },
    {
      "key": "82.0",
      "line_index": 82,
      "inline_index": 0,
      "line_hash": "1a427e38",
      "speaker": "",
      "ja": "真宵とは反対側の{G_PlayerName}の隣に座り、2人で{G_PlayerName}を挟むような形になっている。",
      "zh": ""
    },
    {
      "key": "83.0",
      "line_index": 83,
      "inline_index": 0,
      "line_hash": "cc36f45b",
      "speaker": "",
      "ja": "フィリスはわざとなのか無自覚なのか、その体格に見合わない大き目の胸をむぎゅりと押し付けるようにして近づいてきた。",
      "zh": ""
    },
    {
      "key": "87.1",
      "line_index": 87,
      "inline_index": 1,
      "line_hash": "e0f40015",
      "speaker": "真宵",
      "ja": "（む～っ！　フィリスもおっぱい押しつけてるー！）",
      "zh": ""
    },
    {
      "key": "89.1",
      "line_index": 89,
      "inline_index": 1,
      "line_hash": "3ecc19cb",
      "speaker": "真宵",
      "ja": "（あたしだって負けてたまるか～！　そぉれ！　おっぱいをぐりぐり押しつけて～！）",
      "zh": ""
    },
    {
      "key": "91.1",
      "line_index": 91,
      "inline_index": 1,
      "line_hash": "d44878f8",
      "speaker": "真宵",
      "ja": "おにぃ、あたしにも見せてよ～♥",
      "zh": ""
    },
    {
      "key": "93.0",
      "line_index": 93,
      "inline_index": 0,
      "line_hash": "f38eba3d",
      "speaker": "{G_PlayerName}",
      "ja": "あ、そ、その……",
      "zh": ""
    },
    {
      "key": "95.1",
      "line_index": 95,
      "inline_index": 1,
      "line_hash": "8e5fc46",
      "speaker": "真宵",
      "ja": "（が～ん！　……おにぃ……フィリスが抱きついたときとは明らかに違うリアクション……）",
      "zh": ""
    },
    {
      "key": "97.1",
      "line_index": 97,
      "inline_index": 1,
      "line_hash": "c239551",
      "speaker": "真宵",
      "ja": "（おにぃ……おにぃは……おっぱい星人だったんだ……）",
      "zh": ""
    },
    {
      "key": "99.1",
      "line_index": 99,
      "inline_index": 1,
      "line_hash": "868245f5",
      "speaker": "真宵",
      "ja": "（こうなったら！　おにぃに相応しい女になるよう、おっぱいを大きくしないと！）",
      "zh": ""
    },
    {
      "key": "101.1",
      "line_index": 101,
      "inline_index": 1,
      "line_hash": "624fd4dc",
      "speaker": "真宵",
      "ja": "（まずは大量に牛乳を飲んで、おっぱいマッサージとか……おっぱいが大きくなることを片っ端からするぞー！）",
      "zh": ""
    },
    {
      "key": "103.0",
      "line_index": 103,
      "inline_index": 0,
      "line_hash": "b7e330e6",
      "speaker": "{G_PlayerName}",
      "ja": "ど、どうかしたのか？　真宵……",
      "zh": ""
    },
    {
      "key": "105.1",
      "line_index": 105,
      "inline_index": 1,
      "line_hash": "9f2199a0",
      "speaker": "真宵",
      "ja": "な、なんでもなーい♪　あたしちょっと用事を思い出したから！　またね、おにぃ！",
      "zh": ""
    },
    {
      "key": "107.0",
      "line_index": 107,
      "inline_index": 0,
      "line_hash": "bbd5a9bb",
      "speaker": "",
      "ja": "真宵は決意を胸に、ライバルたちから離れてキッチンへと向かった。",
      "zh": ""
    },
    {
      "key": "109.0",
      "line_index": 109,
      "inline_index": 0,
      "line_hash": "89701a41",
      "speaker": "{G_PlayerName}",
      "ja": "そ、そうか……じゃ、じゃあまた……",
      "zh": ""
    },
    {
      "key": "111.0",
      "line_index": 111,
      "inline_index": 0,
      "line_hash": "a8e39b2b",
      "speaker": "",
      "ja": "真宵が去った後、{G_PlayerName}はルルハやフィリスにバレないよう、こっそりため息をつく。",
      "zh": ""
    },
    {
      "key": "113.0",
      "line_index": 113,
      "inline_index": 0,
      "line_hash": "4bf08b51",
      "speaker": "{G_PlayerName}",
      "ja": "（はぁぁぁ……真宵……小さくてかわいい上にいい匂いしてたなぁ）",
      "zh": ""
    },
    {
      "key": "115.0",
      "line_index": 115,
      "inline_index": 0,
      "line_hash": "acb6e92d",
      "speaker": "{G_PlayerName}",
      "ja": "（ドキドキしているの真宵に気づかれる前に行ってくれて助かったぁ……）",
      "zh": ""
    },
    {
      "key": "117.0",
      "line_index": 117,
      "inline_index": 0,
      "line_hash": "7e2e6123",
      "speaker": "",
      "ja": "今はまだ真宵の乙女心と{G_PlayerName}の純情がすれ違い合っているものの、2人の距離は少しずつ近づいていくのであった……。",
      "zh": ""
    }
  ]
}
