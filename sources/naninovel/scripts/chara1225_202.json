    },
    {
      "key": "238.0",
      "line_index": 238,
      "inline_index": 0,
      "line_hash": "1b61433e",
      "speaker": "",
      "ja": "キャロットは目を閉じ笑みを浮かべながら{G_PlayerName}の射精を受けていく。",
