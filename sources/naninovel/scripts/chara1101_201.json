    {
      "key": "243.0",
      "line_index": 243,
      "inline_index": 0,
      "line_hash": "aee8d093",
      "speaker": "アポロ",
      "ja": "ダメっ、ダメっ！♥　ダメぇ～～～～～っ！！♥♥",
