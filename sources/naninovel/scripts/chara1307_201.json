{
  "lines": [
    {
      "key": "17.0",
      "line_index": 17,
      "inline_index": 0,
      "line_hash": "e2f7fe",
      "speaker": "",
      "ja": "雫と歩く途中、{G_PlayerName}は不意に不調を訴え始める。",
      "zh": ""
    },
    {
      "key": "20.1",
      "line_index": 20,
      "inline_index": 1,
      "line_hash": "80c42ebf",
      "speaker": "雫",
      "ja": "急にどうしたんですか、早く行きますよ",
      "zh": ""
    },
    {
      "key": "23.0",
      "line_index": 23,
      "inline_index": 0,
      "line_hash": "5d73ca5d",
      "speaker": "{G_PlayerName}",
      "ja": "す、すまん……なにか……体が熱くなって……動けそうにない……",
      "zh": ""
    },
    {
      "key": "26.0",
      "line_index": 26,
      "inline_index": 0,
      "line_hash": "71598ec0",
      "speaker": "",
      "ja": "そう言った{G_PlayerName}の股間ではおちんちんがすっかりいきり立ってしまっていた。",
      "zh": ""
    },
    {
      "key": "29.1",
      "line_index": 29,
      "inline_index": 1,
      "line_hash": "8b3681b4",
      "speaker": "雫",
      "ja": "またルナリングの影響ですか……さっさと立ちなさい、のろま！",
      "zh": ""
    },
    {
      "key": "31.0",
      "line_index": 31,
      "inline_index": 0,
      "line_hash": "7ae18483",
      "speaker": "",
      "ja": "そう罵られても{G_PlayerName}はその場にうずくまったまま動けずにいる。",
      "zh": ""
    },
    {
      "key": "33.0",
      "line_index": 33,
      "inline_index": 0,
      "line_hash": "1d3ab71d",
      "speaker": "",
      "ja": "そんな{G_PlayerName}を呆れた顔で見つめながら雫は大きな溜め息を吐いて呟いた。",
      "zh": ""
    },
    {
      "key": "36.1",
      "line_index": 36,
      "inline_index": 1,
      "line_hash": "311964ad",
      "speaker": "雫",
      "ja": "はぁぁ……仕方ありません……さっさとその愚物を鎮めなさい",
      "zh": ""
    },
    {
      "key": "39.0",
      "line_index": 39,
      "inline_index": 0,
      "line_hash": "7ee9cce4",
      "speaker": "{G_PlayerName}",
      "ja": "だ、だったら……早く鎮まるように手伝ってくれよ……うぅぅ……",
      "zh": ""
    },
    {
      "key": "43.1",
      "line_index": 43,
      "inline_index": 1,
      "line_hash": "96341e92",
      "speaker": "雫",
      "ja": "なんでそんなことをしなければいけないんです！　自分で何とかしなさい！",
      "zh": ""
    },
    {
      "key": "46.0",
      "line_index": 46,
      "inline_index": 0,
      "line_hash": "34731ba2",
      "speaker": "{G_PlayerName}",
      "ja": "で、でもこのままじゃ……うっ……うぅぅ……",
      "zh": ""
    },
    {
      "key": "49.0",
      "line_index": 49,
      "inline_index": 0,
      "line_hash": "1046df6f",
      "speaker": "",
      "ja": "{G_PlayerName}はあまりの高まりに勃起したおちんちんを取り出すと激しくしごき始める。",
      "zh": ""
    },
    {
      "key": "51.0",
      "line_index": 51,
      "inline_index": 0,
      "line_hash": "aa69d632",
      "speaker": "",
      "ja": "しかしオナニーぐらいではまるで鎮まる気配がない。",
      "zh": ""
    },
    {
      "key": "53.0",
      "line_index": 53,
      "inline_index": 0,
      "line_hash": "6e97cf7c",
      "speaker": "",
      "ja": "しばらく様子を見ていた雫だが、一向に終わりそうにない{G_PlayerName}の自慰行為にしびれを切らした。",
      "zh": ""
    },
    {
      "key": "56.1",
      "line_index": 56,
      "inline_index": 1,
      "line_hash": "76f31fd8",
      "speaker": "雫",
      "ja": "……仕方ありません……この服を汚すわけにはいきませんから……口でして差し上げます……",
      "zh": ""
    },
    {
      "key": "69.0",
      "line_index": 69,
      "inline_index": 0,
      "line_hash": "cdc3a28e",
      "speaker": "雫",
      "ja": "あむぅぅ……んぐ……んぐ……んぢゅる……うううっ……",
      "zh": ""
    },
    {
      "key": "71.0",
      "line_index": 71,
      "inline_index": 0,
      "line_hash": "b1992557",
      "speaker": "",
      "ja": "{G_PlayerName}のことを睨み付けながら雫は勃起したおちんちんを喉奥まで咥え込み、自ら頭を前後に振った。",
      "zh": ""
    },
    {
      "key": "73.0",
      "line_index": 73,
      "inline_index": 0,
      "line_hash": "a2d595c0",
      "speaker": "",
      "ja": "その度に{G_PlayerName}の肉竿全体が生暖かい感触に包まれ快感を覚える。",
      "zh": ""
    },
    {
      "key": "76.0",
      "line_index": 76,
      "inline_index": 0,
      "line_hash": "2f52dc7f",
      "speaker": "{G_PlayerName}",
      "ja": "あっ……あっ……くぅぅ……",
      "zh": ""
    },
    {
      "key": "79.0",
      "line_index": 79,
      "inline_index": 0,
      "line_hash": "18c860c7",
      "speaker": "",
      "ja": "気持ちよさそうに悶える{G_PlayerName}だが雫の方はすっかり苛立ってしまっていた。",
      "zh": ""
    },
    {
      "key": "82.0",
      "line_index": 82,
      "inline_index": 0,
      "line_hash": "f9d205d1",
      "speaker": "雫",
      "ja": "んんっ……なぜ私がこんなことを……！　うむぅぅ……ほら、さっさと出してしまいなさい！　んっぐんっぐ！",
      "zh": ""
    },
    {
      "key": "84.0",
      "line_index": 84,
      "inline_index": 0,
      "line_hash": "636e981d",
      "speaker": "",
      "ja": "{G_PlayerName}を早く射精させたい雫は激しいストロークで反り返った陰茎を口全体で責め立てていく。",
      "zh": ""
    },
    {
      "key": "86.0",
      "line_index": 86,
      "inline_index": 0,
      "line_hash": "2f742ae4",
      "speaker": "",
      "ja": "舌が裏スジに擦れる感触に{G_PlayerName}は激しい快感に襲われた。",
      "zh": ""
    },
    {
      "key": "89.0",
      "line_index": 89,
      "inline_index": 0,
      "line_hash": "21d3b6b7",
      "speaker": "{G_PlayerName}",
      "ja": "す、すご……いっ……いいっ……はぁ……はぁ……",
      "zh": ""
    },
    {
      "key": "93.0",
      "line_index": 93,
      "inline_index": 0,
      "line_hash": "f2761f67",
      "speaker": "雫",
      "ja": "んんんっ……こ、こんなにおちんちん……んっ……じゅぼっ……大きくさせて……むぢゅるぅぅ……",
      "zh": ""
    },
    {
      "key": "95.0",
      "line_index": 95,
      "inline_index": 0,
      "line_hash": "98b97aa7",
      "speaker": "",
      "ja": "雫は文句を言いつつも激しく{G_PlayerName}の剛直を喉元まで呑み込んで舐め回していく。",
      "zh": ""
    },
    {
      "key": "97.0",
      "line_index": 97,
      "inline_index": 0,
      "line_hash": "100fc5d1",
      "speaker": "",
      "ja": "その刺激に{G_PlayerName}の興奮は高まって、おちんちんの先からぬるっとした汁が滲み出してきた。",
      "zh": ""
    },
    {
      "key": "99.0",
      "line_index": 99,
      "inline_index": 0,
      "line_hash": "9df78fe4",
      "speaker": "",
      "ja": "雫は独特の匂いと感覚に嫌悪感を抱きつつ、それでも頭を前後に振って{G_PlayerName}の陰茎を根本まで何度も咥え込んでいく。",
      "zh": ""
    },
    {
      "key": "102.0",
      "line_index": 102,
      "inline_index": 0,
      "line_hash": "2f088e3d",
      "speaker": "雫",
      "ja": "んっぷっ！　んんんっ！　んぢゅるっ、ぢゅるぢゅる！　おふぅ！　おぅぅぅ！",
      "zh": ""
    },
    {
      "key": "105.0",
      "line_index": 105,
      "inline_index": 0,
      "line_hash": "10aa0bb6",
      "speaker": "{G_PlayerName}",
      "ja": "す、すごい……喉の奥に亀頭が当たる感じ……あっ……あぁぁぁ……",
      "zh": ""
    },
    {
      "key": "108.0",
      "line_index": 108,
      "inline_index": 0,
      "line_hash": "8fe47a7c",
      "speaker": "",
      "ja": "あまりにも激しい抽送に{G_PlayerName}は小さく体を震わせながら身悶えていった。",
      "zh": ""
    },
    {
      "key": "110.0",
      "line_index": 110,
      "inline_index": 0,
      "line_hash": "86659394",
      "speaker": "",
      "ja": "それでも雫のイラマチオは容赦なく、まるで精液を搾り取ろうとするように口全体で強く吸いついていく。",
      "zh": ""
    },
    {
      "key": "113.0",
      "line_index": 113,
      "inline_index": 0,
      "line_hash": "248da7f1",
      "speaker": "雫",
      "ja": "んっ！　んっ！　んっくぅぅぅ！　うっぷっ！　うっ！　んむぅぅぅっ！　ぢゅるるるっ！",
      "zh": ""
    },
    {
      "key": "116.0",
      "line_index": 116,
      "inline_index": 0,
      "line_hash": "9276bf8f",
      "speaker": "{G_PlayerName}",
      "ja": "あっ……うっ……うぅっ……はぁ……はぁぁ……",
      "zh": ""
    },
    {
      "key": "119.0",
      "line_index": 119,
      "inline_index": 0,
      "line_hash": "713b5bbe",
      "speaker": "",
      "ja": "雫の頭が前後する度に{G_PlayerName}の快感は大きくなってされるがままになっていた。",
      "zh": ""
    },
    {
      "key": "121.0",
      "line_index": 121,
      "inline_index": 0,
      "line_hash": "ae0409c7",
      "speaker": "",
      "ja": "そんな{G_PlayerName}を射精させるために雫は激しく頭を振って強く陰茎にしゃぶり付く。",
      "zh": ""
    },
    {
      "key": "124.0",
      "line_index": 124,
      "inline_index": 0,
      "line_hash": "ee02e80d",
      "speaker": "雫",
      "ja": "ぢゅるぢゅる……ほ、ほら……さっさと出しなさいっ……うむぅぅ……んっ、んんんっ！",
      "zh": ""
    },
    {
      "key": "127.0",
      "line_index": 127,
      "inline_index": 0,
      "line_hash": "9d7cdf82",
      "speaker": "{G_PlayerName}",
      "ja": "あっ……あっ……そんなに強く吸われたら……あうっ……うぅぅっ……",
      "zh": ""
    },
    {
      "key": "130.0",
      "line_index": 130,
      "inline_index": 0,
      "line_hash": "46e12d82",
      "speaker": "",
      "ja": "強くしゃぶられる程に{G_PlayerName}は絶頂へと強制的に誘われていった。",
      "zh": ""
    },
    {
      "key": "132.0",
      "line_index": 132,
      "inline_index": 0,
      "line_hash": "c0a172f6",
      "speaker": "",
      "ja": "陰茎が脈打ち上下に跳ねるが雫は構わずに頭を前後させながら舌を裏スジに擦りつけ続ける。",
      "zh": ""
    },
    {
      "key": "135.0",
      "line_index": 135,
      "inline_index": 0,
      "line_hash": "9929c37c",
      "speaker": "雫",
      "ja": "ぢゅるるっ！　んっくっ！　んっくっ！　んぢゅるぅ！　こんなにおちんちんをビクビクさせて……んちゅるぅ！　汁をだらだら漏らして……ぢゅるぢゅる！",
      "zh": ""
    },
    {
      "key": "138.0",
      "line_index": 138,
      "inline_index": 0,
      "line_hash": "fcfba28e",
      "speaker": "{G_PlayerName}",
      "ja": "も、もう……出るっ……あっ……くぅぅぅっ！",
      "zh": ""
    },
    {
      "key": "141.0",
      "line_index": 141,
      "inline_index": 0,
      "line_hash": "caad4558",
      "speaker": "",
      "ja": "あまりの快感にたまらず{G_PlayerName}は腰を震わせながら雫の口内に勢いよく精液をどぴゅどぴゅと放った。",
      "zh": ""
    },
    {
      "key": "150.0",
      "line_index": 150,
      "inline_index": 0,
      "line_hash": "ee26ad12",
      "speaker": "雫",
      "ja": "んぅっ！！　くっ、ぅ……ごく……ごく……",
      "zh": ""
    },
    {
      "key": "152.0",
      "line_index": 152,
      "inline_index": 0,
      "line_hash": "ef775025",
      "speaker": "",
      "ja": "喉奥に勢いよく流れ込んでくる精液の感触に驚きつつも雫はそれをゆっくりと飲み干していく。",
      "zh": ""
    },
    {
      "key": "154.0",
      "line_index": 154,
      "inline_index": 0,
      "line_hash": "a7ab5d06",
      "speaker": "",
      "ja": "そして全ての精液を飲み干すと恨めしい目で{G_PlayerName}を見つめながら呟いた。",
      "zh": ""
    },
    {
      "key": "157.0",
      "line_index": 157,
      "inline_index": 0,
      "line_hash": "8020859",
      "speaker": "雫",
      "ja": "んふぅぅ……どれだけ出すんですか……精液が喉を駆け抜けていく感覚が気持ち悪いんですけど……んくっ……でも……これで……",
      "zh": ""
    },
    {
      "key": "159.0",
      "line_index": 159,
      "inline_index": 0,
      "line_hash": "7e92f95b",
      "speaker": "",
      "ja": "やっと終わったと思った雫だが射精し終えても{G_PlayerName}のおちんちんは勃起したまま。",
      "zh": ""
    },
    {
      "key": "161.0",
      "line_index": 161,
      "inline_index": 0,
      "line_hash": "d5a779a1",
      "speaker": "",
      "ja": "その状態を目の当たりにして雫は呆れ顔を浮かべて呟く。",
      "zh": ""
    },
    {
      "key": "164.0",
      "line_index": 164,
      "inline_index": 0,
      "line_hash": "c70e2454",
      "speaker": "雫",
      "ja": "……って、この程度で満足するわけないですか……本当に性欲だけは底抜けですね",
      "zh": ""
    },
    {
      "key": "167.0",
      "line_index": 167,
      "inline_index": 0,
      "line_hash": "7bfa94ab",
      "speaker": "{G_PlayerName}",
      "ja": "ど、どうも……",
      "zh": ""
    },
    {
      "key": "171.0",
      "line_index": 171,
      "inline_index": 0,
      "line_hash": "54956e4a",
      "speaker": "雫",
      "ja": "褒めてません……純粋に軽蔑してます……",
      "zh": ""
    },
    {
      "key": "174.0",
      "line_index": 174,
      "inline_index": 0,
      "line_hash": "fe5dbd37",
      "speaker": "{G_PlayerName}",
      "ja": "はは……ははは……",
      "zh": ""
    },
    {
      "key": "177.0",
      "line_index": 177,
      "inline_index": 0,
      "line_hash": "24ade343",
      "speaker": "",
      "ja": "嫌味っぽい感じでそう言った雫はまだ萎えない{G_PlayerName}のおちんちんを手に取った。",
      "zh": ""
    },
    {
      "key": "180.0",
      "line_index": 180,
      "inline_index": 0,
      "line_hash": "abc85af3",
      "speaker": "雫",
      "ja": "仕方ないですね……",
      "zh": ""
    },
    {
      "key": "182.0",
      "line_index": 182,
      "inline_index": 0,
      "line_hash": "9adeb03f",
      "speaker": "",
      "ja": "半ば諦めが入った感じでそう呟いた雫は、再び大きく口を開くと{G_PlayerName}の陰茎をまた根本まで咥え込んでいく。",
      "zh": ""
    },
    {
      "key": "188.0",
      "line_index": 188,
      "inline_index": 0,
      "line_hash": "d4b7b995",
      "speaker": "雫",
      "ja": "んぐっ……うっ……んむぅぅ……んぢゅる……んっくんっくっ……ぢゅるぢゅる……",
      "zh": ""
    },
    {
      "key": "190.0",
      "line_index": 190,
      "inline_index": 0,
      "line_hash": "20dadffb",
      "speaker": "",
      "ja": "再びイラマチオを始めた雫は淫靡な音を立てながら{G_PlayerName}のおちんちんを喉の近くまで使ってしゃぶった。",
      "zh": ""
    },
    {
      "key": "192.0",
      "line_index": 192,
      "inline_index": 0,
      "line_hash": "4f1de915",
      "speaker": "",
      "ja": "その気持ちよさに{G_PlayerName}は思わず呻き声を漏らしながら陰茎を硬く大きく反り返らせていく。",
      "zh": ""
    },
    {
      "key": "194.0",
      "line_index": 194,
      "inline_index": 0,
      "line_hash": "220a5f63",
      "speaker": "",
      "ja": "そんな様子を見て気に入らない{G_PlayerName}を好き勝手にしているという優越感を得た雫は、ご満悦という感じで笑みを浮かべながら何度も深く陰茎を咥え込んだ。",
      "zh": ""
    },
    {
      "key": "197.0",
      "line_index": 197,
      "inline_index": 0,
      "line_hash": "1af2f1e9",
      "speaker": "雫",
      "ja": "んぐんぐっ……んむぅぅ……ぢゅるる……ちゅばちゅば……んふぅぅ……",
      "zh": ""
    },
    {
      "key": "200.0",
      "line_index": 200,
      "inline_index": 0,
      "line_hash": "ec39c44d",
      "speaker": "{G_PlayerName}",
      "ja": "あうぅ……き、気持ちよすぎる……はぁ……はぁ……",
      "zh": ""
    },
    {
      "key": "204.0",
      "line_index": 204,
      "inline_index": 0,
      "line_hash": "bf00f5e1",
      "speaker": "雫",
      "ja": "んんんっ……情けない顔をして……んぢゅるぅぅ！　ほらほら……ちゅるるぅ！　無様にまた射精しなさい……んぐんぐぅ！",
      "zh": ""
    },
    {
      "key": "207.0",
      "line_index": 207,
      "inline_index": 0,
      "line_hash": "9a9e3eeb",
      "speaker": "{G_PlayerName}",
      "ja": "あっ……あっ……あうぅぅ……",
      "zh": ""
    },
    {
      "key": "210.0",
      "line_index": 210,
      "inline_index": 0,
      "line_hash": "d993d906",
      "speaker": "",
      "ja": "何度も根本までおちんちんを咥え込まれ舌で嬲られた{G_PlayerName}はワナワナと唇を震わせながら呻き声を漏らし続ける。",
      "zh": ""
    },
    {
      "key": "212.0",
      "line_index": 212,
      "inline_index": 0,
      "line_hash": "cd6e460e",
      "speaker": "",
      "ja": "そんな{G_PlayerName}を見つめながら雫は喉元まで届いている陰茎を音を立てて舐め回した。",
      "zh": ""
    },
    {
      "key": "215.0",
      "line_index": 215,
      "inline_index": 0,
      "line_hash": "61758fb8",
      "speaker": "雫",
      "ja": "ぢゅるぢゅる！　んっ、ちゅうぅぅぅ！　ちゅばちゅばっ！　んぢゅるぅぅぅ！",
      "zh": ""
    },
    {
      "key": "218.0",
      "line_index": 218,
      "inline_index": 0,
      "line_hash": "a3629bff",
      "speaker": "{G_PlayerName}",
      "ja": "またそんなに……吸われると……うっ……うぅぅ……",
      "zh": ""
    },
    {
      "key": "221.0",
      "line_index": 221,
      "inline_index": 0,
      "line_hash": "9e952b4f",
      "speaker": "",
      "ja": "さっき射精したばかりなのに雫の激しいイラマチオで{G_PlayerName}は再び射精したくなっていく。",
      "zh": ""
    },
    {
      "key": "223.0",
      "line_index": 223,
      "inline_index": 0,
      "line_hash": "c3fa0b45",
      "speaker": "",
      "ja": "おちんちんは雫の口の中で脈打ちながら上下して我慢汁がダラダラと滲み出ていた。",
      "zh": ""
    },
    {
      "key": "225.0",
      "line_index": 225,
      "inline_index": 0,
      "line_hash": "b9cc984b",
      "speaker": "",
      "ja": "それを舌先で舐め取りながら雫は口全体を使って陰茎をしゃぶり尽くしていく。",
      "zh": ""
    },
    {
      "key": "228.0",
      "line_index": 228,
      "inline_index": 0,
      "line_hash": "b3e270fe",
      "speaker": "雫",
      "ja": "んっく！　んっく！　ぢゅるぢゅる！　んむぅぅぅ！　ぢゅぽぢゅぽ！　んむぅぅぅ！",
      "zh": ""
    },
    {
      "key": "230.0",
      "line_index": 230,
      "inline_index": 0,
      "line_hash": "3f5b3578",
      "speaker": "",
      "ja": "どんどん激しくなる頭の動きに{G_PlayerName}はどんどん気持ちよくなって小さく体を震わせ始めた。",
      "zh": ""
    },
    {
      "key": "233.0",
      "line_index": 233,
      "inline_index": 0,
      "line_hash": "8eb5998f",
      "speaker": "雫",
      "ja": "ほらっ……さっさとまた出してしまいなさい……んっ、んんんっ！　あむぅぅ！　んちゅるちゅるる♥　ぢゅっぷぢゅっぷ！",
      "zh": ""
    },
    {
      "key": "236.0",
      "line_index": 236,
      "inline_index": 0,
      "line_hash": "8a3d33f7",
      "speaker": "{G_PlayerName}",
      "ja": "はぁ……はぁ……うっ……うぅぅ……",
      "zh": ""
    },
    {
      "key": "239.0",
      "line_index": 239,
      "inline_index": 0,
      "line_hash": "690ea6c4",
      "speaker": "",
      "ja": "激しい快感に{G_PlayerName}は息を荒げながら呻き声を漏らし続ける。",
      "zh": ""
    },
    {
      "key": "241.0",
      "line_index": 241,
      "inline_index": 0,
      "line_hash": "1808bbeb",
      "speaker": "",
      "ja": "そして勃起したおちんちんは確実に射精に向かっていった。",
      "zh": ""
    },
    {
      "key": "244.0",
      "line_index": 244,
      "inline_index": 0,
      "line_hash": "148c4ecf",
      "speaker": "雫",
      "ja": "んっ！　んむぅぅ！　早く出しなさいっ！　んぢゅるぅ！　ぢゅるぢゅるぅ！　んんんんんっ！",
      "zh": ""
    },
    {
      "key": "246.0",
      "line_index": 246,
      "inline_index": 0,
      "line_hash": "cf400093",
      "speaker": "",
      "ja": "雫の激しいイマラチオに翻弄され、{G_PlayerName}は簡単に二度目の絶頂へと確実に追い込まれていく。",
      "zh": ""
    },
    {
      "key": "249.0",
      "line_index": 249,
      "inline_index": 0,
      "line_hash": "b59ad2f2",
      "speaker": "{G_PlayerName}",
      "ja": "うっ……くっ……ま、また……あっ……あぁぁっ！",
      "zh": ""
    },
    {
      "key": "252.0",
      "line_index": 252,
      "inline_index": 0,
      "line_hash": "54b3dc9f",
      "speaker": "",
      "ja": "再び精液が込み上げてきた{G_PlayerName}は腰を小さく跳ねさせながら雫の喉奥に熱い飛沫を迸らせた。",
      "zh": ""
    },
    {
      "key": "261.0",
      "line_index": 261,
      "inline_index": 0,
      "line_hash": "4d6b2a13",
      "speaker": "雫",
      "ja": "んぐぅっ！！　お……ごっ！",
      "zh": ""
    },
    {
      "key": "263.0",
      "line_index": 263,
      "inline_index": 0,
      "line_hash": "5fce8a42",
      "speaker": "",
      "ja": "勢いよく喉の奥に注がれてくる精液に雫は呻き声を漏らし苦しそうに表情を歪めながらも必死に飲み干していく。",
      "zh": ""
    },
    {
      "key": "266.0",
      "line_index": 266,
      "inline_index": 0,
      "line_hash": "264397e8",
      "speaker": "雫",
      "ja": "んぷぅぅ！　んっ！　んっ、おぅぅっ！　んぐふぅぅ……うっ……んんんっ！",
      "zh": ""
    },
    {
      "key": "269.0",
      "line_index": 269,
      "inline_index": 0,
      "line_hash": "c5bb6a89",
      "speaker": "{G_PlayerName}",
      "ja": "ま、まだ……出る……くぅぅ……！",
      "zh": ""
    },
    {
      "key": "273.0",
      "line_index": 273,
      "inline_index": 0,
      "line_hash": "480815b5",
      "speaker": "雫",
      "ja": "ふうぅぅ……！　ふうぅぅ……！",
      "zh": ""
    },
    {
      "key": "275.0",
      "line_index": 275,
      "inline_index": 0,
      "line_hash": "42d38a3d",
      "speaker": "",
      "ja": "おちんちんを咥えっぱなしなので大量の精液に溺れかけながらも、雫は必死に深呼吸をしつつ喉を鳴らし続けた。",
      "zh": ""
    },
    {
      "key": "277.0",
      "line_index": 277,
      "inline_index": 0,
      "line_hash": "5ad6230f",
      "speaker": "",
      "ja": "そんな雫の喉に{G_PlayerName}は全ての精液をぶちまけて果てるが、勃起した陰茎は萎える気配がない。",
      "zh": ""
    },
    {
      "key": "283.0",
      "line_index": 283,
      "inline_index": 0,
      "line_hash": "1371926d",
      "speaker": "雫",
      "ja": "んはぁぁぁ……あふっ……んんんっ……",
      "zh": ""
    },
    {
      "key": "285.0",
      "line_index": 285,
      "inline_index": 0,
      "line_hash": "81439899",
      "speaker": "",
      "ja": "雫の唇がゆっくりと{G_PlayerName}の陰茎から離れていく。",
      "zh": ""
    },
    {
      "key": "287.0",
      "line_index": 287,
      "inline_index": 0,
      "line_hash": "5146a998",
      "speaker": "",
      "ja": "口とおちんちんの間に飲みきれなかった精液が糸を引いた。",
      "zh": ""
    },
    {
      "key": "290.0",
      "line_index": 290,
      "inline_index": 0,
      "line_hash": "b065a66b",
      "speaker": "雫",
      "ja": "はぁ……はぁ……はぁ……ふぅぅ……はぁぁ……げほげほげほっ……",
      "zh": ""
    },
    {
      "key": "292.0",
      "line_index": 292,
      "inline_index": 0,
      "line_hash": "7fb9e327",
      "speaker": "",
      "ja": "濃くて粘つく精液に咳き込みつつも呼吸しやすくなったことで雫は大きく深呼吸をする。",
      "zh": ""
    },
    {
      "key": "295.0",
      "line_index": 295,
      "inline_index": 0,
      "line_hash": "f6b8ab",
      "speaker": "雫",
      "ja": "はふぅぅぅ……まったく、どれだけ出すんですか……しかもこれだけ出してもまだ勃起したままとは……盛りのついた猿以下ですね",
      "zh": ""
    },
    {
      "key": "297.0",
      "line_index": 297,
      "inline_index": 0,
      "line_hash": "d55bf805",
      "speaker": "",
      "ja": "そんな悪態を吐きながらもまだ萎えない{G_PlayerName}の陰茎をどうしたものかと雫は思案していた。",
      "zh": ""
    }
  ]
}
