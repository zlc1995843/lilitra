{
  "lines": [
    {
      "key": "11.0",
      "line_index": 11,
      "inline_index": 0,
      "line_hash": "91c3bcd",
      "speaker": "{G_PlayerName}",
      "ja": "夏祭りに来てみたものの……すごい人混みだ",
      "zh": ""
    },
    {
      "key": "16.1",
      "line_index": 16,
      "inline_index": 1,
      "line_hash": "7bfdc13e",
      "speaker": "モル",
      "ja": "まったくっすね……自分人混みは苦手っす、お兄さん少し人混みを避けませんか？",
      "zh": ""
    },
    {
      "key": "18.0",
      "line_index": 18,
      "inline_index": 0,
      "line_hash": "e1099122",
      "speaker": "{G_PlayerName}",
      "ja": "そうだな……それじゃあ比較的に人が少ないあっちの屋台の方に行ってみようか",
      "zh": ""
    },
    {
      "key": "20.1",
      "line_index": 20,
      "inline_index": 1,
      "line_hash": "3fc596f5",
      "speaker": "モル",
      "ja": "そうっすね、行きましょう",
      "zh": ""
    },
    {
      "key": "22.0",
      "line_index": 22,
      "inline_index": 0,
      "line_hash": "7113cb64",
      "speaker": "{G_PlayerName}",
      "ja": "しかし……人が多いせいか……暑いな",
      "zh": ""
    },
    {
      "key": "24.1",
      "line_index": 24,
      "inline_index": 1,
      "line_hash": "657a4f77",
      "speaker": "モル",
      "ja": "そうっすね……",
      "zh": ""
    },
    {
      "key": "26.0",
      "line_index": 26,
      "inline_index": 0,
      "line_hash": "928b1890",
      "speaker": "",
      "ja": "2人は並んで歩いているものの、会話はぽつりぽつりとしか生まれない。",
      "zh": ""
    },
    {
      "key": "28.0",
      "line_index": 28,
      "inline_index": 0,
      "line_hash": "d0574ec",
      "speaker": "{G_PlayerName}",
      "ja": "えっと……なあ、モルはどこの屋台を見てみたい？",
      "zh": ""
    },
    {
      "key": "30.1",
      "line_index": 30,
      "inline_index": 1,
      "line_hash": "d6af470",
      "speaker": "モル",
      "ja": "そうっすねぇ……色々な屋台が出てるから……迷うっすね",
      "zh": ""
    },
    {
      "key": "32.0",
      "line_index": 32,
      "inline_index": 0,
      "line_hash": "20619541",
      "speaker": "{G_PlayerName}",
      "ja": "だよなぁ……",
      "zh": ""
    },
    {
      "key": "34.0",
      "line_index": 34,
      "inline_index": 0,
      "line_hash": "7496e95c",
      "speaker": "",
      "ja": "そしてまた訪れる沈黙。しばらくした後、{G_PlayerName}は何かを見つけて明るい声を出す。",
      "zh": ""
    },
    {
      "key": "36.0",
      "line_index": 36,
      "inline_index": 0,
      "line_hash": "12cb9a78",
      "speaker": "{G_PlayerName}",
      "ja": "……あっ、海足獣焼きだって、モル食べるか？",
      "zh": ""
    },
    {
      "key": "38.1",
      "line_index": 38,
      "inline_index": 1,
      "line_hash": "f9e66c33",
      "speaker": "モル",
      "ja": "た、食べたいっす！",
      "zh": ""
    },
    {
      "key": "40.0",
      "line_index": 40,
      "inline_index": 0,
      "line_hash": "c265698d",
      "speaker": "{G_PlayerName}",
      "ja": "じゃあ買って食べるか",
      "zh": ""
    },
    {
      "key": "42.1",
      "line_index": 42,
      "inline_index": 1,
      "line_hash": "af639a52",
      "speaker": "モル",
      "ja": "う、うっす！",
      "zh": ""
    },
    {
      "key": "44.0",
      "line_index": 44,
      "inline_index": 0,
      "line_hash": "b653a516",
      "speaker": "{G_PlayerName}",
      "ja": "（うう……イマイチ話が盛り上がらない……浴衣姿のモルを見て緊張しているせいかな）",
      "zh": ""
    },
    {
      "key": "46.1",
      "line_index": 46,
      "inline_index": 1,
      "line_hash": "93bb19b0",
      "speaker": "モル",
      "ja": "（やばい……お兄さんの浴衣姿♥　一緒に夏祭りに来られてラッキーだったっす！）",
      "zh": ""
    },
    {
      "key": "48.1",
      "line_index": 48,
      "inline_index": 1,
      "line_hash": "7d7642d3",
      "speaker": "モル",
      "ja": "（で、でもお兄さんの浴衣姿がかっこよすぎて……ま、まともに顔が見られないっす）",
      "zh": ""
    },
    {
      "key": "50.0",
      "line_index": 50,
      "inline_index": 0,
      "line_hash": "524ac1e9",
      "speaker": "{G_PlayerName}",
      "ja": "（しかし……モルの浴衣姿、可愛すぎる！　でも可愛いとか言うとモルは嫌がるかな？）",
      "zh": ""
    },
    {
      "key": "52.0",
      "line_index": 52,
      "inline_index": 0,
      "line_hash": "85944370",
      "speaker": "{G_PlayerName}",
      "ja": "え、えっと……すみません、海足獣焼き二つ下さい",
      "zh": ""
    },
    {
      "key": "54.0",
      "line_index": 54,
      "inline_index": 0,
      "line_hash": "3b9c239d",
      "speaker": "{G_PlayerName}",
      "ja": "（ああ、俺は屋台で買うことに逃げてしまってる！　何してるんだ！　情けないぞ！）",
      "zh": ""
    },
    {
      "key": "56.1",
      "line_index": 56,
      "inline_index": 1,
      "line_hash": "dda2cb52",
      "speaker": "モル",
      "ja": "（ど、どうしよう……お兄さんを独り占めできる機会なんてそんなに無いのに……）",
      "zh": ""
    },
    {
      "key": "58.0",
      "line_index": 58,
      "inline_index": 0,
      "line_hash": "2ce15592",
      "speaker": "{G_PlayerName}",
      "ja": "はい、モル……海足獣焼きだよ",
      "zh": ""
    },
    {
      "key": "60.1",
      "line_index": 60,
      "inline_index": 1,
      "line_hash": "c7db1c58",
      "speaker": "モル",
      "ja": "お兄さん、ありがとうっす、いただきます",
      "zh": ""
    },
    {
      "key": "62.1",
      "line_index": 62,
      "inline_index": 1,
      "line_hash": "c0c2c35f",
      "speaker": "モル",
      "ja": "（ううっ……せっかく買ってもらったのに、ドキドキしすぎて味がぜんぜんわからないっす）",
      "zh": ""
    },
    {
      "key": "64.1",
      "line_index": 64,
      "inline_index": 1,
      "line_hash": "8be23dc",
      "speaker": "モル",
      "ja": "（でも！　せっかく二人っきりなんすから、せめて……せめて手を！　手を握りたいっす！）",
      "zh": ""
    },
    {
      "key": "66.0",
      "line_index": 66,
      "inline_index": 0,
      "line_hash": "7dfc1b9d",
      "speaker": "{G_PlayerName}",
      "ja": "……どうだ？　美味しいか？",
      "zh": ""
    },
    {
      "key": "68.1",
      "line_index": 68,
      "inline_index": 1,
      "line_hash": "151871c",
      "speaker": "モル",
      "ja": "うっす！すごく美味しいっす！",
      "zh": ""
    },
    {
      "key": "70.1",
      "line_index": 70,
      "inline_index": 1,
      "line_hash": "c77f3fdf",
      "speaker": "モル",
      "ja": "（しまったっす……タイミングを逸してしまったっす……でも次こそは……っ！）",
      "zh": ""
    },
    {
      "key": "72.0",
      "line_index": 72,
      "inline_index": 0,
      "line_hash": "5145891b",
      "speaker": "{G_PlayerName}",
      "ja": "ふぅぅ……海足獣焼き食べたら汗かいてきたな",
      "zh": ""
    },
    {
      "key": "74.1",
      "line_index": 74,
      "inline_index": 1,
      "line_hash": "6fd6f78b",
      "speaker": "モル",
      "ja": "そ、そうっすね……自分もすごく汗かいてるっす",
      "zh": ""
    },
    {
      "key": "76.1",
      "line_index": 76,
      "inline_index": 1,
      "line_hash": "cba00612",
      "speaker": "モル",
      "ja": "（海足獣焼き食べたからじゃなくて、緊張で半端なく汗が出るっす……）",
      "zh": ""
    },
    {
      "key": "78.1",
      "line_index": 78,
      "inline_index": 1,
      "line_hash": "a8a18159",
      "speaker": "モル",
      "ja": "（でもまだまだ！　次のチャンスを見つけて……今っす！）",
      "zh": ""
    },
    {
      "key": "80.0",
      "line_index": 80,
      "inline_index": 0,
      "line_hash": "8347c9e9",
      "speaker": "{G_PlayerName}",
      "ja": "おっ！　モル、あそこ見てみろよ！　金魚すくいだってよ！　って、でも宇宙海賊はこういうのやらないか……",
      "zh": ""
    },
    {
      "key": "82.1",
      "line_index": 82,
      "inline_index": 1,
      "line_hash": "f0ffe08a",
      "speaker": "モル",
      "ja": "っ！？　あ～そ、そうっすね……チマチマしたのは苦手かもっす……",
      "zh": ""
    },
    {
      "key": "84.1",
      "line_index": 84,
      "inline_index": 1,
      "line_hash": "2a408fb",
      "speaker": "モル",
      "ja": "（くそ～！　また空振りしたっす……もうダメっす……でも最後にお兄さんに触れたいっす……）",
      "zh": ""
    },
    {
      "key": "86.1",
      "line_index": 86,
      "inline_index": 1,
      "line_hash": "24dc002e",
      "speaker": "モル",
      "ja": "（手を握れないならせめて……手の甲をお兄さんの手の甲に……）",
      "zh": ""
    },
    {
      "key": "88.0",
      "line_index": 88,
      "inline_index": 0,
      "line_hash": "84375516",
      "speaker": "",
      "ja": "モルがそう決心して、少し手を{G_PlayerName}へと寄せる。",
      "zh": ""
    },
    {
      "key": "89.0",
      "line_index": 89,
      "inline_index": 0,
      "line_hash": "76ab3da2",
      "speaker": "",
      "ja": "すると思ったよりもねっとりと、自身の手の甲を擦り付けてしまった。",
      "zh": ""
    },
    {
      "key": "91.0",
      "line_index": 91,
      "inline_index": 0,
      "line_hash": "831715dc",
      "speaker": "{G_PlayerName}",
      "ja": "えっ？！　モル……",
      "zh": ""
    },
    {
      "key": "93.1",
      "line_index": 93,
      "inline_index": 1,
      "line_hash": "a8002448",
      "speaker": "モル",
      "ja": "（あっ……お兄さんの手がビクンって……驚かしてしまったっす……）",
      "zh": ""
    },
    {
      "key": "95.0",
      "line_index": 95,
      "inline_index": 0,
      "line_hash": "9ef30db8",
      "speaker": "{G_PlayerName}",
      "ja": "（モル……うつむいて顔を真っ赤にさせて……も、もしかして……手とか……繋いじゃっていいのかな？）",
      "zh": ""
    },
    {
      "key": "97.1",
      "line_index": 97,
      "inline_index": 1,
      "line_hash": "8803c408",
      "speaker": "モル",
      "ja": "お、お兄さん……え、えっと……あわわ……",
      "zh": ""
    },
    {
      "key": "99.0",
      "line_index": 99,
      "inline_index": 0,
      "line_hash": "67413c",
      "speaker": "",
      "ja": "{G_PlayerName}の手が、小さなモルの手を包み込む。",
      "zh": ""
    },
    {
      "key": "100.0",
      "line_index": 100,
      "inline_index": 0,
      "line_hash": "e203e1a0",
      "speaker": "",
      "ja": "気まずい沈黙も、意味合いが変わり2人の体温が溶け合っていった。",
      "zh": ""
    },
    {
      "key": "102.1",
      "line_index": 102,
      "inline_index": 1,
      "line_hash": "d0c9af3a",
      "speaker": "モル",
      "ja": "（お兄さんの方から自分の手を握ってきてくれたっす……しかも顔を真っ赤にさせて……）",
      "zh": ""
    },
    {
      "key": "104.0",
      "line_index": 104,
      "inline_index": 0,
      "line_hash": "ad3940f3",
      "speaker": "{G_PlayerName}",
      "ja": "（い、勢いで手を繋いでしまったけど……ヤバい程ドキドキしてしまう……ああ、緊張する……）",
      "zh": ""
    },
    {
      "key": "106.1",
      "line_index": 106,
      "inline_index": 1,
      "line_hash": "886b90cf",
      "speaker": "モル",
      "ja": "（ああ……お兄さんの手……大きいっす……それに温かくて……はぁぁ♥　ドキドキが止まらないっす♥）",
      "zh": ""
    },
    {
      "key": "108.0",
      "line_index": 108,
      "inline_index": 0,
      "line_hash": "f349f324",
      "speaker": "{G_PlayerName}",
      "ja": "モ、モル……つ、次は……どこの屋台に……い、行こうか？",
      "zh": ""
    },
    {
      "key": "110.1",
      "line_index": 110,
      "inline_index": 1,
      "line_hash": "1d9fcd10",
      "speaker": "モル",
      "ja": "そ、そうっすね……お、お兄さんにお任せするっす……",
      "zh": ""
    },
    {
      "key": "112.1",
      "line_index": 112,
      "inline_index": 1,
      "line_hash": "8bd73688",
      "speaker": "モル",
      "ja": "（すごく嬉しいっすけど……顔から火が出そうな感じっす♥）",
      "zh": ""
    }
  ]
}
