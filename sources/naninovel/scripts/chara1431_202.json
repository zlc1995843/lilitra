    {
      "key": "237.0",
      "line_index": 237,
      "inline_index": 0,
      "line_hash": "9111363c",
      "speaker": "まこ",
      "ja": "あううっ！♥　んぅぅっ！♥　機械っぴ、そんなにおまんこいっぱいされたらぁ……は、はっ！！♥",
      "zh": ""
    },
    {
      "key": "240.0",
      "line_index": 240,
      "inline_index": 0,
      "line_hash": "deacc2c6",
      "speaker": "{G_PlayerName}",
      "ja": "ガマンなんてしなくてもいいぞ……まこがイキたいときいつでもイってくれ",
