{
  "lines": [
    {
      "key": "19.1",
      "line_index": 19,
      "inline_index": 1,
      "line_hash": "c5735ea5",
      "speaker": "ジラド",
      "ja": "魔法少女ジラド様だ！　今日こそお前を倒すのだ！",
      "zh": ""
    },
    {
      "key": "21.0",
      "line_index": 21,
      "inline_index": 0,
      "line_hash": "40dbd5d2",
      "speaker": "",
      "ja": "いきなり部屋にやって来たジラドは{G_PlayerName}を指さしながら啖呵を切ってきた。",
      "zh": ""
    },
    {
      "key": "23.0",
      "line_index": 23,
      "inline_index": 0,
      "line_hash": "375ed310",
      "speaker": "",
      "ja": "そんなジラドを少し呆れ顔で見つめながら{G_PlayerName}は溜め息をつく。",
      "zh": ""
    },
    {
      "key": "26.0",
      "line_index": 26,
      "inline_index": 0,
      "line_hash": "22fc15e8",
      "speaker": "{G_PlayerName}",
      "ja": "はぁぁ……そうかそうか……それで今日は何で戦うつもりなんだ？",
      "zh": ""
    },
    {
      "key": "29.0",
      "line_index": 29,
      "inline_index": 0,
      "line_hash": "cab285c7",
      "speaker": "",
      "ja": "毎度毎度のことなので、{G_PlayerName}は苦笑しながらそう聞くとジラドは自信満々の顔で言った。",
      "zh": ""
    },
    {
      "key": "32.1",
      "line_index": 32,
      "inline_index": 1,
      "line_hash": "48e1df5b",
      "speaker": "ジラド",
      "ja": "最初からジラド様が一番得意な分野で戦っていればよかったんだ！",
      "zh": ""
    },
    {
      "key": "35.0",
      "line_index": 35,
      "inline_index": 0,
      "line_hash": "1537ec63",
      "speaker": "{G_PlayerName}",
      "ja": "一番得意な分野？",
      "zh": ""
    },
    {
      "key": "39.1",
      "line_index": 39,
      "inline_index": 1,
      "line_hash": "188f29c3",
      "speaker": "ジラド",
      "ja": "そうなのだ！　ジラド様の一番得意な分野……力で勝つ！",
      "zh": ""
    },
    {
      "key": "41.0",
      "line_index": 41,
      "inline_index": 0,
      "line_hash": "b602ad8a",
      "speaker": "",
      "ja": "そう意気込んで駆け寄ってきたジラドは、いきなり{G_PlayerName}のズボンとパンツを一気に引き下ろすとそのまま押し倒してきた。",
      "zh": ""
    },
    {
      "key": "56.0",
      "line_index": 56,
      "inline_index": 0,
      "line_hash": "8d49fbb8",
      "speaker": "{G_PlayerName}",
      "ja": "お、おい！　何するんだ！",
      "zh": ""
    },
    {
      "key": "59.0",
      "line_index": 59,
      "inline_index": 0,
      "line_hash": "e9638168",
      "speaker": "",
      "ja": "慌てふためく{G_PlayerName}だがジラドはお構いなしに目の前の陰茎を握りしめ不敵な笑みを浮かべて言った。",
      "zh": ""
    },
    {
      "key": "62.0",
      "line_index": 62,
      "inline_index": 0,
      "line_hash": "dcb13c9",
      "speaker": "ジラド",
      "ja": "ふふん、今更後悔しても遅いぞ！　お前が負けたと認めるまで責めてやる！",
      "zh": ""
    },
    {
      "key": "65.0",
      "line_index": 65,
      "inline_index": 0,
      "line_hash": "6ea48374",
      "speaker": "{G_PlayerName}",
      "ja": "なんだってっ？！",
      "zh": ""
    },
    {
      "key": "69.0",
      "line_index": 69,
      "inline_index": 0,
      "line_hash": "e2b381",
      "speaker": "ジラド",
      "ja": "さあ、ジラド様の力の前にひれ伏すがいい……！",
      "zh": ""
    },
    {
      "key": "71.0",
      "line_index": 71,
      "inline_index": 0,
      "line_hash": "af3d6faa",
      "speaker": "",
      "ja": "そう言うとジラドは握った{G_PlayerName}のおちんちんをぱくっと咥え込んでしまう。",
      "zh": ""
    },
    {
      "key": "78.0",
      "line_index": 78,
      "inline_index": 0,
      "line_hash": "113825a5",
      "speaker": "ジラド",
      "ja": "んぐんぐっ♥　じゅぽじゅぽ♥　んっ、ぢゅるぅ♥　ちゅうちゅう♥",
      "zh": ""
    },
    {
      "key": "81.0",
      "line_index": 81,
      "inline_index": 0,
      "line_hash": "b21b4cf4",
      "speaker": "{G_PlayerName}",
      "ja": "くっ……ぐぅっ……",
      "zh": ""
    },
    {
      "key": "84.0",
      "line_index": 84,
      "inline_index": 0,
      "line_hash": "b74b7393",
      "speaker": "",
      "ja": "激しくしゃぶられる感覚に{G_PlayerName}は呻き声を漏らしつつおちんちんを勃起させた。",
      "zh": ""
    },
    {
      "key": "86.0",
      "line_index": 86,
      "inline_index": 0,
      "line_hash": "16662b8f",
      "speaker": "",
      "ja": "それに気をよくしたようにジラドは頭を振って口全体で大きくなった陰茎をしごき上げてくる。",
      "zh": ""
    },
    {
      "key": "89.0",
      "line_index": 89,
      "inline_index": 0,
      "line_hash": "978b2bff",
      "speaker": "ジラド",
      "ja": "んっくんっくっ♥　ちゅば♥　ちゅるるっ♥　んっ♥　んむぅぅ♥　ぢゅるぢゅるぅ♥",
      "zh": ""
    },
    {
      "key": "92.0",
      "line_index": 92,
      "inline_index": 0,
      "line_hash": "891806db",
      "speaker": "{G_PlayerName}",
      "ja": "そ、そんなに強く吸われたら……あううっ……くっ、うぅぅっ……",
      "zh": ""
    },
    {
      "key": "95.0",
      "line_index": 95,
      "inline_index": 0,
      "line_hash": "6f9a8e65",
      "speaker": "",
      "ja": "高まる快感にジラドの口の中で{G_PlayerName}のおちんちんは硬さと大きさを増してきて脈打ち始めた。",
      "zh": ""
    },
    {
      "key": "97.0",
      "line_index": 97,
      "inline_index": 0,
      "line_hash": "32f2fc81",
      "speaker": "",
      "ja": "そんな{G_PlayerName}の肉竿をジラドの舌が舐め上げて亀頭を転がすように舐め回す。",
      "zh": ""
    },
    {
      "key": "100.0",
      "line_index": 100,
      "inline_index": 0,
      "line_hash": "dc959132",
      "speaker": "ジラド",
      "ja": "あぐぅっ♥　ぢゅるぢゅるぅ♥　んっ、んんっ……うぐうぐぅ♥　んちゅるぅ♥",
      "zh": ""
    },
    {
      "key": "103.0",
      "line_index": 103,
      "inline_index": 0,
      "line_hash": "6ec78da3",
      "speaker": "{G_PlayerName}",
      "ja": "うっ……くっ……あぁぁぁ……",
      "zh": ""
    },
    {
      "key": "106.0",
      "line_index": 106,
      "inline_index": 0,
      "line_hash": "dd64a615",
      "speaker": "",
      "ja": "ジラドの舌が蠢く度にゾクゾクする快感が{G_PlayerName}の背筋を駆け上がった。",
      "zh": ""
    },
    {
      "key": "108.0",
      "line_index": 108,
      "inline_index": 0,
      "line_hash": "c9216a6a",
      "speaker": "",
      "ja": "舐められているおちんちんは強く脈動し始めて、先っぽからねっとりとした汁を溢れさせていく。",
      "zh": ""
    },
    {
      "key": "111.0",
      "line_index": 111,
      "inline_index": 0,
      "line_hash": "214f4af3",
      "speaker": "ジラド",
      "ja": "ぢゅるる♥　ぬるぬるの汁が溢れてきた……ぺちゃぺちゃ♥　ちゅるる♥",
      "zh": ""
    },
    {
      "key": "113.0",
      "line_index": 113,
      "inline_index": 0,
      "line_hash": "369bf93e",
      "speaker": "",
      "ja": "ジラドは亀頭から溢れ出る汁を丹念に舐め取りつつ、じゅぽじゅぽと音を立てながら陰茎をしゃぶった。",
      "zh": ""
    },
    {
      "key": "115.0",
      "line_index": 115,
      "inline_index": 0,
      "line_hash": "ee195c2",
      "speaker": "",
      "ja": "その刺激に{G_PlayerName}は込み上げてくる感覚に襲われ、小さく腰を震わせ始めてしまう。",
      "zh": ""
    },
    {
      "key": "118.0",
      "line_index": 118,
      "inline_index": 0,
      "line_hash": "f1fa19ad",
      "speaker": "ジラド",
      "ja": "がまんするふぁ……うむぅぅ♥　イっていいふぉ♥",
      "zh": ""
    },
    {
      "key": "121.0",
      "line_index": 121,
      "inline_index": 0,
      "line_hash": "66d95487",
      "speaker": "{G_PlayerName}",
      "ja": "くっ！　んんんっ！",
      "zh": ""
    },
    {
      "key": "124.0",
      "line_index": 124,
      "inline_index": 0,
      "line_hash": "509cfc3e",
      "speaker": "",
      "ja": "咥えながら喋られたので、ギザ歯が陰茎に当たって少し痛みを感じる。",
      "zh": ""
    },
    {
      "key": "126.0",
      "line_index": 126,
      "inline_index": 0,
      "line_hash": "64ab9d20",
      "speaker": "",
      "ja": "しかしそれが刺激となって{G_PlayerName}の込み上げてくる感覚が強くなっていった。",
      "zh": ""
    },
    {
      "key": "129.0",
      "line_index": 129,
      "inline_index": 0,
      "line_hash": "a4722240",
      "speaker": "{G_PlayerName}",
      "ja": "あううっ……うっ……だ、だめだ……も、もう……",
      "zh": ""
    },
    {
      "key": "132.0",
      "line_index": 132,
      "inline_index": 0,
      "line_hash": "f0cfa189",
      "speaker": "",
      "ja": "強く吸われ舐め回され我慢できなくなった{G_PlayerName}は呻き声を漏らしつつ腰を小さく震わせる。",
      "zh": ""
    },
    {
      "key": "134.0",
      "line_index": 134,
      "inline_index": 0,
      "line_hash": "9f9729cd",
      "speaker": "",
      "ja": "それでもジラドはしゃぶるのをやめずに、激しく亀頭を吸ってきた。",
      "zh": ""
    },
    {
      "key": "137.0",
      "line_index": 137,
      "inline_index": 0,
      "line_hash": "b05980b3",
      "speaker": "ジラド",
      "ja": "んぢゅるぅぅ♥　ぢゅるぢゅるぅ♥　んっ、んんんっ♥　じゅぽじゅぽぉ♥",
      "zh": ""
    },
    {
      "key": "140.0",
      "line_index": 140,
      "inline_index": 0,
      "line_hash": "cae0fc86",
      "speaker": "{G_PlayerName}",
      "ja": "うっ……あああっ……もうだめだ、射精る……ぅぅっ！",
      "zh": ""
    },
    {
      "key": "143.0",
      "line_index": 143,
      "inline_index": 0,
      "line_hash": "b59c7590",
      "speaker": "",
      "ja": "限界に達してしまった{G_PlayerName}はそう言うと勢いよく精液を噴き上げてしまう。",
      "zh": ""
    },
    {
      "key": "151.0",
      "line_index": 151,
      "inline_index": 0,
      "line_hash": "2b105ee2",
      "speaker": "ジラド",
      "ja": "うわっ！！",
      "zh": ""
    },
    {
      "key": "153.0",
      "line_index": 153,
      "inline_index": 0,
      "line_hash": "bd62cda1",
      "speaker": "",
      "ja": "いきなり脈打つおちんちんが射精したことに驚いたジラドは声を上げて口を離した。",
      "zh": ""
    },
    {
      "key": "155.0",
      "line_index": 155,
      "inline_index": 0,
      "line_hash": "a33b10a0",
      "speaker": "",
      "ja": "しかし少し口の中に飛び込んだ精液の味に顔をしかめつつ、それでも興奮した感じで呟く。",
      "zh": ""
    },
    {
      "key": "158.0",
      "line_index": 158,
      "inline_index": 0,
      "line_hash": "c8f317de",
      "speaker": "ジラド",
      "ja": "あっついのが沢山出たな♥",
      "zh": ""
    },
    {
      "key": "161.0",
      "line_index": 161,
      "inline_index": 0,
      "line_hash": "1ad23ffc",
      "speaker": "{G_PlayerName}",
      "ja": "うっ……くっ……ぅぅぅっ……",
      "zh": ""
    },
    {
      "key": "164.0",
      "line_index": 164,
      "inline_index": 0,
      "line_hash": "8d7d0882",
      "speaker": "",
      "ja": "妙な敗北感に苛まれながらも{G_PlayerName}は何度も陰茎を跳ねさせながら全ての精液を出し切って果てた。",
      "zh": ""
    },
    {
      "key": "166.0",
      "line_index": 166,
      "inline_index": 0,
      "line_hash": "bda98538",
      "speaker": "",
      "ja": "そんな{G_PlayerName}を見て優位に立ったと感じたのかジラドが得意げに告げる。",
      "zh": ""
    },
    {
      "key": "169.0",
      "line_index": 169,
      "inline_index": 0,
      "line_hash": "741b015c",
      "speaker": "ジラド",
      "ja": "どうだ、まいったか？",
      "zh": ""
    },
    {
      "key": "172.0",
      "line_index": 172,
      "inline_index": 0,
      "line_hash": "b23020a0",
      "speaker": "{G_PlayerName}",
      "ja": "ま、まだまだ余裕だよ……",
      "zh": ""
    },
    {
      "key": "175.0",
      "line_index": 175,
      "inline_index": 0,
      "line_hash": "b9278c75",
      "speaker": "",
      "ja": "辱めを受けたような感覚に{G_PlayerName}はついつい強気な返答をしたのだが、それがジラドの負けん気に火を付けた。",
      "zh": ""
    },
    {
      "key": "178.0",
      "line_index": 178,
      "inline_index": 0,
      "line_hash": "70235f26",
      "speaker": "ジラド",
      "ja": "なら、もう一回だ！",
      "zh": ""
    },
    {
      "key": "180.0",
      "line_index": 180,
      "inline_index": 0,
      "line_hash": "aed3a5ff",
      "speaker": "",
      "ja": "ムッとしながらそう言ったジラドは果てたばかりの陰茎を再び強くしゃぶってくる。",
      "zh": ""
    },
    {
      "key": "187.0",
      "line_index": 187,
      "inline_index": 0,
      "line_hash": "8c79a4df",
      "speaker": "ジラド",
      "ja": "んぢゅるるるっ！　ぢゅるぢゅるぅ！　じゅぼじゅぼっ！　むちゅるるるぅ！",
      "zh": ""
    },
    {
      "key": "190.0",
      "line_index": 190,
      "inline_index": 0,
      "line_hash": "e802d6b0",
      "speaker": "{G_PlayerName}",
      "ja": "ぐっ、さっきより激しい……！",
      "zh": ""
    },
    {
      "key": "193.0",
      "line_index": 193,
      "inline_index": 0,
      "line_hash": "2a56ca6d",
      "speaker": "",
      "ja": "あまりにも強くおちんちんを吸われた{G_PlayerName}は呻き声を漏らしながら身悶えた。",
      "zh": ""
    },
    {
      "key": "195.0",
      "line_index": 195,
      "inline_index": 0,
      "line_hash": "9adb065b",
      "speaker": "",
      "ja": "果てたばかりの陰茎は激しい刺激を受けて萎えることも許されず再びいきり立っていってしまう。",
      "zh": ""
    },
    {
      "key": "198.0",
      "line_index": 198,
      "inline_index": 0,
      "line_hash": "4c1e6fd2",
      "speaker": "ジラド",
      "ja": "んんんっ！　んちゅぅぅ！　ちゅばちゅば！　また硬くなってきたのだ……んっ、うむぅぅ！",
      "zh": ""
    },
    {
      "key": "200.0",
      "line_index": 200,
      "inline_index": 0,
      "line_hash": "ff271ddf",
      "speaker": "",
      "ja": "派手に音を立てながらおちんちんをしゃぶられ亀頭を転がすように舐め回された{G_PlayerName}は、強烈な快感に体を震わせた。",
      "zh": ""
    },
    {
      "key": "202.0",
      "line_index": 202,
      "inline_index": 0,
      "line_hash": "deec2634",
      "speaker": "",
      "ja": "それでもジラドは容赦なく裏スジを舐め上げてくびれをねっとりと舐めてくる。",
      "zh": ""
    },
    {
      "key": "205.0",
      "line_index": 205,
      "inline_index": 0,
      "line_hash": "a48c7bb3",
      "speaker": "ジラド",
      "ja": "ちゅばちゅば！　ぢゅるるぅ♥　んっ、んんんんっ♥　また出してしまうのだ……んぐんぐっ♥",
      "zh": ""
    },
    {
      "key": "208.0",
      "line_index": 208,
      "inline_index": 0,
      "line_hash": "13ba90ab",
      "speaker": "{G_PlayerName}",
      "ja": "うっ……ううっ……そんなに舐め回されたら……くぅぅっ！",
      "zh": ""
    },
    {
      "key": "212.0",
      "line_index": 212,
      "inline_index": 0,
      "line_hash": "c4d6622c",
      "speaker": "ジラド",
      "ja": "むぢゅるぅ！　ちゅばちゅば！　んっ、んんっ！　さっさとイってしまえ！　ぢゅるぢゅるる！",
      "zh": ""
    },
    {
      "key": "214.0",
      "line_index": 214,
      "inline_index": 0,
      "line_hash": "32c983b1",
      "speaker": "",
      "ja": "あまりにも攻撃的で激しいフェラチオに、{G_PlayerName}は再び射精へと追い込まれていった。",
      "zh": ""
    },
    {
      "key": "216.0",
      "line_index": 216,
      "inline_index": 0,
      "line_hash": "64afaad8",
      "speaker": "",
      "ja": "陰茎はまた強く脈動し始めてびくんびくんと上下に跳ねる。",
      "zh": ""
    },
    {
      "key": "218.0",
      "line_index": 218,
      "inline_index": 0,
      "line_hash": "f7bac6bc",
      "speaker": "",
      "ja": "それをジラドの口が押さえ込みながら何度も頭を振ってしゃぶった。",
      "zh": ""
    },
    {
      "key": "221.0",
      "line_index": 221,
      "inline_index": 0,
      "line_hash": "5d4c0f03",
      "speaker": "ジラド",
      "ja": "んぐんぐっ♥　ぢゅぽぢゅぽ♥　イっちゃえ♥　イけっ♥　むぐぅ♥　ぢゅるるぅ♥　ちゅっ、ちゅるぅ♥",
      "zh": ""
    },
    {
      "key": "224.0",
      "line_index": 224,
      "inline_index": 0,
      "line_hash": "152ca13b",
      "speaker": "{G_PlayerName}",
      "ja": "あっ……うっ……うあぁ……",
      "zh": ""
    },
    {
      "key": "227.0",
      "line_index": 227,
      "inline_index": 0,
      "line_hash": "534ef900",
      "speaker": "",
      "ja": "高まる快感に{G_PlayerName}は体を震わせながら呻き声を漏らす。",
      "zh": ""
    },
    {
      "key": "229.0",
      "line_index": 229,
      "inline_index": 0,
      "line_hash": "fc186695",
      "speaker": "",
      "ja": "その様子を見ながらジラドは頭を動かす速度を速めていった。",
      "zh": ""
    },
    {
      "key": "232.0",
      "line_index": 232,
      "inline_index": 0,
      "line_hash": "1db57934",
      "speaker": "ジラド",
      "ja": "んむぅ♥　んぢゅるぢゅるぅ♥　むちゅるぅぅ♥　ぢゅっ♥　ずぢゅるぅ♥　ぺちゃぺちゃぺちゃ♥",
      "zh": ""
    },
    {
      "key": "234.0",
      "line_index": 234,
      "inline_index": 0,
      "line_hash": "acca0601",
      "speaker": "",
      "ja": "淫靡な音を立てながらジラドは{G_PlayerName}のおちんちんを激しく吸いしゃぶる。",
      "zh": ""
    },
    {
      "key": "236.0",
      "line_index": 236,
      "inline_index": 0,
      "line_hash": "cdfc77e5",
      "speaker": "",
      "ja": "頭が上下する度に裏スジに舌が擦れて{G_PlayerName}はどんどん射精に向かって高まっていった。",
      "zh": ""
    },
    {
      "key": "239.0",
      "line_index": 239,
      "inline_index": 0,
      "line_hash": "fa4fc7b1",
      "speaker": "ジラド",
      "ja": "早くイっちゃうのだ！　んぐうむぅ♥　ちゅばちゅば♥　精液どぴゅどぴゅ漏らすのだ！　んんんんっ♥",
      "zh": ""
    },
    {
      "key": "242.0",
      "line_index": 242,
      "inline_index": 0,
      "line_hash": "676692d3",
      "speaker": "{G_PlayerName}",
      "ja": "くっ……うぅぅっ……",
      "zh": ""
    },
    {
      "key": "245.0",
      "line_index": 245,
      "inline_index": 0,
      "line_hash": "34ba21b1",
      "speaker": "",
      "ja": "必死に堪えようとする{G_PlayerName}だが、それ以上に激しい刺激を与えられ、射精したいという衝動は増すばかり。",
      "zh": ""
    },
    {
      "key": "247.0",
      "line_index": 247,
      "inline_index": 0,
      "line_hash": "85e0bc26",
      "speaker": "",
      "ja": "限界まで膨らんだ陰茎はジラドの口の中でびくんびくんと上下した。",
      "zh": ""
    },
    {
      "key": "250.0",
      "line_index": 250,
      "inline_index": 0,
      "line_hash": "813bc593",
      "speaker": "ジラド",
      "ja": "もう我慢できないだろ？♥　ぢゅるるぅ♥　んっ、んんんっ♥　ジラド様に敗北してイクのだ♥　むぐぅ♥　じゅぽじゅぽ♥",
      "zh": ""
    },
    {
      "key": "253.0",
      "line_index": 253,
      "inline_index": 0,
      "line_hash": "c8f03e8d",
      "speaker": "{G_PlayerName}",
      "ja": "～～～っ！　限界だ！　射精る！",
      "zh": ""
    },
    {
      "key": "256.0",
      "line_index": 256,
      "inline_index": 0,
      "line_hash": "d30c9b07",
      "speaker": "",
      "ja": "あまりにも激しくしゃぶられた{G_PlayerName}は堪えきれずにまた勢いよく精液を放ってしまう。",
      "zh": ""
    },
    {
      "key": "264.0",
      "line_index": 264,
      "inline_index": 0,
      "line_hash": "88648c6a",
      "speaker": "ジラド",
      "ja": "～～～っ♥　むぐっ♥",
      "zh": ""
    },
    {
      "key": "266.0",
      "line_index": 266,
      "inline_index": 0,
      "line_hash": "2096d9a",
      "speaker": "",
      "ja": "今度は口を離すことなく、ジラドはどぴゅどぴゅと放たれる精液をしっかりと受け止めた。",
      "zh": ""
    },
    {
      "key": "269.0",
      "line_index": 269,
      "inline_index": 0,
      "line_hash": "f892db83",
      "speaker": "{G_PlayerName}",
      "ja": "くっ……うっ……ううっ……",
      "zh": ""
    },
    {
      "key": "272.0",
      "line_index": 272,
      "inline_index": 0,
      "line_hash": "f13185c",
      "speaker": "",
      "ja": "{G_PlayerName}はそのままジラドの口に何度も何度も精液をほとばしらせてしまう。",
      "zh": ""
    },
    {
      "key": "274.0",
      "line_index": 274,
      "inline_index": 0,
      "line_hash": "87285f8",
      "speaker": "",
      "ja": "その大量の精液をジラドは全て喉を鳴らして飲み続けた。",
      "zh": ""
    },
    {
      "key": "277.0",
      "line_index": 277,
      "inline_index": 0,
      "line_hash": "aa45fe4d",
      "speaker": "ジラド",
      "ja": "んっくっ♥　んっくっ♥　んぐんぐっ♥　んっ、んんんっ♥　ごっくんっ♥",
      "zh": ""
    },
    {
      "key": "280.0",
      "line_index": 280,
      "inline_index": 0,
      "line_hash": "5d83212d",
      "speaker": "{G_PlayerName}",
      "ja": "あうぅ……あっ……うっ……うぅぅ……",
      "zh": ""
    },
    {
      "key": "283.0",
      "line_index": 283,
      "inline_index": 0,
      "line_hash": "fd87314a",
      "speaker": "",
      "ja": "射精するおちんちんの先を強く吸われた{G_PlayerName}は、全ての精液をジラドの口の中に注ぎ込んで果てる。",
      "zh": ""
    },
    {
      "key": "285.0",
      "line_index": 285,
      "inline_index": 0,
      "line_hash": "598c4a9c",
      "speaker": "",
      "ja": "それをジラドは尿道内のものまで残さずに吸い出し飲み干した。",
      "zh": ""
    },
    {
      "key": "288.0",
      "line_index": 288,
      "inline_index": 0,
      "line_hash": "25720bc4",
      "speaker": "ジラド",
      "ja": "ぢゅるるっ♥　んちゅるぅ♥　んっ♥　んっ♥　んんっ♥　ちゅるちゅるぅ♥",
      "zh": ""
    },
    {
      "key": "290.0",
      "line_index": 290,
      "inline_index": 0,
      "line_hash": "29adc77c",
      "speaker": "",
      "ja": "全ての精液を吸い尽くしたジラドは{G_PlayerName}の陰茎から口を離す。",
      "zh": ""
    },
    {
      "key": "293.0",
      "line_index": 293,
      "inline_index": 0,
      "line_hash": "ffb91c4f",
      "speaker": "ジラド",
      "ja": "へへっ、二回もイカせてやったぞっ♥　これでジラド様の勝ちだな♥",
      "zh": ""
    },
    {
      "key": "295.0",
      "line_index": 295,
      "inline_index": 0,
      "line_hash": "283be897",
      "speaker": "",
      "ja": "勝ち誇ったようにそう言いながらジラドは射精を終えた{G_PlayerName}を満足げな顔で見つめていた。",
      "zh": ""
    }
  ]
}
