    },
    {
      "key": "225.0",
      "line_index": 225,
      "inline_index": 0,
      "line_hash": "d92e9ab3",
      "speaker": "",
      "ja": "その締め付けに{G_PlayerName}も限界に達してしまった。",
      "zh": ""
