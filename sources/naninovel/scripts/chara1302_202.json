{
  "lines": [
    {
      "key": "25.1",
      "line_index": 25,
      "inline_index": 1,
      "line_hash": "a6d5f482",
      "speaker": "ドリー",
      "ja": "ひゃわあっ！？♥　な、なな、何？　なんで抱きかかえて……♥",
      "zh": ""
    },
    {
      "key": "28.1",
      "line_index": 28,
      "inline_index": 1,
      "line_hash": "53ef58f7",
      "speaker": "ドリー",
      "ja": "（こ、これ、お姫様抱っこ……？♥　こんなふうにされちゃうなんて……胸が、ドキドキしてくるぅ……♥）",
      "zh": ""
    },
    {
      "key": "30.0",
      "line_index": 30,
      "inline_index": 0,
      "line_hash": "e5c555da",
      "speaker": "",
      "ja": "ドリーとセックス……そう考えた瞬間、俺は彼女を抱きかかえていた。",
      "zh": ""
    },
    {
      "key": "31.0",
      "line_index": 31,
      "inline_index": 0,
      "line_hash": "8d69b98f",
      "speaker": "",
      "ja": "そして優しくベッドに寝かせると、彼女の身体を覆い隠すメイド服に手を伸ばす。",
      "zh": ""
    },
    {
      "key": "34.1",
      "line_index": 34,
      "inline_index": 1,
      "line_hash": "50263c1a",
      "speaker": "ドリー",
      "ja": "あ……やっぱ脱がなきゃダメ……？♥",
      "zh": ""
    },
    {
      "key": "37.0",
      "line_index": 37,
      "inline_index": 0,
      "line_hash": "5020ea72",
      "speaker": "{G_PlayerName}",
      "ja": "脱ぐのイヤか……？",
      "zh": ""
    },
    {
      "key": "41.1",
      "line_index": 41,
      "inline_index": 1,
      "line_hash": "20ea7353",
      "speaker": "ドリー",
      "ja": "そ、そんなことないっす、けど……♥",
      "zh": ""
    },
    {
      "key": "44.1",
      "line_index": 44,
      "inline_index": 1,
      "line_hash": "6280a191",
      "speaker": "ドリー",
      "ja": "（まいったな……裸なんてグリム様とお風呂に入る時くらいしか他の人に見せたことないし……♥）",
      "zh": ""
    },
    {
      "key": "47.1",
      "line_index": 47,
      "inline_index": 1,
      "line_hash": "7e55009f",
      "speaker": "ドリー",
      "ja": "（いいって言った手前、拒否するわけにもいかないし……でも余計な気も遣われたくないし……♥）",
      "zh": ""
    },
    {
      "key": "50.1",
      "line_index": 50,
      "inline_index": 1,
      "line_hash": "fd759fd0",
      "speaker": "ドリー",
      "ja": "（心の中で少し望んでたけど、まさか今日本番までなんて思ってもいなかった……♥）",
      "zh": ""
    },
    {
      "key": "53.0",
      "line_index": 53,
      "inline_index": 0,
      "line_hash": "cedbd310",
      "speaker": "{G_PlayerName}",
      "ja": "ドリー、脱がすぞ？",
      "zh": ""
    },
    {
      "key": "57.1",
      "line_index": 57,
      "inline_index": 1,
      "line_hash": "6bc1b10f",
      "speaker": "ドリー",
      "ja": "う、うん……♥　あ、やっぱ自分で脱ぐ……♥　機械士さんも勝手に脱いで……♥",
      "zh": ""
    },
    {
      "key": "60.0",
      "line_index": 60,
      "inline_index": 0,
      "line_hash": "52732752",
      "speaker": "{G_PlayerName}",
      "ja": "そ、そうか、わかった",
      "zh": ""
    },
    {
      "key": "64.1",
      "line_index": 64,
      "inline_index": 1,
      "line_hash": "78f9011c",
      "speaker": "ドリー",
      "ja": "（もうなるようにしかならないか……♥　でも相手が機械士さんなら、初めてでも後悔なんてしないでしょ……♥）",
      "zh": ""
    },
    {
      "key": "81.0",
      "line_index": 81,
      "inline_index": 0,
      "line_hash": "652cfe21",
      "speaker": "ドリー",
      "ja": "はぁ～……♥　なんかさっきよりおっきくなってる……？♥",
      "zh": ""
    },
    {
      "key": "83.0",
      "line_index": 83,
      "inline_index": 0,
      "line_hash": "ed52b476",
      "speaker": "",
      "ja": "今にも張り裂けそうなほどに膨れ上がった肉棒に興味津々のドリー。",
      "zh": ""
    },
    {
      "key": "84.0",
      "line_index": 84,
      "inline_index": 0,
      "line_hash": "b2178f75",
      "speaker": "",
      "ja": "小さく白い指が亀頭に触れ、ゾクっとした快感に全身が震えてしまう。",
      "zh": ""
    },
    {
      "key": "87.0",
      "line_index": 87,
      "inline_index": 0,
      "line_hash": "eea41b02",
      "speaker": "{G_PlayerName}",
      "ja": "そうかもしれない……",
      "zh": ""
    },
    {
      "key": "91.0",
      "line_index": 91,
      "inline_index": 0,
      "line_hash": "2be9f7af",
      "speaker": "ドリー",
      "ja": "あ……♥　んぅ……機械士さんっ……♥",
      "zh": ""
    },
    {
      "key": "93.0",
      "line_index": 93,
      "inline_index": 0,
      "line_hash": "f4ccc257",
      "speaker": "",
      "ja": "ドリーの膨らみに手を伸ばし、クニクニと揉んでいく。",
      "zh": ""
    },
    {
      "key": "94.0",
      "line_index": 94,
      "inline_index": 0,
      "line_hash": "a45be95",
      "speaker": "",
      "ja": "小さくてもしっかりと弾力があり、心地よい柔らかさにどんどん指が動く。",
      "zh": ""
    },
    {
      "key": "96.0",
      "line_index": 96,
      "inline_index": 0,
      "line_hash": "f0ad62f0",
      "speaker": "",
      "ja": "小さく声をあげるドリーは今までにないくらい可愛く見え、それが俺をより興奮させていく。",
      "zh": ""
    },
    {
      "key": "99.0",
      "line_index": 99,
      "inline_index": 0,
      "line_hash": "28ce2b04",
      "speaker": "ドリー",
      "ja": "（機械士さんのおちんちん、どんどん熱くなってる……♥　あぁ……今からあんな大きなモノをうちの中に……♥）",
      "zh": ""
    },
    {
      "key": "102.0",
      "line_index": 102,
      "inline_index": 0,
      "line_hash": "b8147f47",
      "speaker": "ドリー",
      "ja": "（さすがに、少し怖い、かも……♥　おまんこ裂けたりしないかな……♥）",
      "zh": ""
    },
    {
      "key": "105.0",
      "line_index": 105,
      "inline_index": 0,
      "line_hash": "a8d57739",
      "speaker": "{G_PlayerName}",
      "ja": "ドリー……？",
      "zh": ""
    },
    {
      "key": "109.0",
      "line_index": 109,
      "inline_index": 0,
      "line_hash": "8fe34507",
      "speaker": "ドリー",
      "ja": "えっ？　あ、な、なに……？♥　うちの身体見て醒めちゃった？♥",
      "zh": ""
    },
    {
      "key": "112.0",
      "line_index": 112,
      "inline_index": 0,
      "line_hash": "7154028a",
      "speaker": "{G_PlayerName}",
      "ja": "そんなわけあるか……ドリーの裸見て余計にシたくなったよ。ただ、なんか不安そうに見えてさ……",
      "zh": ""
    },
    {
      "key": "116.0",
      "line_index": 116,
      "inline_index": 0,
      "line_hash": "cc9831d1",
      "speaker": "ドリー",
      "ja": "あ～……うん、まぁ、その……機械士さんのおっきいからさ……ちょっとばかし、ね……♥",
      "zh": ""
    },
    {
      "key": "119.0",
      "line_index": 119,
      "inline_index": 0,
      "line_hash": "d825add5",
      "speaker": "ドリー",
      "ja": "でもまぁだいじょうぶっしょ……♥　おまんこっておちんちん挿るようにできてんだしさ……♥",
      "zh": ""
    },
    {
      "key": "122.0",
      "line_index": 122,
      "inline_index": 0,
      "line_hash": "6500d4e5",
      "speaker": "{G_PlayerName}",
      "ja": "……慣れてるんだな",
      "zh": ""
    },
    {
      "key": "126.0",
      "line_index": 126,
      "inline_index": 0,
      "line_hash": "1a584621",
      "speaker": "ドリー",
      "ja": "まぁ……一応は……メイドだから、ね……♥",
      "zh": ""
    },
    {
      "key": "129.0",
      "line_index": 129,
      "inline_index": 0,
      "line_hash": "1e29ff84",
      "speaker": "ドリー",
      "ja": "（なんでウソなんてついてんだろ……初めてって素直に言っちゃえばいいのに……♥）",
      "zh": ""
    },
    {
      "key": "132.0",
      "line_index": 132,
      "inline_index": 0,
      "line_hash": "24954f56",
      "speaker": "{G_PlayerName}",
      "ja": "じゃあそろそろ……挿れるぞ、ドリー",
      "zh": ""
    },
    {
      "key": "136.0",
      "line_index": 136,
      "inline_index": 0,
      "line_hash": "215cbe5e",
      "speaker": "ドリー",
      "ja": "う、うん……♥",
      "zh": ""
    },
    {
      "key": "143.0",
      "line_index": 143,
      "inline_index": 0,
      "line_hash": "2157b6c1",
      "speaker": "ドリー",
      "ja": "ううっ！？♥　うあ、んぅ……ふぅ、んっ……んんんんん～～～っ！！♥",
      "zh": ""
    },
    {
      "key": "145.0",
      "line_index": 145,
      "inline_index": 0,
      "line_hash": "649c735f",
      "speaker": "",
      "ja": "俺はできるだけ冷静に、そう考えながら膣穴に肉棒の先端を押し込む。",
      "zh": ""
    },
    {
      "key": "147.0",
      "line_index": 147,
      "inline_index": 0,
      "line_hash": "f58b93ba",
      "speaker": "",
      "ja": "膣中はぐちゅぐちゅに濡れていたが、想像以上に膣が狭い。",
      "zh": ""
    },
    {
      "key": "148.0",
      "line_index": 148,
      "inline_index": 0,
      "line_hash": "5e5df18b",
      "speaker": "",
      "ja": "入り込んだ異物を押し戻すように反発するが、俺はドリーの足首を掴むと腰を一気に前に突き出した。",
      "zh": ""
    },
    {
      "key": "151.0",
      "line_index": 151,
      "inline_index": 0,
      "line_hash": "ff0aa950",
      "speaker": "ドリー",
      "ja": "（挿ってる……ホントに挿っちゃってる……♥　硬くて太いのが、おまんこミチミチ拡げてくるぅ……！♥）",
      "zh": ""
    },
    {
      "key": "154.0",
      "line_index": 154,
      "inline_index": 0,
      "line_hash": "c673c456",
      "speaker": "{G_PlayerName}",
      "ja": "ドリーのおまんこ、キツキツだな……本当に慣れているのか？　実は初めてってことはないのか……？",
      "zh": ""
    },
    {
      "key": "158.0",
      "line_index": 158,
      "inline_index": 0,
      "line_hash": "e9a867d6",
      "speaker": "ドリー",
      "ja": "んんっ……そんなこと……あうっ！♥　全然、このくらい余裕なんですけどっ♥",
      "zh": ""
    },
    {
      "key": "161.0",
      "line_index": 161,
      "inline_index": 0,
      "line_hash": "4dbb0676",
      "speaker": "{G_PlayerName}",
      "ja": "そうか……わかった、ドリーの言葉信じるよ",
      "zh": ""
    },
    {
      "key": "164.0",
      "line_index": 164,
      "inline_index": 0,
      "line_hash": "fc0c161d",
      "speaker": "",
      "ja": "俺はそうドリーに告げると、腰をゆっくりと動かし始める。",
      "zh": ""
    },
    {
      "key": "166.0",
      "line_index": 166,
      "inline_index": 0,
      "line_hash": "a8cb67b7",
      "speaker": "",
      "ja": "最初こそ膣が反発していたが、今は肉棒を受け入れるように締め付ける。",
      "zh": ""
    },
    {
      "key": "167.0",
      "line_index": 167,
      "inline_index": 0,
      "line_hash": "3139c4a6",
      "speaker": "",
      "ja": "ぎゅっぎゅと強い圧で肉棒が締め付けられ、動くたびに無数のヒダが亀頭を包み込むように舐め回す。",
      "zh": ""
    },
    {
      "key": "169.0",
      "line_index": 169,
      "inline_index": 0,
      "line_hash": "9fbdbef0",
      "speaker": "",
      "ja": "長く続けられそうにない、そう思ってしまうが膣の気持ち良さがピストンを自然と早めてしまう。",
      "zh": ""
    },
    {
      "key": "172.0",
      "line_index": 172,
      "inline_index": 0,
      "line_hash": "f37b210a",
      "speaker": "ドリー",
      "ja": "はぁ、んんぅ♥　ふぅ、ふぅぅ……！♥　んくっ！♥　お、奥、そんなに……あうっ！♥　ゴツゴツ、当たるぅ……！♥",
      "zh": ""
    },
    {
      "key": "175.0",
      "line_index": 175,
      "inline_index": 0,
      "line_hash": "e64079e8",
      "speaker": "ドリー",
      "ja": "（セックス、なんかすごすぎぃ……！♥　奥突かれるたびに息詰まるぅ……♥）",
      "zh": ""
    },
    {
      "key": "178.0",
      "line_index": 178,
      "inline_index": 0,
      "line_hash": "62d57b61",
      "speaker": "ドリー",
      "ja": "（でも、なんか……気持ち、いいかもぉ……♥　指で弄るのと全然違う……♥　出っ張りに擦られてゾクゾクしてくるぅ……♥）",
      "zh": ""
    },
    {
      "key": "180.0",
      "line_index": 180,
      "inline_index": 0,
      "line_hash": "d5ee2592",
      "speaker": "",
      "ja": "肉棒を出し入れするたびに愛液が掻き出され、ドリーの下半身がいやらしく濡れていく。",
      "zh": ""
    },
    {
      "key": "182.0",
      "line_index": 182,
      "inline_index": 0,
      "line_hash": "6aa8634e",
      "speaker": "",
      "ja": "喘ぎ声が少しずつ大きくなり始め、声の大きさに比例して膣の動くが活発になる。",
      "zh": ""
    },
    {
      "key": "183.0",
      "line_index": 183,
      "inline_index": 0,
      "line_hash": "6176db30",
      "speaker": "",
      "ja": "下腹部は肉棒の出し入れに合わせ歪に歪み、本当にドリーと一つになっている実感が湧いて来る。",
      "zh": ""
    },
    {
      "key": "186.0",
      "line_index": 186,
      "inline_index": 0,
      "line_hash": "90b980ab",
      "speaker": "ドリー",
      "ja": "うう、ぐっ……！♥　そ、そんなに早く動くんすっか……！？♥　ちょ、待って……ううっ！♥　そんなに強くされたら息が……うううっ！！♥",
      "zh": ""
    },
    {
      "key": "189.0",
      "line_index": 189,
      "inline_index": 0,
      "line_hash": "54900e0f",
      "speaker": "{G_PlayerName}",
      "ja": "（なんだ、これ……！　ヒダが絡みついてくるっ……！）",
      "zh": ""
    },
    {
      "key": "193.0",
      "line_index": 193,
      "inline_index": 0,
      "line_hash": "a8963370",
      "speaker": "ドリー",
      "ja": "（気持ちいっ、気持ち良い……！♥　初めてなのに、気持ち良くなっちゃってるぅ……！！♥）",
      "zh": ""
    },
    {
      "key": "196.0",
      "line_index": 196,
      "inline_index": 0,
      "line_hash": "64b1e28a",
      "speaker": "ドリー",
      "ja": "（エッチの手引書にこんなに気持ち良いなんて書いてなかったじゃんっ……！！♥）",
      "zh": ""
    },
    {
      "key": "198.0",
      "line_index": 198,
      "inline_index": 0,
      "line_hash": "438f08b6",
      "speaker": "",
      "ja": "ドリーは快感に我慢できないのか腰を捩らせる。",
      "zh": ""
    },
    {
      "key": "199.0",
      "line_index": 199,
      "inline_index": 0,
      "line_hash": "78925739",
      "speaker": "",
      "ja": "狭すぎる膣で歪に肉棒を擦られ、それが俺に更なる快感をもたらす。",
      "zh": ""
    },
    {
      "key": "201.0",
      "line_index": 201,
      "inline_index": 0,
      "line_hash": "4fd5a018",
      "speaker": "",
      "ja": "脳裏を何度もよぎる射精の衝動。",
      "zh": ""
    },
    {
      "key": "202.0",
      "line_index": 202,
      "inline_index": 0,
      "line_hash": "1badc20",
      "speaker": "",
      "ja": "俺はその衝動に突き動かされるように腰を大きく動かしていく。",
      "zh": ""
    },
    {
      "key": "205.0",
      "line_index": 205,
      "inline_index": 0,
      "line_hash": "7fcb3745",
      "speaker": "ドリー",
      "ja": "んひぃっ！♥　うう、奥ばっかりぃ……！♥　んは、んぅぅぅっ！♥　ふぅ、んふぅぅっ！！♥　そこぉ……だめぇ……あぐっ！♥",
      "zh": ""
    },
    {
      "key": "208.0",
      "line_index": 208,
      "inline_index": 0,
      "line_hash": "ab19a5c9",
      "speaker": "{G_PlayerName}",
      "ja": "くぅ……！　ドリー、もうダメだ……！　このまま出すけど構わないよなっ！？",
      "zh": ""
    },
    {
      "key": "212.0",
      "line_index": 212,
      "inline_index": 0,
      "line_hash": "5681a179",
      "speaker": "ドリー",
      "ja": "ふえぇ、それってぇ……うう、中に……！？♥",
      "zh": ""
    },
    {
      "key": "215.0",
      "line_index": 215,
      "inline_index": 0,
      "line_hash": "b0677fc6",
      "speaker": "ドリー",
      "ja": "（中に、なんて……万が一があったら……♥　うう、どう返事すればぁ……♥）",
      "zh": ""
    },
    {
      "key": "218.0",
      "line_index": 218,
      "inline_index": 0,
      "line_hash": "4279bd49",
      "speaker": "{G_PlayerName}",
      "ja": "くっ！　もう限界……！　出るっ！！",
      "zh": ""
    },
    {
      "key": "229.0",
      "line_index": 229,
      "inline_index": 0,
      "line_hash": "cad88f57",
      "speaker": "ドリー",
      "ja": "はうっ！？♥　あ、あっ……熱いぃ……！♥　んんんっ……！！♥",
      "zh": ""
    },
    {
      "key": "231.0",
      "line_index": 231,
      "inline_index": 0,
      "line_hash": "efc8ddcb",
      "speaker": "",
      "ja": "俺は興奮のままにドリーのあそこの中にこみ上げる熱い塊をぶちまける。",
      "zh": ""
    },
    {
      "key": "233.0",
      "line_index": 233,
      "inline_index": 0,
      "line_hash": "374ed9d0",
      "speaker": "",
      "ja": "一度の射精では物足りず、俺は腰を小刻みに揺らしとろとろの膣で精液を扱き出す。",
      "zh": ""
    },
    {
      "key": "234.0",
      "line_index": 234,
      "inline_index": 0,
      "line_hash": "95d054b4",
      "speaker": "",
      "ja": "射精のたびにドリーは小さく声を上げ、大きな瞳で射精に夢中になっている俺を見つめていた。",
      "zh": ""
    },
    {
      "key": "237.0",
      "line_index": 237,
      "inline_index": 0,
      "line_hash": "5dc49cf",
      "speaker": "ドリー",
      "ja": "（これが、中出し……♥　熱いのがお腹の奥に広がって……おまんこ蕩けるぅ……♥）",
      "zh": ""
    },
    {
      "key": "240.0",
      "line_index": 240,
      "inline_index": 0,
      "line_hash": "bc06c6ec",
      "speaker": "ドリー",
      "ja": "（こんなに出してくれるってことは、問題なくセックス終えられたのかな……♥　機械士さんに余計な気遣いをさせずにすんだのかな……♥）",
      "zh": ""
    },
    {
      "key": "243.0",
      "line_index": 243,
      "inline_index": 0,
      "line_hash": "e6bcaf05",
      "speaker": "ドリー",
      "ja": "（ま、どっちでもいっか……♥　機械士さんが気持ち良くなってくれたんだったら……♥）",
      "zh": ""
    },
    {
      "key": "246.0",
      "line_index": 246,
      "inline_index": 0,
      "line_hash": "6c45938a",
      "speaker": "ドリー",
      "ja": "わりと早く終わりましたね、お疲れさまでした",
      "zh": ""
    },
    {
      "key": "248.0",
      "line_index": 248,
      "inline_index": 0,
      "line_hash": "c8c0def2",
      "speaker": "",
      "ja": "ドリーが笑みを見せたと思った矢先、普段の気怠そうな表情に戻る。",
      "zh": ""
    },
    {
      "key": "249.0",
      "line_index": 249,
      "inline_index": 0,
      "line_hash": "80f39b41",
      "speaker": "",
      "ja": "もうセックスが終わったと判断したのか、ふぅ、と小さく何度も息を吐き呼吸を整えていた。",
      "zh": ""
    },
    {
      "key": "251.0",
      "line_index": 251,
      "inline_index": 0,
      "line_hash": "6fbf7642",
      "speaker": "",
      "ja": "しかし俺のドリーを欲しがるオスのドス黒い欲望は未だに心の中にくすぶっている。",
      "zh": ""
    },
    {
      "key": "253.0",
      "line_index": 253,
      "inline_index": 0,
      "line_hash": "760523a1",
      "speaker": "",
      "ja": "ほんの少し前まで見せていたドリーの快感に悶えるあの表情。",
      "zh": ""
    },
    {
      "key": "254.0",
      "line_index": 254,
      "inline_index": 0,
      "line_hash": "4742fcc8",
      "speaker": "",
      "ja": "気持ち良さから逃げるように腰を捩らせる姿。",
      "zh": ""
    },
    {
      "key": "255.0",
      "line_index": 255,
      "inline_index": 0,
      "line_hash": "e903e860",
      "speaker": "",
      "ja": "それが未だに俺を興奮させ続け、肉棒は依然として硬いままであった。",
      "zh": ""
    },
    {
      "key": "258.0",
      "line_index": 258,
      "inline_index": 0,
      "line_hash": "1e3271c1",
      "speaker": "ドリー",
      "ja": "じゃ、おちんちん綺麗にするんで、そのままで──",
      "zh": ""
    },
    {
      "key": "265.0",
      "line_index": 265,
      "inline_index": 0,
      "line_hash": "9cb3fd1d",
      "speaker": "ドリー",
      "ja": "はうううっ！？♥　機械士さんっ！？♥　あっ♥　ふぅ、待ってぇ、なんで動いて……んんんっ！！",
      "zh": ""
    },
    {
      "key": "267.0",
      "line_index": 267,
      "inline_index": 0,
      "line_hash": "44911b7b",
      "speaker": "",
      "ja": "ドリーが起き上がろうとした瞬間、俺はピストンを再開する。",
      "zh": ""
    },
    {
      "key": "269.0",
      "line_index": 269,
      "inline_index": 0,
      "line_hash": "e36306b2",
      "speaker": "",
      "ja": "突然の俺の行動に慌てふためくドリー。",
      "zh": ""
    },
    {
      "key": "270.0",
      "line_index": 270,
      "inline_index": 0,
      "line_hash": "2daaf38a",
      "speaker": "",
      "ja": "快感から逃げるように身体を捩らせるが、俺は細い腰を掴むと執拗に肉棒の出し入れを繰り返す。",
      "zh": ""
    },
    {
      "key": "272.0",
      "line_index": 272,
      "inline_index": 0,
      "line_hash": "1d3b0b46",
      "speaker": "",
      "ja": "愛液と精液が狭い膣の中で掻き回されて、ぐちゅぐちゅといやらしい音が響く。",
      "zh": ""
    },
    {
      "key": "273.0",
      "line_index": 273,
      "inline_index": 0,
      "line_hash": "1fd8cc24",
      "speaker": "",
      "ja": "ピストンのたびに無数のヒダが肉棒を撫で、ゾクっとした快感にどんどんのめり込んでいく。",
      "zh": ""
    },
    {
      "key": "276.0",
      "line_index": 276,
      "inline_index": 0,
      "line_hash": "ef3ff343",
      "speaker": "ドリー",
      "ja": "待って、待ってぇ……！♥　あれだけ射精したのに、んんっ！♥　まだ続けるつもり！？♥",
      "zh": ""
    },
    {
      "key": "279.0",
      "line_index": 279,
      "inline_index": 0,
      "line_hash": "4839de8f",
      "speaker": "{G_PlayerName}",
      "ja": "当たり前だ……！　ドリーをもっと感じたい！　ドリーにももっと気持ち良くなって欲しいっ！",
      "zh": ""
    },
    {
      "key": "283.0",
      "line_index": 283,
      "inline_index": 0,
      "line_hash": "fa1ed41b",
      "speaker": "ドリー",
      "ja": "あひぃ、ひぃっ！♥　激しいの、んあっ！♥　ダメだってぇ……！♥　んんっ！！♥",
      "zh": ""
    },
    {
      "key": "286.0",
      "line_index": 286,
      "inline_index": 0,
      "line_hash": "63148d2c",
      "speaker": "ドリー",
      "ja": "（メチャクチャ感じる……！♥　さっきより全然気持ち良くなってる……！！♥　どうして、なんでこんなに感じてしまうの……！♥）",
      "zh": ""
    },
    {
      "key": "289.0",
      "line_index": 289,
      "inline_index": 0,
      "line_hash": "31fa816f",
      "speaker": "{G_PlayerName}",
      "ja": "（やっぱウソなんじゃないか……？　どう見てもセックスに手馴れているとは思えない……）",
      "zh": ""
    },
    {
      "key": "292.0",
      "line_index": 292,
      "inline_index": 0,
      "line_hash": "75c7909e",
      "speaker": "",
      "ja": "首をブンブンと横に振り、ひたすらに快感に耐えるドリーを見てそんなことを考えてしまう。",
      "zh": ""
    },
    {
      "key": "294.0",
      "line_index": 294,
      "inline_index": 0,
      "line_hash": "1dec29",
      "speaker": "",
      "ja": "もし初めてなら優しくしないと、そう頭では理解してたが腰が勝手に動いて止まらない。",
      "zh": ""
    },
    {
      "key": "296.0",
      "line_index": 296,
      "inline_index": 0,
      "line_hash": "db7619f6",
      "speaker": "",
      "ja": "ドリーの膣の気持ち良さに完全に心奪われ、よりドリーと密着して感じようと俺は身体を前に傾けピストンを繰り返す。",
      "zh": ""
    },
    {
      "key": "299.0",
      "line_index": 299,
      "inline_index": 0,
      "line_hash": "dc78fb9b",
      "speaker": "ドリー",
      "ja": "あっ♥　んあっ！♥　これ、ダメ……！♥　くぅ、んんっ！♥　おまんこ、感じる、感じちゃう……！♥　はうう……！！♥",
      "zh": ""
    },
    {
      "key": "302.0",
      "line_index": 302,
      "inline_index": 0,
      "line_hash": "8edccffd",
      "speaker": "ドリー",
      "ja": "待って、止まってぇ……！♥　このままじゃ、うち……あうっ！♥",
      "zh": ""
    },
    {
      "key": "305.0",
      "line_index": 305,
      "inline_index": 0,
      "line_hash": "34bf917e",
      "speaker": "ドリー",
      "ja": "あ……♥　んぅ、ふぅ、ふぅ……♥　機械士、さんっ……♥　んんっ、んはぁっ！♥",
      "zh": ""
    },
    {
      "key": "307.0",
      "line_index": 307,
      "inline_index": 0,
      "line_hash": "3675286f",
      "speaker": "",
      "ja": "僅かに不安げな表情を見せていたドリーをなだめる様にそっと頬に手を伸ばす。",
      "zh": ""
    },
    {
      "key": "309.0",
      "line_index": 309,
      "inline_index": 0,
      "line_hash": "5a9f747d",
      "speaker": "",
      "ja": "ぷにぷにの頬を撫でるとドリーはうっすらと目を開け、少し安心したような表情を俺に見せてきた。",
      "zh": ""
    },
    {
      "key": "312.0",
      "line_index": 312,
      "inline_index": 0,
      "line_hash": "da3f72af",
      "speaker": "{G_PlayerName}",
      "ja": "怖がらなくてもだいじょうぶだから……快感を素直に受け入れて",
      "zh": ""
    },
    {
      "key": "316.0",
      "line_index": 316,
      "inline_index": 0,
      "line_hash": "4f50e991",
      "speaker": "ドリー",
      "ja": "う、うん……♥　ふぅ、んんっ……！♥　はぁ、んはぁ、あっ♥　あ、んあっ！♥　はぁぁ……！！♥",
      "zh": ""
    },
    {
      "key": "319.0",
      "line_index": 319,
      "inline_index": 0,
      "line_hash": "82a7329b",
      "speaker": "ドリー",
      "ja": "（機械士さんの手、すごく大きい……♥　なんだか安心できる……♥　そっか、素直に快感を受け入れる……それだけでいいんだ……♥）",
      "zh": ""
    },
    {
      "key": "322.0",
      "line_index": 322,
      "inline_index": 0,
      "line_hash": "654da253",
      "speaker": "{G_PlayerName}",
      "ja": "ぅあっ！？　くぅぅぅぅ……！　し、締まるっ……！！",
      "zh": ""
    },
    {
      "key": "325.0",
      "line_index": 325,
      "inline_index": 0,
      "line_hash": "dca89d36",
      "speaker": "",
      "ja": "急に膣の動きが変化し、吸い付くように蠢く。",
      "zh": ""
    },
    {
      "key": "326.0",
      "line_index": 326,
      "inline_index": 0,
      "line_hash": "5e90c5",
      "speaker": "",
      "ja": "より俺たちの性器が密着し、狭すぎる膣をこじ開けるようにピストンを繰り返す。",
      "zh": ""
    },
    {
      "key": "328.0",
      "line_index": 328,
      "inline_index": 0,
      "line_hash": "c893cd85",
      "speaker": "",
      "ja": "動くたびに俺とドリーは甘い吐息が口から漏れ、快感に身体を震わせる。",
      "zh": ""
    },
    {
      "key": "330.0",
      "line_index": 330,
      "inline_index": 0,
      "line_hash": "f018b530",
      "speaker": "",
      "ja": "そんな柔膣に何度も締め付けられ、射精したばかりだというのにもう限界が近づいて来るのを感じる。",
      "zh": ""
    },
    {
      "key": "333.0",
      "line_index": 333,
      "inline_index": 0,
      "line_hash": "2307e8f8",
      "speaker": "ドリー",
      "ja": "機械士さんっ、うち、もう……！♥　んんんん～っ！♥",
      "zh": ""
    },
    {
      "key": "336.0",
      "line_index": 336,
      "inline_index": 0,
      "line_hash": "44605289",
      "speaker": "{G_PlayerName}",
      "ja": "俺も……！　また中に出すぞ……",
      "zh": ""
    },
    {
      "key": "340.0",
      "line_index": 340,
      "inline_index": 0,
      "line_hash": "35bf7480",
      "speaker": "ドリー",
      "ja": "うん、出して……！♥　またうちの中でイって……！♥　気持ち良くっ、なってぇ……！！♥",
      "zh": ""
    },
    {
      "key": "343.0",
      "line_index": 343,
      "inline_index": 0,
      "line_hash": "71fbee33",
      "speaker": "ドリー",
      "ja": "あううっ！♥　イっ……！♥　ふぅ、ふあ、あっ……んっ、んんんんんんーーーっ！！♥♥",
      "zh": ""
    },
    {
      "key": "353.0",
      "line_index": 353,
      "inline_index": 0,
      "line_hash": "42ed2ccc",
      "speaker": "ドリー",
      "ja": "んあっ！♥　ふぅ、ふあぁ、んぅぅ……また、いっぱいっ、出てるぅ……！♥　ふぅ、ふぅぅ……！♥",
      "zh": ""
    },
    {
      "key": "355.0",
      "line_index": 355,
      "inline_index": 0,
      "line_hash": "8a69317f",
      "speaker": "",
      "ja": "絶頂に達したドリーの膣が肉棒を吸い上げ、精液を搾り取ってくる。",
      "zh": ""
    },
    {
      "key": "356.0",
      "line_index": 356,
      "inline_index": 0,
      "line_hash": "eee4117c",
      "speaker": "",
      "ja": "その締め付けに俺は四度目にも関わらず大量の射精を繰り返してしまった。",
      "zh": ""
    },
    {
      "key": "359.0",
      "line_index": 359,
      "inline_index": 0,
      "line_hash": "60744c",
      "speaker": "ドリー",
      "ja": "熱いぃ……おまんこ、溶けるぅ……♥　はぁ、はぁぁ……ああ、まだびゅるびゅるしてるぅ……あふぅぅ……♥",
      "zh": ""
    },
    {
      "key": "361.0",
      "line_index": 361,
      "inline_index": 0,
      "line_hash": "87a53189",
      "speaker": "",
      "ja": "すっかり快楽に溺れたドリーは甘い声をあげながら精液を受け止める。",
      "zh": ""
    },
    {
      "key": "362.0",
      "line_index": 362,
      "inline_index": 0,
      "line_hash": "56028e4c",
      "speaker": "",
      "ja": "俺も同様に快楽に溺れ、小刻みに腰を揺すりながら子宮の中に精液を注ぎ込んでいく。",
      "zh": ""
    },
    {
      "key": "365.0",
      "line_index": 365,
      "inline_index": 0,
      "line_hash": "614e1fe6",
      "speaker": "ドリー",
      "ja": "んはぁ、はぁ……うう、こんな、はずでは……♥　はぁ、はぁ……♥",
      "zh": ""
    },
    {
      "key": "368.0",
      "line_index": 368,
      "inline_index": 0,
      "line_hash": "7cb3d6ec",
      "speaker": "{G_PlayerName}",
      "ja": "ドリー、本当は初めてだったんだろ……？",
      "zh": ""
    },
    {
      "key": "372.0",
      "line_index": 372,
      "inline_index": 0,
      "line_hash": "4ae0b552",
      "speaker": "ドリー",
      "ja": "それは……まぁ、その……はぁ、はぁぁ……♥　ただ、ヘンに気遣ってほしくなくて……♥",
      "zh": ""
    },
    {
      "key": "375.0",
      "line_index": 375,
      "inline_index": 0,
      "line_hash": "833a8756",
      "speaker": "{G_PlayerName}",
      "ja": "そっか……でも女の子を気遣うのは男として当然のことだぞ。だからそんなこと今後は気にしなくてもいいから",
      "zh": ""
    },
    {
      "key": "378.0",
      "line_index": 378,
      "inline_index": 0,
      "line_hash": "54673044",
      "speaker": "",
      "ja": "ドリーの髪をそっと撫でると、照れくさそうに僅かに顔を背ける。",
      "zh": ""
    },
    {
      "key": "379.0",
      "line_index": 379,
      "inline_index": 0,
      "line_hash": "ba4bb106",
      "speaker": "",
      "ja": "そんなドリーが最高に可愛く、俺は何度もドリーの髪を撫で続けた。",
      "zh": ""
    },
    {
      "key": "382.0",
      "line_index": 382,
      "inline_index": 0,
      "line_hash": "ba70742",
      "speaker": "ドリー",
      "ja": "（機械士さん、優しいな……うぅ、胸がきゅんとしちゃった……♥）",
      "zh": ""
    },
    {
      "key": "385.0",
      "line_index": 385,
      "inline_index": 0,
      "line_hash": "c3c63d66",
      "speaker": "ドリー",
      "ja": "（でも、いつから見透かされていたんだろ……もしかしてフェラしたときから……？♥　それならうち、完全にピエロじゃん……めっちゃハズいよ……♥）",
      "zh": ""
    },
    {
      "key": "388.0",
      "line_index": 388,
      "inline_index": 0,
      "line_hash": "fab38f6",
      "speaker": "{G_PlayerName}",
      "ja": "ドリー……俺もっとドリーとエッチしたい……ダメか？",
      "zh": ""
    },
    {
      "key": "392.0",
      "line_index": 392,
      "inline_index": 0,
      "line_hash": "c609a195",
      "speaker": "ドリー",
      "ja": "あー……うん、その……うちも、そのぉ……し、したい、かも……？♥",
      "zh": ""
    },
    {
      "key": "395.0",
      "line_index": 395,
      "inline_index": 0,
      "line_hash": "e7aa501c",
      "speaker": "ドリー",
      "ja": "でも次はもう少し優しく……あ、やっぱ今の無し♥　機械士さんの好きなように──",
      "zh": ""
    },
    {
      "key": "398.0",
      "line_index": 398,
      "inline_index": 0,
      "line_hash": "759d5556",
      "speaker": "{G_PlayerName}",
      "ja": "ドリー、素直になって",
      "zh": ""
    },
    {
      "key": "402.0",
      "line_index": 402,
      "inline_index": 0,
      "line_hash": "24d798a1",
      "speaker": "ドリー",
      "ja": "うう……わ、わかりました、素直に……少しだけ、ほんの少しだけ優しく、してください……♥",
      "zh": ""
    },
    {
      "key": "404.0",
      "line_index": 404,
      "inline_index": 0,
      "line_hash": "d3851c39",
      "speaker": "",
      "ja": "俺はドリーの言葉に頷くと、ピストンを再開する。",
      "zh": ""
    },
    {
      "key": "405.0",
      "line_index": 405,
      "inline_index": 0,
      "line_hash": "26a7dea1",
      "speaker": "",
      "ja": "今度は二人でもっと気持ち良く、心が通じ合うセックスを……そんなことを考えながらドリーを求めるのであった。",
      "zh": ""
    }
  ]
}
