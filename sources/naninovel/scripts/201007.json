{
  "lines": [
    {
      "key": "15.1",
      "line_index": 15,
      "inline_index": 1,
      "line_hash": "a8613eca",
      "speaker": "ラチャナ",
      "ja": "ふー、スイカとやらで腹いっぱいじゃ！",
      "zh": ""
    },
    {
      "key": "17.1",
      "line_index": 17,
      "inline_index": 1,
      "line_hash": "1e4cf653",
      "speaker": "ミキュナ",
      "ja": "美味しかったですね～！　みずみずしくって、喉もばっちり潤いました♪",
      "zh": ""
    },
    {
      "key": "19.1",
      "line_index": 19,
      "inline_index": 1,
      "line_hash": "2a64c8f0",
      "speaker": "ラチャナ",
      "ja": "村でも栽培できたりせんかのう？",
      "zh": ""
    },
    {
      "key": "21.1",
      "line_index": 21,
      "inline_index": 1,
      "line_hash": "db5355b7",
      "speaker": "ミキュナ",
      "ja": "うーん、環境が合ってれば、この種で……って、全部食べちゃいましたけど……大丈夫ですかね……？",
      "zh": ""
    },
    {
      "key": "23.1",
      "line_index": 23,
      "inline_index": 1,
      "line_hash": "a43d67ff",
      "speaker": "ラチャナ",
      "ja": "問題なかろう！　では次の復讐じゃが……",
      "zh": ""
    },
    {
      "key": "25.1",
      "line_index": 25,
      "inline_index": 1,
      "line_hash": "682b2af8",
      "speaker": "ミキュナ",
      "ja": "ま、まだ続けるんですか？　そろそろ皆さんとも遊びたいです……",
      "zh": ""
    },
    {
      "key": "27.1",
      "line_index": 27,
      "inline_index": 1,
      "line_hash": "e7576d73",
      "speaker": "ラチャナ",
      "ja": "これも遊びのようなものじゃ！　次は海におる奴らの足をくすぐるぞ！",
      "zh": ""
    },
    {
      "key": "29.1",
      "line_index": 29,
      "inline_index": 1,
      "line_hash": "9b5cfcf2",
      "speaker": "ミキュナ",
      "ja": "ヒェッ……小さい……でも、それくらいなら私がいなくてもできますよね……？",
      "zh": ""
    },
    {
      "key": "31.1",
      "line_index": 31,
      "inline_index": 1,
      "line_hash": "7794ed3c",
      "speaker": "ラチャナ",
      "ja": "む……当然じゃ。わしの力を見せてやろう！",
      "zh": ""
    },
    {
      "key": "33.1",
      "line_index": 33,
      "inline_index": 1,
      "line_hash": "70f871f6",
      "speaker": "ミキュナ",
      "ja": "（足をくすぐるだけで力とか言われても……）",
      "zh": ""
    },
    {
      "key": "35.1",
      "line_index": 35,
      "inline_index": 1,
      "line_hash": "93a2389e",
      "speaker": "ラチャナ",
      "ja": "ククク……村の若者をマッサージする際、拷問とまでいわしめたワシの指さばきを見せてやるわ……！",
      "zh": ""
    },
    {
      "key": "37.1",
      "line_index": 37,
      "inline_index": 1,
      "line_hash": "ae2f69be",
      "speaker": "ラチャナ",
      "ja": "……む？　何か空が暗く……",
      "zh": ""
    },
    {
      "key": "48.0",
      "line_index": 48,
      "inline_index": 0,
      "line_hash": "656fe229",
      "speaker": "流されるラチャナ",
      "ja": "ぎゃ～～～～っ！！？",
      "zh": ""
    },
    {
      "key": "50.0",
      "line_index": 50,
      "inline_index": 0,
      "line_hash": "f21848ff",
      "speaker": "",
      "ja": "天空から現れた巨大な何かが海に着水して、高波がラチャナをさらう……と言うより、押し流した。",
      "zh": ""
    },
    {
      "key": "52.1",
      "line_index": 52,
      "inline_index": 1,
      "line_hash": "6e8c7ea1",
      "speaker": "ミキュナ",
      "ja": "ラっ……ラチャナさーーん！？",
      "zh": ""
    },
    {
      "key": "67.1",
      "line_index": 67,
      "inline_index": 1,
      "line_hash": "159636fb",
      "speaker": "ミキュナ",
      "ja": "だ、大丈夫ですか……",
      "zh": ""
    },
    {
      "key": "73.1",
      "line_index": 73,
      "inline_index": 1,
      "line_hash": "3ee4de8b",
      "speaker": "ラチャナ",
      "ja": "絶対許さぬ……今に見ておれ……",
      "zh": ""
    },
    {
      "key": "75.1",
      "line_index": 75,
      "inline_index": 1,
      "line_hash": "2beb01ed",
      "speaker": "ミキュナ",
      "ja": "{G_PlayerName}さん達、何もしてないですよ……",
      "zh": ""
    },
    {
      "key": "77.1",
      "line_index": 77,
      "inline_index": 1,
      "line_hash": "86275344",
      "speaker": "ラチャナ",
      "ja": "あんな巨大なチュー……セン？　じゃぞ！？　あやつらの仲間に決まっとる！",
      "zh": ""
    },
    {
      "key": "79.1",
      "line_index": 79,
      "inline_index": 1,
      "line_hash": "941116f0",
      "speaker": "ミキュナ",
      "ja": "宇宙船、ですね？　……でも、皆さん戦ってますよ？",
      "zh": ""
    },
    {
      "key": "92.1",
      "line_index": 92,
      "inline_index": 1,
      "line_hash": "4534d16c",
      "speaker": "アイディル",
      "ja": "あっはっは！　あんた達、しばらく見ないうちに腕が落ちたんじゃないの！？",
      "zh": ""
    },
    {
      "key": "94.1",
      "line_index": 94,
      "inline_index": 1,
      "line_hash": "f9288521",
      "speaker": "コハル",
      "ja": "こちとら疲れてるのよ……！　もう、めんどくさいわね！",
      "zh": ""
    },
    {
      "key": "96.1",
      "line_index": 96,
      "inline_index": 1,
      "line_hash": "634d10f6",
      "speaker": "プリズム",
      "ja": "もー、このインスピレーションがくすぐられないレトロな人たち何なんですか～！？",
      "zh": ""
    },
    {
      "key": "98.1",
      "line_index": 98,
      "inline_index": 1,
      "line_hash": "d301cec3",
      "speaker": "アイディル",
      "ja": "えっ……なんか、傷つくんだけど……",
      "zh": ""
    },
    {
      "key": "111.1",
      "line_index": 111,
      "inline_index": 1,
      "line_hash": "905c4d23",
      "speaker": "ラチャナ",
      "ja": "む……じゃが、見た感じ本気ではなかろう。チャンバラのような物じゃて",
      "zh": ""
    },
    {
      "key": "113.1",
      "line_index": 113,
      "inline_index": 1,
      "line_hash": "3bf331dc",
      "speaker": "ミキュナ",
      "ja": "でも完全に仲が良い相手ってわけじゃなさそうですし……",
      "zh": ""
    },
    {
      "key": "115.1",
      "line_index": 115,
      "inline_index": 1,
      "line_hash": "847031f3",
      "speaker": "ミキュナ",
      "ja": "あっ……チャンスじゃないですか？",
      "zh": ""
    },
    {
      "key": "117.1",
      "line_index": 117,
      "inline_index": 1,
      "line_hash": "1dc2dc07",
      "speaker": "ラチャナ",
      "ja": "チャンスじゃと？",
      "zh": ""
    },
    {
      "key": "119.1",
      "line_index": 119,
      "inline_index": 1,
      "line_hash": "3d7ceab8",
      "speaker": "ミキュナ",
      "ja": "はい！　ドサクサにまぎれて合流して、スイカの事とかくすぐった事を告白して謝るんです！",
      "zh": ""
    },
    {
      "key": "121.1",
      "line_index": 121,
      "inline_index": 1,
      "line_hash": "930825ec",
      "speaker": "ミキュナ",
      "ja": "そしたらこの後も、色々遊べたり何か食べさせてもらえるかも……",
      "zh": ""
    },
    {
      "key": "123.1",
      "line_index": 123,
      "inline_index": 1,
      "line_hash": "9c413804",
      "speaker": "ラチャナ",
      "ja": "……む……いや、ダメじゃ",
      "zh": ""
    },
    {
      "key": "125.1",
      "line_index": 125,
      "inline_index": 1,
      "line_hash": "677a2c2b",
      "speaker": "ミキュナ",
      "ja": "なんでですか～！？　まだ拗ねてるんですか？",
      "zh": ""
    },
    {
      "key": "127.1",
      "line_index": 127,
      "inline_index": 1,
      "line_hash": "bb2bd0bf",
      "speaker": "ラチャナ",
      "ja": "……今は人が多すぎて恥ずかし……というか……つまり、不利じゃ！　もっと、少ない時を見計らうぞ！",
      "zh": ""
    },
    {
      "key": "132.1",
      "line_index": 132,
      "inline_index": 1,
      "line_hash": "483a98f1",
      "speaker": "ミキュナ",
      "ja": "……もしかして、ただの恥ずかしがり屋……？",
      "zh": ""
    }
  ]
}
